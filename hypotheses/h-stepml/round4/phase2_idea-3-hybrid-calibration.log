pd\n    36→import yaml\n    37→\n    38→# ---------------------------------------------------------------------------\n    39→# Paths\n    40→# ---------------------------------------------------------------------------\n    41→_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n    42→_SHARED_DIR = os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"shared\")\n    43→_REPO_ROOT = os.path.abspath(os.path.join(_SHARED_DIR, \"..\", \"..\", \"..\"))\n    44→_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\n    45→_BINARY = os.path.join(_REPO_ROOT, \"simulation_worker\")\n    46→\n    47→sys.path.insert(0, _SHARED_DIR)\n    48→from data_loader import (\n    49→    load_all_experiments,\n    50→    parse_experiment_metadata,\n    51→)\n    52→\n    53→# Output directories\n    54→H1_OUTPUT = os.path.join(_SCRIPT_DIR, \"h1-principled-base\", \"output\")\n    55→H2_OUTPUT = os.path.join(_SCRIPT_DIR, \"h2-constrained-cmaes\", \"output\")\n    56→H3_OUTPUT = os.path.join(_SCRIPT_DIR, \"h3-lomo\", \"output\")\n    57→H4_OUTPUT = os.path.join(_SCRIPT_DIR, \"h4-lowo\", \"output\")\n    58→\n    59→for d in [H1_OUTPUT, H2_OUTPUT, H3_OUTPUT, H4_OUTPUT]:\n    60→    os.makedirs(d, exist_ok=True)\n    61→\n    62→BLOCK_SIZE_TOKENS = 16\n    63→\n    64→\n    65→def normalize_model_name(name):\n    66→    \"\"\"Normalize model names: strip -hf suffix.\"\"\"\n    67→    return re.sub(r\"-hf$\", \"\", name)\n    68→\n    69→\n    70→# ---------------------------------------------------------------------------\n    71→# Experiment parsing helpers (same as validate_blis.py)\n    72→# ---------------------------------------------------------------------------\n    73→def parse_experiment_dir(dirname):\n    74→    pattern = re.compile(r\"^(\\d{8}-\\d{6})-(.+)-tp(\\d+)-(\\w+)$\")\n    75→    m = pattern.match(dirname)\n    76→    if m:\n    77→        return {\"timestamp\": m.group(1), \"model\": m.group(2),\n    78→                \"tp\": int(m.group(3)), \"workload\": m.group(4)}\n    79→    tp_matches = list(re.finditer(r\"-tp(\\d+)-\", dirname))\n    80→    if not tp_matches:\n    81→        raise ValueError(f\"Cannot parse: {dirname}\")\n    82→    last = tp_matches[-1]\n    83→    return {\"timestamp\": dirname[:15], \"model\": dirname[16:last.start()],\n    84→            \"tp\": int(last.group(1)), \"workload\": dirname[last.end():]}\n    85→\n    86→\n    87→def load_ground_truth(exp_dir):\n    88→    with open(os.path.join(exp_dir, \"results\", \"summary_lifecycle_metrics.json\")) as f:\n    89→        data = json.load(f)\n    90→    s = data.get(\"successes\", {})\n    91→    lat = s.get(\"latency\", {})\n    92→    return {\n    93→        \"e2e_mean_s\": lat.get(\"request_latency\", {}).get(\"mean\", 0),\n    94→        \"ttft_mean_s\": lat.get(\"time_to_first_token\", {}).get(\"mean\", 0),\n    95→        \"itl_mean_s\": lat.get(\"inter_token_latency\", {}).get(\"mean\", 0),\n    96→        \"throughput_rps\": s.get(\"throughput\", {}).get(\"requests_per_sec\", 0),\n    97→        \"num_requests\": data.get(\"load_summary\", {}).get(\"count\", 0),\n    98→        \"prompt_len_mean\": s.get(\"prompt_len\", {}).get(\"mean\", 0),\n    99→        \"output_len_mean\": s.get(\"output_len\", {}).get(\"mean\", 0),\n   100→    }\n   101→\n   102→\n   103→def load_exp_config(exp_dir):\n   104→    with open(os.path.join(exp_dir, \"exp-config.yaml\")) as f:\n   105→        return yaml.safe_load(f)\n   106→\n   107→\n   108→def load_profile(exp_dir):\n   109→    with open(os.path.join(exp_dir, \"profile.yaml\")) as f:\n   110→        content = f.read()\n   111→    try:\n   112→        return json.loads(content)\n   113→    except json.JSONDecodeError:\n   114→        return yaml.safe_load(content)\n   115→\n   116→\n   117→def extract_kv_blocks(exp_dir):\n   118→    path = os.path.join(exp_dir, \"vllm.log\")\n   119→    if not os.path.isfile(path):\n   120→        return None\n   121→    with open(path) as f:\n   122→        for line in f:\n   123→            m = re.search(r\"GPU KV cache size:\\s+([\\d,]+)\\s+tokens\", line)\n   124→            if m:\n   125→                return int(m.group(1).replace(\",\", \"\")) // BLOCK_SIZE_TOKENS\n   126→    return None\n   127→\n   128→\n   129→def extract_cpu_kv_blocks(exp_dir):\n   130→    path = os.path.join(exp_dir, \"vllm.log\")\n   131→    if not os.path.isfile(path):\n   132→        return 0\n   133→    cpu_bytes = None\n   134→    kv_shape = None\n   135→    with open(path) as f:\n   136→        for line in f:\n   137→            if cpu_bytes is None:\n   138→                m = re.search(r\"cpu_bytes_to_use['\\\"]?:\\s*([\\d.]+)\", line)\n   139→                if m:\n   140→                    cpu_bytes = float(m.group(1))\n   141→            if kv_shape is None:\n   142→                m = re.search(\n   143→                    r\"cross layer KV cache of shape \\((\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+)\\)\",\n   144→                    line)\n   145→                if m:\n   146→                    kv_shape = tuple(int(m.group(i)) for i in range(1, 7))\n   147→            if cpu_bytes is not None and kv_shape is not None:\n   148→                break\n   149→    if not cpu_bytes or not kv_shape or cpu_bytes == 0:\n   150→        return 0\n   151→    _, nl, _, bs, nkv, hd = kv_shape\n   152→    return int(cpu_bytes) // (nl * 2 * bs * nkv * hd * 2)\n   153→\n   154→\n   155→# ---------------------------------------------------------------------------\n   156→# Workload spec (with clients expanded)\n   157→# ---------------------------------------------------------------------------\n   158→def build_workload_spec(profile, gt):\n   159→    data = profile.get(\"data\", {})\n   160→    load_cfg = profile.get(\"load\", {})\n   161→    sp = data.get(\"shared_prefix\", {})\n   162→\n   163→    stages = [{\"rate\": s[\"rate\"], \"duration\": s[\"duration\"]}\n   164→              for s in load_cfg.get(\"stages\", [])]\n   165→    if not stages:\n   166→        n = gt.get(\"num_requests\", 1000)\n   167→        rps = max(gt.get(\"throughput_rps\", 10), 1)\n   168→        stages.append({\"rate\": rps, \"duration\": int(n / rps) + 60})\n   169→\n   170→    total_dur = sum(s[\"duration\"] for s in stages)\n   171→    agg_rate = sum(s[\"rate\"] * s[\"duration\"] for s in stages) / total_dur\n   172→    total_req = int(sum(s[\"rate\"] * s[\"duration\"] for s in stages))\n   173→    horizon = int(total_dur * 1_000_000) + 60_000_000\n   174→\n   175→    np_ = sp.get(\"num_unique_system_prompts\", 9)\n   176→    nu = sp.get(\"num_users_per_system_prompt\", 5)\n   177→    nc = np_ * nu\n   178→    ql = sp.get(\"question_len\", int(gt.get(\"prompt_len_mean\", 500)))\n   179→    ol = sp.get(\"output_len\", int(gt.get(\"output_len_mean\", 250)))\n   180→    spl = sp.get(\"system_prompt_len\", 100)\n   181→\n   182→    rf = 1.0 / nc\n   183→    clients = []\n   184→    for p in range(np_):\n   185→        for u in range(nu):\n   186→            clients.append({\n   187→                \"id\": f\"prompt-{p}-user-{u}\",\n   188→                \"tenant_id\": f\"prompt-{p}\",\n   189→                \"slo_class\": \"batch\",\n   190→                \"rate_fraction\": rf,\n   191→                \"arrival\": {\"process\": \"poisson\"},\n   192→                \"input_distribution\": {\"type\": \"constant\", \"params\": {\"value\": float(ql)}},\n   193→                \"output_distribution\": {\"type\": \"constant\", \"params\": {\"value\": float(ol)}},\n   194→                \"prefix_group\": f\"prompt-{p}\",\n   195→                \"prefix_length\": spl,\n   196→                \"streaming\": False,\n   197→            })\n   198→\n   199→    return {\n   200→        \"version\": \"2\", \"seed\": 42, \"category\": \"language\",\n   201→        \"num_requests\": total_req, \"horizon\": horizon,\n   202→        \"aggregate_rate\": agg_rate, \"clients\": clients,\n   203→    }\n   204→\n   205→\n   206→# ---------------------------------------------------------------------------\n   207→# BLIS execution\n   208→# ---------------------------------------------------------------------------\n   209→def run_blis(exp_dir, alpha, beta):\n   210→    \"\"\"Run BLIS and return metrics dict or None.\"\"\"\n   211→    gt = load_ground_truth(exp_dir)\n   212→    cfg = load_exp_config(exp_dir)\n   213→    kv = extract_kv_blocks(exp_dir)\n   214→    if kv is None:\n   215→        return None\n   216→    cpu_kv = extract_cpu_kv_blocks(exp_dir)\n   217→    try:\n   218→        profile = load_profile(exp_dir)\n   219→    except Exception:\n   220→        return None\n   221→\n   222→    spec = build_workload_spec(profile, gt)\n   223→    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".yaml\", delete=False) as f:\n   224→        yaml.dump(spec, f, default_flow_style=False)\n   225→        sp = f.name\n   226→    with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n   227→        rp = f.name\n   228→\n   229→    cmd = [\n   230→        _BINARY, \"run\",\n   231→        \"--model\", cfg.get(\"model\", \"unknown\"),\n   232→        \"--workload-spec\", sp,\n   233→        \"--tp\", str(cfg.get(\"tensor_parallelism\", 1)),\n   234→        \"--max-model-len\", str(cfg.get(\"max_model_len\", 4096)),\n   235→        \"--max-num-running-reqs\", str(cfg.get(\"max_num_seqs\", 128)),\n   236→        \"--max-num-scheduled-tokens\", str(cfg.get(\"max_num_batched_tokens\", 2048)),\n   237→        \"--total-kv-blocks\", str(kv),\n   238→        \"--block-size-in-tokens\", str(BLOCK_SIZE_TOKENS),\n   239→        \"--alpha-coeffs=\" + \",\".join(str(c) for c in alpha),\n   240→        \"--beta-coeffs=\" + \",\".join(str(c) for c in beta),\n   241→        \"--results-path\", rp, \"--log\", \"error\",\n   242→    ]\n   243→    if cpu_kv > 0:\n   244→        cmd.extend([\"--kv-cpu-blocks\", str(cpu_kv)])\n   245→\n   246→    try:\n   247→        result = subprocess.run(cmd, capture_output=True, text=True, timeout=300, cwd=_REPO_ROOT)\n   248→    except (subprocess.TimeoutExpired, FileNotFoundError):\n   249→        return None\n   250→    finally:\n   251→        for p in [sp, rp]:\n   252→            try:\n   253→                os.unlink(p)\n   254→            except OSError:\n   255→                pass\n   256→\n   257→    if result.returncode != 0:\n   258→        return None\n   259→    return _parse_stdout(result.stdout)\n   260→\n   261→\n   262→def _parse_stdout(stdout):\n   263→    lines = stdout.split(\"\\n\")\n   264→    jl = []\n   265→    in_json = False\n   266→    depth = 0\n   267→    for line in lines:\n   268→        if \"Simulation Metrics\" in line:\n   269→            in_json = False\n   270→            jl = []\n   271→            continue\n   272→        if not in_json and line.strip().startswith(\"{\"):\n   273→            in_json = True\n   274→            depth = 0\n   275→        if in_json:\n   276→            jl.append(line)\n   277→            depth += line.count(\"{\") - line.count(\"}\")\n   278→            if depth <= 0:\n   279→                break\n   280→    if not jl:\n   281→        return None\n   282→    try:\n   283→        m = json.loads(\"\\n\".join(jl))\n   284→    except json.JSONDecodeError:\n   285→        return None\n   286→    return {\n   287→        \"e2e_mean_ms\": m.get(\"e2e_mean_ms\", 0),\n   288→        \"ttft_mean_ms\": m.get(\"ttft_mean_ms\", 0),\n   289→        \"itl_mean_ms\": m.get(\"itl_mean_ms\", 0),\n   290→        \"completed_requests\": m.get(\"completed_requests\", 0),\n   291→    }\n   292→\n   293→\n   294→def rel_error(pred, obs):\n   295→    if obs == 0:\n   296→        return float(\"inf\") if pred != 0 else 0.0\n   297→    return abs(pred - obs) / obs\n   298→\n   299→\n   300→# ---------------------------------------------------------------------------\n   301→# Enumerate experiments\n   302→# ---------------------------------------------------------------------------\n   303→def list_experiments():\n   304→    exps = []\n   305→    for d in sorted(os.listdir(_DATA_ROOT)):\n   306→        dp = os.path.join(_DATA_ROOT, d)\n   307→        if not os.path.isdir(dp):\n   308→            continue\n   309→        if not os.path.isfile(os.path.join(dp, \"results\", \"summary_lifecycle_metrics.json\")):\n   310→            continue\n   311→        try:\n   312→            meta = parse_experiment_dir(d)\n   313→        except ValueError:\n   314→            continue\n   315→        exps.append({\"dirname\": d, \"dirpath\": dp, \"model\": meta[\"model\"],\n   316→                      \"tp\": meta[\"tp\"], \"workload\": meta[\"workload\"]})\n   317→    return exps\n   318→\n   319→\n   320→# ===================================================================\n   321→# H1: PRINCIPLED BASE\n   322→# ===================================================================\n   323→def derive_effective_step_times(experiments):\n   324→    \"\"\"Derive per-model effective step time from E2E ground truth.\n   325→\n   326→    effective_step_us = (E2E_mean - TTFT_mean) * 1e6 / output_len_mean\n   327→\n   328→    This is what the step time SHOULD be to reproduce E2E correctly.\n   329→    \"\"\"\n   330→    model_data = defaultdict(list)\n   331→    for exp in experiments:\n   332→        gt = load_ground_truth(exp[\"dirpath\"])\n   333→        e2e_us = gt[\"e2e_mean_s\"] * 1_000_000\n   334→        ttft_us = gt[\"ttft_mean_s\"] * 1_000_000\n   335→        out_len = gt[\"output_len_mean\"]\n   336→        if out_len > 0:\n   337→            eff_step = (e2e_us - ttft_us) / out_len\n   338→            model_data[exp[\"model\"]].append({\n   339→                \"experiment\": exp[\"dirname\"],\n   340→                \"workload\": exp[\"workload\"],\n   341→                \"e2e_us\": e2e_us,\n   342→                \"ttft_us\": ttft_us,\n   343→                \"output_len\": out_len,\n   344→                \"prompt_len\": gt[\"prompt_len_mean\"],\n   345→                \"effective_step_us\": eff_step,\n   346→            })\n   347→    return model_data\n   348→\n   349→\n   350→def train_step_regression(step_df, effective_targets):\n   351→    \"\"\"Train per-model regression using step data features and E2E-derived targets.\n   352→\n   353→    The key idea: we know what the average step time SHOULD be (from E2E),\n   354→    and we know the step-level features (prefill_tokens, decode_tokens, batch_size).\n   355→    We train: step_time = beta0 + beta1 * prefill + beta2 * decode\n   356→    where beta0 is set to the E2E-derived effective step time as a baseline,\n   357→    and beta1/beta2 capture the marginal cost of additional tokens.\n   358→\n   359→    Since BLIS processes one batch at a time and the beta equation applies to the\n   360→    whole batch, we need:\n   361→    - beta0: base step time (overhead, independent of batch content)\n   362→    - beta1: marginal cost per prefill token\n   363→    - beta2: marginal cost per decode token\n   364→\n   365→    From the step data, we can compute the average batch composition to calibrate.\n   366→    \"\"\"\n   367→    from sklearn.linear_model import Ridge\n   368→\n   369→    results = {}\n   370→    for model in sorted(step_df[\"model\"].unique()):\n   371→        mdf = step_df[step_df[\"model\"] == model].dropna(subset=[\"step.duration_us\"])\n   372→        if len(mdf) < 20:\n   373→            continue\n   374→\n   375→        norm = normalize_model_name(model)\n   376→\n   377→        # Get E2E-derived effective step times for this model\n   378→        eff_data = effective_targets.get(model, [])\n   379→        if not eff_data:\n   380→            # Try with -hf variant\n   381→            for k, v in effective_targets.items():\n   382→                if normalize_model_name(k) == norm:\n   383→                    eff_data = v\n   384→                    break\n   385→\n   386→        if not eff_data:\n   387→            continue\n   388→\n   389→        mean_eff_step = np.mean([d[\"effective_step_us\"] for d in eff_data])\n   390→\n   391→        # Compute average batch composition from step data\n   392→        prefill = mdf.get(\"batch.prefill_tokens\", pd.Series(0, index=mdf.index)).fillna(0).astype(float)\n   393→        decode = mdf.get(\"batch.decode_tokens\", pd.Series(0, index=mdf.index)).fillna(0).astype(float)\n   394→        duration = mdf[\"step.duration_us\"].astype(float)\n   395→\n   396→        avg_prefill = float(prefill.mean())\n   397→        avg_decode = float(decode.mean())\n   398→        avg_duration = float(duration.mean())\n   399→\n   400→        # The overhead multiplier: how much bigger must step times be?\n   401→        if avg_duration > 0:\n   402→            multiplier = mean_eff_step / avg_duration\n   403→        else:\n   404→            multiplier = 2.0\n   405→        multiplier = max(1.0, multiplier)\n   406→\n   407→        # Train regression on SCALED step times\n   408→        y_scaled = duration.values * multiplier\n   409→        X = np.column_stack([prefill.values, decode.values])\n   410→\n   411→        reg = Ridge(alpha=10.0, fit_intercept=True)\n   412→        reg.fit(X, y_scaled)\n   413→\n   414→        beta0 = max(float(reg.intercept_), mean_eff_step * 0.3)  # At least 30% of target as floor\n   415→        beta1 = max(0.0, float(reg.coef_[0]))\n   416→        beta2 = max(0.0, float(reg.coef_[1]))\n   417→\n   418→        # Sanity check: with average batch, does our model predict ~mean_eff_step?\n   419→        pred_avg = beta0 + beta1 * avg_prefill + beta2 * avg_decode\n   420→        ratio = pred_avg / mean_eff_step if mean_eff_step > 0 else 1.0\n   421→\n   422→        results[model] = {\n   423→            \"beta0\": beta0,\n   424→            \"beta1_prefill\": beta1,\n   425→            \"beta2_decode\": beta2,\n   426→            \"mean_eff_step_us\": mean_eff_step,\n   427→            \"multiplier\": multiplier,\n   428→            \"avg_prefill\": avg_prefill,\n   429→            \"avg_decode\": avg_decode,\n   430→            \"avg_duration_us\": avg_duration,\n   431→            \"pred_at_avg_batch\": pred_avg,\n   432→            \"ratio_pred_target\": ratio,\n   433→            \"n_steps\": len(mdf),\n   434→        }\n   435→\n   436→        print(\n   437→            f\"  {model}: beta0={beta0:.0f} beta1={beta1:.3f} beta2={beta2:.1f} \"\n   438→            f\"| eff_step={mean_eff_step:.0f}us mult={multiplier:.1f}x \"\n   439→            f\"pred@avg={pred_avg:.0f}us\"\n   440→        )\n   441→\n   442→    return results\n   443→\n   444→\n   445→def compute_ttft_corrections(experiments):\n   446→    \"\"\"Per-model TTFT from ground truth.\"\"\"\n   447→    model_ttfts = defaultdict(list)\n   448→    for exp in experiments:\n   449→        gt = load_ground_truth(exp[\"dirpath\"])\n   450→        if gt[\"ttft_mean_s\"] > 0:\n   451→            model_ttfts[exp[\"model\"]].append(gt[\"ttft_mean_s\"] * 1_000_000)\n   452→\n   453→    result = {}\n   454→    for model, vals in model_ttfts.items():\n   455→        result[model] = float(np.mean(vals))\n   456→        print(f\"  {model}: TTFT={result[model]/1000:.1f}ms\")\n   457→    return result\n   458→\n   459→\n   460→def validate_coeffs(experiments, per_model_coeffs):\n   461→    \"\"\"Run BLIS validation for all experiments with given coefficients.\"\"\"\n   462→    results = []\n   463→    for exp in experiments:\n   464→        model = exp[\"model\"]\n   465→        norm = normalize_model_name(model)\n   466→\n   467→        coeffs = None\n   468→        for k, v in per_model_coeffs.items():\n   469→            if k == model or normalize_model_name(k) == norm:\n   470→                coeffs = v\n   471→                break\n   472→        if coeffs is None:\n   473→            results.append({\"experiment\": exp[\"dirname\"], \"model\": model,\n   474→                            \"workload\": exp[\"workload\"], \"status\": \"no_coeffs\"})\n   475→            continue\n   476→\n   477→        gt = load_ground_truth(exp[\"dirpath\"])\n   478→        blis = run_blis(exp[\"dirpath\"], coeffs[\"alpha\"], coeffs[\"beta\"])\n   479→        if blis is None:\n   480→            results.append({\"experiment\": exp[\"dirname\"], \"model\": model,\n   481→                            \"workload\": exp[\"workload\"], \"status\": \"blis_failed\"})\n   482→            continue\n   483→\n   484→        e = rel_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n   485→        t = rel_error(blis[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000)\n   486→        i = rel_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n   487→\n   488→        print(\n   489→            f\"  {exp['dirname']}: E2E={e*100:.1f}% TTFT={t*100:.1f}% ITL={i*100:.1f}%  \"\n   490→            f\"(pred={blis['e2e_mean_ms']:.0f}ms gt={gt['e2e_mean_s']*1000:.0f}ms)\"\n   491→        )\n   492→\n   493→        results.append({\n   494→            \"experiment\": exp[\"dirname\"], \"model\": model,\n   495→            \"workload\": exp[\"workload\"], \"tp\": exp[\"tp\"], \"status\": \"ok\",\n   496→            \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n   497→            \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n   498→            \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n   499→            \"blis_e2e_ms\": blis[\"e2e_mean_ms\"],\n   500→            \"blis_ttft_ms\": blis[\"ttft_mean_ms\"],\n   501→            \"blis_itl_ms\": blis[\"itl_mean_ms\"],\n   502→            \"e2e_error\": e, \"ttft_error\": t, \"itl_error\": i,\n   503→            \"alpha\": coeffs[\"alpha\"], \"beta\": coeffs[\"beta\"],\n   504→        })\n   505→    return results\n   506→\n   507→\n   508→def run_h1(experiments, step_df):\n   509→    \"\"\"Run H1: Principled Base.\"\"\"\n   510→    print(\"\\n\" + \"=\" * 70)\n   511→    print(\"H1: PRINCIPLED BASE -- E2E-Derived Step Time + TTFT Corrections\")\n   512→    print(\"=\" * 70)\n   513→\n   514→    # Step 1: Derive effective step times from E2E data\n   515→    print(\"\\n--- Step 1: Derive effective step times from E2E ---\")\n   516→    eff_data = derive_effective_step_times(experiments)\n   517→    for model, data in sorted(eff_data.items()):\n   518→        mean_eff = np.mean([d[\"effective_step_us\"] for d in data])\n   519→        print(f\"  {model}: effective_step={mean_eff:.0f}us ({mean_eff/1000:.1f}ms) from {len(data)} experiments\")\n   520→\n   521→    # Step 2: Train regression\n   522→    print(\"\\n--- Step 2: Train per-model regression ---\")\n   523→    regression = train_step_regression(step_df, eff_data)\n   524→\n   525→    # Step 3: TTFT corrections\n   526→    print(\"\\n--- Step 3: TTFT corrections ---\")\n   527→    ttft = compute_ttft_corrections(experiments)\n   528→\n   529→    # Step 4: Build coefficients\n   530→    print(\"\\n--- Step 4: Build alpha/beta coefficients ---\")\n   531→    per_model_coeffs = {}\n   532→    for model, reg in regression.items():\n   533→        norm = normalize_model_name(model)\n   534→        ttft_us = 0\n   535→        for k, v in ttft.items():\n   536→            if k == model or normalize_model_name(k) == norm:\n   537→                ttft_us = v\n   538→                break\n   539→\n   540→        alpha = [ttft_us, 0.0, 0.0]\n   541→        beta = [reg[\"beta0\"], reg[\"beta1_prefill\"], reg[\"beta2_decode\"]]\n   542→        per_model_coeffs[model] = {\"alpha\": alpha, \"beta\": beta}\n   543→        print(\n   544→            f\"  {model}: alpha=[{alpha[0]:.0f},0,0] \"\n   545→            f\"beta=[{beta[0]:.0f}, {beta[1]:.3f}, {beta[2]:.1f}]\"\n   546→        )\n   547→\n   548→    # Step 5: Validate\n   549→    print(\"\\n--- Step 5: BLIS validation ---\")\n   550→    results = validate_coeffs(experiments, per_model_coeffs)\n   551→\n   552→    df = pd.DataFrame(results)\n   553→    df.to_csv(os.path.join(H1_OUTPUT, \"blis_validation.csv\"), index=False)\n   554→    ok = df[df[\"status\"] == \"ok\"]\n   555→\n   556→    summary = {}\n   557→    if len(ok) > 0:\n   558→        summary = {\n   559→            \"mean_e2e_error_pct\": float(ok[\"e2e_error\"].mean() * 100),\n   560→            \"mean_ttft_error_pct\": float(ok[\"ttft_error\"].mean() * 100),\n   561→            \"mean_itl_error_pct\": float(ok[\"itl_error\"].mean() * 100),\n   562→            \"median_e2e_error_pct\": float(ok[\"e2e_error\"].median() * 100),\n   563→            \"n_experiments\": len(ok),\n   564→            \"n_below_10_e2e\": int((ok[\"e2e_error\"] < 0.10).sum()),\n   565→            \"n_below_20_e2e\": int((ok[\"e2e_error\"] < 0.20).sum()),\n   566→            \"per_model_coeffs\": {k: v for k, v in per_model_coeffs.items()},\n   567→            \"regression\": regression,\n   568→            \"ttft_us\": {k: float(v) for k, v in ttft.items()},\n   569→            \"effective_step_data\": {k: [d for d in v] for k, v in eff_data.items()},\n   570→        }\n   571→\n   572→    with open(os.path.join(H1_OUTPUT, \"h1_summary.json\"), \"w\") as f:\n   573→        json.dump(summary, f, indent=2, default=str)\n   574→\n   575→    _print_table(\"H1 PRINCIPLED BASE\", ok)\n   576→\n   577→    return {\"per_model_coeffs\": per_model_coeffs, \"regression\": regression,\n   578→            \"results\": results, \"summary\": summary}\n   579→\n   580→\n   581→# ===================================================================\n   582→# H2: CONSTRAINED CMA-ES\n   583→# ===================================================================\n   584→def cmaes_objective(x, base_alpha, base_beta, model_experiments):\n   585→    \"\"\"Evaluate candidate coefficients on model's experiments.\n   586→\n   587→    x = [scale_b0, scale_b1, scale_b2, scale_a0, alpha2]\n   588→    \"\"\"\n   589→    s0, s1, s2, sa, a2 = x\n   590→    alpha = [base_alpha[0] * sa, base_alpha[1], a2]\n   591→    beta = [base_beta[0] * s0, base_beta[1] * s1, base_beta[2] * s2]\n   592→\n   593→    e2e_errs = []\n   594→    itl_errs = []\n   595→    for exp in model_experiments:\n   596→        gt = load_ground_truth(exp[\"dirpath\"])\n   597→        blis = run_blis(exp[\"dirpath\"], alpha, beta)\n   598→        if blis is None:\n   599→            return 100.0\n   600→        e2e_errs.append(rel_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000))\n   601→        itl_errs.append(rel_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000))\n   602→\n   603→    me = np.mean(e2e_errs)\n   604→    mi = np.mean(itl_errs)\n   605→    return float(0.5 * me + 0.5 * mi + 5.0 * max(0, mi - 0.20))\n   606→\n   607→\n   608→def run_h2(experiments, h1_coeffs):\n   609→    \"\"\"Run H2: Constrained CMA-ES.\"\"\"\n   610→    print(\"\\n\" + \"=\" * 70)\n   611→    print(\"H2: CONSTRAINED CMA-ES RESIDUAL TUNING\")\n   612→    print(\"=\" * 70)\n   613→\n   614→    try:\n   615→        import cma\n   616→    except ImportError:\n   617→        print(\"ERROR: cma not installed\")\n   618→        return {\"error\": \"cma not installed\"}\n   619→\n   620→    model_exps = defaultdict(list)\n   621→    for exp in experiments:\n   622→        model_exps[normalize_model_name(exp[\"model\"])].append(exp)\n   623→\n   624→    optimized = {}\n   625→    for nm, mexps in sorted(model_exps.items()):\n   626→        print(f\"\\n--- Optimizing {nm} ({len(mexps)} exps) ---\")\n   627→\n   628→        base = None\n   629→        for k, v in h1_coeffs.items():\n   630→            if normalize_model_name(k) == nm:\n   631→                base = v\n   632→                break\n   633→        if not base:\n   634→            print(f\"  SKIP: no base coefficients\")\n   635→            continue\n   636→\n   637→        ba, bb = base[\"alpha\"], base[\"beta\"]\n   638→\n   639→        # Wider bounds: +-30% for scales, [0, 2000] for alpha2\n   640→        x0 = [1.0, 1.0, 1.0, 1.0, 0.0]\n   641→        opts = {\n   642→            \"maxfevals\": 60,\n   643→            \"bounds\": [[0.70, 0.70, 0.70, 0.70, 0.0],\n   644→                       [1.30, 1.30, 1.30, 1.30, 2000.0]],\n   645→            \"seed\": 42, \"verbose\": -9, \"tolfun\": 1e-6,\n   646→        }\n   647→\n   648→        es = cma.CMAEvolutionStrategy(x0, 0.08, opts)\n   649→        es.optimize(lambda x: cmaes_objective(x, ba, bb, mexps))\n   650→        r = es.result\n   651→\n   652→        s0, s1, s2, sa, a2 = r.xbest\n   653→        oa = [ba[0] * sa, ba[1], a2]\n   654→        ob = [bb[0] * s0, bb[1] * s1, bb[2] * s2]\n   655→        optimized[nm] = {\"alpha\": oa, \"beta\": ob}\n   656→\n   657→        print(f\"  Best f={r.fbest:.4f} scales=[{s0:.3f},{s1:.3f},{s2:.3f},{sa:.3f}] a2={a2:.0f}\")\n   658→        print(f\"  alpha=[{oa[0]:.0f},{oa[1]:.1f},{oa[2]:.0f}]\")\n   659→        print(f\"  beta=[{ob[0]:.0f},{ob[1]:.3f},{ob[2]:.1f}]\")\n   660→        print(f\"  {r.evaluations} evals\")\n   661→\n   662→    # Validate\n   663→    print(\"\\n--- Full validation ---\")\n   664→    per_model_coeffs = {}\n   665→    for k, v in optimized.items():\n   666→        per_model_coeffs[k] = v  # Already normalized\n   667→\n   668→    results = []\n   669→    for exp in experiments:\n   670→        norm = normalize_model_name(exp[\"model\"])\n   671→        coeffs = optimized.get(norm)\n   672→        if not coeffs:\n   673→            results.append({\"experiment\": exp[\"dirname\"], \"model\": exp[\"model\"],\n   674→                            \"workload\": exp[\"workload\"], \"status\": \"no_coeffs\"})\n   675→            continue\n   676→\n   677→        gt = load_ground_truth(exp[\"dirpath\"])\n   678→        blis = run_blis(exp[\"dirpath\"], coeffs[\"alpha\"], coeffs[\"beta\"])\n   679→        if not blis:\n   680→            results.append({\"experiment\": exp[\"dirname\"], \"model\": exp[\"model\"],\n   681→                            \"workload\": exp[\"workload\"], \"status\": \"blis_failed\"})\n   682→            continue\n   683→\n   684→        e = rel_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n   685→        t = rel_error(blis[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000)\n   686→        i = rel_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n   687→\n   688→        print(\n   689→            f\"  {exp['dirname']}: E2E={e*100:.1f}% TTFT={t*100:.1f}% ITL={i*100:.1f}%  \"\n   690→            f\"(pred={blis['e2e_mean_ms']:.0f}ms gt={gt['e2e_mean_s']*1000:.0f}ms)\"\n   691→        )\n   692→\n   693→        results.append({\n   694→            \"experiment\": exp[\"dirname\"], \"model\": exp[\"model\"],\n   695→            \"workload\": exp[\"workload\"], \"tp\": exp[\"tp\"], \"status\": \"ok\",\n   696→            \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000, \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n   697→            \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n   698→            \"blis_e2e_ms\": blis[\"e2e_mean_ms\"], \"blis_ttft_ms\": blis[\"ttft_mean_ms\"],\n   699→            \"blis_itl_ms\": blis[\"itl_mean_ms\"],\n   700→            \"e2e_error\": e, \"ttft_error\": t, \"itl_error\": i,\n   701→        })\n   702→\n   703→    df = pd.DataFrame(results)\n   704→    df.to_csv(os.path.join(H2_OUTPUT, \"blis_validation.csv\"), index=False)\n   705→    ok = df[df[\"status\"] == \"ok\"]\n   706→\n   707→    summary = {}\n   708→    if len(ok) > 0:\n   709→        summary = {\n   710→            \"mean_e2e_error_pct\": float(ok[\"e2e_error\"].mean() * 100),\n   711→            \"mean_ttft_error_pct\": float(ok[\"ttft_error\"].mean() * 100),\n   712→            \"mean_itl_error_pct\": float(ok[\"itl_error\"].mean() * 100),\n   713→            \"median_e2e_error_pct\": float(ok[\"e2e_error\"].median() * 100),\n   714→            \"n_experiments\": len(ok),\n   715→            \"n_below_10_e2e\": int((ok[\"e2e_error\"] < 0.10).sum()),\n   716→            \"n_below_20_e2e\": int((ok[\"e2e_error\"] < 0.20).sum()),\n   717→            \"optimized_coeffs\": optimized,\n   718→        }\n   719→\n   720→    with open(os.path.join(H2_OUTPUT, \"h2_summary.json\"), \"w\") as f:\n   721→        json.dump(summary, f, indent=2, default=str)\n   722→\n   723→    _print_table(\"H2 CMA-ES\", ok)\n   724→\n   725→    return {\"optimized_coeffs\": optimized, \"results\": results, \"summary\": summary}\n   726→\n   727→\n   728→# ===================================================================\n   729→# H3: LOMO\n   730→# ===================================================================\n   731→def run_h3(experiments, step_df):\n   732→    print(\"\\n\" + \"=\" * 70)\n   733→    print(\"H3: LEAVE-ONE-MODEL-OUT (LOMO)\")\n   734→    print(\"=\" * 70)\n   735→\n   736→    model_exps = defaultdict(list)\n   737→    for exp in experiments:\n   738→        model_exps[normalize_model_name(exp[\"model\"])].append(exp)\n   739→    models = sorted(model_exps.keys())\n   740→    print(f\"Models: {models}\")\n   741→\n   742→    all_results = []\n   743→    fold_summaries = []\n   744→\n   745→    for holdout in models:\n   746→        print(f\"\\n--- Hold out {holdout} ---\")\n   747→\n   748→        # Train on other models\n   749→        train_exps = [e for e in experiments if normalize_model_name(e[\"model\"]) != holdout]\n   750→        train_mask = step_df[\"model\"].map(normalize_model_name) != holdout\n   751→        train_df = step_df[train_mask].copy()\n   752→\n   753→        eff_data = derive_effective_step_times(train_exps)\n   754→        regression = train_step_regression(train_df, eff_data)\n   755→        ttft = compute_ttft_corrections(train_exps)\n   756→\n   757→        # Try each donor\n   758→        donor_results = {}\n   759→        for donor in [m for m in models if m != holdout]:\n   760→            donor_coeffs = None\n   761→            for k, reg in regression.items():\n   762→                if normalize_model_name(k) == donor:\n   763→                    ttft_us = 0\n   764→                    for tk, tv in ttft.items():\n   765→                        if normalize_model_name(tk) == donor:\n   766→                            ttft_us = tv\n   767→                            break\n   768→                    donor_coeffs = {\n   769→                        \"alpha\": [ttft_us, 0.0, 0.0],\n   770→                        \"beta\": [reg[\"beta0\"], reg[\"beta1_prefill\"], reg[\"beta2_decode\"]],\n   771→                    }\n   772→                    break\n   773→\n   774→            if not donor_coeffs:\n   775→                continue\n   776→\n   777→            errors = []\n   778→            for exp in model_exps[holdout]:\n   779→                gt = load_ground_truth(exp[\"dirpath\"])\n   780→                blis = run_blis(exp[\"dirpath\"], donor_coeffs[\"alpha\"], donor_coeffs[\"beta\"])\n   781→                if not blis:\n   782→                    continue\n   783→                e = rel_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n   784→                i = rel_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n   785→                errors.append({\"experiment\": exp[\"dirname\"], \"donor\": donor,\n   786→                               \"holdout\": holdout, \"e2e_error\": e, \"itl_error\": i,\n   787→                               \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n   788→                               \"blis_e2e_ms\": blis[\"e2e_mean_ms\"]})\n   789→\n   790→            if errors:\n   791→                me = np.mean([x[\"e2e_error\"] for x in errors])\n   792→                mi = np.mean([x[\"itl_error\"] for x in errors])\n   793→                donor_results[donor] = {\"mean_e2e\": me, \"mean_itl\": mi, \"errors\": errors}\n   794→                print(f\"  {donor} -> {holdout}: E2E={me*100:.1f}% ITL={mi*100:.1f}%\")\n   795→                all_results.extend(errors)\n   796→\n   797→        if donor_results:\n   798→            best = min(donor_results, key=lambda d: donor_results[d][\"mean_e2e\"])\n   799→            b = donor_results[best]\n   800→            fold_summaries.append({\n   801→                \"holdout\": holdout, \"best_donor\": best,\n   802→                \"best_e2e\": b[\"mean_e2e\"], \"best_itl\": b[\"mean_itl\"],\n   803→                \"all_donors\": {d: {\"e2e\": v[\"mean_e2e\"], \"itl\": v[\"mean_itl\"]}\n   804→                               for d, v in donor_results.items()},\n   805→            })\n   806→            print(f\"  Best: {best} (E2E={b['mean_e2e']*100:.1f}%)\")\n   807→\n   808→    pd.DataFrame(all_results).to_csv(os.path.join(H3_OUTPUT, \"lomo_results.csv\"), index=False)\n   809→\n   810→    summary = {\n   811→        \"fold_summaries\": fold_summaries,\n   812→        \"mean_best_donor_e2e_pct\": float(np.mean([f[\"best_e2e\"] for f in fold_summaries]) * 100) if fold_summaries else 0,\n   813→        \"mean_best_donor_itl_pct\": float(np.mean([f[\"best_itl\"] for f in fold_summaries]) * 100) if fold_summaries else 0,\n   814→    }\n   815→    with open(os.path.join(H3_OUTPUT, \"h3_summary.json\"), \"w\") as f:\n   816→        json.dump(summary, f, indent=2, default=str)\n   817→\n   818→    print(\"\\n--- LOMO Summary ---\")\n   819→    for fs in fold_summaries:\n   820→        print(f\"  {fs['holdout']:<25} best={fs['best_donor']:<25} E2E={fs['best_e2e']*100:.1f}% ITL={fs['best_itl']*100:.1f}%\")\n   821→    if fold_summaries:\n   822→        print(f\"  MEAN best-donor E2E={summary['mean_best_donor_e2e_pct']:.1f}% ITL={summary['mean_best_donor_itl_pct']:.1f}%\")\n   823→\n   824→    return {\"summary\": summary, \"fold_summaries\": fold_summaries}\n   825→\n   826→\n   827→# ===================================================================\n   828→# H4: LOWO\n   829→# ===================================================================\n   830→def run_h4(experiments, coeffs):\n   831→    print(\"\\n\" + \"=\" * 70)\n   832→    print(\"H4: LEAVE-ONE-WORKLOAD-OUT (LOWO)\")\n   833→    print(\"=\" * 70)\n   834→\n   835→    results = []\n   836→    for exp in experiments:\n   837→        norm = normalize_model_name(exp[\"model\"])\n   838→        c = coeffs.get(norm)\n   839→        if not c:\n   840→            continue\n   841→        gt = load_ground_truth(exp[\"dirpath\"])\n   842→        blis = run_blis(exp[\"dirpath\"], c[\"alpha\"], c[\"beta\"])\n   843→        if not blis:\n   844→            continue\n   845→        e = rel_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n   846→        i = rel_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n   847→        results.append({\n   848→            \"experiment\": exp[\"dirname\"], \"model\": exp[\"model\"],\n   849→            \"norm_model\": norm, \"workload\": exp[\"workload\"],\n   850→            \"e2e_error\": e, \"itl_error\": i,\n   851→            \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000, \"blis_e2e_ms\": blis[\"e2e_mean_ms\"],\n   852→        })\n   853→\n   854→    df = pd.DataFrame(results)\n   855→    df.to_csv(os.path.join(H4_OUTPUT, \"lowo_results.csv\"), index=False)\n   856→\n   857→    # Per-model breakdown\n   858→    mw_stats = {}\n   859→    for nm in sorted(df[\"norm_model\"].unique()):\n   860→        mdf = df[df[\"norm_model\"] == nm]\n   861→        pw = {}\n   862→        for wl in sorted(mdf[\"workload\"].unique()):\n   863→            wdf = mdf[mdf[\"workload\"] == wl]\n   864→            pw[wl] = {\"e2e\": float(wdf[\"e2e_error\"].mean()), \"itl\": float(wdf[\"itl_error\"].mean())}\n   865→        errs = [v[\"e2e\"] for v in pw.values()]\n   866→        rng = (max(errs) - min(errs)) * 100 if len(errs) > 1 else 0\n   867→        mw_stats[nm] = {\"per_wl\": pw, \"range_pp\": rng, \"mean_e2e\": float(mdf[\"e2e_error\"].mean())}\n   868→\n   869→    agg_e2e = float(df[\"e2e_error\"].mean()) if len(df) > 0 else 1.0\n   870→    agg_itl = float(df[\"itl_error\"].mean()) if len(df) > 0 else 1.0\n   871→    within2x = int((df[\"e2e_error\"] < 2 * agg_e2e).sum()) if len(df) > 0 else 0\n   872→\n   873→    summary = {\n   874→        \"aggregate_e2e_pct\": agg_e2e * 100, \"aggregate_itl_pct\": agg_itl * 100,\n   875→        \"n_within_2x\": within2x, \"n_total\": len(df),\n   876→        \"model_workload_stats\": mw_stats,\n   877→    }\n   878→    with open(os.path.join(H4_OUTPUT, \"h4_summary.json\"), \"w\") as f:\n   879→        json.dump(summary, f, indent=2, default=str)\n   880→\n   881→    print(f\"\\n--- LOWO Summary ---\")\n   882→    print(f\"Aggregate E2E: {agg_e2e*100:.1f}% | Within 2x: {within2x}/{len(df)}\")\n   883→    for nm, st in sorted(mw_stats.items()):\n   884→        print(f\"  {nm}: range={st['range_pp']:.1f}pp mean_e2e={st['mean_e2e']*100:.1f}%\")\n   885→        for wl, ws in sorted(st[\"per_wl\"].items()):\n   886→            print(f\"    {wl}: E2E={ws['e2e']*100:.1f}% ITL={ws['itl']*100:.1f}%\")\n   887→\n   888→    return {\"summary\": summary}\n   889→\n   890→\n   891→def _print_table(title, ok):\n   892→    if ok is None or len(ok) == 0:\n   893→        print(f\"\\n{title}: No results!\")\n   894→        return\n   895→    me = ok[\"e2e_error\"].mean() * 100\n   896→    mt = ok[\"ttft_error\"].mean() * 100\n   897→    mi = ok[\"itl_error\"].mean() * 100\n   898→    b10 = (ok[\"e2e_error\"] < 0.10).sum()\n   899→    b20 = (ok[\"e2e_error\"] < 0.20).sum()\n   900→    print(f\"\\n{'=' * 70}\")\n   901→    print(f\"{title} RESULTS\")\n   902→    print(f\"{'=' * 70}\")\n   903→    print(f\"N={len(ok)} | E2E={me:.1f}% | TTFT={mt:.1f}% | ITL={mi:.1f}% | <10%={b10}/{len(ok)} | <20%={b20}/{len(ok)}\")\n   904→    print(f\"{'Experiment':<55} {'E2E%':>7} {'TTFT%':>7} {'ITL%':>7}\")\n   905→    print(\"-\" * 80)\n   906→    for _, r in ok.iterrows():\n   907→        print(f\"{r['experiment']:<55} {r['e2e_error']*100:>7.1f} {r['ttft_error']*100:>7.1f} {r['itl_error']*100:>7.1f}\")\n   908→    print(\"-\" * 80)\n   909→    print(f\"{'MEAN':<55} {me:>7.1f} {mt:>7.1f} {mi:>7.1f}\")\n   910→\n   911→\n   912→def main():\n   913→    t0 = time.time()\n   914→    print(\"=\" * 70)\n   915→    print(\"ROUND 4 IDEA 3: HYBRID CALIBRATION\")\n   916→    print(\"=\" * 70)\n   917→\n   918→    if not os.path.isfile(_BINARY):\n   919→        print(\"Building BLIS...\")\n   920→        subprocess.run([\"go\", \"build\", \"-o\", _BINARY, \"main.go\"], cwd=_REPO_ROOT, check=True)\n   921→\n   922→    print(\"\\n--- Loading step data ---\")\n   923→    step_df = load_all_experiments(_DATA_ROOT)\n   924→    print(f\"{len(step_df)} steps, {step_df['experiment_id'].nunique()} experiments\")\n   925→\n   926→    experiments = list_experiments()\n   927→    print(f\"{len(experiments)} experiments for validation\")\n   928→\n   929→    h1 = run_h1(experiments, step_df)\n   930→    h2 = run_h2(experiments, h1[\"per_model_coeffs\"])\n   931→    h3 = run_h3(experiments, step_df)\n   932→\n   933→    # H4 uses H2 coefficients if available, else H1\n   934→    h4_coeffs = h2.get(\"optimized_coeffs\", {})\n   935→    if not h4_coeffs:\n   936→        h4_coeffs = {}\n   937→        for k, v in h1[\"per_model_coeffs\"].items():\n   938→            h4_coeffs[normalize_model_name(k)] = v\n   939→    h4 = run_h4(experiments, h4_coeffs)\n   940→\n   941→    elapsed = time.time() - t0\n   942→    h1s = h1.get(\"summary\", {})\n   943→    h2s = h2.get(\"summary\", {})\n   944→    h3s = h3.get(\"summary\", {})\n   945→    h4s = h4.get(\"summary\", {})\n   946→\n   947→    print(\"\\n\" + \"=\" * 70)\n   948→    print(\"GRAND SUMMARY\")\n   949→    print(\"=\" * 70)\n   950→    print(f\"{'Hyp':<25} {'E2E%':>8} {'ITL%':>8} {'<10%':>6} {'Note':>25}\")\n   951→    print(\"-\" * 75)\n   952→    print(f\"{'H1 Base':<25} {h1s.get('mean_e2e_error_pct',0):>8.1f} {h1s.get('mean_itl_error_pct',0):>8.1f} {h1s.get('n_below_10_e2e',0):>6} {'target <30%':>25}\")\n   953→    print(f\"{'H2 CMA-ES':<25} {h2s.get('mean_e2e_error_pct',0):>8.1f} {h2s.get('mean_itl_error_pct',0):>8.1f} {h2s.get('n_below_10_e2e',0):>6} {'target <12%':>25}\")\n   954→    print(f\"{'H3 LOMO best-donor':<25} {h3s.get('mean_best_donor_e2e_pct',0):>8.1f} {h3s.get('mean_best_donor_itl_pct',0):>8.1f} {'':>6} {'target <20%':>25}\")\n   955→    n2x = h4s.get('n_within_2x', 0)\n   956→    nt = h4s.get('n_total', 0)\n   957→    print(f\"{'H4 LOWO':<25} {h4s.get('aggregate_e2e_pct',0):>8.1f} {h4s.get('aggregate_itl_pct',0):>8.1f} {'':>6} {f'{n2x}/{nt} within 2x':>25}\")\n   958→\n   959→    print(f\"\\nR3 baselines: CMA-ES 15.1/87.4 | TraceReplay 56.2/9.5 | LOMO 14.8\")\n   960→    print(f\"Runtime: {elapsed:.0f}s ({elapsed/60:.1f}min)\")\n   961→\n   962→    json.dump({\"h1\": h1s, \"h2\": h2s, \"h3\": h3s, \"h4\": h4s, \"runtime_s\": elapsed},\n   963→              open(os.path.join(_SCRIPT_DIR, \"grand_summary.json\"), \"w\"), indent=2, default=str)\n   964→\n   965→\n   966→if __name__ == \"__main__\":\n   967→    main()\n   968→"}]},"parent_tool_use_id":"toolu_bdrk_01CfKY3CEYt1bGTQUxibMBP7","session_id":"e652145f-d03b-4eb5-bbf8-d7db257fe10a","uuid":"9a082ccf-6023-424b-957e-8172e1640d18"}
