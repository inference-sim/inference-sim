{"type":"assistant","message":{"id":"msg_bdrk_01NzqVJykGtXwc5Hjsu4dCFJ","type":"message","role":"assistant","model":"claude-opus-4-6","content":[{"type":"tool_use","id":"toolu_bdrk_01NF7LsscNZudSYFVzySaQaD","name":"Edit","input":{"replace_all":false,"file_path":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round4-idea-3-hybrid-calibration/hypotheses/h-stepml/round4/idea-3-hybrid-calibration/run_all.py","old_string":"def derive_effective_step_times(experiments):\n    \"\"\"Derive per-model effective step time from E2E ground truth.\n\n    effective_step_us = (E2E_mean - TTFT_mean) * 1e6 / output_len_mean\n\n    This is what the step time SHOULD be to reproduce E2E correctly.\n    \"\"\"\n    model_data = defaultdict(list)\n    for exp in experiments:\n        gt = load_ground_truth(exp[\"dirpath\"])\n        e2e_us = gt[\"e2e_mean_s\"] * 1_000_000\n        ttft_us = gt[\"ttft_mean_s\"] * 1_000_000\n        out_len = gt[\"output_len_mean\"]\n        if out_len > 0:\n            eff_step = (e2e_us - ttft_us) / out_len\n            model_data[exp[\"model\"]].append({\n                \"experiment\": exp[\"dirname\"],\n                \"workload\": exp[\"workload\"],\n                \"e2e_us\": e2e_us,\n                \"ttft_us\": ttft_us,\n                \"output_len\": out_len,\n                \"prompt_len\": gt[\"prompt_len_mean\"],\n                \"effective_step_us\": eff_step,\n            })\n    return model_data\n\n\ndef train_step_regression(step_df, effective_targets):\n    \"\"\"Train per-model regression using step data features and E2E-derived targets.\n\n    The key idea: we know what the average step time SHOULD be (from E2E),\n    and we know the step-level features (prefill_tokens, decode_tokens, batch_size).\n    We train: step_time = beta0 + beta1 * prefill + beta2 * decode\n    where beta0 is set to the E2E-derived effective step time as a baseline,\n    and beta1/beta2 capture the marginal cost of additional tokens.\n\n    Since BLIS processes one batch at a time and the beta equation applies to the\n    whole batch, we need:\n    - beta0: base step time (overhead, independent of batch content)\n    - beta1: marginal cost per prefill token\n    - beta2: marginal cost per decode token\n\n    From the step data, we can compute the average batch composition to calibrate.\n    \"\"\"\n    from sklearn.linear_model import Ridge\n\n    results = {}\n    for model in sorted(step_df[\"model\"].unique()):\n        mdf = step_df[step_df[\"model\"] == model].dropna(subset=[\"step.duration_us\"])\n        if len(mdf) < 20:\n            continue\n\n        norm = normalize_model_name(model)\n\n        # Get E2E-derived effective step times for this model\n        eff_data = effective_targets.get(model, [])\n        if not eff_data:\n            # Try with -hf variant\n            for k, v in effective_targets.items():\n                if normalize_model_name(k) == norm:\n                    eff_data = v\n                    break\n\n        if not eff_data:\n            continue\n\n        mean_eff_step = np.mean([d[\"effective_step_us\"] for d in eff_data])\n\n        # Compute average batch composition from step data\n        prefill = mdf.get(\"batch.prefill_tokens\", pd.Series(0, index=mdf.index)).fillna(0).astype(float)\n        decode = mdf.get(\"batch.decode_tokens\", pd.Series(0, index=mdf.index)).fillna(0).astype(float)\n        duration = mdf[\"step.duration_us\"].astype(float)\n\n        avg_prefill = float(prefill.mean())\n        avg_decode = float(decode.mean())\n        avg_duration = float(duration.mean())\n\n        # The overhead multiplier: how much bigger must step times be?\n        if avg_duration > 0:\n            multiplier = mean_eff_step / avg_duration\n        else:\n            multiplier = 2.0\n        multiplier = max(1.0, multiplier)\n\n        # Train regression on SCALED step times\n        y_scaled = duration.values * multiplier\n        X = np.column_stack([prefill.values, decode.values])\n\n        reg = Ridge(alpha=10.0, fit_intercept=True)\n        reg.fit(X, y_scaled)\n\n        beta0 = max(float(reg.intercept_), mean_eff_step * 0.3)  # At least 30% of target as floor\n        beta1 = max(0.0, float(reg.coef_[0]))\n        beta2 = max(0.0, float(reg.coef_[1]))\n\n        # Sanity check: with average batch, does our model predict ~mean_eff_step?\n        pred_avg = beta0 + beta1 * avg_prefill + beta2 * avg_decode\n        ratio = pred_avg / mean_eff_step if mean_eff_step > 0 else 1.0\n\n        results[model] = {\n            \"beta0\": beta0,\n            \"beta1_prefill\": beta1,\n            \"beta2_decode\": beta2,\n            \"mean_eff_step_us\": mean_eff_step,\n            \"multiplier\": multiplier,\n            \"avg_prefill\": avg_prefill,\n            \"avg_decode\": avg_decode,\n            \"avg_duration_us\": avg_duration,\n            \"pred_at_avg_batch\": pred_avg,\n            \"ratio_pred_target\": ratio,\n            \"n_steps\": len(mdf),\n        }\n\n        print(\n            f\"  {model}: beta0={beta0:.0f} beta1={beta1:.3f} beta2={beta2:.1f} \"\n            f\"| eff_step={mean_eff_step:.0f}us mult={multiplier:.1f}x \"\n            f\"pred@avg={pred_avg:.0f}us\"\n        )\n\n    return results","new_string":"def calibrate_coefficients(experiments, step_df):\n    \"\"\"Calibrate per-model beta coefficients from ground truth E2E data.\n\n    Strategy:\n    1. Compute target step time from E2E: target = (E2E - TTFT) / output_len\n    2. Compute average batch composition from step data (avg decode batch size)\n    3. Set beta2 = measured_step_duration / avg_decode_batch (marginal per-token cost)\n    4. Set beta0 = target_step - beta2 * avg_decode_batch (overhead floor)\n    5. Set beta1 from regression on prefill steps (marginal prefill cost)\n\n    The overhead floor (beta0) captures CPU scheduling, CUDA sync, memory management\n    -- all the time that step.duration_us does NOT measure.\n    \"\"\"\n    from sklearn.linear_model import Ridge\n\n    # Gather per-model ground truth\n    model_gt = defaultdict(list)\n    for exp in experiments:\n        gt = load_ground_truth(exp[\"dirpath\"])\n        model_gt[exp[\"model\"]].append(gt)\n\n    results = {}\n    for model in sorted(step_df[\"model\"].unique()):\n        mdf = step_df[step_df[\"model\"] == model].dropna(subset=[\"step.duration_us\"])\n        if len(mdf) < 20:\n            continue\n\n        norm = normalize_model_name(model)\n\n        # Get ground truth for this model (merge variants)\n        gts = model_gt.get(model, [])\n        if not gts:\n            for k, v in model_gt.items():\n                if normalize_model_name(k) == norm:\n                    gts.extend(v)\n\n        if not gts:\n            continue\n\n        # Target step time from E2E\n        avg_e2e_us = np.mean([g[\"e2e_mean_s\"] for g in gts]) * 1_000_000\n        avg_ttft_us = np.mean([g[\"ttft_mean_s\"] for g in gts]) * 1_000_000\n        avg_outlen = np.mean([g[\"output_len_mean\"] for g in gts])\n        target_step_us = (avg_e2e_us - avg_ttft_us) / avg_outlen if avg_outlen > 0 else 10000\n\n        # Average batch composition from step data\n        decode = mdf.get(\"batch.decode_tokens\", pd.Series(0, index=mdf.index)).fillna(0).astype(float)\n        prefill = mdf.get(\"batch.prefill_tokens\", pd.Series(0, index=mdf.index)).fillna(0).astype(float)\n        duration = mdf[\"step.duration_us\"].astype(float)\n\n        avg_decode_batch = float(decode.mean())\n        avg_prefill_batch = float(prefill.mean())\n        avg_dur = float(duration.mean())\n\n        # beta2 = marginal cost per decode token (from measured GPU time / batch size)\n        # This captures the compute cost that DOES scale with batch size\n        beta2 = avg_dur / avg_decode_batch if avg_decode_batch > 0 else 10.0\n\n        # beta0 = overhead floor (everything that doesn't scale with batch)\n        beta0 = target_step_us - beta2 * avg_decode_batch\n        beta0 = max(beta0, 1000)  # At least 1ms floor\n\n        # beta1 from regression on mixed (prefill) steps\n        mixed = mdf[prefill > 0]\n        if len(mixed) > 10:\n            X_mixed = mixed[[\"batch.prefill_tokens\"]].values.astype(float)\n            y_mixed = mixed[\"step.duration_us\"].values.astype(float)\n            reg = Ridge(alpha=10.0)\n            reg.fit(X_mixed, y_mixed)\n            beta1 = max(0.0, float(reg.coef_[0]))\n        else:\n            beta1 = beta2 * 0.5  # Rough estimate: prefill ~half decode cost per token\n\n        # Verify: predicted step at average batch should approximate target\n        pred_avg = beta0 + beta1 * avg_prefill_batch + beta2 * avg_decode_batch\n        ratio = pred_avg / target_step_us if target_step_us > 0 else 1.0\n\n        results[model] = {\n            \"beta0\": beta0,\n            \"beta1_prefill\": beta1,\n            \"beta2_decode\": beta2,\n            \"target_step_us\": target_step_us,\n            \"avg_decode_batch\": avg_decode_batch,\n            \"avg_dur_us\": avg_dur,\n            \"pred_at_avg\": pred_avg,\n            \"ratio\": ratio,\n            \"n_steps\": len(mdf),\n        }\n\n        print(\n            f\"  {model}: beta0={beta0:.0f} beta1={beta1:.2f} beta2={beta2:.1f} \"\n            f\"| target={target_step_us:.0f}us avg_batch={avg_decode_batch:.1f} \"\n            f\"pred@avg={pred_avg:.0f}us ratio={ratio:.2f}\"\n        )\n\n    return results"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"output_tokens":0},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01CfKY3CEYt1bGTQUxibMBP7","session_id":"e652145f-d03b-4eb5-bbf8-d7db257fe10a","uuid":"bf88e1b6-851c-46d4-a3f4-3f4e2a5176e4"}
