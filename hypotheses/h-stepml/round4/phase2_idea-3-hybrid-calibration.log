{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01CrhPR2XJMH2hXT16ECDmLR","type":"tool_result","content":"     1→package workload\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"math\"\n     6→\t\"math/rand\"\n     7→\t\"sort\"\n     8→\n     9→\t\"github.com/inference-sim/inference-sim/sim\"\n    10→)\n    11→\n    12→// GenerateRequests creates a request sequence from a WorkloadSpec.\n    13→// Deterministic given the same spec, seed, and maxRequests.\n    14→// maxRequests caps the total number of requests (0 = unlimited, use horizon only).\n    15→// Returns requests sorted by ArrivalTime with sequential IDs.\n    16→func GenerateRequests(spec *WorkloadSpec, horizon int64, maxRequests int64) ([]*sim.Request, error) {\n    17→\tif horizon <= 0 {\n    18→\t\treturn nil, nil // EC-5: zero/negative horizon returns empty\n    19→\t}\n    20→\tif maxRequests < 0 {\n    21→\t\treturn nil, fmt.Errorf(\"maxRequests must be non-negative, got %d\", maxRequests)\n    22→\t}\n    23→\t// Expand inference-perf spec if specified (populates spec.Clients)\n    24→\tif spec.InferencePerf != nil && len(spec.Clients) == 0 {\n    25→\t\texpanded, err := ExpandInferencePerfSpec(spec.InferencePerf, spec.Seed)\n    26→\t\tif err != nil {\n    27→\t\t\treturn nil, fmt.Errorf(\"expanding inference-perf spec: %w\", err)\n    28→\t\t}\n    29→\t\tspec.Clients = expanded.Clients\n    30→\t\tif spec.Category == \"\" {\n    31→\t\t\tspec.Category = expanded.Category\n    32→\t\t}\n    33→\t\tif spec.AggregateRate <= 0 {\n    34→\t\t\tspec.AggregateRate = expanded.AggregateRate\n    35→\t\t}\n    36→\t}\n    37→\n    38→\t// Load ServeGen data if specified (populates spec.Clients)\n    39→\tif spec.ServeGenData != nil && len(spec.Clients) == 0 {\n    40→\t\tif err := loadServeGenData(spec); err != nil {\n    41→\t\t\treturn nil, fmt.Errorf(\"loading ServeGen data: %w\", err)\n    42→\t\t}\n    43→\t}\n    44→\n    45→\tUpgradeV1ToV2(spec)\n    46→\n    47→\tif err := spec.Validate(); err != nil {\n    48→\t\treturn nil, fmt.Errorf(\"invalid workload spec: %w\", err)\n    49→\t}\n    50→\n    51→\t// Create partitioned RNG for deterministic generation\n    52→\trng := sim.NewPartitionedRNG(sim.NewSimulationKey(spec.Seed))\n    53→\tworkloadRNG := rng.ForSubsystem(sim.SubsystemWorkloadGen)\n    54→\n    55→\t// Normalize rate fractions\n    56→\tclientRates := normalizeRateFractions(spec.Clients, spec.AggregateRate)\n    57→\n    58→\t// Generate shared prefix tokens per prefix group\n    59→\tprefixes := generatePrefixTokens(spec.Clients, workloadRNG)\n    60→\n    61→\t// Per-client generation cap: prevent OOM when horizon >> maxRequests.\n    62→\t// Each client generates at most 2x maxRequests, then post-merge truncation finalizes.\n    63→\tperClientCap := int64(0)\n    64→\tif maxRequests > 0 {\n    65→\t\tperClientCap = 2 * maxRequests\n    66→\t\tif perClientCap < maxRequests { // int64 overflow guard\n    67→\t\t\tperClientCap = math.MaxInt64\n    68→\t\t}\n    69→\t}\n    70→\n    71→\t// Per-client generation\n    72→\tvar allRequests []*sim.Request\n    73→\tfor i := range spec.Clients {\n    74→\t\tclient := &spec.Clients[i]\n    75→\t\tclientRate := clientRates[i]\n    76→\t\tif clientRate <= 0 {\n    77→\t\t\tcontinue // EC-4: skip zero-rate clients\n    78→\t\t}\n    79→\n    80→\t\t// Create per-client RNG (derived from main RNG for isolation)"}]},"parent_tool_use_id":"toolu_bdrk_01CfKY3CEYt1bGTQUxibMBP7","session_id":"e652145f-d03b-4eb5-bbf8-d7db257fe10a","uuid":"ba949f99-2900-4edf-b897-122ae251481e"}
