{"type":"assistant","message":{"id":"msg_bdrk_013zHnjANbMqs7NwxNxrR1V5","type":"message","role":"assistant","model":"claude-opus-4-6","content":[{"type":"tool_use","id":"toolu_bdrk_0131z7ML2Lom6xzqo9HDy7W9","name":"Bash","input":{"command":"python3 -c \"\nimport json, yaml, tempfile, subprocess, os\n\n# Load the profile.yaml from first experiment\nexp_dir = 'eval/ground_truth/20260217-162547-llama-2-7b-tp1-roleplay'\nwith open(os.path.join(exp_dir, 'profile.yaml')) as f:\n    profile = json.loads(f.read())\n\nsp = profile['data']['shared_prefix']\nstages = profile['load']['stages']\n\n# Build proper workload spec with clients expanded\nnum_prompts = sp.get('num_unique_system_prompts', 10)\nnum_users = sp.get('num_users_per_system_prompt', 5)\nnum_clients = num_prompts * num_users\n\ntotal_duration = sum(s['duration'] for s in stages)\naggregate_rate = sum(s['rate'] * s['duration'] for s in stages) / total_duration\ntotal_requests = int(sum(s['rate'] * s['duration'] for s in stages))\nhorizon = int(total_duration * 1_000_000) + 60_000_000\n\nrate_fraction = 1.0 / num_clients\nclients = []\nfor p in range(num_prompts):\n    for u in range(num_users):\n        client = {\n            'id': f'prompt-{p}-user-{u}',\n            'tenant_id': f'prompt-{p}',\n            'slo_class': 'batch',\n            'rate_fraction': rate_fraction,\n            'arrival': {'process': 'poisson'},\n            'input_distribution': {'type': 'constant', 'params': {'value': float(sp.get('question_len', 600))}},\n            'output_distribution': {'type': 'constant', 'params': {'value': float(sp.get('output_len', 251))}},\n            'prefix_group': f'prompt-{p}',\n            'prefix_length': sp.get('system_prompt_len', 150),\n            'streaming': False,\n        }\n        clients.append(client)\n\nspec = {\n    'version': '2',\n    'seed': 42,\n    'category': 'language',\n    'num_requests': total_requests,\n    'horizon': horizon,\n    'aggregate_rate': aggregate_rate,\n    'clients': clients,\n}\n\nwith tempfile.NamedTemporaryFile(mode='w', suffix='.yaml', delete=False) as f:\n    yaml.dump(spec, f, default_flow_style=False)\n    spec_path = f.name\n\nprint(f'Spec written to {spec_path}')\nprint(f'Clients: {len(clients)}, rate: {aggregate_rate}, requests: {total_requests}')\n\n# Test BLIS\ncmd = [\n    './simulation_worker', 'run',\n    '--model', 'meta-llama/Llama-2-7b-hf',\n    '--workload-spec', spec_path,\n    '--tp', '1',\n    '--max-model-len', '4096',\n    '--max-num-running-reqs', '128',\n    '--max-num-scheduled-tokens', '2048',\n    '--total-kv-blocks', '7462',\n    '--block-size-in-tokens', '16',\n    '--alpha-coeffs=16000,0,0',\n    '--beta-coeffs=3000,0.5,20',\n    '--log', 'error',\n]\nresult = subprocess.run(cmd, capture_output=True, text=True, timeout=120)\nprint(f'Return code: {result.returncode}')\nif result.returncode != 0:\n    print(f'STDERR: {result.stderr[:1000]}')\nelse:\n    # Parse output\n    lines = result.stdout.split('\\\\n')\n    for line in lines:\n        if 'mean' in line.lower() or 'e2e' in line.lower() or 'completed' in line.lower():\n            print(line)\n    # Find JSON\n    in_json = False\n    json_lines = []\n    for line in lines:\n        if 'Simulation Metrics' in line:\n            in_json = False\n            json_lines = []\n            continue\n        if not in_json and line.strip().startswith('{'):\n            in_json = True\n        if in_json:\n            json_lines.append(line)\n            if line.strip().startswith('}'):\n                break\n    if json_lines:\n        metrics = json.loads('\\\\n'.join(json_lines))\n        print(f'BLIS results: E2E={metrics.get(\\\"e2e_mean_ms\\\", 0):.1f}ms, TTFT={metrics.get(\\\"ttft_mean_ms\\\", 0):.1f}ms, ITL={metrics.get(\\\"itl_mean_ms\\\", 0):.2f}ms')\n\nos.unlink(spec_path)\n\" 2>&1","description":"Test BLIS with properly formatted workload spec","timeout":180000}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"output_tokens":0},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01CfKY3CEYt1bGTQUxibMBP7","session_id":"e652145f-d03b-4eb5-bbf8-d7db257fe10a","uuid":"2167b7d2-55ee-4d1b-bd71-e19654d7836d"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_0131z7ML2Lom6xzqo9HDy7W9","type":"tool_result","content":"Spec written to /var/folders/4d/3z6n7y4x5n72q1263gks_w440000gn/T/tmp330cz6m4.yaml\nClients: 50, rate: 6.0, requests: 7200\nReturn code: 0\n  \"completed_requests\": 7200,\n  \"e2e_mean_ms\": 804.6525347222223,\n  \"e2e_p90_ms\": 817.7105,\n  \"e2e_p95_ms\": 821.8234,\n  \"e2e_p99_ms\": 832.06514,\n  \"ttft_mean_ms\": 20.938247500000003,\n  \"itl_mean_ms\": 3.122367678176184,\nBLIS results: E2E=804.7ms, TTFT=20.9ms, ITL=3.12ms","is_error":false}]},"parent_tool_use_id":"toolu_bdrk_01CfKY3CEYt1bGTQUxibMBP7","session_id":"e652145f-d03b-4eb5-bbf8-d7db257fe10a","uuid":"653f4ff5-fc9c-4818-80d1-9923ee364871"}
{"type":"assistant","message":{"id":"msg_bdrk_01C19b9wUwPMcfD2mnKcahTD","type":"message","role":"assistant","model":"claude-opus-4-6","content":[{"type":"tool_use","id":"toolu_bdrk_016ccAevVFA2iN7qUf46JCN3","name":"Write","input":{"file_path":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round4-idea-3-hybrid-calibration/hypotheses/h-stepml/round4/idea-3-hybrid-calibration/run_all.py","content":"#!/usr/bin/env python3\n\"\"\"Round 4 Idea 3: Hybrid Calibration — All 4 Sub-Hypotheses.\n\nThis script runs all four sub-hypotheses for the hybrid calibration approach:\n  H1: Principled base (overhead-floor regression + TTFT corrections)\n  H2: Constrained CMA-ES residual tuning (+-20% around H1 coefficients)\n  H3: Leave-one-model-out (LOMO) cross-validation\n  H4: Leave-one-workload-out (LOWO) cross-validation\n\nKey design decisions:\n  - Uses alpha/beta coefficients (the proven BLIS interface) rather than StepML\n    model artifacts, since that's the interface that has been demonstrated to work.\n  - Expands inference_perf profiles into proper v2 workload specs with clients\n    (BLIS Validate() requires clients before GenerateRequests expansion).\n  - Uses known R3 overhead floors as starting points for regression.\n  - Trains per-model linear regression: step_time = beta0 + beta1*prefill + beta2*decode\n  - TTFT correction as alpha0 (QueueingTime intercept).\n\"\"\"\n\nimport json\nimport math\nimport os\nimport re\nimport subprocess\nimport sys\nimport tempfile\nimport time\nfrom collections import defaultdict\n\nimport numpy as np\nimport pandas as pd\nimport yaml\n\n# ---------------------------------------------------------------------------\n# Paths\n# ---------------------------------------------------------------------------\n_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n_SHARED_DIR = os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"shared\")\n_REPO_ROOT = os.path.abspath(os.path.join(_SHARED_DIR, \"..\", \"..\", \"..\"))\n_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\n_BINARY = os.path.join(_REPO_ROOT, \"simulation_worker\")\n\nsys.path.insert(0, _SHARED_DIR)\nfrom data_loader import (\n    load_all_experiments,\n    load_lifecycle_data,\n    parse_experiment_metadata,\n)\n\n# Output directories\nH1_OUTPUT = os.path.join(_SCRIPT_DIR, \"h1-principled-base\", \"output\")\nH2_OUTPUT = os.path.join(_SCRIPT_DIR, \"h2-constrained-cmaes\", \"output\")\nH3_OUTPUT = os.path.join(_SCRIPT_DIR, \"h3-lomo\", \"output\")\nH4_OUTPUT = os.path.join(_SCRIPT_DIR, \"h4-lowo\", \"output\")\n\nfor d in [H1_OUTPUT, H2_OUTPUT, H3_OUTPUT, H4_OUTPUT]:\n    os.makedirs(d, exist_ok=True)\n\nBLOCK_SIZE_TOKENS = 16\n\n# R3 known overhead floors (microseconds) — used as starting points\nR3_OVERHEAD_FLOORS = {\n    \"llama-2-7b\": 3897,\n    \"codellama-34b\": 6673,\n    \"llama-2-70b\": 8029,\n    \"llama-2-70b-hf\": 8203,\n    \"mixtral-8x7b-v0-1\": 9125,\n}\n\n# R3 known TTFT corrections (microseconds)\nR3_TTFT_CORRECTIONS = {\n    \"llama-2-7b\": 16000,\n    \"codellama-34b\": 40000,\n    \"llama-2-70b\": 50000,\n    \"llama-2-70b-hf\": 50000,\n    \"mixtral-8x7b-v0-1\": 61000,\n}\n\n\n# ---------------------------------------------------------------------------\n# Model name normalization\n# ---------------------------------------------------------------------------\ndef normalize_model_name(name: str) -> str:\n    \"\"\"Normalize model names: strip -hf suffix.\"\"\"\n    return re.sub(r\"-hf$\", \"\", name)\n\n\n# ---------------------------------------------------------------------------\n# Experiment metadata & parsing helpers\n# ---------------------------------------------------------------------------\ndef parse_experiment_dir(dirname: str) -> dict:\n    \"\"\"Parse experiment metadata from directory name.\"\"\"\n    pattern = re.compile(r\"^(\\d{8}-\\d{6})-(.+)-tp(\\d+)-(\\w+)$\")\n    m = pattern.match(dirname)\n    if m:\n        return {\n            \"timestamp\": m.group(1),\n            \"model\": m.group(2),\n            \"tp\": int(m.group(3)),\n            \"workload\": m.group(4),\n        }\n    tp_matches = list(re.finditer(r\"-tp(\\d+)-\", dirname))\n    if not tp_matches:\n        raise ValueError(f\"Cannot parse experiment dir: {dirname}\")\n    last_tp = tp_matches[-1]\n    return {\n        \"timestamp\": dirname[:15],\n        \"model\": dirname[16 : last_tp.start()],\n        \"tp\": int(last_tp.group(1)),\n        \"workload\": dirname[last_tp.end() :],\n    }\n\n\ndef load_ground_truth(experiment_dir: str) -> dict:\n    \"\"\"Load summary latency metrics from ground-truth experiment.\"\"\"\n    summary_path = os.path.join(\n        experiment_dir, \"results\", \"summary_lifecycle_metrics.json\"\n    )\n    with open(summary_path) as f:\n        data = json.load(f)\n    successes = data.get(\"successes\", {})\n    latency = successes.get(\"latency\", {})\n    return {\n        \"e2e_mean_s\": latency.get(\"request_latency\", {}).get(\"mean\", 0),\n        \"ttft_mean_s\": latency.get(\"time_to_first_token\", {}).get(\"mean\", 0),\n        \"itl_mean_s\": latency.get(\"inter_token_latency\", {}).get(\"mean\", 0),\n        \"throughput_rps\": successes.get(\"throughput\", {}).get(\"requests_per_sec\", 0),\n        \"num_requests\": data.get(\"load_summary\", {}).get(\"count\", 0),\n        \"prompt_len_mean\": successes.get(\"prompt_len\", {}).get(\"mean\", 0),\n        \"output_len_mean\": successes.get(\"output_len\", {}).get(\"mean\", 0),\n    }\n\n\ndef load_exp_config(experiment_dir: str) -> dict:\n    \"\"\"Load exp-config.yaml.\"\"\"\n    with open(os.path.join(experiment_dir, \"exp-config.yaml\")) as f:\n        return yaml.safe_load(f)\n\n\ndef load_profile(experiment_dir: str) -> dict:\n    \"\"\"Load profile.yaml (JSON despite .yaml extension).\"\"\"\n    with open(os.path.join(experiment_dir, \"profile.yaml\")) as f:\n        content = f.read()\n    try:\n        return json.loads(content)\n    except json.JSONDecodeError:\n        return yaml.safe_load(content)\n\n\ndef extract_kv_blocks(experiment_dir: str) -> int | None:\n    \"\"\"Parse vllm.log for GPU KV cache size and convert to blocks.\"\"\"\n    vllm_log_path = os.path.join(experiment_dir, \"vllm.log\")\n    if not os.path.isfile(vllm_log_path):\n        return None\n    pattern = re.compile(r\"GPU KV cache size:\\s+([\\d,]+)\\s+tokens\")\n    with open(vllm_log_path) as f:\n        for line in f:\n            m = pattern.search(line)\n            if m:\n                tokens = int(m.group(1).replace(\",\", \"\"))\n                return tokens // BLOCK_SIZE_TOKENS\n    return None\n\n\ndef extract_cpu_kv_blocks(experiment_dir: str) -> int:\n    \"\"\"Parse vllm.log for CPU offloading config.\"\"\"\n    vllm_log_path = os.path.join(experiment_dir, \"vllm.log\")\n    if not os.path.isfile(vllm_log_path):\n        return 0\n    cpu_bytes = None\n    kv_shape = None\n    with open(vllm_log_path) as f:\n        for line in f:\n            if cpu_bytes is None:\n                m = re.search(r\"cpu_bytes_to_use['\\\"]?:\\s*([\\d.]+)\", line)\n                if m:\n                    cpu_bytes = float(m.group(1))\n            if kv_shape is None:\n                m = re.search(\n                    r\"cross layer KV cache of shape \\((\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+)\\)\",\n                    line,\n                )\n                if m:\n                    kv_shape = tuple(int(m.group(i)) for i in range(1, 7))\n            if cpu_bytes is not None and kv_shape is not None:\n                break\n    if cpu_bytes is None or kv_shape is None or cpu_bytes == 0:\n        return 0\n    _, num_layers, _, block_size, num_kv_heads, head_dim = kv_shape\n    per_block_bytes = num_layers * 2 * block_size * num_kv_heads * head_dim * 2\n    return int(cpu_bytes) // per_block_bytes\n\n\n# ---------------------------------------------------------------------------\n# Workload spec construction (fixed — expands inference_perf into clients)\n# ---------------------------------------------------------------------------\ndef build_workload_spec_with_clients(profile: dict, ground_truth: dict) -> dict:\n    \"\"\"Build a BLIS-compatible workload spec with clients already expanded.\n\n    This is the fix for the validation issue: BLIS's Validate() requires\n    clients to be present. The inference_perf expansion happens in\n    GenerateRequests() which runs AFTER Validate() in cmd/root.go.\n    \"\"\"\n    data = profile.get(\"data\", {})\n    load_config = profile.get(\"load\", {})\n    sp = data.get(\"shared_prefix\", {})\n\n    stages = []\n    for stage in load_config.get(\"stages\", []):\n        stages.append({\"rate\": stage[\"rate\"], \"duration\": stage[\"duration\"]})\n\n    if not stages:\n        num_requests = ground_truth.get(\"num_requests\", 1000)\n        rps = ground_truth.get(\"throughput_rps\", 10)\n        duration = int(num_requests / rps) + 60\n        stages.append({\"rate\": rps, \"duration\": duration})\n\n    total_duration = sum(s[\"duration\"] for s in stages)\n    aggregate_rate = sum(s[\"rate\"] * s[\"duration\"] for s in stages) / total_duration\n    total_requests = int(sum(s[\"rate\"] * s[\"duration\"] for s in stages))\n    horizon = int(total_duration * 1_000_000) + 60_000_000\n\n    num_prompts = sp.get(\"num_unique_system_prompts\", 9)\n    num_users = sp.get(\"num_users_per_system_prompt\", 5)\n    num_clients = num_prompts * num_users\n    question_len = sp.get(\"question_len\", int(ground_truth.get(\"prompt_len_mean\", 500)))\n    output_len = sp.get(\"output_len\", int(ground_truth.get(\"output_len_mean\", 250)))\n    system_prompt_len = sp.get(\"system_prompt_len\", 100)\n\n    rate_fraction = 1.0 / num_clients\n    clients = []\n    for p in range(num_prompts):\n        for u in range(num_users):\n            client = {\n                \"id\": f\"prompt-{p}-user-{u}\",\n                \"tenant_id\": f\"prompt-{p}\",\n                \"slo_class\": \"batch\",\n                \"rate_fraction\": rate_fraction,\n                \"arrival\": {\"process\": \"poisson\"},\n                \"input_distribution\": {\n                    \"type\": \"constant\",\n                    \"params\": {\"value\": float(question_len)},\n                },\n                \"output_distribution\": {\n                    \"type\": \"constant\",\n                    \"params\": {\"value\": float(output_len)},\n                },\n                \"prefix_group\": f\"prompt-{p}\",\n                \"prefix_length\": system_prompt_len,\n                \"streaming\": False,\n            }\n            clients.append(client)\n\n    return {\n        \"version\": \"2\",\n        \"seed\": 42,\n        \"category\": \"language\",\n        \"num_requests\": total_requests,\n        \"horizon\": horizon,\n        \"aggregate_rate\": aggregate_rate,\n        \"clients\": clients,\n    }\n\n\n# ---------------------------------------------------------------------------\n# BLIS execution\n# ---------------------------------------------------------------------------\ndef run_blis(\n    exp_dir: str,\n    alpha_coeffs: list[float],\n    beta_coeffs: list[float],\n) -> dict | None:\n    \"\"\"Run BLIS on a ground-truth experiment with given coefficients.\n\n    Returns dict with e2e_mean_ms, ttft_mean_ms, itl_mean_ms, or None on failure.\n    \"\"\"\n    gt = load_ground_truth(exp_dir)\n    exp_config = load_exp_config(exp_dir)\n    total_kv_blocks = extract_kv_blocks(exp_dir)\n    if total_kv_blocks is None:\n        return None\n    cpu_kv_blocks = extract_cpu_kv_blocks(exp_dir)\n\n    try:\n        profile = load_profile(exp_dir)\n    except Exception:\n        return None\n\n    workload_spec = build_workload_spec_with_clients(profile, gt)\n\n    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".yaml\", delete=False) as f:\n        yaml.dump(workload_spec, f, default_flow_style=False)\n        spec_path = f.name\n\n    with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n        results_path = f.name\n\n    model_name = exp_config.get(\"model\", \"unknown\")\n    tp = exp_config.get(\"tensor_parallelism\", 1)\n    max_model_len = exp_config.get(\"max_model_len\", 4096)\n    max_num_seqs = exp_config.get(\"max_num_seqs\", 128)\n    max_batched = exp_config.get(\"max_num_batched_tokens\", 2048)\n\n    cmd = [\n        _BINARY,\n        \"run\",\n        \"--model\", model_name,\n        \"--workload-spec\", spec_path,\n        \"--tp\", str(tp),\n        \"--max-model-len\", str(max_model_len),\n        \"--max-num-running-reqs\", str(max_num_seqs),\n        \"--max-num-scheduled-tokens\", str(max_batched),\n        \"--total-kv-blocks\", str(total_kv_blocks),\n        \"--block-size-in-tokens\", str(BLOCK_SIZE_TOKENS),\n        \"--alpha-coeffs=\" + \",\".join(str(c) for c in alpha_coeffs),\n        \"--beta-coeffs=\" + \",\".join(str(c) for c in beta_coeffs),\n        \"--results-path\", results_path,\n        \"--log\", \"error\",\n    ]\n\n    if cpu_kv_blocks > 0:\n        cmd.insert(-2, \"--kv-cpu-blocks\")\n        cmd.insert(-2, str(cpu_kv_blocks))\n\n    try:\n        result = subprocess.run(\n            cmd,\n            capture_output=True,\n            text=True,\n            timeout=300,\n            cwd=_REPO_ROOT,\n        )\n    except (subprocess.TimeoutExpired, FileNotFoundError):\n        return None\n    finally:\n        try:\n            os.unlink(spec_path)\n        except OSError:\n            pass\n        try:\n            os.unlink(results_path)\n        except OSError:\n            pass\n\n    if result.returncode != 0:\n        return None\n\n    return parse_blis_stdout(result.stdout)\n\n\ndef parse_blis_stdout(stdout: str) -> dict | None:\n    \"\"\"Parse BLIS stdout for metrics JSON.\"\"\"\n    lines = stdout.split(\"\\n\")\n    json_lines = []\n    in_json = False\n    brace_depth = 0\n\n    for line in lines:\n        if \"Simulation Metrics\" in line:\n            in_json = False\n            json_lines = []\n            continue\n        if not in_json and line.strip().startswith(\"{\"):\n            in_json = True\n            brace_depth = 0\n        if in_json:\n            json_lines.append(line)\n            brace_depth += line.count(\"{\") - line.count(\"}\")\n            if brace_depth <= 0:\n                break\n\n    if not json_lines:\n        return None\n\n    try:\n        metrics = json.loads(\"\\n\".join(json_lines))\n    except json.JSONDecodeError:\n        return None\n\n    return {\n        \"e2e_mean_ms\": metrics.get(\"e2e_mean_ms\", 0),\n        \"ttft_mean_ms\": metrics.get(\"ttft_mean_ms\", 0),\n        \"itl_mean_ms\": metrics.get(\"itl_mean_ms\", 0),\n        \"completed_requests\": metrics.get(\"completed_requests\", 0),\n    }\n\n\ndef compute_relative_error(predicted: float, observed: float) -> float:\n    \"\"\"Compute |predicted - observed| / observed.\"\"\"\n    if observed == 0:\n        return float(\"inf\") if predicted != 0 else 0.0\n    return abs(predicted - observed) / observed\n\n\n# ---------------------------------------------------------------------------\n# Enumerate experiments\n# ---------------------------------------------------------------------------\ndef list_experiments() -> list[dict]:\n    \"\"\"List all valid experiments with metadata.\"\"\"\n    experiments = []\n    for dirname in sorted(os.listdir(_DATA_ROOT)):\n        dirpath = os.path.join(_DATA_ROOT, dirname)\n        if not os.path.isdir(dirpath):\n            continue\n        summary_path = os.path.join(dirpath, \"results\", \"summary_lifecycle_metrics.json\")\n        if not os.path.isfile(summary_path):\n            continue\n        try:\n            meta = parse_experiment_dir(dirname)\n        except ValueError:\n            continue\n        experiments.append({\n            \"dirname\": dirname,\n            \"dirpath\": dirpath,\n            \"model\": meta[\"model\"],\n            \"tp\": meta[\"tp\"],\n            \"workload\": meta[\"workload\"],\n        })\n    return experiments\n\n\n# ===================================================================\n# H1: PRINCIPLED BASE — Overhead-Floor Regression + TTFT Corrections\n# ===================================================================\ndef compute_per_model_cycle_time_stats(step_df: pd.DataFrame) -> dict:\n    \"\"\"Compute per-model step time statistics from step-level data.\n\n    Instead of using lifecycle ITL (which has measurement issues with\n    sub-millisecond medians), we use the known R3 overhead floors as the\n    basis for the overhead multiplier.\n    \"\"\"\n    stats = {}\n    for model in sorted(step_df[\"model\"].unique()):\n        mdf = step_df[step_df[\"model\"] == model]\n        dur = mdf[\"step.duration_us\"].dropna().astype(float)\n        if len(dur) == 0:\n            continue\n\n        norm_model = normalize_model_name(model)\n        overhead_floor = R3_OVERHEAD_FLOORS.get(norm_model, R3_OVERHEAD_FLOORS.get(model, 5000))\n\n        stats[model] = {\n            \"median_dur_us\": float(dur.median()),\n            \"mean_dur_us\": float(dur.mean()),\n            \"p90_dur_us\": float(dur.quantile(0.9)),\n            \"overhead_floor_us\": overhead_floor,\n            \"n_steps\": len(dur),\n        }\n    return stats\n\n\ndef train_per_model_regression(\n    step_df: pd.DataFrame,\n    overhead_floors: dict[str, float],\n) -> dict:\n    \"\"\"Train per-model linear regression for step time.\n\n    Model: step_time_us = beta0 + beta1 * prefill_tokens + beta2 * decode_tokens\n\n    The key insight: we use the overhead floor as the minimum step time\n    (the intercept must be at least the overhead floor). The regression\n    is trained on the raw step.duration_us data, and then beta0 is set\n    to max(regression_intercept, overhead_floor).\n    \"\"\"\n    from sklearn.linear_model import Ridge\n\n    results = {}\n\n    for model_name in sorted(step_df[\"model\"].unique()):\n        mdf = step_df[step_df[\"model\"] == model_name].copy()\n        mdf = mdf.dropna(subset=[\"step.duration_us\"])\n        if len(mdf) < 20:\n            continue\n\n        norm_model = normalize_model_name(model_name)\n        overhead = overhead_floors.get(model_name, overhead_floors.get(norm_model, 5000))\n\n        # Features: prefill_tokens, decode_tokens\n        prefill = mdf.get(\"batch.prefill_tokens\", pd.Series(0, index=mdf.index)).fillna(0).astype(float)\n        decode = mdf.get(\"batch.decode_tokens\", pd.Series(0, index=mdf.index)).fillna(0).astype(float)\n        y = mdf[\"step.duration_us\"].astype(float).values\n\n        X = np.column_stack([prefill.values, decode.values])\n\n        # Train Ridge regression with positive intercept\n        reg = Ridge(alpha=10.0, fit_intercept=True)\n        reg.fit(X, y)\n\n        raw_intercept = float(reg.intercept_)\n        coeff_prefill = float(reg.coef_[0])\n        coeff_decode = float(reg.coef_[1])\n\n        # The overhead floor is the minimum step time — this captures\n        # CPU overhead, CUDA sync, etc. that step.duration_us misses.\n        # We use it as beta0 instead of the regression intercept.\n        beta0 = max(overhead, raw_intercept)\n\n        # Ensure coefficients are non-negative (physics constraint)\n        coeff_prefill = max(0.0, coeff_prefill)\n        coeff_decode = max(0.0, coeff_decode)\n\n        # Compute MAPE for fitted values\n        pred = beta0 + coeff_prefill * X[:, 0] + coeff_decode * X[:, 1]\n        abs_errors = np.abs(pred - y) / np.maximum(y, 1.0)\n        mape = float(np.mean(abs_errors) * 100)\n\n        results[model_name] = {\n            \"beta0\": beta0,\n            \"beta1_prefill\": coeff_prefill,\n            \"beta2_decode\": coeff_decode,\n            \"raw_intercept\": raw_intercept,\n            \"overhead_floor\": overhead,\n            \"step_mape\": mape,\n            \"n_steps\": len(mdf),\n            \"mean_step_us\": float(y.mean()),\n            \"median_step_us\": float(np.median(y)),\n        }\n\n        print(\n            f\"  {model_name}: beta0={beta0:.0f} beta1={coeff_prefill:.3f} \"\n            f\"beta2={coeff_decode:.1f} MAPE={mape:.1f}% n={len(mdf)}\"\n        )\n\n    return results\n\n\ndef compute_ttft_corrections(experiments: list[dict]) -> dict:\n    \"\"\"Compute per-model TTFT corrections from lifecycle data.\n\n    TTFT = time_to_first_token from lifecycle data (ground truth).\n    We use the mean across all experiments for each model as alpha0.\n    \"\"\"\n    model_ttfts = defaultdict(list)\n\n    for exp in experiments:\n        gt = load_ground_truth(exp[\"dirpath\"])\n        ttft_s = gt.get(\"ttft_mean_s\", 0)\n        if ttft_s > 0:\n            model_ttfts[exp[\"model\"]].append(ttft_s * 1_000_000)  # us\n\n    result = {}\n    for model, vals in model_ttfts.items():\n        mean_ttft = float(np.mean(vals))\n        norm_model = normalize_model_name(model)\n\n        # Use R3 values as fallback/starting points\n        r3_ttft = R3_TTFT_CORRECTIONS.get(norm_model, R3_TTFT_CORRECTIONS.get(model, 30000))\n\n        # Weighted average: 70% observed, 30% R3 prior\n        blended = 0.7 * mean_ttft + 0.3 * r3_ttft\n\n        result[model] = blended\n        print(f\"  {model}: observed={mean_ttft/1000:.1f}ms, R3={r3_ttft/1000:.1f}ms, blended={blended/1000:.1f}ms\")\n\n    return result\n\n\ndef run_h1(experiments: list[dict], step_df: pd.DataFrame) -> dict:\n    \"\"\"Run H1: Principled Base.\"\"\"\n    print(\"\\n\" + \"=\" * 70)\n    print(\"H1: PRINCIPLED BASE — Overhead-Floor Regression + TTFT Corrections\")\n    print(\"=\" * 70)\n\n    # Step 1: Per-model step time stats\n    print(\"\\n--- Step 1: Per-model step time statistics ---\")\n    step_stats = compute_per_model_cycle_time_stats(step_df)\n    for model, stats in step_stats.items():\n        print(\n            f\"  {model}: median={stats['median_dur_us']:.0f}us, \"\n            f\"overhead={stats['overhead_floor_us']}us, n={stats['n_steps']}\"\n        )\n\n    # Step 2: Train regression\n    print(\"\\n--- Step 2: Train per-model regression ---\")\n    overhead_floors = {m: s[\"overhead_floor_us\"] for m, s in step_stats.items()}\n    regression = train_per_model_regression(step_df, overhead_floors)\n\n    # Step 3: TTFT corrections\n    print(\"\\n--- Step 3: TTFT corrections ---\")\n    ttft_corrections = compute_ttft_corrections(experiments)\n\n    # Step 4: Build per-model alpha/beta coefficients\n    print(\"\\n--- Step 4: Build coefficients ---\")\n    per_model_coeffs = {}\n    for model_name, reg in regression.items():\n        norm = normalize_model_name(model_name)\n        ttft_us = ttft_corrections.get(model_name, ttft_corrections.get(norm, 30000))\n\n        # alpha = [alpha0 (TTFT intercept), alpha1 (input len coeff), alpha2 (output token proc)]\n        # beta = [beta0 (intercept/overhead), beta1 (prefill coeff), beta2 (decode coeff)]\n        alpha = [ttft_us, 0.0, 0.0]\n        beta = [reg[\"beta0\"], reg[\"beta1_prefill\"], reg[\"beta2_decode\"]]\n\n        per_model_coeffs[model_name] = {\"alpha\": alpha, \"beta\": beta}\n        print(\n            f\"  {model_name}: alpha={[f'{a:.0f}' for a in alpha]}, \"\n            f\"beta=[{beta[0]:.0f}, {beta[1]:.3f}, {beta[2]:.1f}]\"\n        )\n\n    # Step 5: BLIS validation\n    print(\"\\n--- Step 5: BLIS validation ---\")\n    results = []\n    for exp in experiments:\n        model = exp[\"model\"]\n        norm = normalize_model_name(model)\n\n        coeffs = per_model_coeffs.get(model)\n        if coeffs is None:\n            coeffs = per_model_coeffs.get(norm)\n        if coeffs is None:\n            # Try matching normalized names\n            for k, v in per_model_coeffs.items():\n                if normalize_model_name(k) == norm:\n                    coeffs = v\n                    break\n        if coeffs is None:\n            print(f\"  {exp['dirname']}: SKIP (no coefficients for {model})\")\n            results.append({\n                \"experiment\": exp[\"dirname\"],\n                \"model\": model,\n                \"workload\": exp[\"workload\"],\n                \"status\": \"no_coeffs\",\n            })\n            continue\n\n        gt = load_ground_truth(exp[\"dirpath\"])\n\n        blis = run_blis(exp[\"dirpath\"], coeffs[\"alpha\"], coeffs[\"beta\"])\n        if blis is None:\n            print(f\"  {exp['dirname']}: BLIS FAILED\")\n            results.append({\n                \"experiment\": exp[\"dirname\"],\n                \"model\": model,\n                \"workload\": exp[\"workload\"],\n                \"status\": \"blis_failed\",\n            })\n            continue\n\n        e2e_err = compute_relative_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n        ttft_err = compute_relative_error(blis[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000)\n        itl_err = compute_relative_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n\n        print(\n            f\"  {exp['dirname']}: E2E={e2e_err*100:.1f}% \"\n            f\"TTFT={ttft_err*100:.1f}% ITL={itl_err*100:.1f}%  \"\n            f\"(pred={blis['e2e_mean_ms']:.0f}ms gt={gt['e2e_mean_s']*1000:.0f}ms)\"\n        )\n\n        results.append({\n            \"experiment\": exp[\"dirname\"],\n            \"model\": model,\n            \"workload\": exp[\"workload\"],\n            \"tp\": exp[\"tp\"],\n            \"status\": \"ok\",\n            \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n            \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n            \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n            \"blis_e2e_ms\": blis[\"e2e_mean_ms\"],\n            \"blis_ttft_ms\": blis[\"ttft_mean_ms\"],\n            \"blis_itl_ms\": blis[\"itl_mean_ms\"],\n            \"e2e_error\": e2e_err,\n            \"ttft_error\": ttft_err,\n            \"itl_error\": itl_err,\n            \"alpha\": coeffs[\"alpha\"],\n            \"beta\": coeffs[\"beta\"],\n        })\n\n    # Save results\n    results_df = pd.DataFrame(results)\n    results_df.to_csv(os.path.join(H1_OUTPUT, \"blis_validation.csv\"), index=False)\n\n    ok = results_df[results_df[\"status\"] == \"ok\"]\n    summary = {}\n    if len(ok) > 0:\n        summary = {\n            \"mean_e2e_error_pct\": float(ok[\"e2e_error\"].mean() * 100),\n            \"mean_ttft_error_pct\": float(ok[\"ttft_error\"].mean() * 100),\n            \"mean_itl_error_pct\": float(ok[\"itl_error\"].mean() * 100),\n            \"median_e2e_error_pct\": float(ok[\"e2e_error\"].median() * 100),\n            \"n_experiments\": len(ok),\n            \"n_below_10_e2e\": int((ok[\"e2e_error\"] < 0.10).sum()),\n            \"n_below_20_e2e\": int((ok[\"e2e_error\"] < 0.20).sum()),\n            \"per_model_coeffs\": {\n                k: {\"alpha\": v[\"alpha\"], \"beta\": v[\"beta\"]}\n                for k, v in per_model_coeffs.items()\n            },\n            \"regression\": regression,\n            \"ttft_corrections_us\": {k: float(v) for k, v in ttft_corrections.items()},\n            \"per_experiment\": ok[\n                [\"experiment\", \"model\", \"workload\", \"e2e_error\", \"ttft_error\", \"itl_error\",\n                 \"gt_e2e_ms\", \"blis_e2e_ms\", \"gt_itl_ms\", \"blis_itl_ms\"]\n            ].to_dict(\"records\"),\n        }\n\n    with open(os.path.join(H1_OUTPUT, \"h1_summary.json\"), \"w\") as f:\n        json.dump(summary, f, indent=2, default=str)\n\n    print_summary_table(\"H1 PRINCIPLED BASE\", ok)\n\n    return {\n        \"per_model_coeffs\": per_model_coeffs,\n        \"regression\": regression,\n        \"results\": results,\n        \"summary\": summary,\n    }\n\n\n# ===================================================================\n# H2: CONSTRAINED CMA-ES RESIDUAL TUNING\n# ===================================================================\ndef cmaes_objective(\n    x: np.ndarray,\n    model_name: str,\n    base_coeffs: dict,\n    experiments: list[dict],\n) -> float:\n    \"\"\"CMA-ES objective: dual-objective E2E + ITL.\n\n    x = [scale_beta0, scale_beta1, scale_beta2, scale_alpha0, alpha2_output_proc]\n    Each scale is multiplicative around the base value (centered at 1.0).\n    alpha2 is absolute (0 to 500us range).\n    \"\"\"\n    scale_b0, scale_b1, scale_b2, scale_a0, alpha2 = x\n\n    base_alpha = base_coeffs[\"alpha\"]\n    base_beta = base_coeffs[\"beta\"]\n\n    alpha = [base_alpha[0] * scale_a0, base_alpha[1], alpha2]\n    beta = [base_beta[0] * scale_b0, base_beta[1] * scale_b1, base_beta[2] * scale_b2]\n\n    norm = normalize_model_name(model_name)\n    model_experiments = [\n        e for e in experiments\n        if normalize_model_name(e[\"model\"]) == norm\n    ]\n\n    if not model_experiments:\n        return 100.0\n\n    e2e_errors = []\n    itl_errors = []\n\n    for exp in model_experiments:\n        gt = load_ground_truth(exp[\"dirpath\"])\n        blis = run_blis(exp[\"dirpath\"], alpha, beta)\n        if blis is None:\n            return 100.0\n\n        e2e_err = compute_relative_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n        itl_err = compute_relative_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n        e2e_errors.append(e2e_err)\n        itl_errors.append(itl_err)\n\n    mean_e2e = np.mean(e2e_errors)\n    mean_itl = np.mean(itl_errors)\n\n    # Dual objective with ITL penalty\n    objective = 0.5 * mean_e2e + 0.5 * mean_itl + 5.0 * max(0, mean_itl - 0.20)\n    return float(objective)\n\n\ndef run_h2(\n    experiments: list[dict],\n    h1_coeffs: dict,\n) -> dict:\n    \"\"\"Run H2: Constrained CMA-ES Residual Tuning.\"\"\"\n    print(\"\\n\" + \"=\" * 70)\n    print(\"H2: CONSTRAINED CMA-ES RESIDUAL TUNING\")\n    print(\"=\" * 70)\n\n    try:\n        import cma\n    except ImportError:\n        print(\"ERROR: cma package not installed. Install with: pip install cma\")\n        return {\"error\": \"cma not installed\"}\n\n    # Group experiments by normalized model\n    model_experiments = defaultdict(list)\n    for exp in experiments:\n        norm = normalize_model_name(exp[\"model\"])\n        model_experiments[norm].append(exp)\n\n    optimized_coeffs = {}\n\n    for norm_model, model_exps in sorted(model_experiments.items()):\n        print(f\"\\n--- Optimizing {norm_model} ({len(model_exps)} experiments) ---\")\n\n        # Find base coefficients\n        base_coeffs = None\n        for model_name, coeffs in h1_coeffs.items():\n            if normalize_model_name(model_name) == norm_model:\n                base_coeffs = coeffs\n                break\n        if base_coeffs is None:\n            print(f\"  SKIP: no base coefficients\")\n            continue\n\n        # CMA-ES: optimize scale factors around 1.0\n        # x = [scale_beta0, scale_beta1, scale_beta2, scale_alpha0, alpha2]\n        x0 = [1.0, 1.0, 1.0, 1.0, 0.0]\n        sigma0 = 0.05  # Small initial step (tight search)\n\n        # Bounds: +-20% for scales, [0, 500] for alpha2\n        bounds = [\n            [0.80, 0.80, 0.80, 0.80, 0.0],     # lower\n            [1.20, 1.20, 1.20, 1.20, 500.0],    # upper\n        ]\n\n        opts = {\n            \"maxfevals\": 80,\n            \"bounds\": bounds,\n            \"seed\": 42,\n            \"verbose\": -9,  # Suppress CMA-ES output\n            \"tolfun\": 1e-6,\n        }\n\n        def obj(x):\n            return cmaes_objective(x, norm_model, base_coeffs, experiments)\n\n        es = cma.CMAEvolutionStrategy(x0, sigma0, opts)\n        es.optimize(obj)\n        result = es.result\n\n        best_x = result.xbest\n        best_f = result.fbest\n\n        scale_b0, scale_b1, scale_b2, scale_a0, alpha2 = best_x\n        opt_alpha = [\n            base_coeffs[\"alpha\"][0] * scale_a0,\n            base_coeffs[\"alpha\"][1],\n            alpha2,\n        ]\n        opt_beta = [\n            base_coeffs[\"beta\"][0] * scale_b0,\n            base_coeffs[\"beta\"][1] * scale_b1,\n            base_coeffs[\"beta\"][2] * scale_b2,\n        ]\n\n        optimized_coeffs[norm_model] = {\"alpha\": opt_alpha, \"beta\": opt_beta}\n\n        print(\n            f\"  Best: f={best_f:.4f}, scales=[{scale_b0:.3f}, {scale_b1:.3f}, \"\n            f\"{scale_b2:.3f}, {scale_a0:.3f}], alpha2={alpha2:.0f}\"\n        )\n        print(f\"  Optimized alpha={[f'{a:.0f}' for a in opt_alpha]}\")\n        print(f\"  Optimized beta=[{opt_beta[0]:.0f}, {opt_beta[1]:.3f}, {opt_beta[2]:.1f}]\")\n        print(f\"  Evaluations: {result.evaluations}\")\n\n    # Full validation with optimized coefficients\n    print(\"\\n--- Full validation with CMA-ES optimized coefficients ---\")\n    results = []\n    for exp in experiments:\n        model = exp[\"model\"]\n        norm = normalize_model_name(model)\n\n        coeffs = optimized_coeffs.get(norm)\n        if coeffs is None:\n            results.append({\n                \"experiment\": exp[\"dirname\"],\n                \"model\": model,\n                \"workload\": exp[\"workload\"],\n                \"status\": \"no_coeffs\",\n            })\n            continue\n\n        gt = load_ground_truth(exp[\"dirpath\"])\n        blis = run_blis(exp[\"dirpath\"], coeffs[\"alpha\"], coeffs[\"beta\"])\n\n        if blis is None:\n            results.append({\n                \"experiment\": exp[\"dirname\"],\n                \"model\": model,\n                \"workload\": exp[\"workload\"],\n                \"status\": \"blis_failed\",\n            })\n            continue\n\n        e2e_err = compute_relative_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n        ttft_err = compute_relative_error(blis[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000)\n        itl_err = compute_relative_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n\n        print(\n            f\"  {exp['dirname']}: E2E={e2e_err*100:.1f}% \"\n            f\"TTFT={ttft_err*100:.1f}% ITL={itl_err*100:.1f}%  \"\n            f\"(pred={blis['e2e_mean_ms']:.0f}ms gt={gt['e2e_mean_s']*1000:.0f}ms)\"\n        )\n\n        results.append({\n            \"experiment\": exp[\"dirname\"],\n            \"model\": model,\n            \"workload\": exp[\"workload\"],\n            \"tp\": exp[\"tp\"],\n            \"status\": \"ok\",\n            \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n            \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n            \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n            \"blis_e2e_ms\": blis[\"e2e_mean_ms\"],\n            \"blis_ttft_ms\": blis[\"ttft_mean_ms\"],\n            \"blis_itl_ms\": blis[\"itl_mean_ms\"],\n            \"e2e_error\": e2e_err,\n            \"ttft_error\": ttft_err,\n            \"itl_error\": itl_err,\n            \"alpha\": coeffs[\"alpha\"],\n            \"beta\": coeffs[\"beta\"],\n        })\n\n    results_df = pd.DataFrame(results)\n    results_df.to_csv(os.path.join(H2_OUTPUT, \"blis_validation.csv\"), index=False)\n\n    ok = results_df[results_df[\"status\"] == \"ok\"]\n    summary = {}\n    if len(ok) > 0:\n        summary = {\n            \"mean_e2e_error_pct\": float(ok[\"e2e_error\"].mean() * 100),\n            \"mean_ttft_error_pct\": float(ok[\"ttft_error\"].mean() * 100),\n            \"mean_itl_error_pct\": float(ok[\"itl_error\"].mean() * 100),\n            \"median_e2e_error_pct\": float(ok[\"e2e_error\"].median() * 100),\n            \"n_experiments\": len(ok),\n            \"n_below_10_e2e\": int((ok[\"e2e_error\"] < 0.10).sum()),\n            \"n_below_20_e2e\": int((ok[\"e2e_error\"] < 0.20).sum()),\n            \"optimized_coeffs\": {\n                k: {\"alpha\": v[\"alpha\"], \"beta\": v[\"beta\"]}\n                for k, v in optimized_coeffs.items()\n            },\n            \"per_experiment\": ok[\n                [\"experiment\", \"model\", \"workload\", \"e2e_error\", \"ttft_error\", \"itl_error\",\n                 \"gt_e2e_ms\", \"blis_e2e_ms\", \"gt_itl_ms\", \"blis_itl_ms\"]\n            ].to_dict(\"records\"),\n        }\n\n    with open(os.path.join(H2_OUTPUT, \"h2_summary.json\"), \"w\") as f:\n        json.dump(summary, f, indent=2, default=str)\n\n    print_summary_table(\"H2 CONSTRAINED CMA-ES\", ok)\n\n    return {\n        \"optimized_coeffs\": optimized_coeffs,\n        \"results\": results,\n        \"summary\": summary,\n    }\n\n\n# ===================================================================\n# H3: LEAVE-ONE-MODEL-OUT (LOMO) CROSS-VALIDATION\n# ===================================================================\ndef run_h3(\n    experiments: list[dict],\n    step_df: pd.DataFrame,\n) -> dict:\n    \"\"\"Run H3: LOMO Cross-Validation.\n\n    For each model, train on the other 3 models' data and evaluate\n    BLIS E2E/ITL on the held-out model's experiments.\n    \"\"\"\n    print(\"\\n\" + \"=\" * 70)\n    print(\"H3: LEAVE-ONE-MODEL-OUT (LOMO) CROSS-VALIDATION\")\n    print(\"=\" * 70)\n\n    # Get unique normalized models\n    model_experiments = defaultdict(list)\n    for exp in experiments:\n        norm = normalize_model_name(exp[\"model\"])\n        model_experiments[norm].append(exp)\n\n    unique_models = sorted(model_experiments.keys())\n    print(f\"Models: {unique_models}\")\n\n    all_results = []\n    fold_summaries = []\n\n    for holdout_model in unique_models:\n        print(f\"\\n--- Fold: Hold out {holdout_model} ---\")\n\n        # Train set: all steps NOT from holdout model\n        train_mask = step_df[\"model\"].map(normalize_model_name) != holdout_model\n        train_df = step_df[train_mask].copy()\n\n        # Train regression on remaining models\n        overhead_floors = {}\n        for model in train_df[\"model\"].unique():\n            norm = normalize_model_name(model)\n            overhead_floors[model] = R3_OVERHEAD_FLOORS.get(\n                norm, R3_OVERHEAD_FLOORS.get(model, 5000)\n            )\n\n        print(f\"  Training on {len(train_df)} steps from {sorted(train_df['model'].unique())}\")\n        regression = train_per_model_regression(train_df, overhead_floors)\n\n        # Compute TTFT from training experiments\n        train_experiments = [\n            e for e in experiments\n            if normalize_model_name(e[\"model\"]) != holdout_model\n        ]\n        ttft_corrections = compute_ttft_corrections(train_experiments)\n\n        # For the held-out model, use the NEAREST donor model's coefficients\n        holdout_experiments = model_experiments[holdout_model]\n\n        # Try each donor model's coefficients\n        donor_results = {}\n        for donor_model in [m for m in unique_models if m != holdout_model]:\n            # Find donor coefficients\n            donor_coeffs = None\n            for model_name, reg in regression.items():\n                if normalize_model_name(model_name) == donor_model:\n                    ttft_us = 0\n                    for k, v in ttft_corrections.items():\n                        if normalize_model_name(k) == donor_model:\n                            ttft_us = v\n                            break\n                    if ttft_us == 0:\n                        ttft_us = R3_TTFT_CORRECTIONS.get(donor_model, 30000)\n\n                    donor_coeffs = {\n                        \"alpha\": [ttft_us, 0.0, 0.0],\n                        \"beta\": [reg[\"beta0\"], reg[\"beta1_prefill\"], reg[\"beta2_decode\"]],\n                    }\n                    break\n\n            if donor_coeffs is None:\n                continue\n\n            # Evaluate on holdout model's experiments\n            fold_errors = []\n            for exp in holdout_experiments:\n                gt = load_ground_truth(exp[\"dirpath\"])\n                blis = run_blis(exp[\"dirpath\"], donor_coeffs[\"alpha\"], donor_coeffs[\"beta\"])\n\n                if blis is None:\n                    continue\n\n                e2e_err = compute_relative_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n                itl_err = compute_relative_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n                fold_errors.append({\n                    \"experiment\": exp[\"dirname\"],\n                    \"donor\": donor_model,\n                    \"holdout\": holdout_model,\n                    \"e2e_error\": e2e_err,\n                    \"itl_error\": itl_err,\n                    \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n                    \"blis_e2e_ms\": blis[\"e2e_mean_ms\"],\n                    \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n                    \"blis_itl_ms\": blis[\"itl_mean_ms\"],\n                })\n\n            if fold_errors:\n                mean_e2e = np.mean([f[\"e2e_error\"] for f in fold_errors])\n                mean_itl = np.mean([f[\"itl_error\"] for f in fold_errors])\n                donor_results[donor_model] = {\n                    \"mean_e2e\": mean_e2e,\n                    \"mean_itl\": mean_itl,\n                    \"errors\": fold_errors,\n                }\n                print(\n                    f\"  Donor {donor_model} -> {holdout_model}: \"\n                    f\"E2E={mean_e2e*100:.1f}% ITL={mean_itl*100:.1f}%\"\n                )\n                all_results.extend(fold_errors)\n\n        # Find best donor\n        if donor_results:\n            best_donor = min(donor_results, key=lambda d: donor_results[d][\"mean_e2e\"])\n            best = donor_results[best_donor]\n            fold_summaries.append({\n                \"holdout_model\": holdout_model,\n                \"best_donor\": best_donor,\n                \"best_donor_e2e\": best[\"mean_e2e\"],\n                \"best_donor_itl\": best[\"mean_itl\"],\n                \"all_donors\": {\n                    d: {\"e2e\": v[\"mean_e2e\"], \"itl\": v[\"mean_itl\"]}\n                    for d, v in donor_results.items()\n                },\n            })\n            print(\n                f\"  Best donor: {best_donor} (E2E={best['mean_e2e']*100:.1f}%, \"\n                f\"ITL={best['mean_itl']*100:.1f}%)\"\n            )\n\n    # Save results\n    all_df = pd.DataFrame(all_results)\n    all_df.to_csv(os.path.join(H3_OUTPUT, \"lomo_results.csv\"), index=False)\n\n    summary = {\n        \"fold_summaries\": fold_summaries,\n        \"mean_best_donor_e2e_pct\": float(\n            np.mean([f[\"best_donor_e2e\"] for f in fold_summaries]) * 100\n        ) if fold_summaries else 0,\n        \"mean_best_donor_itl_pct\": float(\n            np.mean([f[\"best_donor_itl\"] for f in fold_summaries]) * 100\n        ) if fold_summaries else 0,\n    }\n\n    with open(os.path.join(H3_OUTPUT, \"h3_summary.json\"), \"w\") as f:\n        json.dump(summary, f, indent=2, default=str)\n\n    print(\"\\n--- LOMO Summary ---\")\n    print(f\"{'Holdout':<25} {'Best Donor':<25} {'E2E%':>8} {'ITL%':>8}\")\n    print(\"-\" * 70)\n    for fs in fold_summaries:\n        print(\n            f\"{fs['holdout_model']:<25} {fs['best_donor']:<25} \"\n            f\"{fs['best_donor_e2e']*100:>8.1f} {fs['best_donor_itl']*100:>8.1f}\"\n        )\n    if fold_summaries:\n        print(\"-\" * 70)\n        print(\n            f\"{'MEAN':<25} {'':<25} \"\n            f\"{summary['mean_best_donor_e2e_pct']:>8.1f} \"\n            f\"{summary['mean_best_donor_itl_pct']:>8.1f}\"\n        )\n\n    return {\"summary\": summary, \"fold_summaries\": fold_summaries}\n\n\n# ===================================================================\n# H4: LEAVE-ONE-WORKLOAD-OUT (LOWO) CROSS-VALIDATION\n# ===================================================================\ndef run_h4(\n    experiments: list[dict],\n    h2_coeffs: dict,\n) -> dict:\n    \"\"\"Run H4: LOWO Cross-Validation.\n\n    Uses H2's best coefficients and evaluates per-workload stability.\n    \"\"\"\n    print(\"\\n\" + \"=\" * 70)\n    print(\"H4: LEAVE-ONE-WORKLOAD-OUT (LOWO) CROSS-VALIDATION\")\n    print(\"=\" * 70)\n\n    # Group by workload\n    workload_experiments = defaultdict(list)\n    for exp in experiments:\n        workload_experiments[exp[\"workload\"]].append(exp)\n\n    unique_workloads = sorted(workload_experiments.keys())\n    print(f\"Workloads: {unique_workloads}\")\n\n    # Evaluate all experiments with H2 coefficients (or h2_coeffs)\n    all_results = []\n    for exp in experiments:\n        norm = normalize_model_name(exp[\"model\"])\n        coeffs = h2_coeffs.get(norm)\n        if coeffs is None:\n            continue\n\n        gt = load_ground_truth(exp[\"dirpath\"])\n        blis = run_blis(exp[\"dirpath\"], coeffs[\"alpha\"], coeffs[\"beta\"])\n        if blis is None:\n            continue\n\n        e2e_err = compute_relative_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n        itl_err = compute_relative_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n\n        all_results.append({\n            \"experiment\": exp[\"dirname\"],\n            \"model\": exp[\"model\"],\n            \"norm_model\": norm,\n            \"workload\": exp[\"workload\"],\n            \"e2e_error\": e2e_err,\n            \"itl_error\": itl_err,\n            \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n            \"blis_e2e_ms\": blis[\"e2e_mean_ms\"],\n            \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n            \"blis_itl_ms\": blis[\"itl_mean_ms\"],\n        })\n\n    results_df = pd.DataFrame(all_results)\n    results_df.to_csv(os.path.join(H4_OUTPUT, \"lowo_results.csv\"), index=False)\n\n    # Per-model workload variance\n    print(\"\\n--- Per-model workload breakdown ---\")\n    model_workload_stats = {}\n    for norm_model in sorted(results_df[\"norm_model\"].unique()):\n        model_df = results_df[results_df[\"norm_model\"] == norm_model]\n        per_workload = {}\n        for workload in sorted(model_df[\"workload\"].unique()):\n            wdf = model_df[model_df[\"workload\"] == workload]\n            per_workload[workload] = {\n                \"e2e_error\": float(wdf[\"e2e_error\"].mean()),\n                \"itl_error\": float(wdf[\"itl_error\"].mean()),\n            }\n\n        e2e_errors = [v[\"e2e_error\"] for v in per_workload.values()]\n        variance_pp = (max(e2e_errors) - min(e2e_errors)) * 100 if len(e2e_errors) > 1 else 0\n\n        model_workload_stats[norm_model] = {\n            \"per_workload\": per_workload,\n            \"e2e_range_pp\": variance_pp,\n            \"mean_e2e\": float(model_df[\"e2e_error\"].mean()),\n        }\n\n        print(f\"\\n  {norm_model}: range={variance_pp:.1f}pp\")\n        for wl, wlstats in per_workload.items():\n            print(f\"    {wl}: E2E={wlstats['e2e_error']*100:.1f}% ITL={wlstats['itl_error']*100:.1f}%\")\n\n    # Aggregate statistics\n    aggregate_e2e = float(results_df[\"e2e_error\"].mean()) if len(results_df) > 0 else 1.0\n    n_within_2x = int((results_df[\"e2e_error\"] < 2 * aggregate_e2e).sum()) if len(results_df) > 0 else 0\n\n    summary = {\n        \"aggregate_e2e_pct\": aggregate_e2e * 100,\n        \"aggregate_itl_pct\": float(results_df[\"itl_error\"].mean() * 100) if len(results_df) > 0 else 0,\n        \"n_within_2x_aggregate\": n_within_2x,\n        \"n_total\": len(results_df),\n        \"model_workload_stats\": model_workload_stats,\n        \"per_experiment\": results_df.to_dict(\"records\") if len(results_df) > 0 else [],\n    }\n\n    with open(os.path.join(H4_OUTPUT, \"h4_summary.json\"), \"w\") as f:\n        json.dump(summary, f, indent=2, default=str)\n\n    # Dense model variance check\n    dense_models = [m for m in model_workload_stats if \"mixtral\" not in m]\n    dense_ranges = [model_workload_stats[m][\"e2e_range_pp\"] for m in dense_models]\n\n    print(f\"\\n--- LOWO Summary ---\")\n    print(f\"Aggregate E2E: {aggregate_e2e*100:.1f}%\")\n    print(f\"Within 2x aggregate: {n_within_2x}/{len(results_df)}\")\n    if dense_ranges:\n        print(f\"Dense model max range: {max(dense_ranges):.1f}pp (target <=20pp)\")\n    print(f\"{'Model':<25} {'Range(pp)':>10} {'Mean E2E%':>10}\")\n    print(\"-\" * 50)\n    for model, stats in sorted(model_workload_stats.items()):\n        print(f\"{model:<25} {stats['e2e_range_pp']:>10.1f} {stats['mean_e2e']*100:>10.1f}\")\n\n    return {\"summary\": summary}\n\n\n# ===================================================================\n# Utilities\n# ===================================================================\ndef print_summary_table(title: str, ok_df: pd.DataFrame):\n    \"\"\"Print a formatted summary table.\"\"\"\n    if ok_df is None or len(ok_df) == 0:\n        print(f\"\\n{title}: No results!\")\n        return\n\n    mean_e2e = ok_df[\"e2e_error\"].mean() * 100\n    mean_ttft = ok_df[\"ttft_error\"].mean() * 100\n    mean_itl = ok_df[\"itl_error\"].mean() * 100\n    below_10 = (ok_df[\"e2e_error\"] < 0.10).sum()\n    below_20 = (ok_df[\"e2e_error\"] < 0.20).sum()\n\n    print(f\"\\n{'=' * 70}\")\n    print(f\"{title} RESULTS\")\n    print(f\"{'=' * 70}\")\n    print(f\"Experiments: {len(ok_df)}\")\n    print(f\"Mean E2E:  {mean_e2e:.1f}%\")\n    print(f\"Mean TTFT: {mean_ttft:.1f}%\")\n    print(f\"Mean ITL:  {mean_itl:.1f}%\")\n    print(f\"Median E2E: {ok_df['e2e_error'].median()*100:.1f}%\")\n    print(f\"E2E < 10%: {below_10}/{len(ok_df)}\")\n    print(f\"E2E < 20%: {below_20}/{len(ok_df)}\")\n\n    print(f\"\\n{'Experiment':<55} {'E2E%':>7} {'TTFT%':>7} {'ITL%':>7}\")\n    print(\"-\" * 80)\n    for _, row in ok_df.iterrows():\n        print(\n            f\"{row['experiment']:<55} \"\n            f\"{row['e2e_error']*100:>7.1f} \"\n            f\"{row['ttft_error']*100:>7.1f} \"\n            f\"{row['itl_error']*100:>7.1f}\"\n        )\n    print(\"-\" * 80)\n    print(f\"{'MEAN':<55} {mean_e2e:>7.1f} {mean_ttft:>7.1f} {mean_itl:>7.1f}\")\n\n\n# ===================================================================\n# MAIN\n# ===================================================================\ndef main():\n    start_time = time.time()\n\n    print(\"=\" * 70)\n    print(\"ROUND 4, IDEA 3: HYBRID CALIBRATION — ALL SUB-HYPOTHESES\")\n    print(\"=\" * 70)\n    print(f\"Data root: {_DATA_ROOT}\")\n    print(f\"BLIS binary: {_BINARY}\")\n\n    # Build binary if needed\n    if not os.path.isfile(_BINARY):\n        print(\"Building BLIS binary...\")\n        subprocess.run(\n            [\"go\", \"build\", \"-o\", _BINARY, \"main.go\"],\n            cwd=_REPO_ROOT,\n            check=True,\n        )\n\n    # Load data\n    print(\"\\n--- Loading step-level data ---\")\n    step_df = load_all_experiments(_DATA_ROOT)\n    print(f\"Loaded {len(step_df)} steps from {step_df['experiment_id'].nunique()} experiments\")\n    print(f\"Models: {sorted(step_df['model'].unique())}\")\n\n    experiments = list_experiments()\n    print(f\"Experiments for BLIS validation: {len(experiments)}\")\n\n    # ---------------------------------------------------------------\n    # H1: Principled Base\n    # ---------------------------------------------------------------\n    h1_results = run_h1(experiments, step_df)\n\n    # ---------------------------------------------------------------\n    # H2: Constrained CMA-ES\n    # ---------------------------------------------------------------\n    h2_results = run_h2(experiments, h1_results[\"per_model_coeffs\"])\n\n    # ---------------------------------------------------------------\n    # H3: LOMO\n    # ---------------------------------------------------------------\n    h3_results = run_h3(experiments, step_df)\n\n    # ---------------------------------------------------------------\n    # H4: LOWO\n    # ---------------------------------------------------------------\n    h2_coeffs = h2_results.get(\"optimized_coeffs\", {})\n    if not h2_coeffs:\n        # Fall back to H1 coefficients\n        h2_coeffs = {}\n        for k, v in h1_results[\"per_model_coeffs\"].items():\n            h2_coeffs[normalize_model_name(k)] = v\n    h4_results = run_h4(experiments, h2_coeffs)\n\n    # ---------------------------------------------------------------\n    # Grand Summary\n    # ---------------------------------------------------------------\n    elapsed = time.time() - start_time\n    print(\"\\n\" + \"=\" * 70)\n    print(\"GRAND SUMMARY\")\n    print(\"=\" * 70)\n\n    h1_s = h1_results.get(\"summary\", {})\n    h2_s = h2_results.get(\"summary\", {})\n    h3_s = h3_results.get(\"summary\", {})\n    h4_s = h4_results.get(\"summary\", {})\n\n    print(f\"\\n{'Hypothesis':<30} {'E2E%':>8} {'ITL%':>8} {'<10% E2E':>10} {'Note':>20}\")\n    print(\"-\" * 80)\n    print(\n        f\"{'H1 Principled Base':<30} \"\n        f\"{h1_s.get('mean_e2e_error_pct', 0):>8.1f} \"\n        f\"{h1_s.get('mean_itl_error_pct', 0):>8.1f} \"\n        f\"{h1_s.get('n_below_10_e2e', 0):>10} \"\n        f\"{'target <30% E2E':>20}\"\n    )\n    print(\n        f\"{'H2 CMA-ES Residual':<30} \"\n        f\"{h2_s.get('mean_e2e_error_pct', 0):>8.1f} \"\n        f\"{h2_s.get('mean_itl_error_pct', 0):>8.1f} \"\n        f\"{h2_s.get('n_below_10_e2e', 0):>10} \"\n        f\"{'target <12% E2E':>20}\"\n    )\n    print(\n        f\"{'H3 LOMO best-donor':<30} \"\n        f\"{h3_s.get('mean_best_donor_e2e_pct', 0):>8.1f} \"\n        f\"{h3_s.get('mean_best_donor_itl_pct', 0):>8.1f} \"\n        f\"{'':>10} \"\n        f\"{'target <20% E2E':>20}\"\n    )\n    print(\n        f\"{'H4 LOWO aggregate':<30} \"\n        f\"{h4_s.get('aggregate_e2e_pct', 0):>8.1f} \"\n        f\"{h4_s.get('aggregate_itl_pct', 0):>8.1f} \"\n        f\"{'':>10} \"\n        f\"{f'{h4_s.get(\\\"n_within_2x_aggregate\\\",0)}/{h4_s.get(\\\"n_total\\\",0)} within 2x':>20}\"\n    )\n\n    print(f\"\\n--- R3 Baselines for comparison ---\")\n    print(f\"R3 CMA-ES:       E2E=15.1%, ITL=87.4%, 4/10 <10%\")\n    print(f\"R3 Trace Replay: E2E=56.2%, ITL=9.5%\")\n    print(f\"R3 LOMO:         E2E=14.8% (best donor)\")\n\n    print(f\"\\nTotal runtime: {elapsed:.0f}s ({elapsed/60:.1f}min)\")\n\n    # Save grand summary\n    grand = {\n        \"h1\": h1_s,\n        \"h2\": h2_s,\n        \"h3\": h3_s,\n        \"h4\": h4_s,\n        \"runtime_s\": elapsed,\n        \"r3_baselines\": {\n            \"cmaes\": {\"e2e\": 15.1, \"itl\": 87.4},\n            \"trace_replay\": {\"e2e\": 56.2, \"itl\": 9.5},\n            \"lomo\": {\"e2e\": 14.8},\n        },\n    }\n    with open(os.path.join(_SCRIPT_DIR, \"grand_summary.json\"), \"w\") as f:\n        json.dump(grand, f, indent=2, default=str)\n\n    print(f\"\\nAll results saved to sub-hypothesis output directories.\")\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"output_tokens":0},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01CfKY3CEYt1bGTQUxibMBP7","session_id":"e652145f-d03b-4eb5-bbf8-d7db257fe10a","uuid":"beae4135-bd19-4d47-acf9-dbace30cfe93"}
