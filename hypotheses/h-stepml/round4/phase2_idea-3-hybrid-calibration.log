model FairBatching regression ---\")","-    models = train_per_model_regression(ct_df)","+    # Step 2: Load step data and compute multipliers","+    print(\"\\n--- Step 2: Compute overhead multipliers ---\")","+    step_df = load_all_experiments(data_root)","+    multipliers = compute_overhead_multipliers(step_df, itl_data)"," ","-    # Save regression results","+    # Step 3: Train regression on scaled step times","+    print(\"\\n--- Step 3: Train per-model regression on scaled step times ---\")","+    models = train_per_model_regression(step_df, multipliers)","+","     with open(os.path.join(OUTPUT_DIR, \"regression_results.json\"), \"w\") as f:","-        json.dump(models, f, indent=2)","+        json.dump(models, f, indent=2, default=str)"," ","-    # Step 3: Estimate TTFT corrections from lifecycle data","-    print(\"\\n--- Step 3: Estimate TTFT corrections ---\")","+    # Step 4: TTFT corrections","+    print(\"\\n--- Step 4: TTFT corrections ---\")","     ttft_corrections = estimate_ttft_corrections(data_root)"," ","-    # Fall back to hardcoded values if estimation fails","-    for model, default_val in TTFT_CORRECTIONS_US.items():","-        if model not in ttft_corrections:","-            ttft_corrections[model] = default_val","-            print(f\"  Using default TTFT correction for {model}: {default_val}us\")","-","-    # Step 4: Export StepML artifacts","-    print(\"\\n--- Step 4: Export StepML artifacts ---\")","+    # Step 5: Export artifacts","+    print(\"\\n--- Step 5: Export StepML artifacts ---\")","     artifact_dir = os.path.join(OUTPUT_DIR, \"artifacts\")","     os.makedirs(artifact_dir, exist_ok=True)"," ","-    artifacts = {}  # {model_name: artifact_path}","+    artifacts = {}","     for model_name, regimes in models.items():","-        # Find TTFT correction for this model","         ttft_us = 0","         for ttft_model, ttft_val in ttft_corrections.items():","-            if ttft_model == model_name or model_name.startswith(ttft_model):","+            if ttft_model == model_name or ttft_model.replace(\"-hf\", \"\") == model_name.replace(\"-hf\", \"\"):","                 ttft_us = ttft_val","                 break","-        if ttft_us == 0:","-            # Try normalized name","-            normalized = model_name.replace(\"-hf\", \"\")","-            for ttft_model, ttft_val in ttft_corrections.items():","-                if ttft_model.replace(\"-hf\", \"\") == normalized:","-                    ttft_us = ttft_val","-                    break"," ","         artifact_path = os.path.join(artifact_dir, f\"{model_name}.json\")","         export_stepml_artifact(model_name, regimes, ttft_us, artifact_path)","         artifacts[model_name] = artifact_path"," ","-    # Step 5: Run BLIS validation","-    print(\"\\n--- Step 5: BLIS validation ---\")","+    # Step 6: BLIS validation","+    print(\"\\n--- Step 6: BLIS validation ---\")","     results_csv = os.path.join(OUTPUT_DIR, \"blis_validation.csv\")","     results_df = run_blis_validation_per_model(data_root, artifacts, results_csv)"," ","     # Summary","-    ok_results = results_df[results_df[\"status\"] == \"ok\"]","-    if len(ok_results) > 0:","-        mean_e2e = ok_results[\"e2e_error\"].mean() * 100","-        mean_ttft = ok_results[\"ttft_error\"].mean() * 100","-        mean_itl = ok_results[\"itl_error\"].mean() * 100","+    ok = results_df[results_df[\"status\"] == \"ok\"]","+    if len(ok) > 0:","+        mean_e2e = ok[\"e2e_error\"].mean() * 100","+        mean_ttft = ok[\"ttft_error\"].mean() * 100","+        mean_itl = ok[\"itl_error\"].mean() * 100"," ","         print(\"\\n\" + \"=\" * 70)","-        print(\"STAGE 1 RESULTS\")","+        print(\"STAGE 1 RESULTS SUMMARY\")","         print(\"=\" * 70)","-        print(f\"Experiments completed: {len(ok_results)}\")","-        print(f\"Mean E2E error:  {mean_e2e:.1f}% (target: <30%)\")","-        print(f\"Mean TTFT error: {mean_ttft:.1f}%\")","-        print(f\"Mean ITL error:  {mean_itl:.1f}% (target: <20%)\")","+        print(f\"Experiments: {len(ok)}\")","+        print(f\"Mean E2E:  {mean_e2e:.1f}% (target <30%)\")","+        print(f\"Mean TTFT: {mean_ttft:.1f}%\")","+        print(f\"Mean ITL:  {mean_itl:.1f}% (target <20%)\")","+        below_10 = (ok[\"e2e_error\"] < 0.10).sum()","+        print(f\"E2E < 10%: {below_10}/{len(ok)}\")"," ","-        below_10 = (ok_results[\"e2e_error\"] < 0.10).sum()","-        print(f\"E2E < 10%: {below_10}/{len(ok_results)}\")","-","-        # Per-experiment table","         print(f\"\\n{'Experiment':<55} {'E2E%':>7} {'TTFT%':>7} {'ITL%':>7}\")","         print(\"-\" * 80)","-        for _, row in ok_results.iterrows():","-            print(f\"{row['experiment']:<55} {row['e2e_error']*100:>7.1f} \"","-                  f\"{row['ttft_error']*100:>7.1f} {row['itl_error']*100:>7.1f}\")","+        for _, row in ok.iterrows():","+            print(","+                f\"{row['experiment']:<55} {row['e2e_error']*100:>7.1f} \"","+                f\"{row['ttft_error']*100:>7.1f} {row['itl_error']*100:>7.1f}\"","+            )","         print(\"-\" * 80)","         print(f\"{'MEAN':<55} {mean_e2e:>7.1f} {mean_ttft:>7.1f} {mean_itl:>7.1f}\")"," "]},{"oldStart":701,"oldLines":17,"newStart":629,"newLines":19,"lines":["             \"mean_e2e_error\": mean_e2e,","             \"mean_ttft_error\": mean_ttft,","             \"mean_itl_error\": mean_itl,","-            \"n_experiments\": len(ok_results),","+            \"n_experiments\": len(ok),","             \"n_below_10_e2e\": int(below_10),","-            \"per_experiment\": ok_results[","-                [\"experiment\", \"model\", \"workload\", \"e2e_error\", \"ttft_error\", \"itl_error\"]","+            \"per_experiment\": ok[","+                [\"experiment\", \"model\", \"workload\", \"e2e_error\", \"ttft_error\", \"itl_error\",","+                 \"gt_e2e_ms\", \"blis_e2e_ms\", \"gt_itl_ms\", \"blis_itl_ms\"]","             ].to_dict(\"records\"),","-            \"regression_results\": models,","+            \"multipliers\": multipliers,","+            \"regression_results\": {k: {rk: rv for rk, rv in v.items() if rk != \"multiplier\"} for k, v in models.items()},","             \"ttft_corrections\": {k: float(v) for k, v in ttft_corrections.items()},","-            \"artifacts\": {k: v for k, v in artifacts.items()},","+            \"itl_data\": itl_data,","         }","         with open(os.path.join(OUTPUT_DIR, \"h1_summary.json\"), \"w\") as f:","-            json.dump(summary, f, indent=2)","+            json.dump(summary, f, indent=2, default=str)","     else:","         print(\"\\nERROR: No experiments completed successfully!\")","         sys.exit(1)"]}],"originalFile":"#!/usr/bin/env python3\n\"\"\"H1: Stage 1 Principled Base — Cycle-Time Regression + TTFT Corrections.\n\nExtracts step cycle times from lifecycle per-token timestamps, trains per-model\nFairBatching regression (cycle_time = a + b*new_tokens + c*kv_sum), applies\nTTFT additive corrections, exports StepML artifacts, and runs BLIS validation.\n\nThis produces the \"principled base\" used by H2's constrained CMA-ES.\n\"\"\"\n\nimport json\nimport os\nimport sys\n\nimport numpy as np\nimport pandas as pd\nfrom sklearn.linear_model import Ridge\n\n# Add shared infrastructure to path\n_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n_IDEA_DIR = os.path.dirname(_SCRIPT_DIR)\n_SHARED_DIR = os.path.join(_IDEA_DIR, \"..\", \"..\", \"shared\")\nsys.path.insert(0, _SHARED_DIR)\n\nfrom data_loader import load_all_experiments, load_lifecycle_data, parse_experiment_metadata, DEFAULT_DATA_ROOT\nfrom evaluation import compute_mape\nfrom validate_blis import (\n    validate_all_experiments,\n    DEFAULT_BINARY,\n)\n\nOUTPUT_DIR = os.path.join(_SCRIPT_DIR, \"output\")\nos.makedirs(OUTPUT_DIR, exist_ok=True)\n\n# ---------------------------------------------------------------------------\n# Step 1: Extract cycle times from lifecycle data\n# ---------------------------------------------------------------------------\n\ndef extract_cycle_times_for_experiment(experiment_dir: str) -> pd.DataFrame:\n    \"\"\"Extract per-step cycle times from lifecycle per-token timestamps.\n\n    Cycle time = inter-token interval (ITI) = time between consecutive\n    output token emissions across ALL requests in a step. This measures\n    the actual wall-clock step period, including CPU overhead.\n\n    Returns DataFrame with columns: step_idx, cycle_time_us, n_tokens\n    \"\"\"\n    lifecycle_df = load_lifecycle_data(experiment_dir)\n\n    # Collect all output token timestamps with their request IDs\n    all_token_events = []\n    for req_id, row in lifecycle_df.iterrows():\n        times = row[\"output_token_times\"]\n        if not times or len(times) < 2:\n            continue\n        for i in range(1, len(times)):\n            iti_s = times[i] - times[i-1]\n            iti_us = iti_s * 1_000_000\n            all_token_events.append({\n                \"request_id\": req_id,\n                \"token_idx\": i,\n                \"iti_us\": iti_us,\n                \"timestamp\": times[i],\n            })\n\n    if not all_token_events:\n        return pd.DataFrame()\n\n    df = pd.DataFrame(all_token_events)\n\n    # Group by approximate step window (tokens emitted in same step\n    # have similar timestamps). Use binning by median ITI.\n    median_iti = df[\"iti_us\"].median()\n\n    # Return per-token ITI data - we'll aggregate at the step level later\n    return df\n\n\ndef extract_step_level_cycle_times(experiment_dir: str, step_df: pd.DataFrame) -> pd.DataFrame:\n    \"\"\"Match lifecycle ITI data with step-level traces to get per-step cycle times.\n\n    Strategy: For each step, the cycle time is the wall-clock time between\n    consecutive step starts (step N+1 start - step N start), computed from\n    step.ts_start_ns. This is simpler and more reliable than ITI matching.\n    \"\"\"\n    if \"step.ts_start_ns\" not in step_df.columns:\n        return pd.DataFrame()\n\n    sorted_steps = step_df.sort_values(\"step.id\").copy()\n    sorted_steps = sorted_steps.dropna(subset=[\"step.ts_start_ns\"])\n\n    if len(sorted_steps) < 2:\n        return pd.DataFrame()\n\n    # Cycle time = difference between consecutive step start timestamps\n    ts_start = sorted_steps[\"step.ts_start_ns\"].values.astype(np.float64)\n    cycle_times_ns = np.diff(ts_start)\n    cycle_times_us = cycle_times_ns / 1000.0\n\n    # The cycle time for step i is ts_start[i+1] - ts_start[i]\n    result = sorted_steps.iloc[:-1].copy()\n    result[\"cycle_time_us\"] = cycle_times_us\n\n    # Filter out implausible cycle times (< 100us or > 100ms)\n    mask = (result[\"cycle_time_us\"] > 100) & (result[\"cycle_time_us\"] < 100_000)\n    result = result[mask]\n\n    return result\n\n\ndef extract_all_cycle_times(data_root: str) -> pd.DataFrame:\n    \"\"\"Extract cycle times across all experiments.\"\"\"\n    step_df = load_all_experiments(data_root)\n\n    frames = []\n    for exp_id in step_df[\"experiment_id\"].unique():\n        exp_steps = step_df[step_df[\"experiment_id\"] == exp_id].copy()\n        exp_dir = os.path.join(data_root, exp_id)\n\n        ct_df = extract_step_level_cycle_times(exp_dir, exp_steps)\n        if len(ct_df) > 0:\n            frames.append(ct_df)\n\n    if not frames:\n        raise RuntimeError(\"No cycle times extracted from any experiment\")\n\n    result = pd.concat(frames, ignore_index=True)\n    print(f\"Extracted {len(result)} step cycle times from {len(frames)} experiments\")\n    return result\n\n\n# ---------------------------------------------------------------------------\n# Step 2: Train per-model FairBatching regression on cycle times\n# ---------------------------------------------------------------------------\n\ndef train_per_model_regression(ct_df: pd.DataFrame) -> dict:\n    \"\"\"Train per-model FairBatching-style regression on cycle times.\n\n    Model: cycle_time = intercept + b1*new_tokens + b2*kv_sum\n    where new_tokens = prefill_tokens + decode_tokens (scheduled_tokens).\n\n    Also trains regime-separated models (decode-only vs mixed).\n\n    Returns dict of {model_name: {regime: {intercept, coefficients, metrics}}}\n    \"\"\"\n    # Compute new_tokens feature\n    ct_df = ct_df.copy()\n    if \"batch.scheduled_tokens\" in ct_df.columns:\n        ct_df[\"new_tokens\"] = ct_df[\"batch.scheduled_tokens\"].astype(float)\n    else:\n        ct_df[\"new_tokens\"] = (\n            ct_df.get(\"batch.prefill_tokens\", pd.Series(0, index=ct_df.index)).astype(float)\n            + ct_df.get(\"batch.decode_tokens\", pd.Series(0, index=ct_df.index)).astype(float)\n        )\n\n    # Compute kv_sum proxy from decode requests * queue depth\n    if \"queue.running_depth\" in ct_df.columns:\n        ct_df[\"kv_proxy\"] = ct_df[\"queue.running_depth\"].astype(float)\n    else:\n        ct_df[\"kv_proxy\"] = ct_df.get(\"batch.num_decode_reqs\", pd.Series(0, index=ct_df.index)).astype(float)\n\n    models = {}\n    for model_name in sorted(ct_df[\"model\"].unique()):\n        model_df = ct_df[ct_df[\"model\"] == model_name].copy()\n\n        # Regime separation\n        if \"batch.prefill_tokens\" in model_df.columns:\n            decode_only = model_df[model_df[\"batch.prefill_tokens\"] == 0]\n            mixed = model_df[model_df[\"batch.prefill_tokens\"] > 0]\n        else:\n            decode_only = model_df\n            mixed = model_df.iloc[0:0]  # empty\n\n        regimes = {}\n\n        # Train decode-only regime\n        if len(decode_only) >= 10:\n            X_decode = decode_only[[\"new_tokens\", \"kv_proxy\"]].values\n            y_decode = decode_only[\"cycle_time_us\"].values\n\n            reg_decode = Ridge(alpha=1.0)\n            reg_decode.fit(X_decode, y_decode)\n            pred_decode = reg_decode.predict(X_decode)\n            mape_decode = compute_mape(pred_decode, y_decode)\n\n            regimes[\"decode_only\"] = {\n                \"intercept\": float(reg_decode.intercept_),\n                \"coeff_new_tokens\": float(reg_decode.coef_[0]),\n                \"coeff_kv_proxy\": float(reg_decode.coef_[1]),\n                \"mape\": mape_decode,\n                \"n_samples\": len(decode_only),\n                \"mean_cycle_time\": float(y_decode.mean()),\n                \"median_cycle_time\": float(np.median(y_decode)),\n            }\n            print(f\"  {model_name} decode-only: intercept={reg_decode.intercept_:.0f}, \"\n                  f\"b_tokens={reg_decode.coef_[0]:.2f}, b_kv={reg_decode.coef_[1]:.2f}, \"\n                  f\"MAPE={mape_decode:.1f}%, n={len(decode_only)}\")\n\n        # Train mixed regime\n        if len(mixed) >= 10:\n            X_mixed = mixed[[\"new_tokens\", \"kv_proxy\"]].values\n            y_mixed = mixed[\"cycle_time_us\"].values\n\n            reg_mixed = Ridge(alpha=1.0)\n            reg_mixed.fit(X_mixed, y_mixed)\n            pred_mixed = reg_mixed.predict(X_mixed)\n            mape_mixed = compute_mape(pred_mixed, y_mixed)\n\n            regimes[\"mixed\"] = {\n                \"intercept\": float(reg_mixed.intercept_),\n                \"coeff_new_tokens\": float(reg_mixed.coef_[0]),\n                \"coeff_kv_proxy\": float(reg_mixed.coef_[1]),\n                \"mape\": mape_mixed,\n                \"n_samples\": len(mixed),\n                \"mean_cycle_time\": float(y_mixed.mean()),\n                \"median_cycle_time\": float(np.median(y_mixed)),\n            }\n            print(f\"  {model_name} mixed:       intercept={reg_mixed.intercept_:.0f}, \"\n                  f\"b_tokens={reg_mixed.coef_[0]:.2f}, b_kv={reg_mixed.coef_[1]:.2f}, \"\n                  f\"MAPE={mape_mixed:.1f}%, n={len(mixed)}\")\n\n        # Train global (all data) as fallback\n        X_all = model_df[[\"new_tokens\", \"kv_proxy\"]].values\n        y_all = model_df[\"cycle_time_us\"].values\n\n        reg_all = Ridge(alpha=1.0)\n        reg_all.fit(X_all, y_all)\n        pred_all = reg_all.predict(X_all)\n        mape_all = compute_mape(pred_all, y_all)\n\n        regimes[\"global\"] = {\n            \"intercept\": float(reg_all.intercept_),\n            \"coeff_new_tokens\": float(reg_all.coef_[0]),\n            \"coeff_kv_proxy\": float(reg_all.coef_[1]),\n            \"mape\": mape_all,\n            \"n_samples\": len(model_df),\n            \"mean_cycle_time\": float(y_all.mean()),\n            \"median_cycle_time\": float(np.median(y_all)),\n        }\n        print(f\"  {model_name} global:      intercept={reg_all.intercept_:.0f}, \"\n              f\"b_tokens={reg_all.coef_[0]:.2f}, b_kv={reg_all.coef_[1]:.2f}, \"\n              f\"MAPE={mape_all:.1f}%, n={len(model_df)}\")\n\n        # Compute ratio: cycle_time / step.duration_us\n        if \"step.duration_us\" in model_df.columns:\n            valid = model_df[model_df[\"step.duration_us\"] > 0]\n            if len(valid) > 0:\n                ratios = valid[\"cycle_time_us\"].values / valid[\"step.duration_us\"].values\n                regimes[\"overhead_ratio\"] = {\n                    \"mean\": float(np.mean(ratios)),\n                    \"median\": float(np.median(ratios)),\n                    \"p10\": float(np.percentile(ratios, 10)),\n                    \"p90\": float(np.percentile(ratios, 90)),\n                }\n                print(f\"  {model_name} overhead ratio: mean={np.mean(ratios):.2f}x, \"\n                      f\"median={np.median(ratios):.2f}x, \"\n                      f\"p10={np.percentile(ratios, 10):.2f}x, \"\n                      f\"p90={np.percentile(ratios, 90):.2f}x\")\n\n        models[model_name] = regimes\n\n    return models\n\n\n# ---------------------------------------------------------------------------\n# Step 3: TTFT additive corrections\n# ---------------------------------------------------------------------------\n\n# Per-model TTFT corrections from R3 H3 (approximate, in microseconds)\n# These are estimated from the data: TTFT_correction = observed_TTFT - simulated_TTFT\nTTFT_CORRECTIONS_US = {\n    \"llama-2-7b\": 16_000,      # ~16ms\n    \"codellama-34b\": 40_000,    # ~40ms\n    \"llama-2-70b\": 50_000,      # ~50ms\n    \"llama-2-70b-hf\": 50_000,   # same model as llama-2-70b\n    \"mixtral-8x7b-v0-1\": 61_000,  # ~61ms\n}\n\n\ndef estimate_ttft_corrections(data_root: str) -> dict:\n    \"\"\"Estimate TTFT corrections from lifecycle data.\n\n    TTFT = first_token_time - start_time for each request.\n    The correction is the difference between observed mean TTFT and\n    what the cycle-time model would predict for the first step.\n    \"\"\"\n    corrections = {}\n\n    for dirname in sorted(os.listdir(data_root)):\n        dirpath = os.path.join(data_root, dirname)\n        if not os.path.isdir(dirpath):\n            continue\n        lifecycle_path = os.path.join(dirpath, \"results\", \"per_request_lifecycle_metrics.json\")\n        if not os.path.isfile(lifecycle_path):\n            continue\n\n        meta = parse_experiment_metadata(dirname)\n        model = meta[\"model\"]\n\n        try:\n            lifecycle_df = load_lifecycle_data(dirpath)\n        except Exception:\n            continue\n\n        # Compute TTFT from lifecycle data\n        ttft_values = []\n        for _, row in lifecycle_df.iterrows():\n            times = row.get(\"output_token_times\", [])\n            start = row.get(\"start_time\", 0)\n            if times and len(times) > 0 and start > 0:\n                ttft_s = times[0] - start\n                if ttft_s > 0:\n                    ttft_values.append(ttft_s)\n\n        if ttft_values:\n            mean_ttft_us = np.mean(ttft_values) * 1_000_000\n            if model not in corrections:\n                corrections[model] = []\n            corrections[model].append(mean_ttft_us)\n\n    # Average TTFT per model\n    result = {}\n    for model, values in corrections.items():\n        result[model] = float(np.mean(values))\n        print(f\"  TTFT correction for {model}: {result[model]:.0f} us ({result[model]/1000:.1f} ms)\")\n\n    return result\n\n\n# ---------------------------------------------------------------------------\n# Step 4: Export StepML artifacts\n# ---------------------------------------------------------------------------\n\ndef export_stepml_artifact(\n    model_name: str,\n    regimes: dict,\n    ttft_correction_us: float,\n    output_path: str,\n):\n    \"\"\"Export per-model StepML JSON artifact for BLIS validation.\n\n    Uses regime-based dispatch with cycle-time regression coefficients.\n    Sets output_token_processing_time_us = 0 (absorbed into cycle time).\n    Sets QueueingTime with TTFT correction.\n    \"\"\"\n    # Use decode-only intercept as overhead floor (minimum step cycle time)\n    if \"decode_only\" in regimes:\n        decode_info = regimes[\"decode_only\"]\n        overhead_us = max(decode_info[\"median_cycle_time\"], decode_info[\"intercept\"])\n    elif \"global\" in regimes:\n        decode_info = regimes[\"global\"]\n        overhead_us = decode_info[\"intercept\"]\n    else:\n        overhead_us = 4000  # fallback\n\n    # Build regime entries for StepML\n    step_time_regimes = []\n\n    if \"decode_only\" in regimes:\n        d = regimes[\"decode_only\"]\n        step_time_regimes.append({\n            \"name\": \"decode_only\",\n            \"condition\": {\"feature\": \"prefill_tokens\", \"op\": \"==\", \"value\": 0},\n            \"model\": {\n                \"model_type\": \"linear\",\n                \"intercept\": d[\"intercept\"],\n                \"feature_coefficients\": {\n                    \"decode_tokens\": d[\"coeff_new_tokens\"],\n                    \"num_decode_reqs\": d[\"coeff_kv_proxy\"],\n                },\n            },\n        })\n\n    if \"mixed\" in regimes:\n        m = regimes[\"mixed\"]\n        step_time_regimes.append({\n            \"name\": \"mixed\",\n            \"condition\": None,\n            \"model\": {\n                \"model_type\": \"linear\",\n                \"intercept\": m[\"intercept\"],\n                \"feature_coefficients\": {\n                    \"scheduled_tokens\": m[\"coeff_new_tokens\"],\n                    \"num_decode_reqs\": m[\"coeff_kv_proxy\"],\n                },\n            },\n        })\n\n    # If no regime models, use global\n    if not step_time_regimes:\n        g = regimes[\"global\"]\n        step_time_regimes.append({\n            \"name\": \"global\",\n            \"condition\": None,\n            \"model\": {\n                \"model_type\": \"linear\",\n                \"intercept\": g[\"intercept\"],\n                \"feature_coefficients\": {\n                    \"scheduled_tokens\": g[\"coeff_new_tokens\"],\n                    \"num_decode_reqs\": g[\"coeff_kv_proxy\"],\n                },\n            },\n        })\n\n    artifact = {\n        \"version\": 2,\n        \"step_time_regimes\": step_time_regimes,\n        \"step_overhead_us\": max(overhead_us, 1000),  # minimum 1ms\n        \"output_token_processing_time_us\": 0,  # absorbed into cycle time\n        \"scheduling_processing_time_us\": 0,\n        \"preemption_processing_time_us\": 0,\n    }\n\n    # Add TTFT correction as queueing time model\n    if ttft_correction_us > 0:\n        artifact[\"queueing_time\"] = {\n            \"model_type\": \"linear\",\n            \"intercept\": ttft_correction_us,\n            \"feature_coefficients\": {},  # constant correction, not input-dependent\n        }\n\n    with open(output_path, \"w\") as f:\n        json.dump(artifact, f, indent=2)\n\n    print(f\"  Exported artifact for {model_name}: overhead={overhead_us:.0f}us, \"\n          f\"TTFT_correction={ttft_correction_us:.0f}us\")\n\n    return artifact\n\n\n# ---------------------------------------------------------------------------\n# Step 5: Run BLIS validation\n# ---------------------------------------------------------------------------\n\ndef run_blis_validation_per_model(\n    data_root: str,\n    artifacts: dict,  # {model_name: artifact_path}\n    output_csv: str,\n) -> pd.DataFrame:\n    \"\"\"Run BLIS validation using per-model StepML artifacts.\n\n    For each experiment, selects the matching model's artifact.\n    \"\"\"\n    from validate_blis import (\n        parse_experiment_dir,\n        load_ground_truth_metrics,\n        load_exp_config,\n        extract_kv_blocks_from_vllm_log,\n        extract_cpu_kv_blocks_from_vllm_log,\n        load_profile,\n        build_workload_spec,\n        run_blis,\n        compute_error,\n        BLOCK_SIZE_TOKENS,\n    )\n    import tempfile\n    import yaml\n\n    binary = DEFAULT_BINARY\n    if not os.path.isfile(binary):\n        import subprocess\n        repo_root = os.path.abspath(os.path.join(_SHARED_DIR, \"..\", \"..\", \"..\"))\n        subprocess.run([\"go\", \"build\", \"-o\", binary, \"main.go\"],\n                       cwd=repo_root, check=True)\n\n    results = []\n    for dirname in sorted(os.listdir(data_root)):\n        dirpath = os.path.join(data_root, dirname)\n        if not os.path.isdir(dirpath):\n            continue\n\n        summary_path = os.path.join(dirpath, \"results\", \"summary_lifecycle_metrics.json\")\n        if not os.path.isfile(summary_path):\n            continue\n\n        try:\n            meta = parse_experiment_dir(dirname)\n        except ValueError:\n            continue\n\n        model_name = meta[\"model\"]\n\n        # Find matching artifact - try exact match, then normalized names\n        artifact_path = None\n        for art_model, art_path in artifacts.items():\n            if art_model == model_name or model_name.startswith(art_model):\n                artifact_path = art_path\n                break\n\n        # Try matching by stripping -hf suffix\n        if artifact_path is None:\n            normalized = model_name.replace(\"-hf\", \"\")\n            for art_model, art_path in artifacts.items():\n                if art_model.replace(\"-hf\", \"\") == normalized:\n                    artifact_path = art_path\n                    break\n\n        if artifact_path is None:\n            print(f\"  SKIP: No artifact for model {model_name}\")\n            results.append({\n                \"experiment\": dirname,\n                \"model\": model_name,\n                \"workload\": meta[\"workload\"],\n                \"status\": \"no_artifact\",\n            })\n            continue\n\n        print(f\"\\n  Running BLIS for {dirname}...\")\n\n        gt = load_ground_truth_metrics(dirpath)\n        exp_config = load_exp_config(dirpath)\n        total_kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n        cpu_kv_blocks = extract_cpu_kv_blocks_from_vllm_log(dirpath)\n\n        if total_kv_blocks is None:\n            results.append({\n                \"experiment\": dirname,\n                \"model\": model_name,\n                \"workload\": meta[\"workload\"],\n                \"status\": \"no_kv_blocks\",\n            })\n            continue\n\n        try:\n            profile = load_profile(dirpath)\n        except Exception:\n            results.append({\n                \"experiment\": dirname,\n                \"model\": model_name,\n                \"workload\": meta[\"workload\"],\n                \"status\": \"no_profile\",\n            })\n            continue\n\n        workload_spec = build_workload_spec(profile, gt)\n\n        with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".yaml\", delete=False) as f:\n            yaml.dump(workload_spec, f, default_flow_style=False)\n            spec_path = f.name\n\n        with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n            results_json_path = f.name\n\n        try:\n            blis_metrics = run_blis(\n                binary=binary,\n                workload_spec_path=spec_path,\n                exp_config=exp_config,\n                total_kv_blocks=total_kv_blocks,\n                alpha_coeffs=[0, 0, 0],\n                beta_coeffs=[0, 0, 0],\n                results_path=results_json_path,\n                stepml_model_path=artifact_path,\n                cpu_kv_blocks=cpu_kv_blocks,\n            )\n        finally:\n            os.unlink(spec_path)\n            if os.path.exists(results_json_path):\n                os.unlink(results_json_path)\n\n        if blis_metrics is None:\n            results.append({\n                \"experiment\": dirname,\n                \"model\": model_name,\n                \"workload\": meta[\"workload\"],\n                \"status\": \"blis_failed\",\n            })\n            continue\n\n        e2e_error = compute_error(blis_metrics[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n        ttft_error = compute_error(blis_metrics[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000)\n        itl_error = compute_error(blis_metrics[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n\n        print(f\"    GT:   E2E={gt['e2e_mean_s']*1000:.1f}ms, \"\n              f\"TTFT={gt['ttft_mean_s']*1000:.1f}ms, \"\n              f\"ITL={gt['itl_mean_s']*1000:.2f}ms\")\n        print(f\"    BLIS: E2E={blis_metrics['e2e_mean_ms']:.1f}ms, \"\n              f\"TTFT={blis_metrics['ttft_mean_ms']:.1f}ms, \"\n              f\"ITL={blis_metrics['itl_mean_ms']:.2f}ms\")\n        print(f\"    Err:  E2E={e2e_error*100:.1f}%, \"\n              f\"TTFT={ttft_error*100:.1f}%, \"\n              f\"ITL={itl_error*100:.1f}%\")\n\n        results.append({\n            \"experiment\": dirname,\n            \"model\": model_name,\n            \"workload\": meta[\"workload\"],\n            \"tp\": meta[\"tp\"],\n            \"status\": \"ok\",\n            \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n            \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n            \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n            \"blis_e2e_ms\": blis_metrics[\"e2e_mean_ms\"],\n            \"blis_ttft_ms\": blis_metrics[\"ttft_mean_ms\"],\n            \"blis_itl_ms\": blis_metrics[\"itl_mean_ms\"],\n            \"e2e_error\": e2e_error,\n            \"ttft_error\": ttft_error,\n            \"itl_error\": itl_error,\n            \"blis_completed\": blis_metrics[\"completed_requests\"],\n            \"gt_requests\": gt[\"num_requests\"],\n        })\n\n    df = pd.DataFrame(results)\n    df.to_csv(output_csv, index=False)\n    return df\n\n\n# ---------------------------------------------------------------------------\n# Main\n# ---------------------------------------------------------------------------\n\ndef main():\n    print(\"=\" * 70)\n    print(\"H1: Stage 1 Principled Base — Cycle-Time Regression + TTFT Corrections\")\n    print(\"=\" * 70)\n\n    data_root = DEFAULT_DATA_ROOT\n\n    # Step 1: Extract cycle times\n    print(\"\\n--- Step 1: Extract cycle times from step timestamps ---\")\n    ct_df = extract_all_cycle_times(data_root)\n    ct_df.to_csv(os.path.join(OUTPUT_DIR, \"cycle_times.csv\"), index=False)\n\n    # Step 2: Train per-model regression\n    print(\"\\n--- Step 2: Train per-model FairBatching regression ---\")\n    models = train_per_model_regression(ct_df)\n\n    # Save regression results\n    with open(os.path.join(OUTPUT_DIR, \"regression_results.json\"), \"w\") as f:\n        json.dump(models, f, indent=2)\n\n    # Step 3: Estimate TTFT corrections from lifecycle data\n    print(\"\\n--- Step 3: Estimate TTFT corrections ---\")\n    ttft_corrections = estimate_ttft_corrections(data_root)\n\n    # Fall back to hardcoded values if estimation fails\n    for model, default_val in TTFT_CORRECTIONS_US.items():\n        if model not in ttft_corrections:\n            ttft_corrections[model] = default_val\n            print(f\"  Using default TTFT correction for {model}: {default_val}us\")\n\n    # Step 4: Export StepML artifacts\n    print(\"\\n--- Step 4: Export StepML artifacts ---\")\n    artifact_dir = os.path.join(OUTPUT_DIR, \"artifacts\")\n    os.makedirs(artifact_dir, exist_ok=True)\n\n    artifacts = {}  # {model_name: artifact_path}\n    for model_name, regimes in models.items():\n        # Find TTFT correction for this model\n        ttft_us = 0\n        for ttft_model, ttft_val in ttft_corrections.items():\n            if ttft_model == model_name or model_name.startswith(ttft_model):\n                ttft_us = ttft_val\n                break\n        if ttft_us == 0:\n            # Try normalized name\n            normalized = model_name.replace(\"-hf\", \"\")\n            for ttft_model, ttft_val in ttft_corrections.items():\n                if ttft_model.replace(\"-hf\", \"\") == normalized:\n                    ttft_us = ttft_val\n                    break\n\n        artifact_path = os.path.join(artifact_dir, f\"{model_name}.json\")\n        export_stepml_artifact(model_name, regimes, ttft_us, artifact_path)\n        artifacts[model_name] = artifact_path\n\n    # Step 5: Run BLIS validation\n    print(\"\\n--- Step 5: BLIS validation ---\")\n    results_csv = os.path.join(OUTPUT_DIR, \"blis_validation.csv\")\n    results_df = run_blis_validation_per_model(data_root, artifacts, results_csv)\n\n    # Summary\n    ok_results = results_df[results_df[\"status\"] == \"ok\"]\n    if len(ok_results) > 0:\n        mean_e2e = ok_results[\"e2e_error\"].mean() * 100\n        mean_ttft = ok_results[\"ttft_error\"].mean() * 100\n        mean_itl = ok_results[\"itl_error\"].mean() * 100\n\n        print(\"\\n\" + \"=\" * 70)\n        print(\"STAGE 1 RESULTS\")\n        print(\"=\" * 70)\n        print(f\"Experiments completed: {len(ok_results)}\")\n        print(f\"Mean E2E error:  {mean_e2e:.1f}% (target: <30%)\")\n        print(f\"Mean TTFT error: {mean_ttft:.1f}%\")\n        print(f\"Mean ITL error:  {mean_itl:.1f}% (target: <20%)\")\n\n        below_10 = (ok_results[\"e2e_error\"] < 0.10).sum()\n        print(f\"E2E < 10%: {below_10}/{len(ok_results)}\")\n\n        # Per-experiment table\n        print(f\"\\n{'Experiment':<55} {'E2E%':>7} {'TTFT%':>7} {'ITL%':>7}\")\n        print(\"-\" * 80)\n        for _, row in ok_results.iterrows():\n            print(f\"{row['experiment']:<55} {row['e2e_error']*100:>7.1f} \"\n                  f\"{row['ttft_error']*100:>7.1f} {row['itl_error']*100:>7.1f}\")\n        print(\"-\" * 80)\n        print(f\"{'MEAN':<55} {mean_e2e:>7.1f} {mean_ttft:>7.1f} {mean_itl:>7.1f}\")\n\n        # Save summary\n        summary = {\n            \"mean_e2e_error\": mean_e2e,\n            \"mean_ttft_error\": mean_ttft,\n            \"mean_itl_error\": mean_itl,\n            \"n_experiments\": len(ok_results),\n            \"n_below_10_e2e\": int(below_10),\n            \"per_experiment\": ok_results[\n                [\"experiment\", \"model\", \"workload\", \"e2e_error\", \"ttft_error\", \"itl_error\"]\n            ].to_dict(\"records\"),\n            \"regression_results\": models,\n            \"ttft_corrections\": {k: float(v) for k, v in ttft_corrections.items()},\n            \"artifacts\": {k: v for k, v in artifacts.items()},\n        }\n        with open(os.path.join(OUTPUT_DIR, \"h1_summary.json\"), \"w\") as f:\n            json.dump(summary, f, indent=2)\n    else:\n        print(\"\\nERROR: No experiments completed successfully!\")\n        sys.exit(1)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}
