{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01MuT93xxiTkUBrhPxFtiC8F","type":"tool_result","content":"     1→// Package latency provides latency model implementations for the BLIS simulator.\n     2→// The LatencyModel interface is defined in sim/ (parent package).\n     3→// This package provides BlackboxLatencyModel (alpha/beta regression) and\n     4→// RooflineLatencyModel (analytical FLOPs/bandwidth).\n     5→package latency\n     6→\n     7→import (\n     8→\t\"fmt\"\n     9→\t\"math\"\n    10→\n    11→\t\"github.com/inference-sim/inference-sim/sim\"\n    12→\t\"github.com/inference-sim/inference-sim/sim/internal/util\"\n    13→)\n    14→\n    15→// BlackboxLatencyModel estimates latency using trained alpha/beta regression coefficients.\n    16→// Beta coefficients estimate step time: beta0 + beta1*cacheMissTokens + beta2*decodeTokens.\n    17→// Alpha coefficients estimate overheads: alpha0 + alpha1*inputLen (queueing), alpha2 (output processing).\n    18→type BlackboxLatencyModel struct {\n    19→\tbetaCoeffs  []float64\n    20→\talphaCoeffs []float64\n    21→}\n    22→\n    23→func (m *BlackboxLatencyModel) StepTime(batch []*sim.Request) int64 {\n    24→\tvar totalCacheMissTokens, totalDecodeTokens int64\n    25→\tfor _, req := range batch {\n    26→\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n    27→\t\t\t// Prefill phase: NumNewTokens are cache-miss tokens\n    28→\t\t\ttotalCacheMissTokens += int64(req.NumNewTokens)\n    29→\t\t} else if len(req.OutputTokens) > 0 {\n    30→\t\t\t// Decode phase: NumNewTokens is 1 (set by FormBatch)\n    31→\t\t\ttotalDecodeTokens += int64(req.NumNewTokens)\n    32→\t\t}\n    33→\t}\n    34→\tvar totalStepTime float64\n    35→\ttotalStepTime += m.betaCoeffs[0]\n    36→\ttotalStepTime += m.betaCoeffs[1] * float64(totalCacheMissTokens)\n    37→\ttotalStepTime += m.betaCoeffs[2] * float64(totalDecodeTokens)\n    38→\treturn int64(totalStepTime)\n    39→}\n    40→\n    41→func (m *BlackboxLatencyModel) QueueingTime(req *sim.Request) int64 {\n    42→\tvar totalProcessingTime float64\n    43→\ttotalProcessingTime += m.alphaCoeffs[0]\n    44→\ttotalProcessingTime += m.alphaCoeffs[1] * float64(len(req.InputTokens))\n    45→\treturn int64(totalProcessingTime)\n    46→}\n    47→\n    48→func (m *BlackboxLatencyModel) OutputTokenProcessingTime() int64 {\n    49→\treturn int64(m.alphaCoeffs[2])\n    50→}\n    51→\n    52→func (m *BlackboxLatencyModel) SchedulingProcessingTime() int64 {\n    53→\treturn 0\n    54→}\n    55→\n    56→func (m *BlackboxLatencyModel) PreemptionProcessingTime() int64 {\n    57→\treturn 0\n    58→}\n    59→\n    60→// RooflineLatencyModel estimates latency using analytical FLOPs/bandwidth roofline model.\n    61→// Step time is computed via rooflineStepTime(); overhead estimates use alpha coefficients.\n    62→// In v2 mode (mfuDB != nil), MFU values are looked up from benchmark data instead of\n    63→// using static constants.\n    64→type RooflineLatencyModel struct {\n    65→\tmodelConfig sim.ModelConfig\n    66→\thwConfig    sim.HardwareCalib\n    67→\tmfuDB       *sim.MFUDatabase\n    68→\tgpu         string\n    69→\ttp          int\n    70→\talphaCoeffs []float64\n    71→}\n    72→\n    73→func (m *RooflineLatencyModel) StepTime(batch []*sim.Request) int64 {\n    74→\tstepConfig := StepConfig{\n    75→\t\tPrefillRequests: make([]PrefillRequestConfig, 0, len(batch)),\n    76→\t\tDecodeRequests:  make([]DecodeRequestConfig, 0, len(batch)),\n    77→\t}\n    78→\tfor _, req := range batch {\n    79→\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n    80→\t\t\tstepConfig.PrefillRequests = append(stepConfig.PrefillRequests, PrefillRequestConfig{\n    81→\t\t\t\tProgressIndex:       req.ProgressIndex,\n    82→\t\t\t\tNumNewPrefillTokens: req.NumNewTokens,\n    83→\t\t\t})\n    84→\t\t} else if len(req.OutputTokens) > 0 {\n    85→\t\t\tstepConfig.DecodeRequests = append(stepConfig.DecodeRequests, DecodeRequestConfig{\n    86→\t\t\t\tProgressIndex:      req.ProgressIndex,\n    87→\t\t\t\tNumNewDecodeTokens: req.NumNewTokens,\n    88→\t\t\t})\n    89→\t\t}\n    90→\t}\n    91→\treturn rooflineStepTime(m.gpu, m.modelConfig, m.hwConfig, stepConfig, m.tp, m.mfuDB)\n    92→}\n    93→\n    94→func (m *RooflineLatencyModel) QueueingTime(req *sim.Request) int64 {\n    95→\tvar totalProcessingTime float64\n    96→\ttotalProcessingTime += m.alphaCoeffs[0]\n    97→\ttotalProcessingTime += m.alphaCoeffs[1] * float64(len(req.InputTokens))\n    98→\treturn int64(totalProcessingTime)\n    99→}\n   100→"}]},"parent_tool_use_id":"toolu_bdrk_01CfKY3CEYt1bGTQUxibMBP7","session_id":"e652145f-d03b-4eb5-bbf8-d7db257fe10a","uuid":"83606a5c-15f6-4d07-a64a-613276dfbd30"}
