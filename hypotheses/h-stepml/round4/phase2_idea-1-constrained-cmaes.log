  \"train_mape\": 24.12545456050223,\n      \"train_mspe\": 10.598333136654226,\n      \"train_r\": 0.6241549029307345\n    }\n  },\n  \"e2e_validation\": {\n    \"mean_e2e_error_pct\": 99.37622247041648,\n    \"mean_ttft_error_pct\": 98.899849284533,\n    \"mean_itl_error_pct\": 98.76040372648576,\n    \"experiments_below_10pct\": 0,\n    \"total_experiments\": 10\n  },\n  \"r4_gate\": {\n    \"passed\": true,\n    \"e2e_error\": 99.37622247041648,\n    \"message\": \"R4 gate passed: blackbox E2E mean error = 99.4% (|error| >= 12%). Step-level ML improvement is justified.\"\n  }\n}","numLines":56,"startLine":1,"totalLines":56}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01XkfFwfuhYfHjZsx78YUDTs","type":"tool_result","content":"     1→package latency\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\t\"testing\"\n     7→\n     8→\t\"github.com/inference-sim/inference-sim/sim\"\n     9→)\n    10→\n    11→// validArtifactJSON is a minimal StepML artifact for testing.\n    12→const validArtifactJSON = `{\n    13→\t\"version\": 1,\n    14→\t\"step_time\": {\n    15→\t\t\"model_type\": \"linear\",\n    16→\t\t\"intercept\": 100.0,\n    17→\t\t\"feature_coefficients\": {\n    18→\t\t\t\"prefill_tokens\": 50.0,\n    19→\t\t\t\"decode_tokens\": 5.0\n    20→\t\t}\n    21→\t},\n    22→\t\"queueing_time\": {\n    23→\t\t\"model_type\": \"linear\",\n    24→\t\t\"intercept\": 10.0,\n    25→\t\t\"feature_coefficients\": {\n    26→\t\t\t\"input_len\": 0.5\n    27→\t\t}\n    28→\t},\n    29→\t\"output_token_processing_time_us\": 2.0,\n    30→\t\"scheduling_processing_time_us\": 5.0,\n    31→\t\"preemption_processing_time_us\": 3.0\n    32→}`\n    33→\n    34→func writeArtifact(t *testing.T, content string) string {\n    35→\tt.Helper()\n    36→\tdir := t.TempDir()\n    37→\tpath := filepath.Join(dir, \"model.json\")\n    38→\tif err := os.WriteFile(path, []byte(content), 0o644); err != nil {\n    39→\t\tt.Fatalf(\"write artifact: %v\", err)\n    40→\t}\n    41→\treturn path\n    42→}\n    43→\n    44→func TestLoadStepMLArtifact_Valid(t *testing.T) {\n    45→\tpath := writeArtifact(t, validArtifactJSON)\n    46→\tart, err := LoadStepMLArtifact(path)\n    47→\tif err != nil {\n    48→\t\tt.Fatalf(\"unexpected error: %v\", err)\n    49→\t}\n    50→\tif art.Version != 1 {\n    51→\t\tt.Errorf(\"version = %d, want 1\", art.Version)\n    52→\t}\n    53→\tif art.StepTime.Intercept != 100.0 {\n    54→\t\tt.Errorf(\"step_time intercept = %f, want 100.0\", art.StepTime.Intercept)\n    55→\t}\n    56→\tif art.StepTime.FeatureCoefficients[\"prefill_tokens\"] != 50.0 {\n    57→\t\tt.Errorf(\"prefill_tokens coeff = %f, want 50.0\", art.StepTime.FeatureCoefficients[\"prefill_tokens\"])\n    58→\t}\n    59→}\n    60→\n    61→func TestLoadStepMLArtifact_MissingFile(t *testing.T) {\n    62→\t_, err := LoadStepMLArtifact(\"/nonexistent/path.json\")\n    63→\tif err == nil {\n    64→\t\tt.Fatal(\"expected error for missing file\")\n    65→\t}\n    66→}\n    67→\n    68→func TestLoadStepMLArtifact_MissingStepTime(t *testing.T) {\n    69→\tpath := writeArtifact(t, `{\"version\": 1}`)\n    70→\t_, err := LoadStepMLArtifact(path)\n    71→\tif err == nil {\n    72→\t\tt.Fatal(\"expected error for missing step_time\")\n    73→\t}\n    74→}\n    75→\n    76→func TestLoadStepMLArtifact_InvalidVersion(t *testing.T) {\n    77→\tpath := writeArtifact(t, `{\"version\": 0, \"step_time\": {\"model_type\": \"linear\", \"intercept\": 0}}`)\n    78→\t_, err := LoadStepMLArtifact(path)\n    79→\tif err == nil {\n    80→\t\tt.Fatal(\"expected error for version 0\")\n    81→\t}\n    82→}\n    83→\n    84→func TestLoadStepMLArtifact_NaNCoefficient(t *testing.T) {\n    85→\t// JSON doesn't support NaN natively; test via a model type error instead\n    86→\tpath := writeArtifact(t, `{\"version\": 1, \"step_time\": {\"model_type\": \"neural_net\", \"intercept\": 0}}`)\n    87→\t_, err := LoadStepMLArtifact(path)\n    88→\tif err == nil {\n    89→\t\tt.Fatal(\"expected error for unsupported model_type\")\n    90→\t}\n    91→}\n    92→\n    93→func TestStepMLLatencyModel_StepTime(t *testing.T) {\n    94→\tpath := writeArtifact(t, validArtifactJSON)\n    95→\tart, err := LoadStepMLArtifact(path)\n    96→\tif err != nil {\n    97→\t\tt.Fatalf(\"load artifact: %v\", err)\n    98→\t}\n    99→\tmodel := NewStepMLLatencyModel(art)\n   100→\n   101→\t// Batch: 1 prefill request (100 new tokens), 2 decode requests (1 new token each)\n   102→\tbatch := []*sim.Request{\n   103→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},  // prefill\n   104→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1}, // decode\n   105→\t\t{InputTokens: make([]int, 80), OutputTokens: make([]int, 30), ProgressIndex: 110, NumNewTokens: 1},  // decode\n   106→\t}\n   107→\n   108→\t// Expected: 100 (intercept) + 50*100 (prefill) + 5*2 (decode) = 100 + 5000 + 10 = 5110\n   109→\tgot := model.StepTime(batch)\n   110→\tif got != 5110 {\n   111→\t\tt.Errorf(\"StepTime = %d, want 5110\", got)\n   112→\t}\n   113→}\n   114→\n   115→func TestStepMLLatencyModel_StepTime_Positive(t *testing.T) {\n   116→\t// Test INV-M-1: predictions are always positive\n   117→\tart := &StepMLArtifact{\n   118→\t\tVersion: 1,\n   119→\t\tStepTime: &LinearModel{\n   120→\t\t\tModelType:           \"linear\",\n   121→\t\t\tIntercept:           -1000,\n   122→\t\t\tFeatureCoefficients: map[string]float64{},\n   123→\t\t},\n   124→\t}\n   125→\tmodel := NewStepMLLatencyModel(art)\n   126→\tgot := model.StepTime([]*sim.Request{})\n   127→\tif got < 1 {\n   128→\t\tt.Errorf(\"StepTime = %d, want >= 1 (INV-M-1)\", got)\n   129→\t}\n   130→}\n   131→\n   132→func TestStepMLLatencyModel_QueueingTime(t *testing.T) {\n   133→\tpath := writeArtifact(t, validArtifactJSON)\n   134→\tart, err := LoadStepMLArtifact(path)\n   135→\tif err != nil {\n   136→\t\tt.Fatalf(\"load artifact: %v\", err)\n   137→\t}\n   138→\tmodel := NewStepMLLatencyModel(art)\n   139→\n   140→\treq := &sim.Request{InputTokens: make([]int, 200)}\n   141→\t// Expected: 10 (intercept) + 0.5 * 200 = 110\n   142→\tgot := model.QueueingTime(req)\n   143→\tif got != 110 {\n   144→\t\tt.Errorf(\"QueueingTime = %d, want 110\", got)\n   145→\t}\n   146→}\n   147→\n   148→func TestStepMLLatencyModel_QueueingTime_NilModel(t *testing.T) {\n   149→\tart := &StepMLArtifact{\n   150→\t\tVersion:  1,\n   151→\t\tStepTime: &LinearModel{ModelType: \"linear\", Intercept: 10, FeatureCoefficients: map[string]float64{}},\n   152→\t}\n   153→\tmodel := NewStepMLLatencyModel(art)\n   154→\tgot := model.QueueingTime(&sim.Request{InputTokens: make([]int, 100)})\n   155→\tif got != 0 {\n   156→\t\tt.Errorf(\"QueueingTime with nil model = %d, want 0\", got)\n   157→\t}\n   158→}\n   159→\n   160→func TestStepMLLatencyModel_ConstantMethods(t *testing.T) {\n   161→\tpath := writeArtifact(t, validArtifactJSON)\n   162→\tart, err := LoadStepMLArtifact(path)\n   163→\tif err != nil {\n   164→\t\tt.Fatalf(\"load artifact: %v\", err)\n   165→\t}\n   166→\tmodel := NewStepMLLatencyModel(art)\n   167→\n   168→\tif got := model.OutputTokenProcessingTime(); got != 2 {\n   169→\t\tt.Errorf(\"OutputTokenProcessingTime = %d, want 2\", got)\n   170→\t}\n   171→\tif got := model.SchedulingProcessingTime(); got != 5 {\n   172→\t\tt.Errorf(\"SchedulingProcessingTime = %d, want 5\", got)\n   173→\t}\n   174→\tif got := model.PreemptionProcessingTime(); got != 3 {\n   175→\t\tt.Errorf(\"PreemptionProcessingTime = %d, want 3\", got)\n   176→\t}\n   177→}\n   178→\n   179→func TestStepMLLatencyModel_KVFeatures(t *testing.T) {\n   180→\t// Test that KV proxy features (ProgressIndex) are extracted and used\n   181→\tart := &StepMLArtifact{\n   182→\t\tVersion: 1,\n   183→\t\tStepTime: &LinearModel{\n   184→\t\t\tModelType: \"linear\",\n   185→\t\t\tIntercept: 0,\n   186→\t\t\tFeatureCoefficients: map[string]float64{\n   187→\t\t\t\t\"kv_sum\":  0.1,\n   188→\t\t\t\t\"kv_mean\": 10.0,\n   189→\t\t\t\t\"kv_max\":  1.0,\n   190→\t\t\t},\n   191→\t\t},\n   192→\t}\n   193→\tmodel := NewStepMLLatencyModel(art)\n   194→\n   195→\tbatch := []*sim.Request{\n   196→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1},\n   197→\t\t{InputTokens: make([]int, 200), OutputTokens: make([]int, 100), ProgressIndex: 300, NumNewTokens: 1},\n   198→\t}\n   199→\n   200→\t// kv_sum = 150 + 300 = 450 → 450 * 0.1 = 45\n   201→\t// kv_mean = 225 → 225 * 10 = 2250\n   202→\t// kv_max = 300 → 300 * 1 = 300\n   203→\t// total = 45 + 2250 + 300 = 2595\n   204→\tgot := model.StepTime(batch)\n   205→\tif got != 2595 {\n   206→\t\tt.Errorf(\"StepTime with KV features = %d, want 2595\", got)\n   207→\t}\n   208→}\n   209→\n   210→func TestExtractBatchFeatures(t *testing.T) {\n   211→\tbatch := []*sim.Request{\n   212→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},   // prefill: 50 < 200\n   213→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 1), ProgressIndex: 150, NumNewTokens: 1}, // decode: 150 >= 100\n   214→\t}\n   215→\n   216→\tf := extractBatchFeatures(batch)\n   217→\n   218→\ttests := []struct {\n   219→\t\tname string\n   220→\t\twant float64\n   221→\t}{\n   222→\t\t{\"prefill_tokens\", 100},\n   223→\t\t{\"decode_tokens\", 1},\n   224→\t\t{\"num_prefill_reqs\", 1},\n   225→\t\t{\"num_decode_reqs\", 1},\n   226→\t\t{\"scheduled_tokens\", 101},\n   227→\t\t{\"kv_sum\", 200},    // 50 + 150\n   228→\t\t{\"kv_max\", 150},\n   229→\t\t{\"kv_mean\", 100},   // 200 / 2\n   230→\t}\n   231→\tfor _, tt := range tests {\n   232→\t\tif got := f[tt.name]; got != tt.want {\n   233→\t\t\tt.Errorf(\"feature %q = %f, want %f\", tt.name, got, tt.want)\n   234→\t\t}\n   235→\t}\n   236→}\n   237→\n   238→func TestNewLatencyModel_StepMLDispatch(t *testing.T) {\n   239→\tpath := writeArtifact(t, validArtifactJSON)\n   240→\tcoeffs := sim.NewLatencyCoeffs(\n   241→\t\t[]float64{0, 0, 0}, // beta (unused by stepml)\n   242→\t\t[]float64{0, 0, 0}, // alpha (unused by stepml)\n   243→\t)\n   244→\thw := sim.NewModelHardwareConfig(sim.ModelConfig{}, sim.HardwareCalib{}, \"\", \"\", 0, false).\n   245→\t\tWithStepMLModel(path)\n   246→\n   247→\tmodel, err := NewLatencyModel(coeffs, hw)\n   248→\tif err != nil {\n   249→\t\tt.Fatalf(\"NewLatencyModel with StepML: %v\", err)\n   250→\t}\n   251→\n   252→\tif _, ok := model.(*StepMLLatencyModel); !ok {\n   253→\t\tt.Errorf(\"expected *StepMLLatencyModel, got %T\", model)\n   254→\t}\n   255→}\n   256→\n   257→// regimeArtifactJSON has 2 regimes: decode-only and mixed-batch (fallback).\n   258→const regimeArtifactJSON = `{\n   259→\t\"version\": 2,\n   260→\t\"step_time_regimes\": [\n   261→\t\t{\n   262→\t\t\t\"name\": \"decode_only\",\n   263→\t\t\t\"condition\": {\"feature\": \"prefill_tokens\", \"op\": \"==\", \"value\": 0},\n   264→\t\t\t\"model\": {\n   265→\t\t\t\t\"model_type\": \"linear\",\n   266→\t\t\t\t\"intercept\": 50.0,\n   267→\t\t\t\t\"feature_coefficients\": {\"decode_tokens\": 10.0, \"kv_mean\": 0.5}\n   268→\t\t\t}\n   269→\t\t},\n   270→\t\t{\n   271→\t\t\t\"name\": \"mixed\",\n   272→\t\t\t\"condition\": null,\n   273→\t\t\t\"model\": {\n   274→\t\t\t\t\"model_type\": \"linear\",\n   275→\t\t\t\t\"intercept\": 200.0,\n   276→\t\t\t\t\"feature_coefficients\": {\"prefill_tokens\": 2.0, \"decode_tokens\": 8.0}\n   277→\t\t\t}\n   278→\t\t}\n   279→\t],\n   280→\t\"output_token_processing_time_us\": 1.0,\n   281→\t\"scheduling_processing_time_us\": 2.0,\n   282→\t\"preemption_processing_time_us\": 0.0\n   283→}`\n   284→\n   285→func TestStepMLLatencyModel_RegimeDispatch(t *testing.T) {\n   286→\tpath := writeArtifact(t, regimeArtifactJSON)\n   287→\tart, err := LoadStepMLArtifact(path)\n   288→\tif err != nil {\n   289→\t\tt.Fatalf(\"load regime artifact: %v\", err)\n   290→\t}\n   291→\tmodel := NewStepMLLatencyModel(art)\n   292→\n   293→\t// Decode-only batch: 2 decode requests, 1 new token each\n   294→\tdecodeBatch := []*sim.Request{\n   295→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1},\n   296→\t\t{InputTokens: make([]int, 80), OutputTokens: make([]int, 30), ProgressIndex: 110, NumNewTokens: 1},\n   297→\t}\n   298→\t// prefill_tokens=0 → decode_only regime\n   299→\t// decode_tokens=2, kv_mean=(150+110)/2=130\n   300→\t// Expected: 50 + 10*2 + 0.5*130 = 50 + 20 + 65 = 135\n   301→\tgot := model.StepTime(decodeBatch)\n   302→\tif got != 135 {\n   303→\t\tt.Errorf(\"StepTime(decode_only) = %d, want 135\", got)\n   304→\t}\n   305→\n   306→\t// Mixed batch: 1 prefill + 1 decode\n   307→\tmixedBatch := []*sim.Request{\n   308→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},  // prefill\n   309→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1}, // decode\n   310→\t}\n   311→\t// prefill_tokens=100 > 0 → mixed regime\n   312→\t// decode_tokens=1\n   313→\t// Expected: 200 + 2*100 + 8*1 = 200 + 200 + 8 = 408\n   314→\tgot = model.StepTime(mixedBatch)\n   315→\tif got != 408 {\n   316→\t\tt.Errorf(\"StepTime(mixed) = %d, want 408\", got)\n   317→\t}\n   318→}\n   319→\n   320→func TestStepMLLatencyModel_RegimeNoStepTime(t *testing.T) {\n   321→\t// Artifact with only regimes (no step_time field) should work\n   322→\tpath := writeArtifact(t, regimeArtifactJSON)\n   323→\tart, err := LoadStepMLArtifact(path)\n   324→\tif err != nil {\n   325→\t\tt.Fatalf(\"load: %v\", err)\n   326→\t}\n   327→\tif art.StepTime != nil {\n   328→\t\tt.Error(\"expected nil step_time when using regimes only\")\n   329→\t}\n   330→\tif len(art.StepTimeRegimes) != 2 {\n   331→\t\tt.Errorf(\"got %d regimes, want 2\", len(art.StepTimeRegimes))\n   332→\t}\n   333→}\n   334→\n   335→func TestExtractBatchFeatures_InteractionFeatures(t *testing.T) {\n   336→\tbatch := []*sim.Request{\n   337→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},   // prefill\n   338→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 1), ProgressIndex: 150, NumNewTokens: 1}, // decode\n   339→\t}\n   340→\n   341→\tf := extractBatchFeatures(batch)\n   342→\n   343→\t// prefill_x_decode = 100 * 1 = 100\n   344→\tif got := f[\"prefill_x_decode\"]; got != 100 {\n   345→\t\tt.Errorf(\"prefill_x_decode = %f, want 100\", got)\n   346→\t}\n   347→\t// decode_x_kv_mean = 1 * 100 = 100 (kv_mean = (50+150)/2 = 100)\n   348→\tif got := f[\"decode_x_kv_mean\"]; got != 100 {\n   349→\t\tt.Errorf(\"decode_x_kv_mean = %f, want 100\", got)\n   350→\t}\n   351→\t// prefill_sq = 100 * 100 = 10000\n   352→\tif got := f[\"prefill_sq\"]; got != 10000 {\n   353→\t\tt.Errorf(\"prefill_sq = %f, want 10000\", got)\n   354→\t}\n   355→\t// kv_std: pi values are 50 and 150, mean=100\n   356→\t// variance = ((50-100)^2 + (150-100)^2) / 2 = (2500+2500)/2 = 2500\n   357→\t// std = sqrt(2500) = 50\n   358→\tif got := f[\"kv_std\"]; got != 50 {\n   359→\t\tt.Errorf(\"kv_std = %f, want 50\", got)\n   360→\t}\n   361→}\n   362→\n   363→func TestStepMLLatencyModel_OverheadFloorAndCap(t *testing.T) {\n   364→\t// Overhead floor: prediction < overhead → use overhead.\n   365→\t// Overhead cap: prediction > 3*overhead → clamp to 3*overhead.\n   366→\tart := &StepMLArtifact{\n   367→\t\tVersion: 1,\n   368→\t\tStepTime: &LinearModel{\n   369→\t\t\tModelType:           \"linear\",\n   370→\t\t\tIntercept:           100,\n   371→\t\t\tFeatureCoefficients: map[string]float64{\"decode_tokens\": 200},\n   372→\t\t},\n   373→\t\tStepOverheadUs: 5000,\n   374→\t}\n   375→\tmodel := NewStepMLLatencyModel(art)\n   376→\n   377→\t// Small batch: 100 + 200*1 = 300 < 5000 → floored to 5000\n   378→\tsmall := []*sim.Request{\n   379→\t\t{InputTokens: make([]int, 10), OutputTokens: make([]int, 1), ProgressIndex: 10, NumNewTokens: 1},\n   380→\t}\n   381→\tgot := model.StepTime(small)\n   382→\tif got != 5000 {\n   383→\t\tt.Errorf(\"StepTime(small) = %d, want 5000 (overhead floor)\", got)\n   384→\t}\n   385→\n   386→\t// Large batch: 100 + 200*100 = 20100, cap = 3*5000 = 15000 → capped\n   387→\tvar large []*sim.Request\n   388→\tfor i := 0; i < 100; i++ {\n   389→\t\tlarge = append(large, &sim.Request{\n   390→\t\t\tInputTokens: make([]int, 10), OutputTokens: make([]int, 1),\n   391→\t\t\tProgressIndex: 10, NumNewTokens: 1,\n   392→\t\t})\n   393→\t}\n   394→\tgot = model.StepTime(large)\n   395→\tif got != 15000 {\n   396→\t\tt.Errorf(\"StepTime(large) = %d, want 15000 (overhead cap)\", got)\n   397→\t}\n   398→\n   399→\t// Medium batch: 100 + 200*30 = 6100, between floor and cap → use as-is\n   400→\tvar medium []*sim.Request\n   401→\tfor i := 0; i < 30; i++ {\n   402→\t\tmedium = append(medium, &sim.Request{\n   403→\t\t\tInputTokens: make([]int, 10), OutputTokens: make([]int, 1),\n   404→\t\t\tProgressIndex: 10, NumNewTokens: 1,\n   405→\t\t})\n   406→\t}\n   407→\tgot = model.StepTime(medium)\n   408→\tif got != 6100 {\n   409→\t\tt.Errorf(\"StepTime(medium) = %d, want 6100 (between floor and cap)\", got)\n   410→\t}\n   411→}\n   412→\n   413→func TestNewLatencyModel_StepMLInvalidPath(t *testing.T) {\n   414→\tcoeffs := sim.NewLatencyCoeffs(\n   415→\t\t[]float64{0, 0, 0},\n   416→\t\t[]float64{0, 0, 0},\n   417→\t)\n   418→\thw := sim.NewModelHardwareConfig(sim.ModelConfig{}, sim.HardwareCalib{}, \"\", \"\", 0, false).\n   419→\t\tWithStepMLModel(\"/nonexistent/model.json\")\n   420→\n   421→\t_, err := NewLatencyModel(coeffs, hw)\n   422→\tif err == nil {\n   423→\t\tt.Fatal(\"expected error for nonexistent StepML model path\")\n   424→\t}\n   425→}\n   426→\n   427→func TestNewLatencyModel_RooflineTakesPrecedence(t *testing.T) {\n   428→\t// Verify that roofline dispatch happens before StepML (isolation guarantee)\n   429→\tpath := writeArtifact(t, validArtifactJSON)\n   430→\tcoeffs := sim.NewLatencyCoeffs(\n   431→\t\t[]float64{0, 0, 0},\n   432→\t\t[]float64{0, 0, 0},\n   433→\t)\n   434→\thw := sim.NewModelHardwareConfig(\n   435→\t\tsim.ModelConfig{NumLayers: 32, HiddenDim: 4096, NumHeads: 32, NumKVHeads: 32, VocabSize: 32000, BytesPerParam: 2, IntermediateDim: 11008},\n   436→\t\tsim.HardwareCalib{TFlopsPeak: 989.5, BwPeakTBs: 3.35},\n   437→\t\t\"test-model\", \"H100\", 1, true, // Roofline=true\n   438→\t).WithStepMLModel(path)\n   439→\n   440→\t// This should fail on roofline validation (missing MFU database), NOT try StepML\n   441→\t_, err := NewLatencyModel(coeffs, hw)\n   442→\tif err == nil {\n   443→\t\tt.Fatal(\"expected roofline validation error, not StepML dispatch\")\n   444→\t}\n   445→}\n   446→"}]},"parent_tool_use_id":null,"session_id":"c72182bb-90d4-4f72-be1e-6f3d8138bce2","uuid":"92b5f113-fedb-491c-b355-627b9063a8e6","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round4-idea-1-constrained-cmaes/sim/latency/stepml_test.go","content":"package latency\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/inference-sim/inference-sim/sim\"\n)\n\n// validArtifactJSON is a minimal StepML artifact for testing.\nconst validArtifactJSON = `{\n\t\"version\": 1,\n\t\"step_time\": {\n\t\t\"model_type\": \"linear\",\n\t\t\"intercept\": 100.0,\n\t\t\"feature_coefficients\": {\n\t\t\t\"prefill_tokens\": 50.0,\n\t\t\t\"decode_tokens\": 5.0\n\t\t}\n\t},\n\t\"queueing_time\": {\n\t\t\"model_type\": \"linear\",\n\t\t\"intercept\": 10.0,\n\t\t\"feature_coefficients\": {\n\t\t\t\"input_len\": 0.5\n\t\t}\n\t},\n\t\"output_token_processing_time_us\": 2.0,\n\t\"scheduling_processing_time_us\": 5.0,\n\t\"preemption_processing_time_us\": 3.0\n}`\n\nfunc writeArtifact(t *testing.T, content string) string {\n\tt.Helper()\n\tdir := t.TempDir()\n\tpath := filepath.Join(dir, \"model.json\")\n\tif err := os.WriteFile(path, []byte(content), 0o644); err != nil {\n\t\tt.Fatalf(\"write artifact: %v\", err)\n\t}\n\treturn path\n}\n\nfunc TestLoadStepMLArtifact_Valid(t *testing.T) {\n\tpath := writeArtifact(t, validArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t}\n\tif art.Version != 1 {\n\t\tt.Errorf(\"version = %d, want 1\", art.Version)\n\t}\n\tif art.StepTime.Intercept != 100.0 {\n\t\tt.Errorf(\"step_time intercept = %f, want 100.0\", art.StepTime.Intercept)\n\t}\n\tif art.StepTime.FeatureCoefficients[\"prefill_tokens\"] != 50.0 {\n\t\tt.Errorf(\"prefill_tokens coeff = %f, want 50.0\", art.StepTime.FeatureCoefficients[\"prefill_tokens\"])\n\t}\n}\n\nfunc TestLoadStepMLArtifact_MissingFile(t *testing.T) {\n\t_, err := LoadStepMLArtifact(\"/nonexistent/path.json\")\n\tif err == nil {\n\t\tt.Fatal(\"expected error for missing file\")\n\t}\n}\n\nfunc TestLoadStepMLArtifact_MissingStepTime(t *testing.T) {\n\tpath := writeArtifact(t, `{\"version\": 1}`)\n\t_, err := LoadStepMLArtifact(path)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for missing step_time\")\n\t}\n}\n\nfunc TestLoadStepMLArtifact_InvalidVersion(t *testing.T) {\n\tpath := writeArtifact(t, `{\"version\": 0, \"step_time\": {\"model_type\": \"linear\", \"intercept\": 0}}`)\n\t_, err := LoadStepMLArtifact(path)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for version 0\")\n\t}\n}\n\nfunc TestLoadStepMLArtifact_NaNCoefficient(t *testing.T) {\n\t// JSON doesn't support NaN natively; test via a model type error instead\n\tpath := writeArtifact(t, `{\"version\": 1, \"step_time\": {\"model_type\": \"neural_net\", \"intercept\": 0}}`)\n\t_, err := LoadStepMLArtifact(path)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for unsupported model_type\")\n\t}\n}\n\nfunc TestStepMLLatencyModel_StepTime(t *testing.T) {\n\tpath := writeArtifact(t, validArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"load artifact: %v\", err)\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\t// Batch: 1 prefill request (100 new tokens), 2 decode requests (1 new token each)\n\tbatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},  // prefill\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1}, // decode\n\t\t{InputTokens: make([]int, 80), OutputTokens: make([]int, 30), ProgressIndex: 110, NumNewTokens: 1},  // decode\n\t}\n\n\t// Expected: 100 (intercept) + 50*100 (prefill) + 5*2 (decode) = 100 + 5000 + 10 = 5110\n\tgot := model.StepTime(batch)\n\tif got != 5110 {\n\t\tt.Errorf(\"StepTime = %d, want 5110\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_StepTime_Positive(t *testing.T) {\n\t// Test INV-M-1: predictions are always positive\n\tart := &StepMLArtifact{\n\t\tVersion: 1,\n\t\tStepTime: &LinearModel{\n\t\t\tModelType:           \"linear\",\n\t\t\tIntercept:           -1000,\n\t\t\tFeatureCoefficients: map[string]float64{},\n\t\t},\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\tgot := model.StepTime([]*sim.Request{})\n\tif got < 1 {\n\t\tt.Errorf(\"StepTime = %d, want >= 1 (INV-M-1)\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_QueueingTime(t *testing.T) {\n\tpath := writeArtifact(t, validArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"load artifact: %v\", err)\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\treq := &sim.Request{InputTokens: make([]int, 200)}\n\t// Expected: 10 (intercept) + 0.5 * 200 = 110\n\tgot := model.QueueingTime(req)\n\tif got != 110 {\n\t\tt.Errorf(\"QueueingTime = %d, want 110\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_QueueingTime_NilModel(t *testing.T) {\n\tart := &StepMLArtifact{\n\t\tVersion:  1,\n\t\tStepTime: &LinearModel{ModelType: \"linear\", Intercept: 10, FeatureCoefficients: map[string]float64{}},\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\tgot := model.QueueingTime(&sim.Request{InputTokens: make([]int, 100)})\n\tif got != 0 {\n\t\tt.Errorf(\"QueueingTime with nil model = %d, want 0\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_ConstantMethods(t *testing.T) {\n\tpath := writeArtifact(t, validArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"load artifact: %v\", err)\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\tif got := model.OutputTokenProcessingTime(); got != 2 {\n\t\tt.Errorf(\"OutputTokenProcessingTime = %d, want 2\", got)\n\t}\n\tif got := model.SchedulingProcessingTime(); got != 5 {\n\t\tt.Errorf(\"SchedulingProcessingTime = %d, want 5\", got)\n\t}\n\tif got := model.PreemptionProcessingTime(); got != 3 {\n\t\tt.Errorf(\"PreemptionProcessingTime = %d, want 3\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_KVFeatures(t *testing.T) {\n\t// Test that KV proxy features (ProgressIndex) are extracted and used\n\tart := &StepMLArtifact{\n\t\tVersion: 1,\n\t\tStepTime: &LinearModel{\n\t\t\tModelType: \"linear\",\n\t\t\tIntercept: 0,\n\t\t\tFeatureCoefficients: map[string]float64{\n\t\t\t\t\"kv_sum\":  0.1,\n\t\t\t\t\"kv_mean\": 10.0,\n\t\t\t\t\"kv_max\":  1.0,\n\t\t\t},\n\t\t},\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\tbatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1},\n\t\t{InputTokens: make([]int, 200), OutputTokens: make([]int, 100), ProgressIndex: 300, NumNewTokens: 1},\n\t}\n\n\t// kv_sum = 150 + 300 = 450 → 450 * 0.1 = 45\n\t// kv_mean = 225 → 225 * 10 = 2250\n\t// kv_max = 300 → 300 * 1 = 300\n\t// total = 45 + 2250 + 300 = 2595\n\tgot := model.StepTime(batch)\n\tif got != 2595 {\n\t\tt.Errorf(\"StepTime with KV features = %d, want 2595\", got)\n\t}\n}\n\nfunc TestExtractBatchFeatures(t *testing.T) {\n\tbatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},   // prefill: 50 < 200\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 1), ProgressIndex: 150, NumNewTokens: 1}, // decode: 150 >= 100\n\t}\n\n\tf := extractBatchFeatures(batch)\n\n\ttests := []struct {\n\t\tname string\n\t\twant float64\n\t}{\n\t\t{\"prefill_tokens\", 100},\n\t\t{\"decode_tokens\", 1},\n\t\t{\"num_prefill_reqs\", 1},\n\t\t{\"num_decode_reqs\", 1},\n\t\t{\"scheduled_tokens\", 101},\n\t\t{\"kv_sum\", 200},    // 50 + 150\n\t\t{\"kv_max\", 150},\n\t\t{\"kv_mean\", 100},   // 200 / 2\n\t}\n\tfor _, tt := range tests {\n\t\tif got := f[tt.name]; got != tt.want {\n\t\t\tt.Errorf(\"feature %q = %f, want %f\", tt.name, got, tt.want)\n\t\t}\n\t}\n}\n\nfunc TestNewLatencyModel_StepMLDispatch(t *testing.T) {\n\tpath := writeArtifact(t, validArtifactJSON)\n\tcoeffs := sim.NewLatencyCoeffs(\n\t\t[]float64{0, 0, 0}, // beta (unused by stepml)\n\t\t[]float64{0, 0, 0}, // alpha (unused by stepml)\n\t)\n\thw := sim.NewModelHardwareConfig(sim.ModelConfig{}, sim.HardwareCalib{}, \"\", \"\", 0, false).\n\t\tWithStepMLModel(path)\n\n\tmodel, err := NewLatencyModel(coeffs, hw)\n\tif err != nil {\n\t\tt.Fatalf(\"NewLatencyModel with StepML: %v\", err)\n\t}\n\n\tif _, ok := model.(*StepMLLatencyModel); !ok {\n\t\tt.Errorf(\"expected *StepMLLatencyModel, got %T\", model)\n\t}\n}\n\n// regimeArtifactJSON has 2 regimes: decode-only and mixed-batch (fallback).\nconst regimeArtifactJSON = `{\n\t\"version\": 2,\n\t\"step_time_regimes\": [\n\t\t{\n\t\t\t\"name\": \"decode_only\",\n\t\t\t\"condition\": {\"feature\": \"prefill_tokens\", \"op\": \"==\", \"value\": 0},\n\t\t\t\"model\": {\n\t\t\t\t\"model_type\": \"linear\",\n\t\t\t\t\"intercept\": 50.0,\n\t\t\t\t\"feature_coefficients\": {\"decode_tokens\": 10.0, \"kv_mean\": 0.5}\n\t\t\t}\n\t\t},\n\t\t{\n\t\t\t\"name\": \"mixed\",\n\t\t\t\"condition\": null,\n\t\t\t\"model\": {\n\t\t\t\t\"model_type\": \"linear\",\n\t\t\t\t\"intercept\": 200.0,\n\t\t\t\t\"feature_coefficients\": {\"prefill_tokens\": 2.0, \"decode_tokens\": 8.0}\n\t\t\t}\n\t\t}\n\t],\n\t\"output_token_processing_time_us\": 1.0,\n\t\"scheduling_processing_time_us\": 2.0,\n\t\"preemption_processing_time_us\": 0.0\n}`\n\nfunc TestStepMLLatencyModel_RegimeDispatch(t *testing.T) {\n\tpath := writeArtifact(t, regimeArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"load regime artifact: %v\", err)\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\t// Decode-only batch: 2 decode requests, 1 new token each\n\tdecodeBatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1},\n\t\t{InputTokens: make([]int, 80), OutputTokens: make([]int, 30), ProgressIndex: 110, NumNewTokens: 1},\n\t}\n\t// prefill_tokens=0 → decode_only regime\n\t// decode_tokens=2, kv_mean=(150+110)/2=130\n\t// Expected: 50 + 10*2 + 0.5*130 = 50 + 20 + 65 = 135\n\tgot := model.StepTime(decodeBatch)\n\tif got != 135 {\n\t\tt.Errorf(\"StepTime(decode_only) = %d, want 135\", got)\n\t}\n\n\t// Mixed batch: 1 prefill + 1 decode\n\tmixedBatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},  // prefill\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1}, // decode\n\t}\n\t// prefill_tokens=100 > 0 → mixed regime\n\t// decode_tokens=1\n\t// Expected: 200 + 2*100 + 8*1 = 200 + 200 + 8 = 408\n\tgot = model.StepTime(mixedBatch)\n\tif got != 408 {\n\t\tt.Errorf(\"StepTime(mixed) = %d, want 408\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_RegimeNoStepTime(t *testing.T) {\n\t// Artifact with only regimes (no step_time field) should work\n\tpath := writeArtifact(t, regimeArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"load: %v\", err)\n\t}\n\tif art.StepTime != nil {\n\t\tt.Error(\"expected nil step_time when using regimes only\")\n\t}\n\tif len(art.StepTimeRegimes) != 2 {\n\t\tt.Errorf(\"got %d regimes, want 2\", len(art.StepTimeRegimes))\n\t}\n}\n\nfunc TestExtractBatchFeatures_InteractionFeatures(t *testing.T) {\n\tbatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},   // prefill\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 1), ProgressIndex: 150, NumNewTokens: 1}, // decode\n\t}\n\n\tf := extractBatchFeatures(batch)\n\n\t// prefill_x_decode = 100 * 1 = 100\n\tif got := f[\"prefill_x_decode\"]; got != 100 {\n\t\tt.Errorf(\"prefill_x_decode = %f, want 100\", got)\n\t}\n\t// decode_x_kv_mean = 1 * 100 = 100 (kv_mean = (50+150)/2 = 100)\n\tif got := f[\"decode_x_kv_mean\"]; got != 100 {\n\t\tt.Errorf(\"decode_x_kv_mean = %f, want 100\", got)\n\t}\n\t// prefill_sq = 100 * 100 = 10000\n\tif got := f[\"prefill_sq\"]; got != 10000 {\n\t\tt.Errorf(\"prefill_sq = %f, want 10000\", got)\n\t}\n\t// kv_std: pi values are 50 and 150, mean=100\n\t// variance = ((50-100)^2 + (150-100)^2) / 2 = (2500+2500)/2 = 2500\n\t// std = sqrt(2500) = 50\n\tif got := f[\"kv_std\"]; got != 50 {\n\t\tt.Errorf(\"kv_std = %f, want 50\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_OverheadFloorAndCap(t *testing.T) {\n\t// Overhead floor: prediction < overhead → use overhead.\n\t// Overhead cap: prediction > 3*overhead → clamp to 3*overhead.\n\tart := &StepMLArtifact{\n\t\tVersion: 1,\n\t\tStepTime: &LinearModel{\n\t\t\tModelType:           \"linear\",\n\t\t\tIntercept:           100,\n\t\t\tFeatureCoefficients: map[string]float64{\"decode_tokens\": 200},\n\t\t},\n\t\tStepOverheadUs: 5000,\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\t// Small batch: 100 + 200*1 = 300 < 5000 → floored to 5000\n\tsmall := []*sim.Request{\n\t\t{InputTokens: make([]int, 10), OutputTokens: make([]int, 1), ProgressIndex: 10, NumNewTokens: 1},\n\t}\n\tgot := model.StepTime(small)\n\tif got != 5000 {\n\t\tt.Errorf(\"StepTime(small) = %d, want 5000 (overhead floor)\", got)\n\t}\n\n\t// Large batch: 100 + 200*100 = 20100, cap = 3*5000 = 15000 → capped\n\tvar large []*sim.Request\n\tfor i := 0; i < 100; i++ {\n\t\tlarge = append(large, &sim.Request{\n\t\t\tInputTokens: make([]int, 10), OutputTokens: make([]int, 1),\n\t\t\tProgressIndex: 10, NumNewTokens: 1,\n\t\t})\n\t}\n\tgot = model.StepTime(large)\n\tif got != 15000 {\n\t\tt.Errorf(\"StepTime(large) = %d, want 15000 (overhead cap)\", got)\n\t}\n\n\t// Medium batch: 100 + 200*30 = 6100, between floor and cap → use as-is\n\tvar medium []*sim.Request\n\tfor i := 0; i < 30; i++ {\n\t\tmedium = append(medium, &sim.Request{\n\t\t\tInputTokens: make([]int, 10), OutputTokens: make([]int, 1),\n\t\t\tProgressIndex: 10, NumNewTokens: 1,\n\t\t})\n\t}\n\tgot = model.StepTime(medium)\n\tif got != 6100 {\n\t\tt.Errorf(\"StepTime(medium) = %d, want 6100 (between floor and cap)\", got)\n\t}\n}\n\nfunc TestNewLatencyModel_StepMLInvalidPath(t *testing.T) {\n\tcoeffs := sim.NewLatencyCoeffs(\n\t\t[]float64{0, 0, 0},\n\t\t[]float64{0, 0, 0},\n\t)\n\thw := sim.NewModelHardwareConfig(sim.ModelConfig{}, sim.HardwareCalib{}, \"\", \"\", 0, false).\n\t\tWithStepMLModel(\"/nonexistent/model.json\")\n\n\t_, err := NewLatencyModel(coeffs, hw)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for nonexistent StepML model path\")\n\t}\n}\n\nfunc TestNewLatencyModel_RooflineTakesPrecedence(t *testing.T) {\n\t// Verify that roofline dispatch happens before StepML (isolation guarantee)\n\tpath := writeArtifact(t, validArtifactJSON)\n\tcoeffs := sim.NewLatencyCoeffs(\n\t\t[]float64{0, 0, 0},\n\t\t[]float64{0, 0, 0},\n\t)\n\thw := sim.NewModelHardwareConfig(\n\t\tsim.ModelConfig{NumLayers: 32, HiddenDim: 4096, NumHeads: 32, NumKVHeads: 32, VocabSize: 32000, BytesPerParam: 2, IntermediateDim: 11008},\n\t\tsim.HardwareCalib{TFlopsPeak: 989.5, BwPeakTBs: 3.35},\n\t\t\"test-model\", \"H100\", 1, true, // Roofline=true\n\t).WithStepMLModel(path)\n\n\t// This should fail on roofline validation (missing MFU database), NOT try StepML\n\t_, err := NewLatencyModel(coeffs, hw)\n\tif err == nil {\n\t\tt.Fatal(\"expected roofline validation error, not StepML dispatch\")\n\t}\n}\n","numLines":446,"startLine":1,"totalLines":446}}}
