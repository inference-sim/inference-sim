{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01XjW9ayZYQbMGDsDK7jwzCr","type":"tool_result","content":"     1→\"\"\"Establish baselines for StepML research.\n     2→\n     3→Runs two baselines through BLIS E2E validation and measures E2E/TTFT/ITL error\n     4→against ground truth.  These are the accuracy bars that StepML models must beat.\n     5→\n     6→Baseline 1 — Roofline (analytical):\n     7→    Uses the analytical FLOPs/bandwidth roofline model.  Zero calibration data\n     8→    needed — step time is estimated from model architecture (HuggingFace\n     9→    config.json) and GPU specs (hardware_config.json).\n    10→\n    11→Baseline 2 — Per-model linear regression:\n    12→    Trains a separate 3-coefficient linear regression per model+TP on\n    13→    ground-truth step traces (step_time = beta0 + beta1*prefill + beta2*decode),\n    14→    pooling all workloads for a given model.  Requires training data.\n    15→\n    16→Usage:\n    17→    python establish_baseline.py [--data-root PATH] [--output-dir PATH]\n    18→    python establish_baseline.py --skip-linear              # roofline only\n    19→    python establish_baseline.py --skip-roofline            # linear only\n    20→    python establish_baseline.py --hardware A100            # non-default GPU\n    21→\"\"\"\n    22→\n    23→import argparse\n    24→import csv as csv_mod\n    25→import json\n    26→import os\n    27→import subprocess\n    28→import sys\n    29→import tempfile\n    30→from concurrent.futures import ThreadPoolExecutor, as_completed\n    31→\n    32→import numpy as np\n    33→import pandas as pd\n    34→\n    35→# Add shared/ to path for imports\n    36→_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n    37→sys.path.insert(0, _SCRIPT_DIR)\n    38→\n    39→import yaml\n    40→\n    41→from baselines import BlackboxBaseline, check_r4_gate\n    42→from data_loader import load_all_experiments, load_experiment_steps, parse_experiment_metadata\n    43→from evaluation import compute_mape, compute_mspe, compute_pearson_r, compute_p99_error\n    44→from validate_blis import (\n    45→    build_workload_spec,\n    46→    compute_error,\n    47→    extract_cpu_kv_blocks_from_vllm_log,\n    48→    extract_kv_blocks_from_vllm_log,\n    49→    load_exp_config,\n    50→    load_ground_truth_metrics,\n    51→    load_profile,\n    52→    parse_experiment_dir,\n    53→    run_blis,\n    54→)\n    55→\n    56→_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\"))\n    57→DEFAULT_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\n    58→_DEFAULT_WORKERS = min((os.cpu_count() or 4) // 2, 4)\n    59→\n    60→\n    61→def _build_canonical_model_map(data_root: str) -> dict:\n    62→    \"\"\"Build a map from experiment_id to canonical (model, tp) from exp-config.yaml.\n    63→\n    64→    Directory names have inconsistencies (e.g. \"llama-2-70b\" vs \"llama-2-70b-hf\"\n    65→    for the same model).  exp-config.yaml has the authoritative HF model name.\n    66→    \"\"\"\n    67→    mapping = {}\n    68→    for dirname in sorted(os.listdir(data_root)):\n    69→        config_path = os.path.join(data_root, dirname, \"exp-config.yaml\")\n    70→        if not os.path.isfile(config_path):\n    71→            continue\n    72→        with open(config_path) as f:\n    73→            cfg = yaml.safe_load(f)\n    74→        # Canonical model name from HF (e.g. \"meta-llama/Llama-2-70b-hf\")\n    75→        model = cfg.get(\"model\", \"\")\n    76→        tp = cfg.get(\"tensor_parallelism\", 1)\n    77→        mapping[dirname] = (model, tp)\n    78→    return mapping\n    79→\n    80→\n    81→def train_per_model_coefficients(data_root: str) -> dict:\n    82→    \"\"\"Train a linear regression per model+TP and return fitted coefficients.\n    83→\n    84→    Groups experiments by canonical (model, tp) from exp-config.yaml, trains\n    85→    one linear regression per group, and returns the coefficients.\n    86→\n    87→    Returns:\n    88→        dict keyed by (model, tp) with values:\n    89→        {\n    90→            \"beta0\": float, \"beta1\": float, \"beta2\": float,\n    91→            \"n_steps\": int, \"n_experiments\": int,\n    92→            \"train_mape\": float, \"train_r\": float,\n    93→            \"experiments\": [list of experiment_ids],\n    94→        }\n    95→    \"\"\"\n    96→    if data_root is None:\n    97→        data_root = DEFAULT_DATA_ROOT\n    98→\n    99→    # Build canonical model map from exp-config.yaml\n   100→    canon_map = _build_canonical_model_map(data_root)\n   101→\n   102→    all_steps = load_all_experiments(data_root)\n   103→    if all_steps.empty:\n   104→        raise ValueError(f\"No step data found in {data_root}\")\n   105→\n   106→    # Replace parsed model/tp with canonical values from exp-config.yaml\n   107→    all_steps[\"canonical_model\"] = all_steps[\"experiment_id\"].map(\n   108→        lambda eid: canon_map.get(eid, (\"unknown\", 0))[0]\n   109→    )\n   110→    all_steps[\"canonical_tp\"] = all_steps[\"experiment_id\"].map(\n   111→        lambda eid: canon_map.get(eid, (\"unknown\", 0))[1]\n   112→    )\n   113→\n   114→    # Group by canonical model+tp\n   115→    results = {}\n   116→    for (model, tp), group_df in all_steps.groupby([\"canonical_model\", \"canonical_tp\"]):\n   117→        tp_val = int(tp)\n   118→        baseline = BlackboxBaseline().fit(group_df)\n   119→        coeffs = baseline.coefficients\n   120→\n   121→        predicted = baseline.predict(group_df)\n   122→        actual = group_df[\"step.duration_us\"].values\n   123→\n   124→        train_mape = compute_mape(predicted, actual)\n   125→        train_r = compute_pearson_r(predicted, actual)\n   126→        train_mspe = compute_mspe(predicted, actual)\n   127→\n   128→        experiments = sorted(group_df[\"experiment_id\"].unique().tolist())\n   129→\n   130→        results[(model, tp_val)] = {\n   131→            \"beta0\": coeffs[\"beta0\"],\n   132→            \"beta1\": coeffs[\"beta1\"],\n   133→            \"beta2\": coeffs[\"beta2\"],\n   134→            \"n_steps\": len(group_df),\n   135→            \"n_experiments\": len(experiments),\n   136→            \"train_mape\": train_mape,\n   137→            \"train_mspe\": train_mspe,\n   138→            \"train_r\": train_r,\n   139→            \"experiments\": experiments,\n   140→        }\n   141→\n   142→    return results\n   143→\n   144→\n   145→def _ensure_binary() -> str:\n   146→    \"\"\"Return path to the simulation_worker binary, building if needed.\"\"\"\n   147→    binary = os.path.join(_REPO_ROOT, \"simulation_worker\")\n   148→    if not os.path.isfile(binary):\n   149→        print(\"Building simulation_worker...\", file=sys.stderr)\n   150→        subprocess.run(\n   151→            [\"go\", \"build\", \"-o\", binary, \"main.go\"],\n   152→            cwd=_REPO_ROOT, check=True,\n   153→        )\n   154→    return binary\n   155→\n   156→\n   157→def _run_single_experiment(\n   158→    binary: str,\n   159→    dirname: str,\n   160→    dirpath: str,\n   161→    alpha_coeffs: list[float],\n   162→    beta_coeffs: list[float],\n   163→    roofline: bool = False,\n   164→    hardware: str | None = None,\n   165→    extra_fields: dict | None = None,\n   166→) -> dict:\n   167→    \"\"\"Run BLIS for a single experiment and return a result row.\n   168→\n   169→    This is the unit of work dispatched to the thread pool.\n   170→    \"\"\"\n   171→    try:\n   172→        meta = parse_experiment_dir(dirname)\n   173→    except ValueError:\n   174→        return {\"experiment\": dirname, \"status\": \"parse_failed\"}\n   175→\n   176→    gt = load_ground_truth_metrics(dirpath)\n   177→    exp_config = load_exp_config(dirpath)\n   178→    total_kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n   179→    if total_kv_blocks is None:\n   180→        return {\n   181→            \"experiment\": dirname, \"model\": meta[\"model\"],\n   182→            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   183→            \"status\": \"no_kv_blocks\",\n   184→        }\n   185→    cpu_kv_blocks = extract_cpu_kv_blocks_from_vllm_log(dirpath)\n   186→\n   187→    try:\n   188→        profile = load_profile(dirpath)\n   189→    except Exception:\n   190→        return {\n   191→            \"experiment\": dirname, \"model\": meta[\"model\"],\n   192→            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   193→            \"status\": \"no_profile\",\n   194→        }\n   195→\n   196→    workload_spec = build_workload_spec(profile, gt)\n   197→\n   198→    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".yaml\", delete=False) as f:\n   199→        yaml.dump(workload_spec, f, default_flow_style=False)\n   200→        spec_path = f.name\n   201→\n   202→    with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n   203→        results_json_path = f.name\n   204→\n   205→    try:\n   206→        blis_metrics = run_blis(\n   207→            binary=binary,\n   208→            workload_spec_path=spec_path,\n   209→            exp_config=exp_config,\n   210→            total_kv_blocks=total_kv_blocks,\n   211→            alpha_coeffs=alpha_coeffs,\n   212→            beta_coeffs=beta_coeffs,\n   213→            results_path=results_json_path,\n   214→            roofline=roofline,\n   215→            hardware=hardware,\n   216→            cpu_kv_blocks=cpu_kv_blocks,\n   217→        )\n   218→    finally:\n   219→        os.unlink(spec_path)\n   220→        if os.path.exists(results_json_path):\n   221→            os.unlink(results_json_path)\n   222→\n   223→    if blis_metrics is None:\n   224→        return {\n   225→            \"experiment\": dirname, \"model\": meta[\"model\"],\n   226→            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   227→            \"status\": \"blis_failed\",\n   228→        }\n   229→\n   230→    e2e_err = compute_error(blis_metrics[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n   231→    ttft_err = compute_error(blis_metrics[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000)\n   232→    itl_err = compute_error(blis_metrics[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n   233→\n   234→    marker = \" <10%\" if e2e_err < 0.10 else \"\"\n   235→    print(f\"  {dirname}: GT={gt['e2e_mean_s']*1000:.0f}ms  \"\n   236→          f\"BLIS={blis_metrics['e2e_mean_ms']:.0f}ms  \"\n   237→          f\"E2E={e2e_err*100:.1f}%{marker}\")\n   238→\n   239→    row = {\n   240→        \"experiment\": dirname, \"model\": meta[\"model\"],\n   241→        \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   242→        \"status\": \"ok\",\n   243→        \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n   244→        \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n   245→        \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n   246→        \"blis_e2e_ms\": blis_metrics[\"e2e_mean_ms\"],\n   247→        \"blis_ttft_ms\": blis_metrics[\"ttft_mean_ms\"],\n   248→        \"blis_itl_ms\": blis_metrics[\"itl_mean_ms\"],\n   249→        \"e2e_error\": e2e_err, \"ttft_error\": ttft_err, \"itl_error\": itl_err,\n   250→        \"blis_completed\": blis_metrics[\"completed_requests\"],\n   251→        \"gt_requests\": gt[\"num_requests\"],\n   252→    }\n   253→    if extra_fields:\n   254→        row.update(extra_fields)\n   255→    return row\n   256→\n   257→\n   258→def _write_results_csv(rows: list[dict], output_csv: str) -> None:\n   259→    \"\"\"Write result rows to CSV.\"\"\"\n   260→    if not rows:\n   261→        return\n   262→    all_keys = set()\n   263→    for r in rows:\n   264→        all_keys.update(r.keys())\n   265→    fieldnames = sorted(all_keys)\n   266→    with open(output_csv, \"w\", newline=\"\") as f:\n   267→        writer = csv_mod.DictWriter(f, fieldnames=fieldnames)\n   268→        writer.writeheader()\n   269→        writer.writerows(rows)\n   270→\n   271→\n   272→def _discover_experiments(data_root: str) -> list[tuple[str, str]]:\n   273→    \"\"\"Return list of (dirname, dirpath) for valid experiment directories.\"\"\"\n   274→    experiments = []\n   275→    for dirname in sorted(os.listdir(data_root)):\n   276→        dirpath = os.path.join(data_root, dirname)\n   277→        if not os.path.isdir(dirpath):\n   278→            continue\n   279→        summary_path = os.path.join(dirpath, \"results\", \"summary_lifecycle_metrics.json\")\n   280→        if not os.path.isfile(summary_path):\n   281→            continue\n   282→        experiments.append((dirname, dirpath))\n   283→    return experiments\n   284→\n   285→\n   286→def run_blis_validation(\n   287→    coefficients: dict,\n   288→    data_root: str,\n   289→    output_csv: str,\n   290→    max_workers: int = _DEFAULT_WORKERS,\n   291→) -> str:\n   292→    \"\"\"Run BLIS for each experiment using its model+TP-specific coefficients.\n   293→\n   294→    All experiments run in parallel via ThreadPoolExecutor.\n   295→\n   296→    Returns path to the output CSV.\n   297→    \"\"\"\n   298→    # Build experiment → coefficients lookup\n   299→    exp_to_coeffs = {}\n   300→    for (_model, _tp), coeffs in coefficients.items():\n   301→        for exp_id in coeffs[\"experiments\"]:\n   302→            exp_to_coeffs[exp_id] = coeffs\n   303→\n   304→    binary = _ensure_binary()\n   305→    experiments = _discover_experiments(data_root)\n   306→\n   307→    futures = {}\n   308→    with ThreadPoolExecutor(max_workers=max_workers) as pool:\n   309→        for dirname, dirpath in experiments:\n   310→            coeffs = exp_to_coeffs.get(dirname)\n   311→            if coeffs is None:\n   312→                continue\n   313→            beta = [coeffs[\"beta0\"], coeffs[\"beta1\"], coeffs[\"beta2\"]]\n   314→            extra = {\n   315→                \"beta0\": coeffs[\"beta0\"], \"beta1\": coeffs[\"beta1\"],\n   316→                \"beta2\": coeffs[\"beta2\"], \"train_mape\": coeffs[\"train_mape\"],\n   317→            }\n   318→            fut = pool.submit(\n   319→                _run_single_experiment,\n   320→                binary=binary, dirname=dirname, dirpath=dirpath,\n   321→                alpha_coeffs=[0.0, 0.0, 0.0], beta_coeffs=beta,\n   322→                extra_fields=extra,\n   323→            )\n   324→            futures[fut] = dirname\n   325→\n   326→        all_rows = []\n   327→        for fut in as_completed(futures):\n   328→            all_rows.append(fut.result())\n   329→\n   330→    # Sort by experiment name for deterministic output\n   331→    all_rows.sort(key=lambda r: r[\"experiment\"])\n   332→    _write_results_csv(all_rows, output_csv)\n   333→    return output_csv\n   334→\n   335→\n   336→def run_roofline_validation(\n   337→    data_root: str,\n   338→    output_csv: str,\n   339→    hardware: str = \"H100\",\n   340→    max_workers: int = _DEFAULT_WORKERS,\n   341→) -> str:\n   342→    \"\"\"Run BLIS in roofline mode for all experiments in parallel.\n   343→\n   344→    The roofline model is analytical — no training step.  It estimates step\n   345→    time from FLOPs/bandwidth using HuggingFace model config + GPU hardware\n   346→    specs.  Zero calibration data needed.\n   347→\n   348→    Returns path to the output CSV.\n   349→    \"\"\"\n   350→    print(f\"\\n{'='*60}\")\n   351→    print(f\"  Roofline baseline: hardware={hardware}\")\n   352→    print(f\"  (analytical FLOPs/bandwidth — no trained coefficients)\")\n   353→    print(f\"{'='*60}\")\n   354→\n   355→    binary = _ensure_binary()\n   356→    experiments = _discover_experiments(data_root)\n   357→\n   358→    futures = {}\n   359→    with ThreadPoolExecutor(max_workers=max_workers) as pool:\n   360→        for dirname, dirpath in experiments:\n   361→            fut = pool.submit(\n   362→                _run_single_experiment,\n   363→                binary=binary, dirname=dirname, dirpath=dirpath,\n   364→                alpha_coeffs=[0, 0, 0], beta_coeffs=[0, 0, 0],\n   365→                roofline=True, hardware=hardware,\n   366→            )\n   367→            futures[fut] = dirname\n   368→\n   369→        all_rows = []\n   370→        for fut in as_completed(futures):\n   371→            all_rows.append(fut.result())\n   372→\n   373→    all_rows.sort(key=lambda r: r[\"experiment\"])\n   374→    _write_results_csv(all_rows, output_csv)\n   375→    return output_csv\n   376→\n   377→\n   378→def print_roofline_summary(output_csv: str):\n   379→    \"\"\"Print a human-readable summary of the roofline baseline results.\"\"\"\n   380→    if not os.path.isfile(output_csv):\n   381→        print(\"No roofline results to summarize.\")\n   382→        return\n   383→\n   384→    df = pd.read_csv(output_csv)\n   385→    ok = df[df[\"status\"] == \"ok\"]\n   386→\n   387→    if ok.empty:\n   388→        print(\"\\nNo successful roofline experiments. Check BLIS binary and data.\")\n   389→        return\n   390→\n   391→    print(f\"\\n{'='*70}\")\n   392→    print(\"  ROOFLINE BASELINE RESULTS (analytical — no training)\")\n   393→    print(f\"{'='*70}\")\n   394→\n   395→    print(f\"\\n  Experiments: {len(ok)} completed, \"\n   396→          f\"{len(df) - len(ok)} skipped/failed\")\n   397→\n   398→    print(f\"\\n  {'Experiment':<55s} {'E2E%':>6s} {'TTFT%':>6s} {'ITL%':>6s}\")\n   399→    print(f\"  {'-'*55} {'-'*6} {'-'*6} {'-'*6}\")\n   400→    for _, row in ok.iterrows():\n   401→        e2e_pct = row[\"e2e_error\"] * 100\n   402→        ttft_pct = row[\"ttft_error\"] * 100\n   403→        itl_pct = row[\"itl_error\"] * 100\n   404→        marker = \" <10%\" if e2e_pct < 10 else \"\"\n   405→        print(f\"  {row['experiment']:<55s} \"\n   406→              f\"{e2e_pct:>5.1f}% {ttft_pct:>5.1f}% {itl_pct:>5.1f}%{marker}\")\n   407→\n   408→    e2e_errors = ok[\"e2e_error\"].values * 100\n   409→    ttft_errors = ok[\"ttft_error\"].values * 100\n   410→    itl_errors = ok[\"itl_error\"].values * 100\n   411→\n   412→    print(f\"\\n  Mean E2E error:  {e2e_errors.mean():.1f}%\")\n   413→    print(f\"  Mean TTFT error: {ttft_errors.mean():.1f}%\")\n   414→    print(f\"  Mean ITL error:  {itl_errors.mean():.1f}%\")\n   415→\n   416→    passing = (e2e_errors < 10).sum()\n   417→    print(f\"\\n  E2E < 10%: {passing}/{len(ok)} experiments\")\n   418→\n   419→    # Save summary JSON\n   420→    summary = {\n   421→        \"model\": \"roofline (analytical)\",\n   422→        \"e2e_validation\": {\n   423→            \"mean_e2e_error_pct\": float(e2e_errors.mean()),\n   424→            \"mean_ttft_error_pct\": float(ttft_errors.mean()),\n   425→            \"mean_itl_error_pct\": float(itl_errors.mean()),\n   426→            \"experiments_below_10pct\": int(passing),\n   427→            \"total_experiments\": len(ok),\n   428→        },\n   429→    }\n   430→    summary_path = output_csv.replace(\".csv\", \"_summary.json\")\n   431→    with open(summary_path, \"w\") as f:\n   432→        json.dump(summary, f, indent=2)\n   433→    print(f\"\\n  Summary JSON: {summary_path}\")\n   434→\n   435→\n   436→def print_summary(output_csv: str, coefficients: dict):\n   437→    \"\"\"Print a human-readable summary of the baseline results.\"\"\"\n   438→    if not os.path.isfile(output_csv):\n   439→        print(\"No results to summarize.\")\n   440→        return\n   441→\n   442→    df = pd.read_csv(output_csv)\n   443→    ok = df[df[\"status\"] == \"ok\"]\n   444→\n   445→    if ok.empty:\n   446→        print(\"\\nNo successful experiments. Check BLIS binary and data.\")\n   447→        return\n   448→\n   449→    print(f\"\\n{'='*70}\")\n   450→    print(\"  PER-MODEL LINEAR REGRESSION BASELINE RESULTS\")\n   451→    print(f\"{'='*70}\")\n   452→\n   453→    print(f\"\\n  Experiments: {len(ok)} completed, \"\n   454→          f\"{len(df) - len(ok)} skipped/failed\")\n   455→\n   456→    # Per-step training metrics\n   457→    print(f\"\\n  --- Per-Step Training Metrics (linear regression on step traces) ---\")\n   458→    for (model, tp), coeffs in sorted(coefficients.items()):\n   459→        print(f\"  {model} TP={tp}: \"\n   460→              f\"MAPE={coeffs['train_mape']:.1f}%, \"\n   461→              f\"MSPE={coeffs['train_mspe']:+.1f}%, \"\n   462→              f\"r={coeffs['train_r']:.3f}, \"\n   463→              f\"n_steps={coeffs['n_steps']:,}\")\n   464→        print(f\"    beta = [{coeffs['beta0']:.2f}, \"\n   465→              f\"{coeffs['beta1']:.4f}, {coeffs['beta2']:.4f}]\")\n   466→\n   467→    # E2E validation metrics\n   468→    print(f\"\\n  --- BLIS E2E Validation (simulator vs ground truth) ---\")\n   469→    print(f\"  {'Experiment':<55s} {'E2E%':>6s} {'TTFT%':>6s} {'ITL%':>6s}\")\n   470→    print(f\"  {'-'*55} {'-'*6} {'-'*6} {'-'*6}\")\n   471→    for _, row in ok.iterrows():\n   472→        e2e_pct = row[\"e2e_error\"] * 100\n   473→        ttft_pct = row[\"ttft_error\"] * 100\n   474→        itl_pct = row[\"itl_error\"] * 100\n   475→        marker = \" <10%\" if e2e_pct < 10 else \"\"\n   476→        print(f\"  {row['experiment']:<55s} \"\n   477→              f\"{e2e_pct:>5.1f}% {ttft_pct:>5.1f}% {itl_pct:>5.1f}%{marker}\")\n   478→\n   479→    e2e_errors = ok[\"e2e_error\"].values * 100\n   480→    ttft_errors = ok[\"ttft_error\"].values * 100\n   481→    itl_errors = ok[\"itl_error\"].values * 100\n   482→\n   483→    print(f\"\\n  Mean E2E error:  {e2e_errors.mean():.1f}%\")\n   484→    print(f\"  Mean TTFT error: {ttft_errors.mean():.1f}%\")\n   485→    print(f\"  Mean ITL error:  {itl_errors.mean():.1f}%\")\n   486→\n   487→    passing = (e2e_errors < 10).sum()\n   488→    print(f\"\\n  E2E < 10%: {passing}/{len(ok)} experiments\")\n   489→\n   490→    # R4 gate check\n   491→    print(f\"\\n  --- R4 Gate (is linear regression already good enough?) ---\")\n   492→    r4 = check_r4_gate(e2e_errors.mean())\n   493→    print(f\"  {r4['message']}\")\n   494→\n   495→    # Save summary JSON\n   496→    summary = {\n   497→        \"per_model_coefficients\": {\n   498→            f\"{m}_tp{tp}\": {k: v for k, v in coeffs.items()\n   499→                            if k != \"experiments\"}\n   500→            for (m, tp), coeffs in coefficients.items()\n   501→        },\n   502→        \"e2e_validation\": {\n   503→            \"mean_e2e_error_pct\": float(e2e_errors.mean()),\n   504→            \"mean_ttft_error_pct\": float(ttft_errors.mean()),\n   505→            \"mean_itl_error_pct\": float(itl_errors.mean()),\n   506→            \"experiments_below_10pct\": int(passing),\n   507→            \"total_experiments\": len(ok),\n   508→        },\n   509→        \"r4_gate\": r4,\n   510→    }\n   511→    summary_path = output_csv.replace(\".csv\", \"_summary.json\")\n   512→    with open(summary_path, \"w\") as f:\n   513→        json.dump(summary, f, indent=2)\n   514→    print(f\"\\n  Summary JSON: {summary_path}\")\n   515→\n   516→\n   517→def main():\n   518→    parser = argparse.ArgumentParser(\n   519→        description=\"Establish per-model linear regression baseline\"\n   520→    )\n   521→    parser.add_argument(\n   522→        \"--data-root\",\n   523→        default=DEFAULT_DATA_ROOT,\n   524→        help=\"Path to eval/ground_truth/\",\n   525→    )\n   526→    parser.add_argument(\n   527→        \"--output-dir\",\n   528→        default=os.path.join(_SCRIPT_DIR, \"baseline_results\"),\n   529→        help=\"Directory for output files\",\n   530→    )\n   531→    parser.add_argument(\n   532→        \"--hardware\",\n   533→        default=\"H100\",\n   534→        help=\"GPU type for roofline baseline (default: H100)\",\n   535→    )\n   536→    parser.add_argument(\n   537→        \"--skip-roofline\",\n   538→        action=\"store_true\",\n   539→        help=\"Skip the roofline baseline (only run linear regression)\",\n   540→    )\n   541→    parser.add_argument(\n   542→        \"--skip-linear\",\n   543→        action=\"store_true\",\n   544→        help=\"Skip the linear regression baseline (only run roofline)\",\n   545→    )\n   546→    parser.add_argument(\n   547→        \"--workers\",\n   548→        type=int,\n   549→        default=_DEFAULT_WORKERS,\n   550→        help=f\"Max parallel BLIS runs (default: {_DEFAULT_WORKERS})\",\n   551→    )\n   552→    args = parser.parse_args()\n   553→\n   554→    os.makedirs(args.output_dir, exist_ok=True)\n   555→\n   556→    # --- Baseline 1: Roofline (analytical, no training) ---\n   557→    if not args.skip_roofline:\n   558→        roofline_csv = os.path.join(args.output_dir, \"roofline_baseline.csv\")\n   559→\n   560→        print(f\"Step 1: Running roofline baseline \"\n   561→              f\"(hardware={args.hardware}, workers={args.workers})...\")\n   562→        run_roofline_validation(\n   563→            args.data_root, roofline_csv, args.hardware,\n   564→            max_workers=args.workers,\n   565→        )\n   566→\n   567→        print_roofline_summary(roofline_csv)\n   568→\n   569→    # --- Baseline 2: Per-model linear regression ---\n   570→    if not args.skip_linear:\n   571→        linear_csv = os.path.join(args.output_dir, \"per_model_linear_baseline.csv\")\n   572→\n   573→        step_num = \"2\" if not args.skip_roofline else \"1\"\n   574→        print(f\"\\nStep {step_num}: Training per-model linear regression on step traces...\")\n   575→        coefficients = train_per_model_coefficients(args.data_root)\n   576→        print(f\"  Trained {len(coefficients)} model+TP groups\")\n   577→\n   578→        print(f\"\\nStep {int(step_num)+1}: Running BLIS E2E validation \"\n   579→              f\"(workers={args.workers})...\")\n   580→        run_blis_validation(\n   581→            coefficients, args.data_root, linear_csv,\n   582→            max_workers=args.workers,\n   583→        )\n   584→\n   585→        print_summary(linear_csv, coefficients)\n   586→\n   587→\n   588→if __name__ == \"__main__\":\n   589→    main()\n   590→"}]},"parent_tool_use_id":null,"session_id":"c72182bb-90d4-4f72-be1e-6f3d8138bce2","uuid":"4936a35c-4059-4770-8767-ac11a01f1321","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round4-idea-1-constrained-cmaes/hypotheses/h-stepml/shared/establish_baseline.py","content":"\"\"\"Establish baselines for StepML research.\n\nRuns two baselines through BLIS E2E validation and measures E2E/TTFT/ITL error\nagainst ground truth.  These are the accuracy bars that StepML models must beat.\n\nBaseline 1 — Roofline (analytical):\n    Uses the analytical FLOPs/bandwidth roofline model.  Zero calibration data\n    needed — step time is estimated from model architecture (HuggingFace\n    config.json) and GPU specs (hardware_config.json).\n\nBaseline 2 — Per-model linear regression:\n    Trains a separate 3-coefficient linear regression per model+TP on\n    ground-truth step traces (step_time = beta0 + beta1*prefill + beta2*decode),\n    pooling all workloads for a given model.  Requires training data.\n\nUsage:\n    python establish_baseline.py [--data-root PATH] [--output-dir PATH]\n    python establish_baseline.py --skip-linear              # roofline only\n    python establish_baseline.py --skip-roofline            # linear only\n    python establish_baseline.py --hardware A100            # non-default GPU\n\"\"\"\n\nimport argparse\nimport csv as csv_mod\nimport json\nimport os\nimport subprocess\nimport sys\nimport tempfile\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\n\nimport numpy as np\nimport pandas as pd\n\n# Add shared/ to path for imports\n_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\nsys.path.insert(0, _SCRIPT_DIR)\n\nimport yaml\n\nfrom baselines import BlackboxBaseline, check_r4_gate\nfrom data_loader import load_all_experiments, load_experiment_steps, parse_experiment_metadata\nfrom evaluation import compute_mape, compute_mspe, compute_pearson_r, compute_p99_error\nfrom validate_blis import (\n    build_workload_spec,\n    compute_error,\n    extract_cpu_kv_blocks_from_vllm_log,\n    extract_kv_blocks_from_vllm_log,\n    load_exp_config,\n    load_ground_truth_metrics,\n    load_profile,\n    parse_experiment_dir,\n    run_blis,\n)\n\n_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\"))\nDEFAULT_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\n_DEFAULT_WORKERS = min((os.cpu_count() or 4) // 2, 4)\n\n\ndef _build_canonical_model_map(data_root: str) -> dict:\n    \"\"\"Build a map from experiment_id to canonical (model, tp) from exp-config.yaml.\n\n    Directory names have inconsistencies (e.g. \"llama-2-70b\" vs \"llama-2-70b-hf\"\n    for the same model).  exp-config.yaml has the authoritative HF model name.\n    \"\"\"\n    mapping = {}\n    for dirname in sorted(os.listdir(data_root)):\n        config_path = os.path.join(data_root, dirname, \"exp-config.yaml\")\n        if not os.path.isfile(config_path):\n            continue\n        with open(config_path) as f:\n            cfg = yaml.safe_load(f)\n        # Canonical model name from HF (e.g. \"meta-llama/Llama-2-70b-hf\")\n        model = cfg.get(\"model\", \"\")\n        tp = cfg.get(\"tensor_parallelism\", 1)\n        mapping[dirname] = (model, tp)\n    return mapping\n\n\ndef train_per_model_coefficients(data_root: str) -> dict:\n    \"\"\"Train a linear regression per model+TP and return fitted coefficients.\n\n    Groups experiments by canonical (model, tp) from exp-config.yaml, trains\n    one linear regression per group, and returns the coefficients.\n\n    Returns:\n        dict keyed by (model, tp) with values:\n        {\n            \"beta0\": float, \"beta1\": float, \"beta2\": float,\n            \"n_steps\": int, \"n_experiments\": int,\n            \"train_mape\": float, \"train_r\": float,\n            \"experiments\": [list of experiment_ids],\n        }\n    \"\"\"\n    if data_root is None:\n        data_root = DEFAULT_DATA_ROOT\n\n    # Build canonical model map from exp-config.yaml\n    canon_map = _build_canonical_model_map(data_root)\n\n    all_steps = load_all_experiments(data_root)\n    if all_steps.empty:\n        raise ValueError(f\"No step data found in {data_root}\")\n\n    # Replace parsed model/tp with canonical values from exp-config.yaml\n    all_steps[\"canonical_model\"] = all_steps[\"experiment_id\"].map(\n        lambda eid: canon_map.get(eid, (\"unknown\", 0))[0]\n    )\n    all_steps[\"canonical_tp\"] = all_steps[\"experiment_id\"].map(\n        lambda eid: canon_map.get(eid, (\"unknown\", 0))[1]\n    )\n\n    # Group by canonical model+tp\n    results = {}\n    for (model, tp), group_df in all_steps.groupby([\"canonical_model\", \"canonical_tp\"]):\n        tp_val = int(tp)\n        baseline = BlackboxBaseline().fit(group_df)\n        coeffs = baseline.coefficients\n\n        predicted = baseline.predict(group_df)\n        actual = group_df[\"step.duration_us\"].values\n\n        train_mape = compute_mape(predicted, actual)\n        train_r = compute_pearson_r(predicted, actual)\n        train_mspe = compute_mspe(predicted, actual)\n\n        experiments = sorted(group_df[\"experiment_id\"].unique().tolist())\n\n        results[(model, tp_val)] = {\n            \"beta0\": coeffs[\"beta0\"],\n            \"beta1\": coeffs[\"beta1\"],\n            \"beta2\": coeffs[\"beta2\"],\n            \"n_steps\": len(group_df),\n            \"n_experiments\": len(experiments),\n            \"train_mape\": train_mape,\n            \"train_mspe\": train_mspe,\n            \"train_r\": train_r,\n            \"experiments\": experiments,\n        }\n\n    return results\n\n\ndef _ensure_binary() -> str:\n    \"\"\"Return path to the simulation_worker binary, building if needed.\"\"\"\n    binary = os.path.join(_REPO_ROOT, \"simulation_worker\")\n    if not os.path.isfile(binary):\n        print(\"Building simulation_worker...\", file=sys.stderr)\n        subprocess.run(\n            [\"go\", \"build\", \"-o\", binary, \"main.go\"],\n            cwd=_REPO_ROOT, check=True,\n        )\n    return binary\n\n\ndef _run_single_experiment(\n    binary: str,\n    dirname: str,\n    dirpath: str,\n    alpha_coeffs: list[float],\n    beta_coeffs: list[float],\n    roofline: bool = False,\n    hardware: str | None = None,\n    extra_fields: dict | None = None,\n) -> dict:\n    \"\"\"Run BLIS for a single experiment and return a result row.\n\n    This is the unit of work dispatched to the thread pool.\n    \"\"\"\n    try:\n        meta = parse_experiment_dir(dirname)\n    except ValueError:\n        return {\"experiment\": dirname, \"status\": \"parse_failed\"}\n\n    gt = load_ground_truth_metrics(dirpath)\n    exp_config = load_exp_config(dirpath)\n    total_kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n    if total_kv_blocks is None:\n        return {\n            \"experiment\": dirname, \"model\": meta[\"model\"],\n            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n            \"status\": \"no_kv_blocks\",\n        }\n    cpu_kv_blocks = extract_cpu_kv_blocks_from_vllm_log(dirpath)\n\n    try:\n        profile = load_profile(dirpath)\n    except Exception:\n        return {\n            \"experiment\": dirname, \"model\": meta[\"model\"],\n            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n            \"status\": \"no_profile\",\n        }\n\n    workload_spec = build_workload_spec(profile, gt)\n\n    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".yaml\", delete=False) as f:\n        yaml.dump(workload_spec, f, default_flow_style=False)\n        spec_path = f.name\n\n    with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n        results_json_path = f.name\n\n    try:\n        blis_metrics = run_blis(\n            binary=binary,\n            workload_spec_path=spec_path,\n            exp_config=exp_config,\n            total_kv_blocks=total_kv_blocks,\n            alpha_coeffs=alpha_coeffs,\n            beta_coeffs=beta_coeffs,\n            results_path=results_json_path,\n            roofline=roofline,\n            hardware=hardware,\n            cpu_kv_blocks=cpu_kv_blocks,\n        )\n    finally:\n        os.unlink(spec_path)\n        if os.path.exists(results_json_path):\n            os.unlink(results_json_path)\n\n    if blis_metrics is None:\n        return {\n            \"experiment\": dirname, \"model\": meta[\"model\"],\n            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n            \"status\": \"blis_failed\",\n        }\n\n    e2e_err = compute_error(blis_metrics[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n    ttft_err = compute_error(blis_metrics[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000)\n    itl_err = compute_error(blis_metrics[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n\n    marker = \" <10%\" if e2e_err < 0.10 else \"\"\n    print(f\"  {dirname}: GT={gt['e2e_mean_s']*1000:.0f}ms  \"\n          f\"BLIS={blis_metrics['e2e_mean_ms']:.0f}ms  \"\n          f\"E2E={e2e_err*100:.1f}%{marker}\")\n\n    row = {\n        \"experiment\": dirname, \"model\": meta[\"model\"],\n        \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n        \"status\": \"ok\",\n        \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n        \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n        \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n        \"blis_e2e_ms\": blis_metrics[\"e2e_mean_ms\"],\n        \"blis_ttft_ms\": blis_metrics[\"ttft_mean_ms\"],\n        \"blis_itl_ms\": blis_metrics[\"itl_mean_ms\"],\n        \"e2e_error\": e2e_err, \"ttft_error\": ttft_err, \"itl_error\": itl_err,\n        \"blis_completed\": blis_metrics[\"completed_requests\"],\n        \"gt_requests\": gt[\"num_requests\"],\n    }\n    if extra_fields:\n        row.update(extra_fields)\n    return row\n\n\ndef _write_results_csv(rows: list[dict], output_csv: str) -> None:\n    \"\"\"Write result rows to CSV.\"\"\"\n    if not rows:\n        return\n    all_keys = set()\n    for r in rows:\n        all_keys.update(r.keys())\n    fieldnames = sorted(all_keys)\n    with open(output_csv, \"w\", newline=\"\") as f:\n        writer = csv_mod.DictWriter(f, fieldnames=fieldnames)\n        writer.writeheader()\n        writer.writerows(rows)\n\n\ndef _discover_experiments(data_root: str) -> list[tuple[str, str]]:\n    \"\"\"Return list of (dirname, dirpath) for valid experiment directories.\"\"\"\n    experiments = []\n    for dirname in sorted(os.listdir(data_root)):\n        dirpath = os.path.join(data_root, dirname)\n        if not os.path.isdir(dirpath):\n            continue\n        summary_path = os.path.join(dirpath, \"results\", \"summary_lifecycle_metrics.json\")\n        if not os.path.isfile(summary_path):\n            continue\n        experiments.append((dirname, dirpath))\n    return experiments\n\n\ndef run_blis_validation(\n    coefficients: dict,\n    data_root: str,\n    output_csv: str,\n    max_workers: int = _DEFAULT_WORKERS,\n) -> str:\n    \"\"\"Run BLIS for each experiment using its model+TP-specific coefficients.\n\n    All experiments run in parallel via ThreadPoolExecutor.\n\n    Returns path to the output CSV.\n    \"\"\"\n    # Build experiment → coefficients lookup\n    exp_to_coeffs = {}\n    for (_model, _tp), coeffs in coefficients.items():\n        for exp_id in coeffs[\"experiments\"]:\n            exp_to_coeffs[exp_id] = coeffs\n\n    binary = _ensure_binary()\n    experiments = _discover_experiments(data_root)\n\n    futures = {}\n    with ThreadPoolExecutor(max_workers=max_workers) as pool:\n        for dirname, dirpath in experiments:\n            coeffs = exp_to_coeffs.get(dirname)\n            if coeffs is None:\n                continue\n            beta = [coeffs[\"beta0\"], coeffs[\"beta1\"], coeffs[\"beta2\"]]\n            extra = {\n                \"beta0\": coeffs[\"beta0\"], \"beta1\": coeffs[\"beta1\"],\n                \"beta2\": coeffs[\"beta2\"], \"train_mape\": coeffs[\"train_mape\"],\n            }\n            fut = pool.submit(\n                _run_single_experiment,\n                binary=binary, dirname=dirname, dirpath=dirpath,\n                alpha_coeffs=[0.0, 0.0, 0.0], beta_coeffs=beta,\n                extra_fields=extra,\n            )\n            futures[fut] = dirname\n\n        all_rows = []\n        for fut in as_completed(futures):\n            all_rows.append(fut.result())\n\n    # Sort by experiment name for deterministic output\n    all_rows.sort(key=lambda r: r[\"experiment\"])\n    _write_results_csv(all_rows, output_csv)\n    return output_csv\n\n\ndef run_roofline_validation(\n    data_root: str,\n    output_csv: str,\n    hardware: str = \"H100\",\n    max_workers: int = _DEFAULT_WORKERS,\n) -> str:\n    \"\"\"Run BLIS in roofline mode for all experiments in parallel.\n\n    The roofline model is analytical — no training step.  It estimates step\n    time from FLOPs/bandwidth using HuggingFace model config + GPU hardware\n    specs.  Zero calibration data needed.\n\n    Returns path to the output CSV.\n    \"\"\"\n    print(f\"\\n{'='*60}\")\n    print(f\"  Roofline baseline: hardware={hardware}\")\n    print(f\"  (analytical FLOPs/bandwidth — no trained coefficients)\")\n    print(f\"{'='*60}\")\n\n    binary = _ensure_binary()\n    experiments = _discover_experiments(data_root)\n\n    futures = {}\n    with ThreadPoolExecutor(max_workers=max_workers) as pool:\n        for dirname, dirpath in experiments:\n            fut = pool.submit(\n                _run_single_experiment,\n                binary=binary, dirname=dirname, dirpath=dirpath,\n                alpha_coeffs=[0, 0, 0], beta_coeffs=[0, 0, 0],\n                roofline=True, hardware=hardware,\n            )\n            futures[fut] = dirname\n\n        all_rows = []\n        for fut in as_completed(futures):\n            all_rows.append(fut.result())\n\n    all_rows.sort(key=lambda r: r[\"experiment\"])\n    _write_results_csv(all_rows, output_csv)\n    return output_csv\n\n\ndef print_roofline_summary(output_csv: str):\n    \"\"\"Print a human-readable summary of the roofline baseline results.\"\"\"\n    if not os.path.isfile(output_csv):\n        print(\"No roofline results to summarize.\")\n        return\n\n    df = pd.read_csv(output_csv)\n    ok = df[df[\"status\"] == \"ok\"]\n\n    if ok.empty:\n        print(\"\\nNo successful roofline experiments. Check BLIS binary and data.\")\n        return\n\n    print(f\"\\n{'='*70}\")\n    print(\"  ROOFLINE BASELINE RESULTS (analytical — no training)\")\n    print(f\"{'='*70}\")\n\n    print(f\"\\n  Experiments: {len(ok)} completed, \"\n          f\"{len(df) - len(ok)} skipped/failed\")\n\n    print(f\"\\n  {'Experiment':<55s} {'E2E%':>6s} {'TTFT%':>6s} {'ITL%':>6s}\")\n    print(f\"  {'-'*55} {'-'*6} {'-'*6} {'-'*6}\")\n    for _, row in ok.iterrows():\n        e2e_pct = row[\"e2e_error\"] * 100\n        ttft_pct = row[\"ttft_error\"] * 100\n        itl_pct = row[\"itl_error\"] * 100\n        marker = \" <10%\" if e2e_pct < 10 else \"\"\n        print(f\"  {row['experiment']:<55s} \"\n              f\"{e2e_pct:>5.1f}% {ttft_pct:>5.1f}% {itl_pct:>5.1f}%{marker}\")\n\n    e2e_errors = ok[\"e2e_error\"].values * 100\n    ttft_errors = ok[\"ttft_error\"].values * 100\n    itl_errors = ok[\"itl_error\"].values * 100\n\n    print(f\"\\n  Mean E2E error:  {e2e_errors.mean():.1f}%\")\n    print(f\"  Mean TTFT error: {ttft_errors.mean():.1f}%\")\n    print(f\"  Mean ITL error:  {itl_errors.mean():.1f}%\")\n\n    passing = (e2e_errors < 10).sum()\n    print(f\"\\n  E2E < 10%: {passing}/{len(ok)} experiments\")\n\n    # Save summary JSON\n    summary = {\n        \"model\": \"roofline (analytical)\",\n        \"e2e_validation\": {\n            \"mean_e2e_error_pct\": float(e2e_errors.mean()),\n            \"mean_ttft_error_pct\": float(ttft_errors.mean()),\n            \"mean_itl_error_pct\": float(itl_errors.mean()),\n            \"experiments_below_10pct\": int(passing),\n            \"total_experiments\": len(ok),\n        },\n    }\n    summary_path = output_csv.replace(\".csv\", \"_summary.json\")\n    with open(summary_path, \"w\") as f:\n        json.dump(summary, f, indent=2)\n    print(f\"\\n  Summary JSON: {summary_path}\")\n\n\ndef print_summary(output_csv: str, coefficients: dict):\n    \"\"\"Print a human-readable summary of the baseline results.\"\"\"\n    if not os.path.isfile(output_csv):\n        print(\"No results to summarize.\")\n        return\n\n    df = pd.read_csv(output_csv)\n    ok = df[df[\"status\"] == \"ok\"]\n\n    if ok.empty:\n        print(\"\\nNo successful experiments. Check BLIS binary and data.\")\n        return\n\n    print(f\"\\n{'='*70}\")\n    print(\"  PER-MODEL LINEAR REGRESSION BASELINE RESULTS\")\n    print(f\"{'='*70}\")\n\n    print(f\"\\n  Experiments: {len(ok)} completed, \"\n          f\"{len(df) - len(ok)} skipped/failed\")\n\n    # Per-step training metrics\n    print(f\"\\n  --- Per-Step Training Metrics (linear regression on step traces) ---\")\n    for (model, tp), coeffs in sorted(coefficients.items()):\n        print(f\"  {model} TP={tp}: \"\n              f\"MAPE={coeffs['train_mape']:.1f}%, \"\n              f\"MSPE={coeffs['train_mspe']:+.1f}%, \"\n              f\"r={coeffs['train_r']:.3f}, \"\n              f\"n_steps={coeffs['n_steps']:,}\")\n        print(f\"    beta = [{coeffs['beta0']:.2f}, \"\n              f\"{coeffs['beta1']:.4f}, {coeffs['beta2']:.4f}]\")\n\n    # E2E validation metrics\n    print(f\"\\n  --- BLIS E2E Validation (simulator vs ground truth) ---\")\n    print(f\"  {'Experiment':<55s} {'E2E%':>6s} {'TTFT%':>6s} {'ITL%':>6s}\")\n    print(f\"  {'-'*55} {'-'*6} {'-'*6} {'-'*6}\")\n    for _, row in ok.iterrows():\n        e2e_pct = row[\"e2e_error\"] * 100\n        ttft_pct = row[\"ttft_error\"] * 100\n        itl_pct = row[\"itl_error\"] * 100\n        marker = \" <10%\" if e2e_pct < 10 else \"\"\n        print(f\"  {row['experiment']:<55s} \"\n              f\"{e2e_pct:>5.1f}% {ttft_pct:>5.1f}% {itl_pct:>5.1f}%{marker}\")\n\n    e2e_errors = ok[\"e2e_error\"].values * 100\n    ttft_errors = ok[\"ttft_error\"].values * 100\n    itl_errors = ok[\"itl_error\"].values * 100\n\n    print(f\"\\n  Mean E2E error:  {e2e_errors.mean():.1f}%\")\n    print(f\"  Mean TTFT error: {ttft_errors.mean():.1f}%\")\n    print(f\"  Mean ITL error:  {itl_errors.mean():.1f}%\")\n\n    passing = (e2e_errors < 10).sum()\n    print(f\"\\n  E2E < 10%: {passing}/{len(ok)} experiments\")\n\n    # R4 gate check\n    print(f\"\\n  --- R4 Gate (is linear regression already good enough?) ---\")\n    r4 = check_r4_gate(e2e_errors.mean())\n    print(f\"  {r4['message']}\")\n\n    # Save summary JSON\n    summary = {\n        \"per_model_coefficients\": {\n            f\"{m}_tp{tp}\": {k: v for k, v in coeffs.items()\n                            if k != \"experiments\"}\n            for (m, tp), coeffs in coefficients.items()\n        },\n        \"e2e_validation\": {\n            \"mean_e2e_error_pct\": float(e2e_errors.mean()),\n            \"mean_ttft_error_pct\": float(ttft_errors.mean()),\n            \"mean_itl_error_pct\": float(itl_errors.mean()),\n            \"experiments_below_10pct\": int(passing),\n            \"total_experiments\": len(ok),\n        },\n        \"r4_gate\": r4,\n    }\n    summary_path = output_csv.replace(\".csv\", \"_summary.json\")\n    with open(summary_path, \"w\") as f:\n        json.dump(summary, f, indent=2)\n    print(f\"\\n  Summary JSON: {summary_path}\")\n\n\ndef main():\n    parser = argparse.ArgumentParser(\n        description=\"Establish per-model linear regression baseline\"\n    )\n    parser.add_argument(\n        \"--data-root\",\n        default=DEFAULT_DATA_ROOT,\n        help=\"Path to eval/ground_truth/\",\n    )\n    parser.add_argument(\n        \"--output-dir\",\n        default=os.path.join(_SCRIPT_DIR, \"baseline_results\"),\n        help=\"Directory for output files\",\n    )\n    parser.add_argument(\n        \"--hardware\",\n        default=\"H100\",\n        help=\"GPU type for roofline baseline (default: H100)\",\n    )\n    parser.add_argument(\n        \"--skip-roofline\",\n        action=\"store_true\",\n        help=\"Skip the roofline baseline (only run linear regression)\",\n    )\n    parser.add_argument(\n        \"--skip-linear\",\n        action=\"store_true\",\n        help=\"Skip the linear regression baseline (only run roofline)\",\n    )\n    parser.add_argument(\n        \"--workers\",\n        type=int,\n        default=_DEFAULT_WORKERS,\n        help=f\"Max parallel BLIS runs (default: {_DEFAULT_WORKERS})\",\n    )\n    args = parser.parse_args()\n\n    os.makedirs(args.output_dir, exist_ok=True)\n\n    # --- Baseline 1: Roofline (analytical, no training) ---\n    if not args.skip_roofline:\n        roofline_csv = os.path.join(args.output_dir, \"roofline_baseline.csv\")\n\n        print(f\"Step 1: Running roofline baseline \"\n              f\"(hardware={args.hardware}, workers={args.workers})...\")\n        run_roofline_validation(\n            args.data_root, roofline_csv, args.hardware,\n            max_workers=args.workers,\n        )\n\n        print_roofline_summary(roofline_csv)\n\n    # --- Baseline 2: Per-model linear regression ---\n    if not args.skip_linear:\n        linear_csv = os.path.join(args.output_dir, \"per_model_linear_baseline.csv\")\n\n        step_num = \"2\" if not args.skip_roofline else \"1\"\n        print(f\"\\nStep {step_num}: Training per-model linear regression on step traces...\")\n        coefficients = train_per_model_coefficients(args.data_root)\n        print(f\"  Trained {len(coefficients)} model+TP groups\")\n\n        print(f\"\\nStep {int(step_num)+1}: Running BLIS E2E validation \"\n              f\"(workers={args.workers})...\")\n        run_blis_validation(\n            coefficients, args.data_root, linear_csv,\n            max_workers=args.workers,\n        )\n\n        print_summary(linear_csv, coefficients)\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":590,"startLine":1,"totalLines":590}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01SBhLvx1QaVwLhwCMQdwLAp","type":"tool_result","content":"     1→\"\"\"BLIS validation harness for StepML research.\n     2→\n     3→Runs BLIS on each ground-truth experiment using the *same* vLLM args and\n     4→inference-perf profile, then compares BLIS-predicted latencies against\n     5→observed values.  Produces a per-experiment summary CSV.\n     6→\n     7→All experiment-specific parameters come from the experiment directory itself:\n     8→  - exp-config.yaml   → model, tensor_parallelism, max_model_len,\n     9→                         max_num_batched_tokens, max_num_seqs\n    10→  - profile.yaml      → inference-perf stages + shared_prefix config\n    11→  - vllm.log          → GPU KV cache size (tokens → blocks)\n    12→  - results/summary_lifecycle_metrics.json → ground-truth latencies\n    13→\n    14→Latency coefficients are passed explicitly (--alpha-coeffs / --beta-coeffs)\n    15→or via a StepML model artifact (--stepml-model).\n    16→\n    17→Usage:\n    18→    python validate_blis.py --alpha-coeffs 0,0,0 --beta-coeffs 0,0,0\n    19→    python validate_blis.py --stepml-model path/to/model.json\n    20→\"\"\"\n    21→\n    22→import argparse\n    23→import csv\n    24→import json\n    25→import os\n    26→import re\n    27→import subprocess\n    28→import sys\n    29→import tempfile\n    30→\n    31→import yaml\n    32→\n    33→# ---------------------------------------------------------------------------\n    34→# Paths\n    35→# ---------------------------------------------------------------------------\n    36→_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n    37→_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\"))\n    38→DEFAULT_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\n    39→DEFAULT_BINARY = os.path.join(_REPO_ROOT, \"simulation_worker\")\n    40→\n    41→BLOCK_SIZE_TOKENS = 16\n    42→\n    43→\n    44→# ---------------------------------------------------------------------------\n    45→# Experiment parsing helpers\n    46→# ---------------------------------------------------------------------------\n    47→def parse_experiment_dir(dirname: str) -> dict:\n    48→    \"\"\"Parse experiment metadata from directory name.\n    49→\n    50→    Expected format: <timestamp>-<model>-tp<N>-<workload>\n    51→    \"\"\"\n    52→    pattern = re.compile(r\"^(\\d{8}-\\d{6})-(.+)-tp(\\d+)-(\\w+)$\")\n    53→    m = pattern.match(dirname)\n    54→    if m:\n    55→        return {\n    56→            \"timestamp\": m.group(1),\n    57→            \"model\": m.group(2),\n    58→            \"tp\": int(m.group(3)),\n    59→            \"workload\": m.group(4),\n    60→        }\n    61→    # Fallback: find last -tp<N>-\n    62→    tp_matches = list(re.finditer(r\"-tp(\\d+)-\", dirname))\n    63→    if not tp_matches:\n    64→        raise ValueError(f\"Cannot parse experiment dir: {dirname}\")\n    65→    last_tp = tp_matches[-1]\n    66→    return {\n    67→        \"timestamp\": dirname[:15],\n    68→        \"model\": dirname[16:last_tp.start()],\n    69→        \"tp\": int(last_tp.group(1)),\n    70→        \"workload\": dirname[last_tp.end():],\n    71→    }\n    72→\n    73→\n    74→def load_ground_truth_metrics(experiment_dir: str) -> dict:\n    75→    \"\"\"Load summary latency metrics from ground-truth experiment.\"\"\"\n    76→    summary_path = os.path.join(\n    77→        experiment_dir, \"results\", \"summary_lifecycle_metrics.json\"\n    78→    )\n    79→    with open(summary_path) as f:\n    80→        data = json.load(f)\n    81→\n    82→    successes = data.get(\"successes\", {})\n    83→    latency = successes.get(\"latency\", {})\n    84→\n    85→    return {\n    86→        \"e2e_mean_s\": latency.get(\"request_latency\", {}).get(\"mean\", 0),\n    87→        \"ttft_mean_s\": latency.get(\"time_to_first_token\", {}).get(\"mean\", 0),\n    88→        \"itl_mean_s\": latency.get(\"inter_token_latency\", {}).get(\"mean\", 0),\n    89→        \"throughput_rps\": successes.get(\"throughput\", {}).get(\n    90→            \"requests_per_sec\", 0\n    91→        ),\n    92→        \"num_requests\": data.get(\"load_summary\", {}).get(\"count\", 0),\n    93→        \"prompt_len_mean\": successes.get(\"prompt_len\", {}).get(\"mean\", 0),\n    94→        \"output_len_mean\": successes.get(\"output_len\", {}).get(\"mean\", 0),\n    95→    }\n    96→\n    97→\n    98→def load_exp_config(experiment_dir: str) -> dict:\n    99→    \"\"\"Load exp-config.yaml from experiment directory.\"\"\"\n   100→    config_path = os.path.join(experiment_dir, \"exp-config.yaml\")\n   101→    with open(config_path) as f:\n   102→        return yaml.safe_load(f)\n   103→\n   104→\n   105→def load_profile(experiment_dir: str) -> dict:\n   106→    \"\"\"Load profile.yaml (inference-perf config) from experiment directory.\n   107→\n   108→    profile.yaml is JSON despite the .yaml extension.\n   109→    \"\"\"\n   110→    profile_path = os.path.join(experiment_dir, \"profile.yaml\")\n   111→    with open(profile_path) as f:\n   112→        content = f.read()\n   113→    try:\n   114→        return json.loads(content)\n   115→    except json.JSONDecodeError:\n   116→        return yaml.safe_load(content)\n   117→\n   118→\n   119→def extract_kv_blocks_from_vllm_log(experiment_dir: str) -> int | None:\n   120→    \"\"\"Parse vllm.log for 'GPU KV cache size: N tokens' and convert to blocks.\n   121→\n   122→    Returns total KV blocks (tokens / BLOCK_SIZE_TOKENS), or None if not found.\n   123→    \"\"\"\n   124→    vllm_log_path = os.path.join(experiment_dir, \"vllm.log\")\n   125→    if not os.path.isfile(vllm_log_path):\n   126→        return None\n   127→\n   128→    pattern = re.compile(r\"GPU KV cache size:\\s+([\\d,]+)\\s+tokens\")\n   129→    with open(vllm_log_path) as f:\n   130→        for line in f:\n   131→            m = pattern.search(line)\n   132→            if m:\n   133→                tokens = int(m.group(1).replace(\",\", \"\"))\n   134→                return tokens // BLOCK_SIZE_TOKENS\n   135→    return None\n   136→\n   137→\n   138→def extract_cpu_kv_blocks_from_vllm_log(experiment_dir: str) -> int:\n   139→    \"\"\"Parse vllm.log for CPU offloading config and KV cache shape.\n   140→\n   141→    Computes CPU KV blocks from:\n   142→      - cpu_bytes_to_use from kv_connector_extra_config\n   143→      - per-block size derived from the KV cache shape\n   144→        shape = (num_blocks, num_layers, 2, block_size, num_kv_heads, head_dim)\n   145→        per_block_bytes = num_layers * 2 * block_size * num_kv_heads * head_dim * 2 (fp16)\n   146→\n   147→    Returns 0 if no offloading config found.\n   148→    \"\"\"\n   149→    vllm_log_path = os.path.join(experiment_dir, \"vllm.log\")\n   150→    if not os.path.isfile(vllm_log_path):\n   151→        return 0\n   152→\n   153→    cpu_bytes = None\n   154→    kv_shape = None\n   155→    cpu_pattern = re.compile(r\"cpu_bytes_to_use['\\\"]?:\\s*([\\d.]+)\")\n   156→    shape_pattern = re.compile(\n   157→        r\"cross layer KV cache of shape \\((\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+)\\)\"\n   158→    )\n   159→\n   160→    with open(vllm_log_path) as f:\n   161→        for line in f:\n   162→            if cpu_bytes is None:\n   163→                m = cpu_pattern.search(line)\n   164→                if m:\n   165→                    cpu_bytes = float(m.group(1))\n   166→            if kv_shape is None:\n   167→                m = shape_pattern.search(line)\n   168→                if m:\n   169→                    kv_shape = tuple(int(m.group(i)) for i in range(1, 7))\n   170→            if cpu_bytes is not None and kv_shape is not None:\n   171→                break\n   172→\n   173→    if cpu_bytes is None or kv_shape is None or cpu_bytes == 0:\n   174→        return 0\n   175→\n   176→    # shape = (num_blocks, num_layers, 2, block_size, num_kv_heads, head_dim)\n   177→    _, num_layers, _, block_size, num_kv_heads, head_dim = kv_shape\n   178→    per_block_bytes = num_layers * 2 * block_size * num_kv_heads * head_dim * 2  # fp16\n   179→    return int(cpu_bytes) // per_block_bytes\n   180→\n   181→\n   182→# ---------------------------------------------------------------------------\n   183→# Workload spec construction\n   184→# ---------------------------------------------------------------------------\n   185→def build_workload_spec(profile: dict, ground_truth: dict) -> dict:\n   186→    \"\"\"Build a BLIS workload-spec YAML from inference-perf profile.\n   187→\n   188→    Extracts shared prefix parameters and stage-based load from the profile,\n   189→    then constructs a WorkloadSpec with inference_perf section.\n   190→    \"\"\"\n   191→    data = profile.get(\"data\", {})\n   192→    load_config = profile.get(\"load\", {})\n   193→    sp = data.get(\"shared_prefix\", {})\n   194→\n   195→    stages = []\n   196→    for stage in load_config.get(\"stages\", []):\n   197→        stages.append({\n   198→            \"rate\": stage[\"rate\"],\n   199→            \"duration\": stage[\"duration\"],\n   200→        })\n   201→\n   202→    # Fallback: synthesize a stage from ground-truth throughput\n   203→    if not stages:\n   204→        num_requests = ground_truth.get(\"num_requests\", 1000)\n   205→        rps = ground_truth.get(\"throughput_rps\", 10)\n   206→        duration = int(num_requests / rps) + 60\n   207→        stages.append({\"rate\": rps, \"duration\": duration})\n   208→\n   209→    total_requests = sum(s[\"rate\"] * s[\"duration\"] for s in stages)\n   210→    total_duration_s = sum(s[\"duration\"] for s in stages)\n   211→    horizon_us = int(total_duration_s * 1_000_000) + 60_000_000  # +60s buffer\n   212→\n   213→    # Compute time-weighted average rate (needed by BLIS validation before\n   214→    # InferencePerf expansion fills it in GenerateRequests).\n   215→    aggregate_rate = sum(\n   216→        s[\"rate\"] * s[\"duration\"] for s in stages\n   217→    ) / total_duration_s\n   218→\n   219→    return {\n   220→        \"version\": \"2\",\n   221→        \"seed\": 42,\n   222→        \"num_requests\": int(total_requests),\n   223→        \"horizon\": horizon_us,\n   224→        \"aggregate_rate\": aggregate_rate,\n   225→        \"inference_perf\": {\n   226→            \"stages\": stages,\n   227→            \"shared_prefix\": {\n   228→                \"num_unique_system_prompts\": sp.get(\n   229→                    \"num_unique_system_prompts\", 9\n   230→                ),\n   231→                \"num_users_per_system_prompt\": sp.get(\n   232→                    \"num_users_per_system_prompt\", 5\n   233→                ),\n   234→                \"system_prompt_len\": sp.get(\"system_prompt_len\", 100),\n   235→                \"question_len\": sp.get(\n   236→                    \"question_len\",\n   237→                    int(ground_truth.get(\"prompt_len_mean\", 500)),\n   238→                ),\n   239→                \"output_len\": sp.get(\n   240→                    \"output_len\",\n   241→                    int(ground_truth.get(\"output_len_mean\", 250)),\n   242→                ),\n   243→                \"enable_multi_turn_chat\": sp.get(\n   244→                    \"enable_multi_turn_chat\", False\n   245→                ),\n   246→            },\n   247→        },\n   248→    }\n   249→\n   250→\n   251→# ---------------------------------------------------------------------------\n   252→# BLIS execution\n   253→# ---------------------------------------------------------------------------\n   254→def run_blis(\n   255→    binary: str,\n   256→    workload_spec_path: str,\n   257→    exp_config: dict,\n   258→    total_kv_blocks: int,\n   259→    alpha_coeffs: list[float],\n   260→    beta_coeffs: list[float],\n   261→    results_path: str,\n   262→    stepml_model_path: str | None = None,\n   263→    roofline: bool = False,\n   264→    hardware: str | None = None,\n   265→    cpu_kv_blocks: int = 0,\n   266→) -> dict | None:\n   267→    \"\"\"Run BLIS with the same vLLM args as the ground-truth experiment.\n   268→\n   269→    When roofline=True, uses the analytical roofline latency model instead of\n   270→    alpha/beta coefficients.  Requires hardware (GPU type, e.g. \"H100\").\n   271→\n   272→    Returns dict with e2e_mean_ms, ttft_mean_ms, itl_mean_ms, or None on failure.\n   273→    \"\"\"\n   274→    model_name = exp_config.get(\"model\", \"unknown\")\n   275→    tp = exp_config.get(\"tensor_parallelism\", 1)\n   276→    max_model_len = exp_config.get(\"max_model_len\", 4096)\n   277→    max_num_seqs = exp_config.get(\"max_num_seqs\", 128)\n   278→    max_num_batched_tokens = exp_config.get(\"max_num_batched_tokens\", 2048)\n   279→\n   280→    cmd = [\n   281→        binary,\n   282→        \"run\",\n   283→        \"--model\", model_name,\n   284→        \"--workload-spec\", workload_spec_path,\n   285→        # --- Match vLLM serving args exactly ---\n   286→        \"--tp\", str(tp),\n   287→        \"--max-model-len\", str(max_model_len),\n   288→        \"--max-num-running-reqs\", str(max_num_seqs),\n   289→        \"--max-num-scheduled-tokens\", str(max_num_batched_tokens),\n   290→        \"--total-kv-blocks\", str(total_kv_blocks),\n   291→        \"--block-size-in-tokens\", str(BLOCK_SIZE_TOKENS),\n   292→    ]\n   293→\n   294→    if cpu_kv_blocks > 0:\n   295→        cmd.extend([\"--kv-cpu-blocks\", str(cpu_kv_blocks)])\n   296→\n   297→    if roofline:\n   298→        if not hardware:\n   299→            raise ValueError(\"roofline=True requires hardware (GPU type)\")\n   300→        cmd.extend([\"--roofline\", \"--hardware\", hardware])\n   301→    else:\n   302→        # --- Latency coefficients (use = to handle negative values) ---\n   303→        cmd.append(\"--alpha-coeffs=\" + \",\".join(str(c) for c in alpha_coeffs))\n   304→        cmd.append(\"--beta-coeffs=\" + \",\".join(str(c) for c in beta_coeffs))\n   305→\n   306→    # --- Output ---\n   307→    cmd.extend([\"--results-path\", results_path, \"--log\", \"error\"])\n   308→\n   309→    if stepml_model_path:\n   310→        cmd.extend([\"--stepml-model\", stepml_model_path])\n   311→\n   312→    try:\n   313→        result = subprocess.run(\n   314→            cmd,\n   315→            capture_output=True,\n   316→            text=True,\n   317→            timeout=600,\n   318→            cwd=os.path.dirname(binary),\n   319→        )\n   320→    except subprocess.TimeoutExpired:\n   321→        print(\"  TIMEOUT after 600s\", file=sys.stderr)\n   322→        return None\n   323→    except FileNotFoundError:\n   324→        print(f\"  Binary not found: {binary}\", file=sys.stderr)\n   325→        return None\n   326→\n   327→    if result.returncode != 0:\n   328→        print(\n   329→            f\"  BLIS failed (exit {result.returncode}): {result.stderr[:500]}\",\n   330→            file=sys.stderr,\n   331→        )\n   332→        return None\n   333→\n   334→    return parse_blis_stdout(result.stdout)\n   335→\n   336→\n   337→def parse_blis_stdout(stdout: str) -> dict | None:\n   338→    \"\"\"Parse BLIS stdout for the JSON block after '=== Simulation Metrics ==='.\"\"\"\n   339→    lines = stdout.split(\"\\n\")\n   340→    json_lines = []\n   341→    in_json = False\n   342→    brace_depth = 0\n   343→\n   344→    for line in lines:\n   345→        if \"Simulation Metrics\" in line:\n   346→            in_json = False\n   347→            json_lines = []\n   348→            continue\n   349→        if not in_json and line.strip().startswith(\"{\"):\n   350→            in_json = True\n   351→        if in_json:\n   352→            json_lines.append(line)\n   353→            brace_depth += line.count(\"{\") - line.count(\"}\")\n   354→            if brace_depth <= 0:\n   355→                break\n   356→\n   357→    if not json_lines:\n   358→        return None\n   359→\n   360→    try:\n   361→        metrics = json.loads(\"\\n\".join(json_lines))\n   362→    except json.JSONDecodeError:\n   363→        return None\n   364→\n   365→    return {\n   366→        \"e2e_mean_ms\": metrics.get(\"e2e_mean_ms\", 0),\n   367→        \"ttft_mean_ms\": metrics.get(\"ttft_mean_ms\", 0),\n   368→        \"itl_mean_ms\": metrics.get(\"itl_mean_ms\", 0),\n   369→        \"completed_requests\": metrics.get(\"completed_requests\", 0),\n   370→        \"tokens_per_sec\": metrics.get(\"tokens_per_sec\", 0),\n   371→    }\n   372→\n   373→\n   374→def compute_error(predicted: float, observed: float) -> float:\n   375→    \"\"\"Compute relative error: |predicted - observed| / observed.\"\"\"\n   376→    if observed == 0:\n   377→        return float(\"inf\") if predicted != 0 else 0.0\n   378→    return abs(predicted - observed) / observed\n   379→\n   380→\n   381→# ---------------------------------------------------------------------------\n   382→# Main validation loop\n   383→# ---------------------------------------------------------------------------\n   384→def validate_all_experiments(\n   385→    binary: str,\n   386→    data_root: str,\n   387→    output_path: str,\n   388→    alpha_coeffs: list[float],\n   389→    beta_coeffs: list[float],\n   390→    stepml_model_path: str | None = None,\n   391→    roofline: bool = False,\n   392→    hardware: str | None = None,\n   393→):\n   394→    \"\"\"Run BLIS validation across all ground-truth experiments.\"\"\"\n   395→    results = []\n   396→\n   397→    for dirname in sorted(os.listdir(data_root)):\n   398→        dirpath = os.path.join(data_root, dirname)\n   399→        if not os.path.isdir(dirpath):\n   400→            continue\n   401→\n   402→        summary_path = os.path.join(\n   403→            dirpath, \"results\", \"summary_lifecycle_metrics.json\"\n   404→        )\n   405→        if not os.path.isfile(summary_path):\n   406→            continue\n   407→\n   408→        print(f\"\\n{'='*60}\")\n   409→        print(f\"Experiment: {dirname}\")\n   410→        print(f\"{'='*60}\")\n   411→\n   412→        # Parse metadata from directory name\n   413→        try:\n   414→            meta = parse_experiment_dir(dirname)\n   415→        except ValueError as e:\n   416→            print(f\"  SKIP: {e}\", file=sys.stderr)\n   417→            continue\n   418→\n   419→        # Load ground truth metrics\n   420→        gt = load_ground_truth_metrics(dirpath)\n   421→        print(f\"  Ground truth: E2E={gt['e2e_mean_s']*1000:.1f}ms, \"\n   422→              f\"TTFT={gt['ttft_mean_s']*1000:.1f}ms, \"\n   423→              f\"ITL={gt['itl_mean_s']*1000:.2f}ms\")\n   424→\n   425→        # Load experiment config (vLLM serving args)\n   426→        exp_config = load_exp_config(dirpath)\n   427→\n   428→        # Extract KV cache blocks from vllm.log\n   429→        total_kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n   430→        if total_kv_blocks is None:\n   431→            print(\"  SKIP: Cannot parse KV blocks from vllm.log\",\n   432→                  file=sys.stderr)\n   433→            results.append({\n   434→                \"experiment\": dirname,\n   435→                \"model\": meta[\"model\"],\n   436→                \"workload\": meta[\"workload\"],\n   437→                \"tp\": meta[\"tp\"],\n   438→                \"status\": \"no_kv_blocks\",\n   439→            })\n   440→            continue\n   441→        cpu_kv_blocks = extract_cpu_kv_blocks_from_vllm_log(dirpath)\n   442→        print(f\"  KV blocks: {total_kv_blocks} GPU \"\n   443→              f\"({total_kv_blocks * BLOCK_SIZE_TOKENS:,} tokens)\"\n   444→              f\" + {cpu_kv_blocks} CPU\")\n   445→\n   446→        # Load inference-perf profile and build workload spec\n   447→        try:\n   448→            profile = load_profile(dirpath)\n   449→        except (FileNotFoundError, json.JSONDecodeError, yaml.YAMLError) as e:\n   450→            print(f\"  SKIP: Cannot load profile: {e}\", file=sys.stderr)\n   451→            results.append({\n   452→                \"experiment\": dirname,\n   453→                \"model\": meta[\"model\"],\n   454→                \"workload\": meta[\"workload\"],\n   455→                \"tp\": meta[\"tp\"],\n   456→                \"status\": \"no_profile\",\n   457→            })\n   458→            continue\n   459→\n   460→        workload_spec = build_workload_spec(profile, gt)\n   461→\n   462→        # Write workload spec and results path to temp files\n   463→        with tempfile.NamedTemporaryFile(\n   464→            mode=\"w\", suffix=\".yaml\", delete=False\n   465→        ) as f:\n   466→            yaml.dump(workload_spec, f, default_flow_style=False)\n   467→            spec_path = f.name\n   468→\n   469→        with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n   470→            results_json_path = f.name\n   471→\n   472→        try:\n   473→            blis_metrics = run_blis(\n   474→                binary=binary,\n   475→                workload_spec_path=spec_path,\n   476→                exp_config=exp_config,\n   477→                total_kv_blocks=total_kv_blocks,\n   478→                alpha_coeffs=alpha_coeffs,\n   479→                beta_coeffs=beta_coeffs,\n   480→                results_path=results_json_path,\n   481→                stepml_model_path=stepml_model_path,\n   482→                roofline=roofline,\n   483→                hardware=hardware,\n   484→                cpu_kv_blocks=cpu_kv_blocks,\n   485→            )\n   486→        finally:\n   487→            os.unlink(spec_path)\n   488→            if os.path.exists(results_json_path):\n   489→                os.unlink(results_json_path)\n   490→\n   491→        if blis_metrics is None:\n   492→            results.append({\n   493→                \"experiment\": dirname,\n   494→                \"model\": meta[\"model\"],\n   495→                \"workload\": meta[\"workload\"],\n   496→                \"tp\": meta[\"tp\"],\n   497→                \"status\": \"blis_failed\",\n   498→            })\n   499→            continue\n   500→\n   501→        # Compute errors (ground truth is in seconds, BLIS outputs ms)\n   502→        e2e_error = compute_error(\n   503→            blis_metrics[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000\n   504→        )\n   505→        ttft_error = compute_error(\n   506→            blis_metrics[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000\n   507→        )\n   508→        itl_error = compute_error(\n   509→            blis_metrics[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000\n   510→        )\n   511→\n   512→        print(f\"  BLIS:         E2E={blis_metrics['e2e_mean_ms']:.1f}ms, \"\n   513→              f\"TTFT={blis_metrics['ttft_mean_ms']:.1f}ms, \"\n   514→              f\"ITL={blis_metrics['itl_mean_ms']:.2f}ms\")\n   515→        print(f\"  Errors:       E2E={e2e_error*100:.1f}%, \"\n   516→              f\"TTFT={ttft_error*100:.1f}%, \"\n   517→              f\"ITL={itl_error*100:.1f}%\")\n   518→\n   519→        results.append({\n   520→            \"experiment\": dirname,\n   521→            \"model\": meta[\"model\"],\n   522→            \"workload\": meta[\"workload\"],\n   523→            \"tp\": meta[\"tp\"],\n   524→            \"status\": \"ok\",\n   525→            \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n   526→            \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n   527→            \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n   528→            \"blis_e2e_ms\": blis_metrics[\"e2e_mean_ms\"],\n   529→            \"blis_ttft_ms\": blis_metrics[\"ttft_mean_ms\"],\n   530→            \"blis_itl_ms\": blis_metrics[\"itl_mean_ms\"],\n   531→            \"e2e_error\": e2e_error,\n   532→            \"ttft_error\": ttft_error,\n   533→            \"itl_error\": itl_error,\n   534→            \"blis_completed\": blis_metrics[\"completed_requests\"],\n   535→            \"gt_requests\": gt[\"num_requests\"],\n   536→        })\n   537→\n   538→    # Write summary CSV\n   539→    if results:\n   540→        all_keys = set()\n   541→        for r in results:\n   542→            all_keys.update(r.keys())\n   543→        fieldnames = sorted(all_keys)\n   544→\n   545→        with open(output_path, \"w\", newline=\"\") as f:\n   546→            writer = csv.DictWriter(f, fieldnames=fieldnames)\n   547→            writer.writeheader()\n   548→            writer.writerows(results)\n   549→\n   550→        print(f\"\\n{'='*60}\")\n   551→        print(f\"Summary written to: {output_path}\")\n   552→        print(f\"{'='*60}\")\n   553→\n   554→        ok_results = [r for r in results if r.get(\"status\") == \"ok\"]\n   555→        if ok_results:\n   556→            e2e_errors = [r[\"e2e_error\"] for r in ok_results]\n   557→            ttft_errors = [r[\"ttft_error\"] for r in ok_results]\n   558→            itl_errors = [r[\"itl_error\"] for r in ok_results]\n   559→\n   560→            print(f\"\\nExperiments: {len(ok_results)} completed, \"\n   561→                  f\"{len(results) - len(ok_results)} skipped/failed\")\n   562→            print(f\"E2E  mean error: \"\n   563→                  f\"{sum(e2e_errors)/len(e2e_errors)*100:.1f}%\")\n   564→            print(f\"TTFT mean error: \"\n   565→                  f\"{sum(ttft_errors)/len(ttft_errors)*100:.1f}%\")\n   566→            print(f\"ITL  mean error: \"\n   567→                  f\"{sum(itl_errors)/len(itl_errors)*100:.1f}%\")\n   568→\n   569→            passing = sum(1 for e in e2e_errors if e < 0.10)\n   570→            print(f\"E2E < 10%: {passing}/{len(ok_results)} experiments\")\n   571→\n   572→\n   573→def main():\n   574→    parser = argparse.ArgumentParser(\n   575→        description=\"BLIS validation harness for StepML research\"\n   576→    )\n   577→    parser.add_argument(\n   578→        \"--binary\",\n   579→        default=DEFAULT_BINARY,\n   580→        help=f\"Path to simulation_worker binary (default: {DEFAULT_BINARY})\",\n   581→    )\n   582→    parser.add_argument(\n   583→        \"--data-root\",\n   584→        default=DEFAULT_DATA_ROOT,\n   585→        help=f\"Path to eval/ground_truth/ (default: {DEFAULT_DATA_ROOT})\",\n   586→    )\n   587→    parser.add_argument(\n   588→        \"--output\",\n   589→        default=os.path.join(_SCRIPT_DIR, \"blis_validation_results.csv\"),\n   590→        help=\"Output CSV path\",\n   591→    )\n   592→    parser.add_argument(\n   593→        \"--alpha-coeffs\",\n   594→        default=\"0,0,0\",\n   595→        help=\"Comma-separated alpha coefficients (default: 0,0,0)\",\n   596→    )\n   597→    parser.add_argument(\n   598→        \"--beta-coeffs\",\n   599→        default=\"0,0,0\",\n   600→        help=\"Comma-separated beta coefficients (default: 0,0,0)\",\n   601→    )\n   602→    parser.add_argument(\n   603→        \"--stepml-model\",\n   604→        default=None,\n   605→        help=\"Path to StepML model artifact JSON (optional)\",\n   606→    )\n   607→    parser.add_argument(\n   608→        \"--roofline\",\n   609→        action=\"store_true\",\n   610→        help=\"Use analytical roofline latency model instead of alpha/beta coefficients\",\n   611→    )\n   612→    parser.add_argument(\n   613→        \"--hardware\",\n   614→        default=None,\n   615→        help=\"GPU type for roofline mode (e.g. H100). Required when --roofline is set.\",\n   616→    )\n   617→    args = parser.parse_args()\n   618→\n   619→    if args.roofline and not args.hardware:\n   620→        parser.error(\"--roofline requires --hardware (GPU type, e.g. H100)\")\n   621→\n   622→    alpha_coeffs = [float(x) for x in args.alpha_coeffs.split(\",\")]\n   623→    beta_coeffs = [float(x) for x in args.beta_coeffs.split(\",\")]\n   624→\n   625→    if not args.roofline:\n   626→        if len(alpha_coeffs) < 3:\n   627→            parser.error(\"--alpha-coeffs requires at least 3 values\")\n   628→        if len(beta_coeffs) < 3:\n   629→            parser.error(\"--beta-coeffs requires at least 3 values\")\n   630→\n   631→    # Build binary if needed\n   632→    if not os.path.isfile(args.binary):\n   633→        print(\"Building simulation_worker...\", file=sys.stderr)\n   634→        build_result = subprocess.run(\n   635→            [\"go\", \"build\", \"-o\", args.binary, \"main.go\"],\n   636→            cwd=_REPO_ROOT,\n   637→            capture_output=True,\n   638→            text=True,\n   639→        )\n   640→        if build_result.returncode != 0:\n   641→            print(f\"Build failed: {build_result.stderr}\", file=sys.stderr)\n   642→            sys.exit(1)\n   643→\n   644→    validate_all_experiments(\n   645→        binary=args.binary,\n   646→        data_root=args.data_root,\n   647→        output_path=args.output,\n   648→        alpha_coeffs=alpha_coeffs,\n   649→        beta_coeffs=beta_coeffs,\n   650→        stepml_model_path=args.stepml_model,\n   651→        roofline=args.roofline,\n   652→        hardware=args.hardware,\n   653→    )\n   654→\n   655→\n   656→if __name__ == \"__main__\":\n   657→    main()\n   658→"}]},"parent_tool_use_id":null,"session_id":"c72182bb-90d4-4f72-be1e-6f3d8138bce2","uuid":"65c75d4e-dc3a-479c-b485-5aeb659f343d","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round4-idea-1-constrained-cmaes/hypotheses/h-stepml/shared/validate_blis.py","content":"\"\"\"BLIS validation harness for StepML research.\n\nRuns BLIS on each ground-truth experiment using the *same* vLLM args and\ninference-perf profile, then compares BLIS-predicted latencies against\nobserved values.  Produces a per-experiment summary CSV.\n\nAll experiment-specific parameters come from the experiment directory itself:\n  - exp-config.yaml   → model, tensor_parallelism, max_model_len,\n                         max_num_batched_tokens, max_num_seqs\n  - profile.yaml      → inference-perf stages + shared_prefix config\n  - vllm.log          → GPU KV cache size (tokens → blocks)\n  - results/summary_lifecycle_metrics.json → ground-truth latencies\n\nLatency coefficients are passed explicitly (--alpha-coeffs / --beta-coeffs)\nor via a StepML model artifact (--stepml-model).\n\nUsage:\n    python validate_blis.py --alpha-coeffs 0,0,0 --beta-coeffs 0,0,0\n    python validate_blis.py --stepml-model path/to/model.json\n\"\"\"\n\nimport argparse\nimport csv\nimport json\nimport os\nimport re\nimport subprocess\nimport sys\nimport tempfile\n\nimport yaml\n\n# ---------------------------------------------------------------------------\n# Paths\n# ---------------------------------------------------------------------------\n_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\"))\nDEFAULT_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\nDEFAULT_BINARY = os.path.join(_REPO_ROOT, \"simulation_worker\")\n\nBLOCK_SIZE_TOKENS = 16\n\n\n# ---------------------------------------------------------------------------\n# Experiment parsing helpers\n# ---------------------------------------------------------------------------\ndef parse_experiment_dir(dirname: str) -> dict:\n    \"\"\"Parse experiment metadata from directory name.\n\n    Expected format: <timestamp>-<model>-tp<N>-<workload>\n    \"\"\"\n    pattern = re.compile(r\"^(\\d{8}-\\d{6})-(.+)-tp(\\d+)-(\\w+)$\")\n    m = pattern.match(dirname)\n    if m:\n        return {\n            \"timestamp\": m.group(1),\n            \"model\": m.group(2),\n            \"tp\": int(m.group(3)),\n            \"workload\": m.group(4),\n        }\n    # Fallback: find last -tp<N>-\n    tp_matches = list(re.finditer(r\"-tp(\\d+)-\", dirname))\n    if not tp_matches:\n        raise ValueError(f\"Cannot parse experiment dir: {dirname}\")\n    last_tp = tp_matches[-1]\n    return {\n        \"timestamp\": dirname[:15],\n        \"model\": dirname[16:last_tp.start()],\n        \"tp\": int(last_tp.group(1)),\n        \"workload\": dirname[last_tp.end():],\n    }\n\n\ndef load_ground_truth_metrics(experiment_dir: str) -> dict:\n    \"\"\"Load summary latency metrics from ground-truth experiment.\"\"\"\n    summary_path = os.path.join(\n        experiment_dir, \"results\", \"summary_lifecycle_metrics.json\"\n    )\n    with open(summary_path) as f:\n        data = json.load(f)\n\n    successes = data.get(\"successes\", {})\n    latency = successes.get(\"latency\", {})\n\n    return {\n        \"e2e_mean_s\": latency.get(\"request_latency\", {}).get(\"mean\", 0),\n        \"ttft_mean_s\": latency.get(\"time_to_first_token\", {}).get(\"mean\", 0),\n        \"itl_mean_s\": latency.get(\"inter_token_latency\", {}).get(\"mean\", 0),\n        \"throughput_rps\": successes.get(\"throughput\", {}).get(\n            \"requests_per_sec\", 0\n        ),\n        \"num_requests\": data.get(\"load_summary\", {}).get(\"count\", 0),\n        \"prompt_len_mean\": successes.get(\"prompt_len\", {}).get(\"mean\", 0),\n        \"output_len_mean\": successes.get(\"output_len\", {}).get(\"mean\", 0),\n    }\n\n\ndef load_exp_config(experiment_dir: str) -> dict:\n    \"\"\"Load exp-config.yaml from experiment directory.\"\"\"\n    config_path = os.path.join(experiment_dir, \"exp-config.yaml\")\n    with open(config_path) as f:\n        return yaml.safe_load(f)\n\n\ndef load_profile(experiment_dir: str) -> dict:\n    \"\"\"Load profile.yaml (inference-perf config) from experiment directory.\n\n    profile.yaml is JSON despite the .yaml extension.\n    \"\"\"\n    profile_path = os.path.join(experiment_dir, \"profile.yaml\")\n    with open(profile_path) as f:\n        content = f.read()\n    try:\n        return json.loads(content)\n    except json.JSONDecodeError:\n        return yaml.safe_load(content)\n\n\ndef extract_kv_blocks_from_vllm_log(experiment_dir: str) -> int | None:\n    \"\"\"Parse vllm.log for 'GPU KV cache size: N tokens' and convert to blocks.\n\n    Returns total KV blocks (tokens / BLOCK_SIZE_TOKENS), or None if not found.\n    \"\"\"\n    vllm_log_path = os.path.join(experiment_dir, \"vllm.log\")\n    if not os.path.isfile(vllm_log_path):\n        return None\n\n    pattern = re.compile(r\"GPU KV cache size:\\s+([\\d,]+)\\s+tokens\")\n    with open(vllm_log_path) as f:\n        for line in f:\n            m = pattern.search(line)\n            if m:\n                tokens = int(m.group(1).replace(\",\", \"\"))\n                return tokens // BLOCK_SIZE_TOKENS\n    return None\n\n\ndef extract_cpu_kv_blocks_from_vllm_log(experiment_dir: str) -> int:\n    \"\"\"Parse vllm.log for CPU offloading config and KV cache shape.\n\n    Computes CPU KV blocks from:\n      - cpu_bytes_to_use from kv_connector_extra_config\n      - per-block size derived from the KV cache shape\n        shape = (num_blocks, num_layers, 2, block_size, num_kv_heads, head_dim)\n        per_block_bytes = num_layers * 2 * block_size * num_kv_heads * head_dim * 2 (fp16)\n\n    Returns 0 if no offloading config found.\n    \"\"\"\n    vllm_log_path = os.path.join(experiment_dir, \"vllm.log\")\n    if not os.path.isfile(vllm_log_path):\n        return 0\n\n    cpu_bytes = None\n    kv_shape = None\n    cpu_pattern = re.compile(r\"cpu_bytes_to_use['\\\"]?:\\s*([\\d.]+)\")\n    shape_pattern = re.compile(\n        r\"cross layer KV cache of shape \\((\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+)\\)\"\n    )\n\n    with open(vllm_log_path) as f:\n        for line in f:\n            if cpu_bytes is None:\n                m = cpu_pattern.search(line)\n                if m:\n                    cpu_bytes = float(m.group(1))\n            if kv_shape is None:\n                m = shape_pattern.search(line)\n                if m:\n                    kv_shape = tuple(int(m.group(i)) for i in range(1, 7))\n            if cpu_bytes is not None and kv_shape is not None:\n                break\n\n    if cpu_bytes is None or kv_shape is None or cpu_bytes == 0:\n        return 0\n\n    # shape = (num_blocks, num_layers, 2, block_size, num_kv_heads, head_dim)\n    _, num_layers, _, block_size, num_kv_heads, head_dim = kv_shape\n    per_block_bytes = num_layers * 2 * block_size * num_kv_heads * head_dim * 2  # fp16\n    return int(cpu_bytes) // per_block_bytes\n\n\n# ---------------------------------------------------------------------------\n# Workload spec construction\n# ---------------------------------------------------------------------------\ndef build_workload_spec(profile: dict, ground_truth: dict) -> dict:\n    \"\"\"Build a BLIS workload-spec YAML from inference-perf profile.\n\n    Extracts shared prefix parameters and stage-based load from the profile,\n    then constructs a WorkloadSpec with inference_perf section.\n    \"\"\"\n    data = profile.get(\"data\", {})\n    load_config = profile.get(\"load\", {})\n    sp = data.get(\"shared_prefix\", {})\n\n    stages = []\n    for stage in load_config.get(\"stages\", []):\n        stages.append({\n            \"rate\": stage[\"rate\"],\n            \"duration\": stage[\"duration\"],\n        })\n\n    # Fallback: synthesize a stage from ground-truth throughput\n    if not stages:\n        num_requests = ground_truth.get(\"num_requests\", 1000)\n        rps = ground_truth.get(\"throughput_rps\", 10)\n        duration = int(num_requests / rps) + 60\n        stages.append({\"rate\": rps, \"duration\": duration})\n\n    total_requests = sum(s[\"rate\"] * s[\"duration\"] for s in stages)\n    total_duration_s = sum(s[\"duration\"] for s in stages)\n    horizon_us = int(total_duration_s * 1_000_000) + 60_000_000  # +60s buffer\n\n    # Compute time-weighted average rate (needed by BLIS validation before\n    # InferencePerf expansion fills it in GenerateRequests).\n    aggregate_rate = sum(\n        s[\"rate\"] * s[\"duration\"] for s in stages\n    ) / total_duration_s\n\n    return {\n        \"version\": \"2\",\n        \"seed\": 42,\n        \"num_requests\": int(total_requests),\n        \"horizon\": horizon_us,\n        \"aggregate_rate\": aggregate_rate,\n        \"inference_perf\": {\n            \"stages\": stages,\n            \"shared_prefix\": {\n                \"num_unique_system_prompts\": sp.get(\n                    \"num_unique_system_prompts\", 9\n                ),\n                \"num_users_per_system_prompt\": sp.get(\n                    \"num_users_per_system_prompt\", 5\n                ),\n                \"system_prompt_len\": sp.get(\"system_prompt_len\", 100),\n                \"question_len\": sp.get(\n                    \"question_len\",\n                    int(ground_truth.get(\"prompt_len_mean\", 500)),\n                ),\n                \"output_len\": sp.get(\n                    \"output_len\",\n                    int(ground_truth.get(\"output_len_mean\", 250)),\n                ),\n                \"enable_multi_turn_chat\": sp.get(\n                    \"enable_multi_turn_chat\", False\n                ),\n            },\n        },\n    }\n\n\n# ---------------------------------------------------------------------------\n# BLIS execution\n# ---------------------------------------------------------------------------\ndef run_blis(\n    binary: str,\n    workload_spec_path: str,\n    exp_config: dict,\n    total_kv_blocks: int,\n    alpha_coeffs: list[float],\n    beta_coeffs: list[float],\n    results_path: str,\n    stepml_model_path: str | None = None,\n    roofline: bool = False,\n    hardware: str | None = None,\n    cpu_kv_blocks: int = 0,\n) -> dict | None:\n    \"\"\"Run BLIS with the same vLLM args as the ground-truth experiment.\n\n    When roofline=True, uses the analytical roofline latency model instead of\n    alpha/beta coefficients.  Requires hardware (GPU type, e.g. \"H100\").\n\n    Returns dict with e2e_mean_ms, ttft_mean_ms, itl_mean_ms, or None on failure.\n    \"\"\"\n    model_name = exp_config.get(\"model\", \"unknown\")\n    tp = exp_config.get(\"tensor_parallelism\", 1)\n    max_model_len = exp_config.get(\"max_model_len\", 4096)\n    max_num_seqs = exp_config.get(\"max_num_seqs\", 128)\n    max_num_batched_tokens = exp_config.get(\"max_num_batched_tokens\", 2048)\n\n    cmd = [\n        binary,\n        \"run\",\n        \"--model\", model_name,\n        \"--workload-spec\", workload_spec_path,\n        # --- Match vLLM serving args exactly ---\n        \"--tp\", str(tp),\n        \"--max-model-len\", str(max_model_len),\n        \"--max-num-running-reqs\", str(max_num_seqs),\n        \"--max-num-scheduled-tokens\", str(max_num_batched_tokens),\n        \"--total-kv-blocks\", str(total_kv_blocks),\n        \"--block-size-in-tokens\", str(BLOCK_SIZE_TOKENS),\n    ]\n\n    if cpu_kv_blocks > 0:\n        cmd.extend([\"--kv-cpu-blocks\", str(cpu_kv_blocks)])\n\n    if roofline:\n        if not hardware:\n            raise ValueError(\"roofline=True requires hardware (GPU type)\")\n        cmd.extend([\"--roofline\", \"--hardware\", hardware])\n    else:\n        # --- Latency coefficients (use = to handle negative values) ---\n        cmd.append(\"--alpha-coeffs=\" + \",\".join(str(c) for c in alpha_coeffs))\n        cmd.append(\"--beta-coeffs=\" + \",\".join(str(c) for c in beta_coeffs))\n\n    # --- Output ---\n    cmd.extend([\"--results-path\", results_path, \"--log\", \"error\"])\n\n    if stepml_model_path:\n        cmd.extend([\"--stepml-model\", stepml_model_path])\n\n    try:\n        result = subprocess.run(\n            cmd,\n            capture_output=True,\n            text=True,\n            timeout=600,\n            cwd=os.path.dirname(binary),\n        )\n    except subprocess.TimeoutExpired:\n        print(\"  TIMEOUT after 600s\", file=sys.stderr)\n        return None\n    except FileNotFoundError:\n        print(f\"  Binary not found: {binary}\", file=sys.stderr)\n        return None\n\n    if result.returncode != 0:\n        print(\n            f\"  BLIS failed (exit {result.returncode}): {result.stderr[:500]}\",\n            file=sys.stderr,\n        )\n        return None\n\n    return parse_blis_stdout(result.stdout)\n\n\ndef parse_blis_stdout(stdout: str) -> dict | None:\n    \"\"\"Parse BLIS stdout for the JSON block after '=== Simulation Metrics ==='.\"\"\"\n    lines = stdout.split(\"\\n\")\n    json_lines = []\n    in_json = False\n    brace_depth = 0\n\n    for line in lines:\n        if \"Simulation Metrics\" in line:\n            in_json = False\n            json_lines = []\n            continue\n        if not in_json and line.strip().startswith(\"{\"):\n            in_json = True\n        if in_json:\n            json_lines.append(line)\n            brace_depth += line.count(\"{\") - line.count(\"}\")\n            if brace_depth <= 0:\n                break\n\n    if not json_lines:\n        return None\n\n    try:\n        metrics = json.loads(\"\\n\".join(json_lines))\n    except json.JSONDecodeError:\n        return None\n\n    return {\n        \"e2e_mean_ms\": metrics.get(\"e2e_mean_ms\", 0),\n        \"ttft_mean_ms\": metrics.get(\"ttft_mean_ms\", 0),\n        \"itl_mean_ms\": metrics.get(\"itl_mean_ms\", 0),\n        \"completed_requests\": metrics.get(\"completed_requests\", 0),\n        \"tokens_per_sec\": metrics.get(\"tokens_per_sec\", 0),\n    }\n\n\ndef compute_error(predicted: float, observed: float) -> float:\n    \"\"\"Compute relative error: |predicted - observed| / observed.\"\"\"\n    if observed == 0:\n        return float(\"inf\") if predicted != 0 else 0.0\n    return abs(predicted - observed) / observed\n\n\n# ---------------------------------------------------------------------------\n# Main validation loop\n# ---------------------------------------------------------------------------\ndef validate_all_experiments(\n    binary: str,\n    data_root: str,\n    output_path: str,\n    alpha_coeffs: list[float],\n    beta_coeffs: list[float],\n    stepml_model_path: str | None = None,\n    roofline: bool = False,\n    hardware: str | None = None,\n):\n    \"\"\"Run BLIS validation across all ground-truth experiments.\"\"\"\n    results = []\n\n    for dirname in sorted(os.listdir(data_root)):\n        dirpath = os.path.join(data_root, dirname)\n        if not os.path.isdir(dirpath):\n            continue\n\n        summary_path = os.path.join(\n            dirpath, \"results\", \"summary_lifecycle_metrics.json\"\n        )\n        if not os.path.isfile(summary_path):\n            continue\n\n        print(f\"\\n{'='*60}\")\n        print(f\"Experiment: {dirname}\")\n        print(f\"{'='*60}\")\n\n        # Parse metadata from directory name\n        try:\n            meta = parse_experiment_dir(dirname)\n        except ValueError as e:\n            print(f\"  SKIP: {e}\", file=sys.stderr)\n            continue\n\n        # Load ground truth metrics\n        gt = load_ground_truth_metrics(dirpath)\n        print(f\"  Ground truth: E2E={gt['e2e_mean_s']*1000:.1f}ms, \"\n              f\"TTFT={gt['ttft_mean_s']*1000:.1f}ms, \"\n              f\"ITL={gt['itl_mean_s']*1000:.2f}ms\")\n\n        # Load experiment config (vLLM serving args)\n        exp_config = load_exp_config(dirpath)\n\n        # Extract KV cache blocks from vllm.log\n        total_kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n        if total_kv_blocks is None:\n            print(\"  SKIP: Cannot parse KV blocks from vllm.log\",\n                  file=sys.stderr)\n            results.append({\n                \"experiment\": dirname,\n                \"model\": meta[\"model\"],\n                \"workload\": meta[\"workload\"],\n                \"tp\": meta[\"tp\"],\n                \"status\": \"no_kv_blocks\",\n            })\n            continue\n        cpu_kv_blocks = extract_cpu_kv_blocks_from_vllm_log(dirpath)\n        print(f\"  KV blocks: {total_kv_blocks} GPU \"\n              f\"({total_kv_blocks * BLOCK_SIZE_TOKENS:,} tokens)\"\n              f\" + {cpu_kv_blocks} CPU\")\n\n        # Load inference-perf profile and build workload spec\n        try:\n            profile = load_profile(dirpath)\n        except (FileNotFoundError, json.JSONDecodeError, yaml.YAMLError) as e:\n            print(f\"  SKIP: Cannot load profile: {e}\", file=sys.stderr)\n            results.append({\n                \"experiment\": dirname,\n                \"model\": meta[\"model\"],\n                \"workload\": meta[\"workload\"],\n                \"tp\": meta[\"tp\"],\n                \"status\": \"no_profile\",\n            })\n            continue\n\n        workload_spec = build_workload_spec(profile, gt)\n\n        # Write workload spec and results path to temp files\n        with tempfile.NamedTemporaryFile(\n            mode=\"w\", suffix=\".yaml\", delete=False\n        ) as f:\n            yaml.dump(workload_spec, f, default_flow_style=False)\n            spec_path = f.name\n\n        with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n            results_json_path = f.name\n\n        try:\n            blis_metrics = run_blis(\n                binary=binary,\n                workload_spec_path=spec_path,\n                exp_config=exp_config,\n                total_kv_blocks=total_kv_blocks,\n                alpha_coeffs=alpha_coeffs,\n                beta_coeffs=beta_coeffs,\n                results_path=results_json_path,\n                stepml_model_path=stepml_model_path,\n                roofline=roofline,\n                hardware=hardware,\n                cpu_kv_blocks=cpu_kv_blocks,\n            )\n        finally:\n            os.unlink(spec_path)\n            if os.path.exists(results_json_path):\n                os.unlink(results_json_path)\n\n        if blis_metrics is None:\n            results.append({\n                \"experiment\": dirname,\n                \"model\": meta[\"model\"],\n                \"workload\": meta[\"workload\"],\n                \"tp\": meta[\"tp\"],\n                \"status\": \"blis_failed\",\n            })\n            continue\n\n        # Compute errors (ground truth is in seconds, BLIS outputs ms)\n        e2e_error = compute_error(\n            blis_metrics[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000\n        )\n        ttft_error = compute_error(\n            blis_metrics[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000\n        )\n        itl_error = compute_error(\n            blis_metrics[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000\n        )\n\n        print(f\"  BLIS:         E2E={blis_metrics['e2e_mean_ms']:.1f}ms, \"\n              f\"TTFT={blis_metrics['ttft_mean_ms']:.1f}ms, \"\n              f\"ITL={blis_metrics['itl_mean_ms']:.2f}ms\")\n        print(f\"  Errors:       E2E={e2e_error*100:.1f}%, \"\n              f\"TTFT={ttft_error*100:.1f}%, \"\n              f\"ITL={itl_error*100:.1f}%\")\n\n        results.append({\n            \"experiment\": dirname,\n            \"model\": meta[\"model\"],\n            \"workload\": meta[\"workload\"],\n            \"tp\": meta[\"tp\"],\n            \"status\": \"ok\",\n            \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n            \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n            \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n            \"blis_e2e_ms\": blis_metrics[\"e2e_mean_ms\"],\n            \"blis_ttft_ms\": blis_metrics[\"ttft_mean_ms\"],\n            \"blis_itl_ms\": blis_metrics[\"itl_mean_ms\"],\n            \"e2e_error\": e2e_error,\n            \"ttft_error\": ttft_error,\n            \"itl_error\": itl_error,\n            \"blis_completed\": blis_metrics[\"completed_requests\"],\n            \"gt_requests\": gt[\"num_requests\"],\n        })\n\n    # Write summary CSV\n    if results:\n        all_keys = set()\n        for r in results:\n            all_keys.update(r.keys())\n        fieldnames = sorted(all_keys)\n\n        with open(output_path, \"w\", newline=\"\") as f:\n            writer = csv.DictWriter(f, fieldnames=fieldnames)\n            writer.writeheader()\n            writer.writerows(results)\n\n        print(f\"\\n{'='*60}\")\n        print(f\"Summary written to: {output_path}\")\n        print(f\"{'='*60}\")\n\n        ok_results = [r for r in results if r.get(\"status\") == \"ok\"]\n        if ok_results:\n            e2e_errors = [r[\"e2e_error\"] for r in ok_results]\n            ttft_errors = [r[\"ttft_error\"] for r in ok_results]\n            itl_errors = [r[\"itl_error\"] for r in ok_results]\n\n            print(f\"\\nExperiments: {len(ok_results)} completed, \"\n                  f\"{len(results) - len(ok_results)} skipped/failed\")\n            print(f\"E2E  mean error: \"\n                  f\"{sum(e2e_errors)/len(e2e_errors)*100:.1f}%\")\n            print(f\"TTFT mean error: \"\n                  f\"{sum(ttft_errors)/len(ttft_errors)*100:.1f}%\")\n            print(f\"ITL  mean error: \"\n                  f\"{sum(itl_errors)/len(itl_errors)*100:.1f}%\")\n\n            passing = sum(1 for e in e2e_errors if e < 0.10)\n            print(f\"E2E < 10%: {passing}/{len(ok_results)} experiments\")\n\n\ndef main():\n    parser = argparse.ArgumentParser(\n        description=\"BLIS validation harness for StepML research\"\n    )\n    parser.add_argument(\n        \"--binary\",\n        default=DEFAULT_BINARY,\n        help=f\"Path to simulation_worker binary (default: {DEFAULT_BINARY})\",\n    )\n    parser.add_argument(\n        \"--data-root\",\n        default=DEFAULT_DATA_ROOT,\n        help=f\"Path to eval/ground_truth/ (default: {DEFAULT_DATA_ROOT})\",\n    )\n    parser.add_argument(\n        \"--output\",\n        default=os.path.join(_SCRIPT_DIR, \"blis_validation_results.csv\"),\n        help=\"Output CSV path\",\n    )\n    parser.add_argument(\n        \"--alpha-coeffs\",\n        default=\"0,0,0\",\n        help=\"Comma-separated alpha coefficients (default: 0,0,0)\",\n    )\n    parser.add_argument(\n        \"--beta-coeffs\",\n        default=\"0,0,0\",\n        help=\"Comma-separated beta coefficients (default: 0,0,0)\",\n    )\n    parser.add_argument(\n        \"--stepml-model\",\n        default=None,\n        help=\"Path to StepML model artifact JSON (optional)\",\n    )\n    parser.add_argument(\n        \"--roofline\",\n        action=\"store_true\",\n        help=\"Use analytical roofline latency model instead of alpha/beta coefficients\",\n    )\n    parser.add_argument(\n        \"--hardware\",\n        default=None,\n        help=\"GPU type for roofline mode (e.g. H100). Required when --roofline is set.\",\n    )\n    args = parser.parse_args()\n\n    if args.roofline and not args.hardware:\n        parser.error(\"--roofline requires --hardware (GPU type, e.g. H100)\")\n\n    alpha_coeffs = [float(x) for x in args.alpha_coeffs.split(\",\")]\n    beta_coeffs = [float(x) for x in args.beta_coeffs.split(\",\")]\n\n    if not args.roofline:\n        if len(alpha_coeffs) < 3:\n            parser.error(\"--alpha-coeffs requires at least 3 values\")\n        if len(beta_coeffs) < 3:\n            parser.error(\"--beta-coeffs requires at least 3 values\")\n\n    # Build binary if needed\n    if not os.path.isfile(args.binary):\n        print(\"Building simulation_worker...\", file=sys.stderr)\n        build_result = subprocess.run(\n            [\"go\", \"build\", \"-o\", args.binary, \"main.go\"],\n            cwd=_REPO_ROOT,\n            capture_output=True,\n            text=True,\n        )\n        if build_result.returncode != 0:\n            print(f\"Build failed: {build_result.stderr}\", file=sys.stderr)\n            sys.exit(1)\n\n    validate_all_experiments(\n        binary=args.binary,\n        data_root=args.data_root,\n        output_path=args.output,\n        alpha_coeffs=alpha_coeffs,\n        beta_coeffs=beta_coeffs,\n        stepml_model_path=args.stepml_model,\n        roofline=args.roofline,\n        hardware=args.hardware,\n    )\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":658,"startLine":1,"totalLines":658}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_016Q8oMUH99CTiG65saEDtnj","type":"tool_result","content":"     1→\"\"\"Baseline models for step-time prediction.\n     2→\n     3→Provides two baselines:\n     4→- BlackboxBaseline: re-trained 3-coefficient linear regression matching BLIS blackbox model\n     5→- NaiveMeanBaseline: always predicts the training set mean step duration\n     6→\n     7→Plus calibration and gating utilities for the StepML research workflow.\n     8→\"\"\"\n     9→\n    10→from __future__ import annotations\n    11→\n    12→import numpy as np\n    13→import pandas as pd\n    14→from scipy.optimize import nnls\n    15→\n    16→from evaluation import (\n    17→    compute_mape,\n    18→    compute_mspe,\n    19→    compute_p99_error,\n    20→    compute_pearson_r,\n    21→)\n    22→\n    23→# Feature columns used by the blackbox model\n    24→_FEATURE_COLS = [\"batch.prefill_tokens\", \"batch.decode_tokens\"]\n    25→# Target column\n    26→_TARGET_COL = \"step.duration_us\"\n    27→\n    28→\n    29→class BlackboxBaseline:\n    30→    \"\"\"Re-trained 3-coefficient non-negative linear model matching BLIS blackbox.\n    31→\n    32→    StepTime = beta0 + beta1 * batch.prefill_tokens + beta2 * batch.decode_tokens\n    33→\n    34→    All three coefficients are constrained to be >= 0 via NNLS (non-negative\n    35→    least squares). The intercept is modelled as a third feature (ones column)\n    36→    so that the non-negativity constraint applies uniformly to all betas.\n    37→\n    38→    Column normalization is applied before NNLS to avoid scale mismatch between\n    39→    the ones column (~1) and token columns (~0-2048), then coefficients are\n    40→    rescaled to original units.\n    41→    \"\"\"\n    42→\n    43→    def __init__(self) -> None:\n    44→        self._coeffs: np.ndarray | None = None  # [beta0, beta1, beta2]\n    45→\n    46→    def fit(self, train_df: pd.DataFrame) -> BlackboxBaseline:\n    47→        \"\"\"Train on step-level data using column-normalized NNLS.\n    48→\n    49→        Constructs A = [ones, prefill_tokens, decode_tokens], normalizes each\n    50→        column by its L2 norm, solves NNLS, then rescales coefficients back.\n    51→        \"\"\"\n    52→        X = train_df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n    53→        y = train_df[_TARGET_COL].to_numpy(dtype=np.float64)\n    54→\n    55→        # Build design matrix: [ones, prefill, decode]\n    56→        ones = np.ones((X.shape[0], 1), dtype=np.float64)\n    57→        A = np.hstack([ones, X])\n    58→\n    59→        # Column-normalize to fix conditioning\n    60→        col_norms = np.linalg.norm(A, axis=0)\n    61→        col_norms[col_norms == 0] = 1.0  # guard against zero columns\n    62→        A_normed = A / col_norms\n    63→\n    64→        # Solve NNLS on normalized problem\n    65→        x_normed, _ = nnls(A_normed, y)\n    66→\n    67→        # Rescale coefficients back to original units\n    68→        self._coeffs = x_normed / col_norms\n    69→        return self\n    70→\n    71→    def predict(self, df: pd.DataFrame) -> np.ndarray:\n    72→        \"\"\"Predict step.duration_us from batch features.\"\"\"\n    73→        if self._coeffs is None:\n    74→            raise RuntimeError(\"BlackboxBaseline.predict() called before fit()\")\n    75→        X = df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n    76→        return self._coeffs[0] + X @ self._coeffs[1:]\n    77→\n    78→    @property\n    79→    def coefficients(self) -> dict:\n    80→        \"\"\"Return {\"beta0\": intercept, \"beta1\": prefill_coeff, \"beta2\": decode_coeff}.\"\"\"\n    81→        if self._coeffs is None:\n    82→            raise RuntimeError(\"BlackboxBaseline.coefficients accessed before fit()\")\n    83→        return {\n    84→            \"beta0\": float(self._coeffs[0]),\n    85→            \"beta1\": float(self._coeffs[1]),\n    86→            \"beta2\": float(self._coeffs[2]),\n    87→        }\n    88→\n    89→\n    90→class NaiveMeanBaseline:\n    91→    \"\"\"Always predicts the training set mean step duration.\"\"\"\n    92→\n    93→    def __init__(self) -> None:\n    94→        self._mean: float | None = None\n    95→\n    96→    def fit(self, train_df: pd.DataFrame) -> NaiveMeanBaseline:\n    97→        \"\"\"Compute and store the training set mean of step.duration_us.\"\"\"\n    98→        self._mean = float(train_df[_TARGET_COL].mean())\n    99→        return self\n   100→\n   101→    def predict(self, df: pd.DataFrame) -> np.ndarray:\n   102→        \"\"\"Return an array of the training mean, one per input row.\"\"\"\n   103→        if self._mean is None:\n   104→            raise RuntimeError(\"NaiveMeanBaseline.predict() called before fit()\")\n   105→        return np.full(len(df), self._mean)\n   106→\n   107→\n   108→def compute_baseline_report(\n   109→    train_df: pd.DataFrame,\n   110→    test_df: pd.DataFrame,\n   111→    baselines: dict | None = None,\n   112→) -> dict:\n   113→    \"\"\"Compute evaluation metrics for all baselines.\n   114→\n   115→    Args:\n   116→        train_df: Training split DataFrame with feature and target columns.\n   117→        test_df: Test split DataFrame with feature and target columns.\n   118→        baselines: Optional dict of {name: baseline_instance}. If None, uses\n   119→            default baselines (blackbox + naive_mean).\n   120→\n   121→    Returns:\n   122→        Dict like:\n   123→        {\n   124→            \"blackbox\": {\"mape\": 15.2, \"mspe\": -3.1, \"pearson_r\": 0.89, \"p99_error\": 45.3},\n   125→            \"naive_mean\": {\"mape\": 42.1, ...},\n   126→        }\n   127→        Uses evaluation.py functions (compute_mape, compute_mspe, compute_pearson_r, compute_p99_error).\n   128→    \"\"\"\n   129→    if baselines is None:\n   130→        baselines = {\n   131→            \"blackbox\": BlackboxBaseline(),\n   132→            \"naive_mean\": NaiveMeanBaseline(),\n   133→        }\n   134→\n   135→    actual = test_df[_TARGET_COL].values\n   136→    report: dict = {}\n   137→\n   138→    for name, model in baselines.items():\n   139→        model.fit(train_df)\n   140→        predicted = model.predict(test_df)\n   141→\n   142→        pearson_r = compute_pearson_r(predicted, actual)\n   143→        # pearsonr returns NaN for constant inputs (e.g., NaiveMeanBaseline).\n   144→        # Replace with 0.0 — constant predictions have zero useful correlation.\n   145→        if np.isnan(pearson_r):\n   146→            pearson_r = 0.0\n   147→\n   148→        report[name] = {\n   149→            \"mape\": float(compute_mape(predicted, actual)),\n   150→            \"mspe\": float(compute_mspe(predicted, actual)),\n   151→            \"pearson_r\": float(pearson_r),\n   152→            \"p99_error\": float(compute_p99_error(predicted, actual)),\n   153→        }\n   154→\n   155→    return report\n   156→\n   157→\n   158→def calibrate_short_circuit_threshold(blackbox_mape: float) -> float:\n   159→    \"\"\"Determine the short-circuit threshold for StepML improvement.\n   160→\n   161→    If blackbox MAPE > 25%, threshold = blackbox_MAPE + 10%.\n   162→    Otherwise threshold = 35% (25% + 10% buffer).\n   163→\n   164→    Args:\n   165→        blackbox_mape: The blackbox baseline's MAPE as a percentage.\n   166→\n   167→    Returns:\n   168→        The threshold as a percentage.\n   169→    \"\"\"\n   170→    if blackbox_mape > 25.0:\n   171→        return blackbox_mape + 10.0\n   172→    return 35.0\n   173→\n   174→\n   175→def check_r4_gate(blackbox_e2e_mean_error: float) -> dict:\n   176→    \"\"\"Check if blackbox is already good enough (R4 risk).\n   177→\n   178→    If abs(blackbox_e2e_mean_error) < 12%, flag for research justification review.\n   179→    This means the blackbox model is already performing well at the E2E level,\n   180→    so additional ML complexity may not be justified.\n   181→\n   182→    Args:\n   183→        blackbox_e2e_mean_error: The blackbox baseline's E2E mean error as a percentage.\n   184→\n   185→    Returns:\n   186→        {\"passed\": bool, \"e2e_error\": float, \"message\": str}\n   187→        passed=True means no flag (research is justified).\n   188→        passed=False means flagged (blackbox already good enough, needs justification).\n   189→    \"\"\"\n   190→    e2e_error = float(blackbox_e2e_mean_error)\n   191→    flagged = abs(e2e_error) < 12.0\n   192→\n   193→    if flagged:\n   194→        message = (\n   195→            f\"R4 gate FLAGGED: blackbox E2E mean error = {e2e_error:.1f}% \"\n   196→            f\"(|error| < 12%). Blackbox may already be sufficient. \"\n   197→            f\"Review research justification before proceeding.\"\n   198→        )\n   199→    else:\n   200→        message = (\n   201→            f\"R4 gate passed: blackbox E2E mean error = {e2e_error:.1f}% \"\n   202→            f\"(|error| >= 12%). Step-level ML improvement is justified.\"\n   203→        )\n   204→\n   205→    return {\n   206→        \"passed\": not flagged,\n   207→        \"e2e_error\": e2e_error,\n   208→        \"message\": message,\n   209→    }\n   210→"}]},"parent_tool_use_id":null,"session_id":"c72182bb-90d4-4f72-be1e-6f3d8138bce2","uuid":"d16aa821-a9b3-400c-aa93-8b33c9f7a273","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round4-idea-1-constrained-cmaes/hypotheses/h-stepml/shared/baselines.py","content":"\"\"\"Baseline models for step-time prediction.\n\nProvides two baselines:\n- BlackboxBaseline: re-trained 3-coefficient linear regression matching BLIS blackbox model\n- NaiveMeanBaseline: always predicts the training set mean step duration\n\nPlus calibration and gating utilities for the StepML research workflow.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport numpy as np\nimport pandas as pd\nfrom scipy.optimize import nnls\n\nfrom evaluation import (\n    compute_mape,\n    compute_mspe,\n    compute_p99_error,\n    compute_pearson_r,\n)\n\n# Feature columns used by the blackbox model\n_FEATURE_COLS = [\"batch.prefill_tokens\", \"batch.decode_tokens\"]\n# Target column\n_TARGET_COL = \"step.duration_us\"\n\n\nclass BlackboxBaseline:\n    \"\"\"Re-trained 3-coefficient non-negative linear model matching BLIS blackbox.\n\n    StepTime = beta0 + beta1 * batch.prefill_tokens + beta2 * batch.decode_tokens\n\n    All three coefficients are constrained to be >= 0 via NNLS (non-negative\n    least squares). The intercept is modelled as a third feature (ones column)\n    so that the non-negativity constraint applies uniformly to all betas.\n\n    Column normalization is applied before NNLS to avoid scale mismatch between\n    the ones column (~1) and token columns (~0-2048), then coefficients are\n    rescaled to original units.\n    \"\"\"\n\n    def __init__(self) -> None:\n        self._coeffs: np.ndarray | None = None  # [beta0, beta1, beta2]\n\n    def fit(self, train_df: pd.DataFrame) -> BlackboxBaseline:\n        \"\"\"Train on step-level data using column-normalized NNLS.\n\n        Constructs A = [ones, prefill_tokens, decode_tokens], normalizes each\n        column by its L2 norm, solves NNLS, then rescales coefficients back.\n        \"\"\"\n        X = train_df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n        y = train_df[_TARGET_COL].to_numpy(dtype=np.float64)\n\n        # Build design matrix: [ones, prefill, decode]\n        ones = np.ones((X.shape[0], 1), dtype=np.float64)\n        A = np.hstack([ones, X])\n\n        # Column-normalize to fix conditioning\n        col_norms = np.linalg.norm(A, axis=0)\n        col_norms[col_norms == 0] = 1.0  # guard against zero columns\n        A_normed = A / col_norms\n\n        # Solve NNLS on normalized problem\n        x_normed, _ = nnls(A_normed, y)\n\n        # Rescale coefficients back to original units\n        self._coeffs = x_normed / col_norms\n        return self\n\n    def predict(self, df: pd.DataFrame) -> np.ndarray:\n        \"\"\"Predict step.duration_us from batch features.\"\"\"\n        if self._coeffs is None:\n            raise RuntimeError(\"BlackboxBaseline.predict() called before fit()\")\n        X = df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n        return self._coeffs[0] + X @ self._coeffs[1:]\n\n    @property\n    def coefficients(self) -> dict:\n        \"\"\"Return {\"beta0\": intercept, \"beta1\": prefill_coeff, \"beta2\": decode_coeff}.\"\"\"\n        if self._coeffs is None:\n            raise RuntimeError(\"BlackboxBaseline.coefficients accessed before fit()\")\n        return {\n            \"beta0\": float(self._coeffs[0]),\n            \"beta1\": float(self._coeffs[1]),\n            \"beta2\": float(self._coeffs[2]),\n        }\n\n\nclass NaiveMeanBaseline:\n    \"\"\"Always predicts the training set mean step duration.\"\"\"\n\n    def __init__(self) -> None:\n        self._mean: float | None = None\n\n    def fit(self, train_df: pd.DataFrame) -> NaiveMeanBaseline:\n        \"\"\"Compute and store the training set mean of step.duration_us.\"\"\"\n        self._mean = float(train_df[_TARGET_COL].mean())\n        return self\n\n    def predict(self, df: pd.DataFrame) -> np.ndarray:\n        \"\"\"Return an array of the training mean, one per input row.\"\"\"\n        if self._mean is None:\n            raise RuntimeError(\"NaiveMeanBaseline.predict() called before fit()\")\n        return np.full(len(df), self._mean)\n\n\ndef compute_baseline_report(\n    train_df: pd.DataFrame,\n    test_df: pd.DataFrame,\n    baselines: dict | None = None,\n) -> dict:\n    \"\"\"Compute evaluation metrics for all baselines.\n\n    Args:\n        train_df: Training split DataFrame with feature and target columns.\n        test_df: Test split DataFrame with feature and target columns.\n        baselines: Optional dict of {name: baseline_instance}. If None, uses\n            default baselines (blackbox + naive_mean).\n\n    Returns:\n        Dict like:\n        {\n            \"blackbox\": {\"mape\": 15.2, \"mspe\": -3.1, \"pearson_r\": 0.89, \"p99_error\": 45.3},\n            \"naive_mean\": {\"mape\": 42.1, ...},\n        }\n        Uses evaluation.py functions (compute_mape, compute_mspe, compute_pearson_r, compute_p99_error).\n    \"\"\"\n    if baselines is None:\n        baselines = {\n            \"blackbox\": BlackboxBaseline(),\n            \"naive_mean\": NaiveMeanBaseline(),\n        }\n\n    actual = test_df[_TARGET_COL].values\n    report: dict = {}\n\n    for name, model in baselines.items():\n        model.fit(train_df)\n        predicted = model.predict(test_df)\n\n        pearson_r = compute_pearson_r(predicted, actual)\n        # pearsonr returns NaN for constant inputs (e.g., NaiveMeanBaseline).\n        # Replace with 0.0 — constant predictions have zero useful correlation.\n        if np.isnan(pearson_r):\n            pearson_r = 0.0\n\n        report[name] = {\n            \"mape\": float(compute_mape(predicted, actual)),\n            \"mspe\": float(compute_mspe(predicted, actual)),\n            \"pearson_r\": float(pearson_r),\n            \"p99_error\": float(compute_p99_error(predicted, actual)),\n        }\n\n    return report\n\n\ndef calibrate_short_circuit_threshold(blackbox_mape: float) -> float:\n    \"\"\"Determine the short-circuit threshold for StepML improvement.\n\n    If blackbox MAPE > 25%, threshold = blackbox_MAPE + 10%.\n    Otherwise threshold = 35% (25% + 10% buffer).\n\n    Args:\n        blackbox_mape: The blackbox baseline's MAPE as a percentage.\n\n    Returns:\n        The threshold as a percentage.\n    \"\"\"\n    if blackbox_mape > 25.0:\n        return blackbox_mape + 10.0\n    return 35.0\n\n\ndef check_r4_gate(blackbox_e2e_mean_error: float) -> dict:\n    \"\"\"Check if blackbox is already good enough (R4 risk).\n\n    If abs(blackbox_e2e_mean_error) < 12%, flag for research justification review.\n    This means the blackbox model is already performing well at the E2E level,\n    so additional ML complexity may not be justified.\n\n    Args:\n        blackbox_e2e_mean_error: The blackbox baseline's E2E mean error as a percentage.\n\n    Returns:\n        {\"passed\": bool, \"e2e_error\": float, \"message\": str}\n        passed=True means no flag (research is justified).\n        passed=False means flagged (blackbox already good enough, needs justification).\n    \"\"\"\n    e2e_error = float(blackbox_e2e_mean_error)\n    flagged = abs(e2e_error) < 12.0\n\n    if flagged:\n        message = (\n            f\"R4 gate FLAGGED: blackbox E2E mean error = {e2e_error:.1f}% \"\n            f\"(|error| < 12%). Blackbox may already be sufficient. \"\n            f\"Review research justification before proceeding.\"\n        )\n    else:\n        message = (\n            f\"R4 gate passed: blackbox E2E mean error = {e2e_error:.1f}% \"\n            f\"(|error| >= 12%). Step-level ML improvement is justified.\"\n        )\n\n    return {\n        \"passed\": not flagged,\n        \"e2e_error\": e2e_error,\n        \"message\": message,\n    }\n","numLines":210,"startLine":1,"totalLines":210}}}
