{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01DtMkqxjgPH6AZBpW4WuxP8","type":"tool_result","content":"     1→\"\"\"StepML ground truth data loader.\n     2→\n     3→Loads OpenTelemetry traces (BATCH_SUMMARY events) and per-request lifecycle\n     4→metrics from the eval/ground_truth/ experiment directories into pandas\n     5→DataFrames suitable for ML training and evaluation.\n     6→\"\"\"\n     7→\n     8→import json\n     9→import os\n    10→import re\n    11→\n    12→import pandas as pd\n    13→\n    14→# ---------------------------------------------------------------------------\n    15→# Default data root: eval/ground_truth/ relative to this file's location\n    16→# ---------------------------------------------------------------------------\n    17→DEFAULT_DATA_ROOT = os.path.join(\n    18→    os.path.dirname(__file__), \"..\", \"..\", \"..\", \"eval\", \"ground_truth\"\n    19→)\n    20→\n    21→# Regex to split directory names: YYYYMMDD-HHMMSS-<model>-tp<N>-<workload>\n    22→# The model name can contain hyphens, so we anchor on the -tp<N>- pattern.\n    23→_DIR_PATTERN = re.compile(\n    24→    r\"^(\\d{8}-\\d{6})-(.+)-tp(\\d+)-(\\w+)$\"\n    25→)\n    26→\n    27→\n    28→def parse_experiment_metadata(dirname: str) -> dict:\n    29→    \"\"\"Parse experiment metadata from a directory name.\n    30→\n    31→    Directory names follow the convention:\n    32→        YYYYMMDD-HHMMSS-<model>-tp<N>-<workload>\n    33→\n    34→    The model name may contain hyphens (e.g., llama-2-7b, mixtral-8x7b-v0-1).\n    35→    We locate the *last* occurrence of ``-tp<digits>-`` to split model from\n    36→    workload, since tp values are always a simple integer and the workload\n    37→    name has no hyphens.\n    38→\n    39→    Returns:\n    40→        dict with keys: model, tp, workload, timestamp\n    41→    \"\"\"\n    42→    m = _DIR_PATTERN.match(dirname)\n    43→    if m:\n    44→        return {\n    45→            \"timestamp\": m.group(1),\n    46→            \"model\": m.group(2),\n    47→            \"tp\": int(m.group(3)),\n    48→            \"workload\": m.group(4),\n    49→        }\n    50→\n    51→    # Fallback: find the *last* -tp<digits>- boundary\n    52→    tp_matches = list(re.finditer(r\"-tp(\\d+)-\", dirname))\n    53→    if not tp_matches:\n    54→        raise ValueError(\n    55→            f\"Cannot parse experiment metadata from directory name: {dirname}\"\n    56→        )\n    57→    last_tp = tp_matches[-1]\n    58→    tp_value = int(last_tp.group(1))\n    59→\n    60→    # Timestamp is the first 15 characters: YYYYMMDD-HHMMSS\n    61→    timestamp = dirname[:15]\n    62→    # Model is between timestamp+'-' and the tp boundary\n    63→    model = dirname[16 : last_tp.start()]\n    64→    # Workload is everything after -tp<N>-\n    65→    workload = dirname[last_tp.end() :]\n    66→\n    67→    return {\n    68→        \"timestamp\": timestamp,\n    69→        \"model\": model,\n    70→        \"tp\": tp_value,\n    71→        \"workload\": workload,\n    72→    }\n    73→\n    74→\n    75→def _extract_attribute_value(attr: dict):\n    76→    \"\"\"Extract a scalar value from an OpenTelemetry attribute.\n    77→\n    78→    Attribute values are nested like:\n    79→        {\"key\": \"step.id\", \"value\": {\"intValue\": \"29\"}}\n    80→    or:\n    81→        {\"key\": \"kv.usage_gpu_ratio\", \"value\": {\"doubleValue\": 0.02}}\n    82→\n    83→    Note: intValue is often a string in OTLP JSON encoding.\n    84→    \"\"\"\n    85→    value_obj = attr.get(\"value\", {})\n    86→    if \"intValue\" in value_obj:\n    87→        return int(value_obj[\"intValue\"])\n    88→    if \"doubleValue\" in value_obj:\n    89→        return float(value_obj[\"doubleValue\"])\n    90→    if \"stringValue\" in value_obj:\n    91→        return value_obj[\"stringValue\"]\n    92→    return None\n    93→\n    94→\n    95→def load_experiment_steps(experiment_dir: str) -> pd.DataFrame:\n    96→    \"\"\"Load step-level BATCH_SUMMARY data from an experiment's traces.json.\n    97→\n    98→    Parses the OpenTelemetry JSONL file line by line, extracts events named\n    99→    ``step.BATCH_SUMMARY``, and flattens their attributes into a DataFrame.\n   100→\n   101→    Args:\n   102→        experiment_dir: Path to a single experiment directory containing\n   103→            traces.json.\n   104→\n   105→    Returns:\n   106→        DataFrame with one row per step. Columns include all BATCH_SUMMARY\n   107→        attribute keys plus ``experiment_id`` (the directory basename).\n   108→    \"\"\"\n   109→    traces_path = os.path.join(experiment_dir, \"traces.json\")\n   110→    experiment_id = os.path.basename(experiment_dir)\n   111→    rows = []\n   112→\n   113→    with open(traces_path, \"r\") as f:\n   114→        for line in f:\n   115→            line = line.strip()\n   116→            if not line:\n   117→                continue\n   118→            data = json.loads(line)\n   119→            for resource_span in data.get(\"resourceSpans\", []):\n   120→                for scope_span in resource_span.get(\"scopeSpans\", []):\n   121→                    for span in scope_span.get(\"spans\", []):\n   122→                        for event in span.get(\"events\", []):\n   123→                            if event.get(\"name\") != \"step.BATCH_SUMMARY\":\n   124→                                continue\n   125→                            row = {}\n   126→                            for attr in event.get(\"attributes\", []):\n   127→                                key = attr[\"key\"]\n   128→                                row[key] = _extract_attribute_value(attr)\n   129→                            rows.append(row)\n   130→\n   131→    df = pd.DataFrame(rows)\n   132→    df[\"experiment_id\"] = experiment_id\n   133→\n   134→    # Ensure integer columns are proper int types (not object/float)\n   135→    int_columns = [\n   136→        \"step.id\",\n   137→        \"step.ts_start_ns\",\n   138→        \"step.ts_end_ns\",\n   139→        \"step.duration_us\",\n   140→        \"batch.prefill_tokens\",\n   141→        \"batch.decode_tokens\",\n   142→        \"batch.scheduled_tokens\",\n   143→        \"batch.num_prefill_reqs\",\n   144→        \"batch.num_decode_reqs\",\n   145→        \"batch.num_finished\",\n   146→        \"batch.num_preempted\",\n   147→        \"queue.running_depth\",\n   148→        \"queue.waiting_depth\",\n   149→        \"kv.blocks_free_gpu\",\n   150→        \"kv.blocks_total_gpu\",\n   151→    ]\n   152→    for col in int_columns:\n   153→        if col in df.columns:\n   154→            df[col] = pd.to_numeric(df[col], errors=\"coerce\").astype(\"Int64\")\n   155→\n   156→    # Ensure float columns\n   157→    float_columns = [\"kv.usage_gpu_ratio\"]\n   158→    for col in float_columns:\n   159→        if col in df.columns:\n   160→            df[col] = pd.to_numeric(df[col], errors=\"coerce\").astype(\"float64\")\n   161→\n   162→    return df\n   163→\n   164→\n   165→def load_all_experiments(data_root: str = None) -> pd.DataFrame:\n   166→    \"\"\"Load step data from all experiments and concatenate into one DataFrame.\n   167→\n   168→    Iterates over subdirectories in ``data_root``, calls\n   169→    :func:`load_experiment_steps` for each, and adds metadata columns\n   170→    (model, tp, workload, timestamp) parsed from each directory name.\n   171→\n   172→    Args:\n   173→        data_root: Path to the ground truth data directory. Defaults to\n   174→            ``eval/ground_truth/`` relative to this file.\n   175→\n   176→    Returns:\n   177→        Concatenated DataFrame with all step data plus metadata columns.\n   178→    \"\"\"\n   179→    if data_root is None:\n   180→        data_root = DEFAULT_DATA_ROOT\n   181→\n   182→    frames = []\n   183→    for dirname in sorted(os.listdir(data_root)):\n   184→        dirpath = os.path.join(data_root, dirname)\n   185→        if not os.path.isdir(dirpath):\n   186→            continue\n   187→        # Skip directories that don't look like experiment dirs\n   188→        traces_path = os.path.join(dirpath, \"traces.json\")\n   189→        if not os.path.isfile(traces_path):\n   190→            continue\n   191→\n   192→        df = load_experiment_steps(dirpath)\n   193→        meta = parse_experiment_metadata(dirname)\n   194→        df[\"model\"] = meta[\"model\"]\n   195→        df[\"tp\"] = meta[\"tp\"]\n   196→        df[\"workload\"] = meta[\"workload\"]\n   197→        df[\"timestamp\"] = meta[\"timestamp\"]\n   198→        frames.append(df)\n   199→\n   200→    if not frames:\n   201→        return pd.DataFrame()\n   202→\n   203→    result = pd.concat(frames, ignore_index=True)\n   204→\n   205→    # Ensure tp is integer dtype in the concatenated result\n   206→    result[\"tp\"] = result[\"tp\"].astype(\"Int64\")\n   207→\n   208→    return result\n   209→\n   210→\n   211→def load_lifecycle_data(experiment_dir: str) -> pd.DataFrame:\n   212→    \"\"\"Load per-request lifecycle metrics from an experiment.\n   213→\n   214→    Reads ``results/per_request_lifecycle_metrics.json`` which contains a\n   215→    JSON array of request objects.\n   216→\n   217→    Args:\n   218→        experiment_dir: Path to a single experiment directory.\n   219→\n   220→    Returns:\n   221→        DataFrame indexed by ``request_id`` (0-based) with columns:\n   222→        start_time, end_time, input_tokens, output_tokens,\n   223→        output_token_times (as list).\n   224→    \"\"\"\n   225→    metrics_path = os.path.join(\n   226→        experiment_dir, \"results\", \"per_request_lifecycle_metrics.json\"\n   227→    )\n   228→\n   229→    with open(metrics_path, \"r\") as f:\n   230→        data = json.load(f)\n   231→\n   232→    rows = []\n   233→    for i, entry in enumerate(data):\n   234→        info = entry.get(\"info\", {})\n   235→        rows.append(\n   236→            {\n   237→                \"request_id\": i,\n   238→                \"start_time\": entry.get(\"start_time\"),\n   239→                \"end_time\": entry.get(\"end_time\"),\n   240→                \"input_tokens\": info.get(\"input_tokens\"),\n   241→                \"output_tokens\": info.get(\"output_tokens\"),\n   242→                \"output_token_times\": info.get(\"output_token_times\", []),\n   243→            }\n   244→        )\n   245→\n   246→    df = pd.DataFrame(rows)\n   247→    df = df.set_index(\"request_id\")\n   248→    return df\n   249→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"86483fe6-3d56-425e-9019-868511499ea9"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01WdcRFQHHQYiz3rHBqpZGCG","type":"tool_result","content":"     1→// Package latency provides latency model implementations for the BLIS simulator.\n     2→// The LatencyModel interface is defined in sim/ (parent package).\n     3→// This package provides BlackboxLatencyModel (alpha/beta regression) and\n     4→// RooflineLatencyModel (analytical FLOPs/bandwidth).\n     5→package latency\n     6→\n     7→import (\n     8→\t\"fmt\"\n     9→\t\"math\"\n    10→\n    11→\t\"github.com/inference-sim/inference-sim/sim\"\n    12→\t\"github.com/inference-sim/inference-sim/sim/internal/util\"\n    13→)\n    14→\n    15→// BlackboxLatencyModel estimates latency using trained alpha/beta regression coefficients.\n    16→// Beta coefficients estimate step time: beta0 + beta1*cacheMissTokens + beta2*decodeTokens.\n    17→// Alpha coefficients estimate overheads: alpha0 + alpha1*inputLen (queueing), alpha2 (output processing).\n    18→type BlackboxLatencyModel struct {\n    19→\tbetaCoeffs  []float64\n    20→\talphaCoeffs []float64\n    21→}\n    22→\n    23→func (m *BlackboxLatencyModel) StepTime(batch []*sim.Request) int64 {\n    24→\tvar totalCacheMissTokens, totalDecodeTokens int64\n    25→\tfor _, req := range batch {\n    26→\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n    27→\t\t\t// Prefill phase: NumNewTokens are cache-miss tokens\n    28→\t\t\ttotalCacheMissTokens += int64(req.NumNewTokens)\n    29→\t\t} else if len(req.OutputTokens) > 0 {\n    30→\t\t\t// Decode phase: NumNewTokens is 1 (set by FormBatch)\n    31→\t\t\ttotalDecodeTokens += int64(req.NumNewTokens)\n    32→\t\t}\n    33→\t}\n    34→\tvar totalStepTime float64\n    35→\ttotalStepTime += m.betaCoeffs[0]\n    36→\ttotalStepTime += m.betaCoeffs[1] * float64(totalCacheMissTokens)\n    37→\ttotalStepTime += m.betaCoeffs[2] * float64(totalDecodeTokens)\n    38→\treturn int64(totalStepTime)\n    39→}\n    40→\n    41→func (m *BlackboxLatencyModel) QueueingTime(req *sim.Request) int64 {\n    42→\tvar totalProcessingTime float64\n    43→\ttotalProcessingTime += m.alphaCoeffs[0]\n    44→\ttotalProcessingTime += m.alphaCoeffs[1] * float64(len(req.InputTokens))\n    45→\treturn int64(totalProcessingTime)\n    46→}\n    47→\n    48→func (m *BlackboxLatencyModel) OutputTokenProcessingTime() int64 {\n    49→\treturn int64(m.alphaCoeffs[2])\n    50→}\n    51→\n    52→func (m *BlackboxLatencyModel) SchedulingProcessingTime() int64 {\n    53→\treturn 0\n    54→}\n    55→\n    56→func (m *BlackboxLatencyModel) PreemptionProcessingTime() int64 {\n    57→\treturn 0\n    58→}\n    59→\n    60→// RooflineLatencyModel estimates latency using analytical FLOPs/bandwidth roofline model.\n    61→// Step time is computed via rooflineStepTime(); overhead estimates use alpha coefficients.\n    62→// In v2 mode (mfuDB != nil), MFU values are looked up from benchmark data instead of\n    63→// using static constants.\n    64→type RooflineLatencyModel struct {\n    65→\tmodelConfig sim.ModelConfig\n    66→\thwConfig    sim.HardwareCalib\n    67→\tmfuDB       *sim.MFUDatabase\n    68→\tgpu         string\n    69→\ttp          int\n    70→\talphaCoeffs []float64\n    71→}\n    72→\n    73→func (m *RooflineLatencyModel) StepTime(batch []*sim.Request) int64 {\n    74→\tstepConfig := StepConfig{\n    75→\t\tPrefillRequests: make([]PrefillRequestConfig, 0, len(batch)),\n    76→\t\tDecodeRequests:  make([]DecodeRequestConfig, 0, len(batch)),\n    77→\t}\n    78→\tfor _, req := range batch {\n    79→\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n    80→\t\t\tstepConfig.PrefillRequests = append(stepConfig.PrefillRequests, PrefillRequestConfig{\n    81→\t\t\t\tProgressIndex:       req.ProgressIndex,\n    82→\t\t\t\tNumNewPrefillTokens: req.NumNewTokens,\n    83→\t\t\t})\n    84→\t\t} else if len(req.OutputTokens) > 0 {\n    85→\t\t\tstepConfig.DecodeRequests = append(stepConfig.DecodeRequests, DecodeRequestConfig{\n    86→\t\t\t\tProgressIndex:      req.ProgressIndex,\n    87→\t\t\t\tNumNewDecodeTokens: req.NumNewTokens,\n    88→\t\t\t})\n    89→\t\t}\n    90→\t}\n    91→\treturn rooflineStepTime(m.gpu, m.modelConfig, m.hwConfig, stepConfig, m.tp, m.mfuDB)\n    92→}\n    93→\n    94→func (m *RooflineLatencyModel) QueueingTime(req *sim.Request) int64 {\n    95→\tvar totalProcessingTime float64\n    96→\ttotalProcessingTime += m.alphaCoeffs[0]\n    97→\ttotalProcessingTime += m.alphaCoeffs[1] * float64(len(req.InputTokens))\n    98→\treturn int64(totalProcessingTime)\n    99→}\n   100→\n   101→func (m *RooflineLatencyModel) OutputTokenProcessingTime() int64 {\n   102→\treturn int64(m.alphaCoeffs[2])\n   103→}\n   104→\n   105→func (m *RooflineLatencyModel) SchedulingProcessingTime() int64 {\n   106→\treturn 0\n   107→}\n   108→\n   109→func (m *RooflineLatencyModel) PreemptionProcessingTime() int64 {\n   110→\treturn 0\n   111→}\n   112→\n   113→// validateCoeffs checks for NaN or Inf in a coefficient slice.\n   114→func validateCoeffs(name string, coeffs []float64) error {\n   115→\tfor i, c := range coeffs {\n   116→\t\tif math.IsNaN(c) {\n   117→\t\t\treturn fmt.Errorf(\"latency model: %s[%d] is NaN\", name, i)\n   118→\t\t}\n   119→\t\tif math.IsInf(c, 0) {\n   120→\t\t\treturn fmt.Errorf(\"latency model: %s[%d] is Inf\", name, i)\n   121→\t\t}\n   122→\t}\n   123→\treturn nil\n   124→}\n   125→\n   126→// NewLatencyModel creates the appropriate LatencyModel based on config.\n   127→// Returns RooflineLatencyModel if hw.Roofline is true, BlackboxLatencyModel otherwise.\n   128→// Returns error if coefficient slices are too short, contain NaN/Inf, or roofline config validation fails.\n   129→func NewLatencyModel(coeffs sim.LatencyCoeffs, hw sim.ModelHardwareConfig) (sim.LatencyModel, error) {\n   130→\t// Both implementations index alphaCoeffs[0..2]; validate upfront.\n   131→\tif len(coeffs.AlphaCoeffs) < 3 {\n   132→\t\treturn nil, fmt.Errorf(\"latency model: AlphaCoeffs requires at least 3 elements, got %d\", len(coeffs.AlphaCoeffs))\n   133→\t}\n   134→\tif err := validateCoeffs(\"AlphaCoeffs\", coeffs.AlphaCoeffs); err != nil {\n   135→\t\treturn nil, err\n   136→\t}\n   137→\tif hw.Roofline {\n   138→\t\tif hw.TP <= 0 {\n   139→\t\t\treturn nil, fmt.Errorf(\"latency model: roofline requires TP > 0, got %d\", hw.TP)\n   140→\t\t}\n   141→\t\tif err := ValidateRooflineConfig(hw.ModelConfig, hw.HWConfig); err != nil {\n   142→\t\t\treturn nil, fmt.Errorf(\"latency model: %w\", err)\n   143→\t\t}\n   144→\t\tif hw.MFUDatabase == nil {\n   145→\t\t\treturn nil, fmt.Errorf(\"latency model: roofline requires MFUDatabase (bench_data); provide --bench-data-path or ensure bench_data/ is bundled\")\n   146→\t\t}\n   147→\t\treturn &RooflineLatencyModel{\n   148→\t\t\tmodelConfig: hw.ModelConfig,\n   149→\t\t\thwConfig:    hw.HWConfig,\n   150→\t\t\tmfuDB:       hw.MFUDatabase,\n   151→\t\t\tgpu:         hw.GPU,\n   152→\t\t\ttp:          hw.TP,\n   153→\t\t\talphaCoeffs: coeffs.AlphaCoeffs,\n   154→\t\t}, nil\n   155→\t}\n   156→\t// StepML dispatch: if StepMLModelPath is set, load and use StepML model.\n   157→\tif hw.StepMLModelPath != \"\" {\n   158→\t\tart, err := LoadStepMLArtifact(hw.StepMLModelPath)\n   159→\t\tif err != nil {\n   160→\t\t\treturn nil, fmt.Errorf(\"latency model: %w\", err)\n   161→\t\t}\n   162→\t\treturn NewStepMLLatencyModel(art), nil\n   163→\t}\n   164→\n   165→\t// BlackboxLatencyModel indexes betaCoeffs[0..2]; validate upfront.\n   166→\tif len(coeffs.BetaCoeffs) < 3 {\n   167→\t\treturn nil, fmt.Errorf(\"latency model: BetaCoeffs requires at least 3 elements, got %d\", len(coeffs.BetaCoeffs))\n   168→\t}\n   169→\tif err := validateCoeffs(\"BetaCoeffs\", coeffs.BetaCoeffs); err != nil {\n   170→\t\treturn nil, err\n   171→\t}\n   172→\treturn &BlackboxLatencyModel{\n   173→\t\tbetaCoeffs:  coeffs.BetaCoeffs,\n   174→\t\talphaCoeffs: coeffs.AlphaCoeffs,\n   175→\t}, nil\n   176→}\n   177→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"76f25116-cdfb-45a9-b705-aa358264f2ef"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_019xMktD4LyKh8QZ6QB6rWsJ","type":"tool_result","content":"     1→\"\"\"Validation functions for StepML WP0 infrastructure.\n     2→\n     3→Part A: Temporal split effectiveness — confirms that temporal splitting\n     4→prevents autocorrelation leakage by comparing random vs temporal split MAPE.\n     5→\n     6→Part B: ProgressIndex as KV cache length proxy (R1 gate) — validates that\n     7→total tokens (input + output) correlate with end-to-end request time.\n     8→\"\"\"\n     9→\n    10→from __future__ import annotations\n    11→\n    12→import numpy as np\n    13→import pandas as pd\n    14→from sklearn.linear_model import Ridge\n    15→\n    16→from evaluation import compute_mape, compute_pearson_r\n    17→from splits import temporal_split\n    18→\n    19→\n    20→def temporal_vs_random_split_comparison(\n    21→    all_df: pd.DataFrame,\n    22→    seed: int = 42,\n    23→) -> dict:\n    24→    \"\"\"Compare random vs temporal split to validate temporal split prevents leakage.\n    25→\n    26→    Trains a Ridge regression on batch features (batch.prefill_tokens,\n    27→    batch.decode_tokens) to predict step.duration_us.  Evaluates on\n    28→    test splits from both a random 60/20/20 split and the canonical\n    29→    temporal split.\n    30→\n    31→    If random split MAPE is much lower (gap > 5%), it confirms that temporal\n    32→    splitting correctly prevents autocorrelation leakage: adjacent steps are\n    33→    correlated, so random splitting \"cheats\" by mixing correlated steps\n    34→    across train and test.\n    35→\n    36→    Args:\n    37→        all_df: DataFrame with columns experiment_id, step.id,\n    38→            batch.prefill_tokens, batch.decode_tokens, step.duration_us.\n    39→        seed: Random seed for the random split and Ridge model.\n    40→\n    41→    Returns:\n    42→        Dict with keys:\n    43→        - temporal_mape: MAPE (%) on the temporal test split\n    44→        - random_mape: MAPE (%) on the random test split\n    45→        - gap: temporal_mape - random_mape (positive means temporal is harder)\n    46→        - conclusion: Human-readable interpretation of the result\n    47→    \"\"\"\n    48→    feature_cols = [\"batch.prefill_tokens\", \"batch.decode_tokens\"]\n    49→    target_col = \"step.duration_us\"\n    50→\n    51→    X = all_df[feature_cols].values.astype(np.float64)\n    52→    y = all_df[target_col].values.astype(np.float64)\n    53→\n    54→    # --- Temporal split ---\n    55→    temporal_splits = temporal_split(all_df, seed=seed)\n    56→    train_idx_t = temporal_splits[\"train\"]\n    57→    test_idx_t = temporal_splits[\"test\"]\n    58→\n    59→    model_t = Ridge(alpha=1.0)\n    60→    model_t.fit(X[train_idx_t], y[train_idx_t])\n    61→    pred_t = model_t.predict(X[test_idx_t])\n    62→    temporal_mape = compute_mape(pred_t, y[test_idx_t])\n    63→\n    64→    # --- Random split (60/20/20 shuffled) ---\n    65→    rng = np.random.default_rng(seed)\n    66→    n = len(all_df)\n    67→    perm = rng.permutation(n)\n    68→    n_train = int(round(n * 0.6))\n    69→    n_valid = int(round(n * 0.2))\n    70→    train_idx_r = perm[:n_train]\n    71→    # valid_idx_r = perm[n_train : n_train + n_valid]  # not used\n    72→    test_idx_r = perm[n_train + n_valid :]\n    73→\n    74→    model_r = Ridge(alpha=1.0)\n    75→    model_r.fit(X[train_idx_r], y[train_idx_r])\n    76→    pred_r = model_r.predict(X[test_idx_r])\n    77→    random_mape = compute_mape(pred_r, y[test_idx_r])\n    78→\n    79→    gap = temporal_mape - random_mape\n    80→\n    81→    if gap > 5.0:\n    82→        conclusion = (\n    83→            f\"Temporal split MAPE ({temporal_mape:.1f}%) is {gap:.1f}pp higher \"\n    84→            f\"than random split MAPE ({random_mape:.1f}%). \"\n    85→            f\"This confirms temporal splitting prevents autocorrelation leakage. \"\n    86→            f\"Random splitting allows correlated adjacent steps to leak between \"\n    87→            f\"train and test sets, artificially lowering error.\"\n    88→        )\n    89→    elif gap > 0:\n    90→        conclusion = (\n    91→            f\"Temporal split MAPE ({temporal_mape:.1f}%) is {gap:.1f}pp higher \"\n    92→            f\"than random split MAPE ({random_mape:.1f}%). \"\n    93→            f\"Small gap suggests mild autocorrelation in the data.\"\n    94→        )\n    95→    else:\n    96→        conclusion = (\n    97→            f\"Temporal split MAPE ({temporal_mape:.1f}%) is not higher \"\n    98→            f\"than random split MAPE ({random_mape:.1f}%). \"\n    99→            f\"No evidence of autocorrelation leakage in this dataset.\"\n   100→        )\n   101→\n   102→    return {\n   103→        \"temporal_mape\": float(temporal_mape),\n   104→        \"random_mape\": float(random_mape),\n   105→        \"gap\": float(gap),\n   106→        \"conclusion\": conclusion,\n   107→    }\n   108→\n   109→\n   110→def validate_progress_index(\n   111→    lifecycle_df: pd.DataFrame,\n   112→) -> dict:\n   113→    \"\"\"Validate ProgressIndex as KV cache length proxy (R1 gate).\n   114→\n   115→    ProgressIndex is defined as input_tokens + output_tokens (the total\n   116→    tokens processed by a request).  This function validates that total\n   117→    tokens correlate with end-to-end request time, confirming the proxy\n   118→    is informative for KV cache modeling.\n   119→\n   120→    The R1 gate passes if Pearson correlation > 0.9.  If correlation < 0.9,\n   121→    an informational flag is raised but the gate does not abort.\n   122→\n   123→    Args:\n   124→        lifecycle_df: DataFrame indexed by request_id with columns:\n   125→            start_time, end_time, input_tokens, output_tokens,\n   126→            output_token_times.\n   127→\n   128→    Returns:\n   129→        Dict with keys:\n   130→        - correlation: Pearson r between total_tokens and E2E time\n   131→        - n_requests: Number of requests analyzed\n   132→        - passed: True if correlation >= 0.9\n   133→        - conclusion: Human-readable interpretation\n   134→    \"\"\"\n   135→    n_requests = len(lifecycle_df)\n   136→\n   137→    total_tokens = (\n   138→        lifecycle_df[\"input_tokens\"].values.astype(np.float64)\n   139→        + lifecycle_df[\"output_tokens\"].values.astype(np.float64)\n   140→    )\n   141→    e2e_times = (\n   142→        lifecycle_df[\"end_time\"].values.astype(np.float64)\n   143→        - lifecycle_df[\"start_time\"].values.astype(np.float64)\n   144→    )\n   145→\n   146→    correlation = compute_pearson_r(total_tokens, e2e_times)\n   147→    passed = correlation >= 0.9\n   148→\n   149→    if passed:\n   150→        conclusion = (\n   151→            f\"ProgressIndex proxy validated: Pearson r = {correlation:.3f} \"\n   152→            f\"(n={n_requests}). Total tokens (input + output) correlate \"\n   153→            f\"strongly with E2E time, confirming ProgressIndex is an \"\n   154→            f\"informative KV cache length proxy.\"\n   155→        )\n   156→    else:\n   157→        conclusion = (\n   158→            f\"R1 flag: ProgressIndex correlation is {correlation:.3f} \"\n   159→            f\"(n={n_requests}), below the 0.9 threshold. \"\n   160→            f\"Total tokens are a weak proxy for E2E time in this dataset. \"\n   161→            f\"This is an informational flag — does not abort.\"\n   162→        )\n   163→\n   164→    return {\n   165→        \"correlation\": float(correlation),\n   166→        \"n_requests\": n_requests,\n   167→        \"passed\": passed,\n   168→        \"conclusion\": conclusion,\n   169→    }\n   170→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"32252b09-276c-4a85-b1dc-989394cec17a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01RZv31muZ5AGBMfZiqiSPmH","type":"tool_result","content":"     1→\"\"\"Evaluation harness for step-time prediction models.\n     2→\n     3→Pure computation on arrays — no dependency on real data or external services.\n     4→All percentage values are returned as floats where 10.0 means 10%.\n     5→\"\"\"\n     6→\n     7→from __future__ import annotations\n     8→\n     9→import numpy as np\n    10→from scipy.stats import pearsonr\n    11→\n    12→\n    13→def compute_mape(predicted: np.ndarray, actual: np.ndarray) -> float:\n    14→    \"\"\"Mean Absolute Percentage Error.\n    15→\n    16→    Excludes rows where actual == 0 to avoid division by zero.\n    17→    Returns percentage as a float (e.g., 10.0 for 10%).\n    18→    \"\"\"\n    19→    mask = actual != 0\n    20→    actual_filtered = actual[mask]\n    21→    predicted_filtered = predicted[mask]\n    22→    if len(actual_filtered) == 0:\n    23→        return 0.0\n    24→    abs_pct_errors = np.abs((predicted_filtered - actual_filtered) / actual_filtered)\n    25→    return float(np.mean(abs_pct_errors) * 100.0)\n    26→\n    27→\n    28→def compute_mspe(predicted: np.ndarray, actual: np.ndarray) -> float:\n    29→    \"\"\"Mean Signed Percentage Error.\n    30→\n    31→    Positive values indicate overestimation; negative values indicate\n    32→    underestimation. Excludes rows where actual == 0.\n    33→    Returns percentage as a float (e.g., 15.0 for +15%).\n    34→    \"\"\"\n    35→    mask = actual != 0\n    36→    actual_filtered = actual[mask]\n    37→    predicted_filtered = predicted[mask]\n    38→    if len(actual_filtered) == 0:\n    39→        return 0.0\n    40→    signed_pct_errors = (predicted_filtered - actual_filtered) / actual_filtered\n    41→    return float(np.mean(signed_pct_errors) * 100.0)\n    42→\n    43→\n    44→def compute_pearson_r(predicted: np.ndarray, actual: np.ndarray) -> float:\n    45→    \"\"\"Pearson correlation coefficient between predicted and actual.\"\"\"\n    46→    r, _ = pearsonr(predicted, actual)\n    47→    return float(r)\n    48→\n    49→\n    50→def compute_p99_error(predicted: np.ndarray, actual: np.ndarray) -> float:\n    51→    \"\"\"99th percentile of absolute percentage errors.\n    52→\n    53→    Excludes rows where actual == 0.\n    54→    Returns percentage as a float.\n    55→    \"\"\"\n    56→    mask = actual != 0\n    57→    actual_filtered = actual[mask]\n    58→    predicted_filtered = predicted[mask]\n    59→    if len(actual_filtered) == 0:\n    60→        return 0.0\n    61→    abs_pct_errors = np.abs((predicted_filtered - actual_filtered) / actual_filtered) * 100.0\n    62→    return float(np.percentile(abs_pct_errors, 99))\n    63→\n    64→\n    65→def bootstrap_ci(\n    66→    metric_fn,\n    67→    predicted: np.ndarray,\n    68→    actual: np.ndarray,\n    69→    n_resamples: int = 1000,\n    70→    confidence: float = 0.95,\n    71→    seed: int = 42,\n    72→) -> tuple[float, float]:\n    73→    \"\"\"Bootstrap confidence interval for any metric function.\n    74→\n    75→    Args:\n    76→        metric_fn: A function with signature (predicted, actual) -> float.\n    77→        predicted: Predicted values array.\n    78→        actual: Actual values array.\n    79→        n_resamples: Number of bootstrap resamples.\n    80→        confidence: Confidence level (e.g. 0.95 for 95% CI).\n    81→        seed: Random seed for reproducibility.\n    82→\n    83→    Returns:\n    84→        (lower_bound, upper_bound) tuple.\n    85→    \"\"\"\n    86→    rng = np.random.default_rng(seed)\n    87→    n = len(predicted)\n    88→    bootstrap_estimates = np.empty(n_resamples)\n    89→\n    90→    for i in range(n_resamples):\n    91→        indices = rng.integers(0, n, size=n)\n    92→        bootstrap_estimates[i] = metric_fn(predicted[indices], actual[indices])\n    93→\n    94→    alpha = 1.0 - confidence\n    95→    lower = float(np.percentile(bootstrap_estimates, 100 * alpha / 2))\n    96→    upper = float(np.percentile(bootstrap_estimates, 100 * (1 - alpha / 2)))\n    97→    return lower, upper\n    98→\n    99→\n   100→def compute_e2e_mean_error(\n   101→    predicted_step_times: dict,\n   102→    actual_e2e_times: dict,\n   103→) -> float:\n   104→    \"\"\"Workload-level end-to-end mean error.\n   105→\n   106→    For each request, sums predicted step times to get predicted E2E.\n   107→    Computes mean predicted E2E across requests and compares to the mean\n   108→    of actual E2E times.\n   109→\n   110→    Args:\n   111→        predicted_step_times: {request_id: [step_time1, step_time2, ...]}\n   112→        actual_e2e_times: {request_id: float}\n   113→\n   114→    Returns:\n   115→        Percentage error as a float (e.g. 10.0 for 10%).\n   116→    \"\"\"\n   117→    request_ids = sorted(set(predicted_step_times.keys()) & set(actual_e2e_times.keys()))\n   118→    if not request_ids:\n   119→        return 0.0\n   120→\n   121→    predicted_e2e = np.array([sum(predicted_step_times[rid]) for rid in request_ids])\n   122→    actual_e2e = np.array([actual_e2e_times[rid] for rid in request_ids])\n   123→\n   124→    mean_predicted = np.mean(predicted_e2e)\n   125→    mean_actual = np.mean(actual_e2e)\n   126→\n   127→    if mean_actual == 0:\n   128→        return 0.0\n   129→\n   130→    return float((mean_predicted - mean_actual) / mean_actual * 100.0)\n   131→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"9719f4e0-ce01-41c3-a4e9-a7476d7dc391"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01A76T1J6JgtLdGKce8EuxAd","type":"tool_result","content":"     1→\"\"\"Data splitting strategies for StepML experiments.\n     2→\n     3→Provides three splitting functions for ML training and evaluation:\n     4→\n     5→- **temporal_split**: Within each experiment, sorts steps by step.id and\n     6→  assigns the first 60% to train, next 20% to validation, last 20% to test.\n     7→  Every experiment is represented in all three splits (stratified).\n     8→\n     9→- **leave_one_model_out**: 4-fold cross-validation where each fold holds out\n    10→  all data from one model. Model names are normalized so that variants\n    11→  (e.g., \"llama-2-70b\" and \"llama-2-70b-hf\") are grouped together.\n    12→\n    13→- **leave_one_workload_out**: 4-fold cross-validation where each fold holds\n    14→  out all data from one workload type.\n    15→\n    16→All functions return integer indices (into the DataFrame's index) rather than\n    17→boolean masks, making them compatible with iloc/loc indexing.\n    18→\"\"\"\n    19→\n    20→import re\n    21→\n    22→import numpy as np\n    23→import pandas as pd\n    24→\n    25→\n    26→# ---------------------------------------------------------------------------\n    27→# Model name normalization\n    28→# ---------------------------------------------------------------------------\n    29→# Some experiments use variant names for the same model, e.g.:\n    30→#   \"llama-2-70b\" and \"llama-2-70b-hf\"\n    31→# We normalize by stripping known suffixes so they group together.\n    32→_MODEL_SUFFIX_PATTERN = re.compile(r\"-hf$\")\n    33→\n    34→\n    35→def _normalize_model_name(name: str) -> str:\n    36→    \"\"\"Normalize model names by stripping variant suffixes.\n    37→\n    38→    Examples:\n    39→        \"llama-2-70b-hf\" -> \"llama-2-70b\"\n    40→        \"llama-2-7b\"     -> \"llama-2-7b\"\n    41→        \"mixtral-8x7b-v0-1\" -> \"mixtral-8x7b-v0-1\"\n    42→    \"\"\"\n    43→    return _MODEL_SUFFIX_PATTERN.sub(\"\", name)\n    44→\n    45→\n    46→# ---------------------------------------------------------------------------\n    47→# Temporal split\n    48→# ---------------------------------------------------------------------------\n    49→\n    50→\n    51→def temporal_split(\n    52→    df: pd.DataFrame,\n    53→    train_frac: float = 0.6,\n    54→    valid_frac: float = 0.2,\n    55→    seed: int = 42,\n    56→) -> dict:\n    57→    \"\"\"Split data temporally within each experiment.\n    58→\n    59→    Within each experiment (grouped by ``experiment_id``), rows are sorted by\n    60→    ``step.id`` and the first ``train_frac`` fraction is assigned to training,\n    61→    the next ``valid_frac`` fraction to validation, and the remainder to test.\n    62→\n    63→    This split is deterministic given the data (step ordering is fixed), so\n    64→    the ``seed`` parameter is included for API consistency but does not affect\n    65→    the result.\n    66→\n    67→    Args:\n    68→        df: DataFrame with ``experiment_id`` and ``step.id`` columns.\n    69→        train_frac: Fraction of steps for training (default 0.6).\n    70→        valid_frac: Fraction of steps for validation (default 0.2).\n    71→        seed: Included for API consistency; does not affect the split.\n    72→\n    73→    Returns:\n    74→        Dict with keys ``\"train\"``, ``\"valid\"``, ``\"test\"``, each mapping to a\n    75→        sorted numpy array of integer row indices from df.index.\n    76→    \"\"\"\n    77→    train_indices = []\n    78→    valid_indices = []\n    79→    test_indices = []\n    80→\n    81→    for _exp_id, group in df.groupby(\"experiment_id\"):\n    82→        # Sort by step.id within this experiment\n    83→        sorted_group = group.sort_values(\"step.id\")\n    84→        indices = sorted_group.index.values\n    85→        n = len(indices)\n    86→\n    87→        # Compute split boundaries\n    88→        n_train = int(round(n * train_frac))\n    89→        n_valid = int(round(n * valid_frac))\n    90→\n    91→        train_indices.append(indices[:n_train])\n    92→        valid_indices.append(indices[n_train : n_train + n_valid])\n    93→        test_indices.append(indices[n_train + n_valid :])\n    94→\n    95→    return {\n    96→        \"train\": np.sort(np.concatenate(train_indices)),\n    97→        \"valid\": np.sort(np.concatenate(valid_indices)),\n    98→        \"test\": np.sort(np.concatenate(test_indices)),\n    99→    }\n   100→\n   101→\n   102→# ---------------------------------------------------------------------------\n   103→# Leave-one-model-out\n   104→# ---------------------------------------------------------------------------\n   105→\n   106→\n   107→def leave_one_model_out(df: pd.DataFrame) -> list:\n   108→    \"\"\"Leave-one-model-out cross-validation folds.\n   109→\n   110→    Produces 4 folds, one per unique model. Model names are normalized so\n   111→    that variants like \"llama-2-70b\" and \"llama-2-70b-hf\" are treated as\n   112→    the same model.\n   113→\n   114→    Within each fold, the test set contains all rows for the held-out model,\n   115→    and the training set contains all remaining rows.\n   116→\n   117→    Args:\n   118→        df: DataFrame with a ``model`` column.\n   119→\n   120→    Returns:\n   121→        List of 4 dicts, each with keys:\n   122→        - ``\"train\"``: numpy array of training row indices\n   123→        - ``\"test\"``: numpy array of test row indices\n   124→        - ``\"holdout_model\"``: the normalized model name held out\n   125→\n   126→    Note:\n   127→        As a side effect, the ``model`` column in ``df`` is normalized\n   128→        in-place (e.g., \"llama-2-70b-hf\" becomes \"llama-2-70b\"). This\n   129→        ensures downstream consumers see consistent model names.\n   130→    \"\"\"\n   131→    normalized = df[\"model\"].map(_normalize_model_name)\n   132→    unique_models = sorted(normalized.unique())\n   133→\n   134→    folds = []\n   135→    for holdout_model in unique_models:\n   136→        is_holdout = normalized == holdout_model\n   137→        test_idx = df.index[is_holdout].values\n   138→        train_idx = df.index[~is_holdout].values\n   139→\n   140→        folds.append(\n   141→            {\n   142→                \"train\": np.sort(train_idx),\n   143→                \"test\": np.sort(test_idx),\n   144→                \"holdout_model\": holdout_model,\n   145→            }\n   146→        )\n   147→\n   148→    # Normalize the model column in the dataframe so downstream consumers\n   149→    # see consistent names. This is intentional: variants of the same model\n   150→    # should be unified.\n   151→    df[\"model\"] = normalized.values\n   152→\n   153→    return folds\n   154→\n   155→\n   156→# ---------------------------------------------------------------------------\n   157→# Leave-one-workload-out\n   158→# ---------------------------------------------------------------------------\n   159→\n   160→\n   161→def leave_one_workload_out(df: pd.DataFrame) -> list:\n   162→    \"\"\"Leave-one-workload-out cross-validation folds.\n   163→\n   164→    Produces 4 folds, one per unique workload. Within each fold, the test set\n   165→    contains all rows for the held-out workload, and the training set contains\n   166→    all remaining rows.\n   167→\n   168→    Args:\n   169→        df: DataFrame with a ``workload`` column.\n   170→\n   171→    Returns:\n   172→        List of 4 dicts, each with keys:\n   173→        - ``\"train\"``: numpy array of training row indices\n   174→        - ``\"test\"``: numpy array of test row indices\n   175→        - ``\"holdout_workload\"``: the workload name held out\n   176→    \"\"\"\n   177→    unique_workloads = sorted(df[\"workload\"].unique())\n   178→\n   179→    folds = []\n   180→    for holdout_workload in unique_workloads:\n   181→        is_holdout = df[\"workload\"] == holdout_workload\n   182→        test_idx = df.index[is_holdout].values\n   183→        train_idx = df.index[~is_holdout].values\n   184→\n   185→        folds.append(\n   186→            {\n   187→                \"train\": np.sort(train_idx),\n   188→                \"test\": np.sort(test_idx),\n   189→                \"holdout_workload\": holdout_workload,\n   190→            }\n   191→        )\n   192→\n   193→    return folds\n   194→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"c52998e2-65d0-4f1b-bb6e-26b837cf870c"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01HHdqBJ7QNHgqtXq6CksUoo","type":"tool_result","content":"     1→package sim\n     2→\n     3→// KVCacheConfig groups KV cache parameters for KV store construction.\n     4→type KVCacheConfig struct {\n     5→\tTotalKVBlocks         int64   // GPU tier capacity in blocks (must be > 0)\n     6→\tBlockSizeTokens       int64   // tokens per block (must be > 0)\n     7→\tKVCPUBlocks           int64   // CPU tier capacity (0 = single-tier, default)\n     8→\tKVOffloadThreshold    float64 // GPU utilization threshold for offload (CLI default: 0.9, zero-value: 0)\n     9→\tKVTransferBandwidth   float64 // blocks/tick transfer rate (CLI default: 100.0, zero-value: 0)\n    10→\tKVTransferBaseLatency int64   // fixed cost per transfer (ticks, default 0)\n    11→}\n    12→\n    13→// NewKVCacheConfig creates a KVCacheConfig with all fields explicitly set.\n    14→// This is the canonical constructor — all construction sites must use it (R4).\n    15→// Parameter order matches struct field order.\n    16→func NewKVCacheConfig(totalKVBlocks, blockSizeTokens, kvCPUBlocks int64,\n    17→\tkvOffloadThreshold, kvTransferBandwidth float64,\n    18→\tkvTransferBaseLatency int64) KVCacheConfig {\n    19→\treturn KVCacheConfig{\n    20→\t\tTotalKVBlocks:         totalKVBlocks,\n    21→\t\tBlockSizeTokens:       blockSizeTokens,\n    22→\t\tKVCPUBlocks:           kvCPUBlocks,\n    23→\t\tKVOffloadThreshold:    kvOffloadThreshold,\n    24→\t\tKVTransferBandwidth:   kvTransferBandwidth,\n    25→\t\tKVTransferBaseLatency: kvTransferBaseLatency,\n    26→\t}\n    27→}\n    28→\n    29→// BatchConfig groups batch formation parameters.\n    30→type BatchConfig struct {\n    31→\tMaxRunningReqs            int64 // max requests in RunningBatch\n    32→\tMaxScheduledTokens        int64 // max total new tokens across all requests in RunningBatch\n    33→\tLongPrefillTokenThreshold int64 // threshold for long prefill chunking\n    34→}\n    35→\n    36→// NewBatchConfig creates a BatchConfig with all fields explicitly set.\n    37→// This is the canonical constructor — all construction sites must use it (R4).\n    38→func NewBatchConfig(maxRunningReqs, maxScheduledTokens, longPrefillTokenThreshold int64) BatchConfig {\n    39→\treturn BatchConfig{\n    40→\t\tMaxRunningReqs:            maxRunningReqs,\n    41→\t\tMaxScheduledTokens:        maxScheduledTokens,\n    42→\t\tLongPrefillTokenThreshold: longPrefillTokenThreshold,\n    43→\t}\n    44→}\n    45→\n    46→// LatencyCoeffs groups regression coefficients for the latency model.\n    47→type LatencyCoeffs struct {\n    48→\tBetaCoeffs  []float64 // regression coefficients for step time (≥3 elements required)\n    49→\tAlphaCoeffs []float64 // regression coefficients for queueing time (≥3 elements required)\n    50→}\n    51→\n    52→// NewLatencyCoeffs creates a LatencyCoeffs with all fields explicitly set.\n    53→// This is the canonical constructor — all construction sites must use it (R4).\n    54→func NewLatencyCoeffs(betaCoeffs, alphaCoeffs []float64) LatencyCoeffs {\n    55→\treturn LatencyCoeffs{\n    56→\t\tBetaCoeffs:  betaCoeffs,\n    57→\t\tAlphaCoeffs: alphaCoeffs,\n    58→\t}\n    59→}\n    60→\n    61→// ModelHardwareConfig groups model identity and hardware specification.\n    62→type ModelHardwareConfig struct {\n    63→\tModelConfig      ModelConfig   // HuggingFace model parameters (for roofline mode)\n    64→\tHWConfig         HardwareCalib // GPU specifications (for roofline mode)\n    65→\tMFUDatabase      *MFUDatabase  // MFU benchmark database (for roofline v2 mode, optional)\n    66→\tModel            string        // model name (e.g., \"meta-llama/llama-3.1-8b-instruct\")\n    67→\tGPU              string        // GPU type (e.g., \"H100\")\n    68→\tTP               int           // tensor parallelism degree\n    69→\tRoofline         bool          // true = analytical roofline mode, false = blackbox regression\n    70→\tStepMLModelPath  string        // path to StepML model artifact JSON (optional)\n    71→}\n    72→\n    73→// NewModelHardwareConfig creates a ModelHardwareConfig with all fields explicitly set.\n    74→// This is the canonical constructor — all construction sites must use it (R4).\n    75→// Parameter order matches struct field order.\n    76→func NewModelHardwareConfig(modelConfig ModelConfig, hwConfig HardwareCalib,\n    77→\tmodel, gpu string, tp int, roofline bool) ModelHardwareConfig {\n    78→\treturn ModelHardwareConfig{\n    79→\t\tModelConfig: modelConfig,\n    80→\t\tHWConfig:    hwConfig,\n    81→\t\tMFUDatabase: nil, // MFU database is optional, set separately if needed\n    82→\t\tModel:       model,\n    83→\t\tGPU:         gpu,\n    84→\t\tTP:          tp,\n    85→\t\tRoofline:    roofline,\n    86→\t}\n    87→}\n    88→\n    89→// WithMFUDatabase returns a copy of ModelHardwareConfig with MFU database set.\n    90→// Use this to add roofline v2 support to an existing config.\n    91→func (m ModelHardwareConfig) WithMFUDatabase(mfuDB *MFUDatabase) ModelHardwareConfig {\n    92→\tm.MFUDatabase = mfuDB\n    93→\treturn m\n    94→}\n    95→\n    96→// WithStepMLModel returns a copy of ModelHardwareConfig with StepML model path set.\n    97→func (m ModelHardwareConfig) WithStepMLModel(path string) ModelHardwareConfig {\n    98→\tm.StepMLModelPath = path\n    99→\treturn m\n   100→}\n   101→\n   102→// PolicyConfig groups scheduling and priority policy selection.\n   103→type PolicyConfig struct {\n   104→\tPriorityPolicy string // \"constant\" (default) or \"slo-based\"\n   105→\tScheduler      string // \"fcfs\" (default), \"priority-fcfs\", \"sjf\", \"reverse-priority\"\n   106→}\n   107→\n   108→// NewPolicyConfig creates a PolicyConfig with all fields explicitly set.\n   109→// This is the canonical constructor — all construction sites must use it (R4).\n   110→func NewPolicyConfig(priorityPolicy, scheduler string) PolicyConfig {\n   111→\treturn PolicyConfig{\n   112→\t\tPriorityPolicy: priorityPolicy,\n   113→\t\tScheduler:      scheduler,\n   114→\t}\n   115→}\n   116→\n   117→// WorkloadConfig groups workload generation parameters.\n   118→// Both fields zero-valued means no workload generation (caller injects via InjectArrival).\n   119→// In cluster mode, these fields are typically zero-valued because workload is passed\n   120→// separately to NewClusterSimulator. They are populated only in single-instance mode.\n   121→type WorkloadConfig struct {\n   122→\tGuideLLMConfig         *GuideLLMConfig // distribution-based workload (optional)\n   123→\tTracesWorkloadFilePath string          // CSV trace file path (optional)\n   124→}\n   125→\n   126→// NewWorkloadConfig creates a WorkloadConfig with all fields explicitly set.\n   127→// This is the canonical constructor — all construction sites must use it (R4).\n   128→func NewWorkloadConfig(guideLLMConfig *GuideLLMConfig, tracesWorkloadFilePath string) WorkloadConfig {\n   129→\treturn WorkloadConfig{\n   130→\t\tGuideLLMConfig:         guideLLMConfig,\n   131→\t\tTracesWorkloadFilePath: tracesWorkloadFilePath,\n   132→\t}\n   133→}\n   134→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"f6e0bb6c-968e-4492-a95d-d2ff8a3491bc"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01VqSDJCcG77FgDvXcPVq7Up","type":"tool_result","content":"     1→package latency\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\t\"testing\"\n     7→\n     8→\t\"github.com/inference-sim/inference-sim/sim\"\n     9→)\n    10→\n    11→// validArtifactJSON is a minimal StepML artifact for testing.\n    12→const validArtifactJSON = `{\n    13→\t\"version\": 1,\n    14→\t\"step_time\": {\n    15→\t\t\"model_type\": \"linear\",\n    16→\t\t\"intercept\": 100.0,\n    17→\t\t\"feature_coefficients\": {\n    18→\t\t\t\"prefill_tokens\": 50.0,\n    19→\t\t\t\"decode_tokens\": 5.0\n    20→\t\t}\n    21→\t},\n    22→\t\"queueing_time\": {\n    23→\t\t\"model_type\": \"linear\",\n    24→\t\t\"intercept\": 10.0,\n    25→\t\t\"feature_coefficients\": {\n    26→\t\t\t\"input_len\": 0.5\n    27→\t\t}\n    28→\t},\n    29→\t\"output_token_processing_time_us\": 2.0,\n    30→\t\"scheduling_processing_time_us\": 5.0,\n    31→\t\"preemption_processing_time_us\": 3.0\n    32→}`\n    33→\n    34→func writeArtifact(t *testing.T, content string) string {\n    35→\tt.Helper()\n    36→\tdir := t.TempDir()\n    37→\tpath := filepath.Join(dir, \"model.json\")\n    38→\tif err := os.WriteFile(path, []byte(content), 0o644); err != nil {\n    39→\t\tt.Fatalf(\"write artifact: %v\", err)\n    40→\t}\n    41→\treturn path\n    42→}\n    43→\n    44→func TestLoadStepMLArtifact_Valid(t *testing.T) {\n    45→\tpath := writeArtifact(t, validArtifactJSON)\n    46→\tart, err := LoadStepMLArtifact(path)\n    47→\tif err != nil {\n    48→\t\tt.Fatalf(\"unexpected error: %v\", err)\n    49→\t}\n    50→\tif art.Version != 1 {\n    51→\t\tt.Errorf(\"version = %d, want 1\", art.Version)\n    52→\t}\n    53→\tif art.StepTime.Intercept != 100.0 {\n    54→\t\tt.Errorf(\"step_time intercept = %f, want 100.0\", art.StepTime.Intercept)\n    55→\t}\n    56→\tif art.StepTime.FeatureCoefficients[\"prefill_tokens\"] != 50.0 {\n    57→\t\tt.Errorf(\"prefill_tokens coeff = %f, want 50.0\", art.StepTime.FeatureCoefficients[\"prefill_tokens\"])\n    58→\t}\n    59→}\n    60→\n    61→func TestLoadStepMLArtifact_MissingFile(t *testing.T) {\n    62→\t_, err := LoadStepMLArtifact(\"/nonexistent/path.json\")\n    63→\tif err == nil {\n    64→\t\tt.Fatal(\"expected error for missing file\")\n    65→\t}\n    66→}\n    67→\n    68→func TestLoadStepMLArtifact_MissingStepTime(t *testing.T) {\n    69→\tpath := writeArtifact(t, `{\"version\": 1}`)\n    70→\t_, err := LoadStepMLArtifact(path)\n    71→\tif err == nil {\n    72→\t\tt.Fatal(\"expected error for missing step_time\")\n    73→\t}\n    74→}\n    75→\n    76→func TestLoadStepMLArtifact_InvalidVersion(t *testing.T) {\n    77→\tpath := writeArtifact(t, `{\"version\": 0, \"step_time\": {\"model_type\": \"linear\", \"intercept\": 0}}`)\n    78→\t_, err := LoadStepMLArtifact(path)\n    79→\tif err == nil {\n    80→\t\tt.Fatal(\"expected error for version 0\")\n    81→\t}\n    82→}\n    83→\n    84→func TestLoadStepMLArtifact_NaNCoefficient(t *testing.T) {\n    85→\t// JSON doesn't support NaN natively; test via a model type error instead\n    86→\tpath := writeArtifact(t, `{\"version\": 1, \"step_time\": {\"model_type\": \"neural_net\", \"intercept\": 0}}`)\n    87→\t_, err := LoadStepMLArtifact(path)\n    88→\tif err == nil {\n    89→\t\tt.Fatal(\"expected error for unsupported model_type\")\n    90→\t}\n    91→}\n    92→\n    93→func TestStepMLLatencyModel_StepTime(t *testing.T) {\n    94→\tpath := writeArtifact(t, validArtifactJSON)\n    95→\tart, err := LoadStepMLArtifact(path)\n    96→\tif err != nil {\n    97→\t\tt.Fatalf(\"load artifact: %v\", err)\n    98→\t}\n    99→\tmodel := NewStepMLLatencyModel(art)\n   100→\n   101→\t// Batch: 1 prefill request (100 new tokens), 2 decode requests (1 new token each)\n   102→\tbatch := []*sim.Request{\n   103→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},  // prefill\n   104→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1}, // decode\n   105→\t\t{InputTokens: make([]int, 80), OutputTokens: make([]int, 30), ProgressIndex: 110, NumNewTokens: 1},  // decode\n   106→\t}\n   107→\n   108→\t// Expected: 100 (intercept) + 50*100 (prefill) + 5*2 (decode) = 100 + 5000 + 10 = 5110\n   109→\tgot := model.StepTime(batch)\n   110→\tif got != 5110 {\n   111→\t\tt.Errorf(\"StepTime = %d, want 5110\", got)\n   112→\t}\n   113→}\n   114→\n   115→func TestStepMLLatencyModel_StepTime_Positive(t *testing.T) {\n   116→\t// Test INV-M-1: predictions are always positive\n   117→\tart := &StepMLArtifact{\n   118→\t\tVersion: 1,\n   119→\t\tStepTime: &LinearModel{\n   120→\t\t\tModelType:           \"linear\",\n   121→\t\t\tIntercept:           -1000,\n   122→\t\t\tFeatureCoefficients: map[string]float64{},\n   123→\t\t},\n   124→\t}\n   125→\tmodel := NewStepMLLatencyModel(art)\n   126→\tgot := model.StepTime([]*sim.Request{})\n   127→\tif got < 1 {\n   128→\t\tt.Errorf(\"StepTime = %d, want >= 1 (INV-M-1)\", got)\n   129→\t}\n   130→}\n   131→\n   132→func TestStepMLLatencyModel_QueueingTime(t *testing.T) {\n   133→\tpath := writeArtifact(t, validArtifactJSON)\n   134→\tart, err := LoadStepMLArtifact(path)\n   135→\tif err != nil {\n   136→\t\tt.Fatalf(\"load artifact: %v\", err)\n   137→\t}\n   138→\tmodel := NewStepMLLatencyModel(art)\n   139→\n   140→\treq := &sim.Request{InputTokens: make([]int, 200)}\n   141→\t// Expected: 10 (intercept) + 0.5 * 200 = 110\n   142→\tgot := model.QueueingTime(req)\n   143→\tif got != 110 {\n   144→\t\tt.Errorf(\"QueueingTime = %d, want 110\", got)\n   145→\t}\n   146→}\n   147→\n   148→func TestStepMLLatencyModel_QueueingTime_NilModel(t *testing.T) {\n   149→\tart := &StepMLArtifact{\n   150→\t\tVersion:  1,\n   151→\t\tStepTime: &LinearModel{ModelType: \"linear\", Intercept: 10, FeatureCoefficients: map[string]float64{}},\n   152→\t}\n   153→\tmodel := NewStepMLLatencyModel(art)\n   154→\tgot := model.QueueingTime(&sim.Request{InputTokens: make([]int, 100)})\n   155→\tif got != 0 {\n   156→\t\tt.Errorf(\"QueueingTime with nil model = %d, want 0\", got)\n   157→\t}\n   158→}\n   159→\n   160→func TestStepMLLatencyModel_ConstantMethods(t *testing.T) {\n   161→\tpath := writeArtifact(t, validArtifactJSON)\n   162→\tart, err := LoadStepMLArtifact(path)\n   163→\tif err != nil {\n   164→\t\tt.Fatalf(\"load artifact: %v\", err)\n   165→\t}\n   166→\tmodel := NewStepMLLatencyModel(art)\n   167→\n   168→\tif got := model.OutputTokenProcessingTime(); got != 2 {\n   169→\t\tt.Errorf(\"OutputTokenProcessingTime = %d, want 2\", got)\n   170→\t}\n   171→\tif got := model.SchedulingProcessingTime(); got != 5 {\n   172→\t\tt.Errorf(\"SchedulingProcessingTime = %d, want 5\", got)\n   173→\t}\n   174→\tif got := model.PreemptionProcessingTime(); got != 3 {\n   175→\t\tt.Errorf(\"PreemptionProcessingTime = %d, want 3\", got)\n   176→\t}\n   177→}\n   178→\n   179→func TestStepMLLatencyModel_KVFeatures(t *testing.T) {\n   180→\t// Test that KV proxy features (ProgressIndex) are extracted and used\n   181→\tart := &StepMLArtifact{\n   182→\t\tVersion: 1,\n   183→\t\tStepTime: &LinearModel{\n   184→\t\t\tModelType: \"linear\",\n   185→\t\t\tIntercept: 0,\n   186→\t\t\tFeatureCoefficients: map[string]float64{\n   187→\t\t\t\t\"kv_sum\":  0.1,\n   188→\t\t\t\t\"kv_mean\": 10.0,\n   189→\t\t\t\t\"kv_max\":  1.0,\n   190→\t\t\t},\n   191→\t\t},\n   192→\t}\n   193→\tmodel := NewStepMLLatencyModel(art)\n   194→\n   195→\tbatch := []*sim.Request{\n   196→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1},\n   197→\t\t{InputTokens: make([]int, 200), OutputTokens: make([]int, 100), ProgressIndex: 300, NumNewTokens: 1},\n   198→\t}\n   199→\n   200→\t// kv_sum = 150 + 300 = 450 → 450 * 0.1 = 45\n   201→\t// kv_mean = 225 → 225 * 10 = 2250\n   202→\t// kv_max = 300 → 300 * 1 = 300\n   203→\t// total = 45 + 2250 + 300 = 2595\n   204→\tgot := model.StepTime(batch)\n   205→\tif got != 2595 {\n   206→\t\tt.Errorf(\"StepTime with KV features = %d, want 2595\", got)\n   207→\t}\n   208→}\n   209→\n   210→func TestExtractBatchFeatures(t *testing.T) {\n   211→\tbatch := []*sim.Request{\n   212→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},   // prefill: 50 < 200\n   213→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 1), ProgressIndex: 150, NumNewTokens: 1}, // decode: 150 >= 100\n   214→\t}\n   215→\n   216→\tf := extractBatchFeatures(batch)\n   217→\n   218→\ttests := []struct {\n   219→\t\tname string\n   220→\t\twant float64\n   221→\t}{\n   222→\t\t{\"prefill_tokens\", 100},\n   223→\t\t{\"decode_tokens\", 1},\n   224→\t\t{\"num_prefill_reqs\", 1},\n   225→\t\t{\"num_decode_reqs\", 1},\n   226→\t\t{\"scheduled_tokens\", 101},\n   227→\t\t{\"kv_sum\", 200},    // 50 + 150\n   228→\t\t{\"kv_max\", 150},\n   229→\t\t{\"kv_mean\", 100},   // 200 / 2\n   230→\t}\n   231→\tfor _, tt := range tests {\n   232→\t\tif got := f[tt.name]; got != tt.want {\n   233→\t\t\tt.Errorf(\"feature %q = %f, want %f\", tt.name, got, tt.want)\n   234→\t\t}\n   235→\t}\n   236→}\n   237→\n   238→func TestNewLatencyModel_StepMLDispatch(t *testing.T) {\n   239→\tpath := writeArtifact(t, validArtifactJSON)\n   240→\tcoeffs := sim.NewLatencyCoeffs(\n   241→\t\t[]float64{0, 0, 0}, // beta (unused by stepml)\n   242→\t\t[]float64{0, 0, 0}, // alpha (unused by stepml)\n   243→\t)\n   244→\thw := sim.NewModelHardwareConfig(sim.ModelConfig{}, sim.HardwareCalib{}, \"\", \"\", 0, false).\n   245→\t\tWithStepMLModel(path)\n   246→\n   247→\tmodel, err := NewLatencyModel(coeffs, hw)\n   248→\tif err != nil {\n   249→\t\tt.Fatalf(\"NewLatencyModel with StepML: %v\", err)\n   250→\t}\n   251→\n   252→\tif _, ok := model.(*StepMLLatencyModel); !ok {\n   253→\t\tt.Errorf(\"expected *StepMLLatencyModel, got %T\", model)\n   254→\t}\n   255→}\n   256→\n   257→// regimeArtifactJSON has 2 regimes: decode-only and mixed-batch (fallback).\n   258→const regimeArtifactJSON = `{\n   259→\t\"version\": 2,\n   260→\t\"step_time_regimes\": [\n   261→\t\t{\n   262→\t\t\t\"name\": \"decode_only\",\n   263→\t\t\t\"condition\": {\"feature\": \"prefill_tokens\", \"op\": \"==\", \"value\": 0},\n   264→\t\t\t\"model\": {\n   265→\t\t\t\t\"model_type\": \"linear\",\n   266→\t\t\t\t\"intercept\": 50.0,\n   267→\t\t\t\t\"feature_coefficients\": {\"decode_tokens\": 10.0, \"kv_mean\": 0.5}\n   268→\t\t\t}\n   269→\t\t},\n   270→\t\t{\n   271→\t\t\t\"name\": \"mixed\",\n   272→\t\t\t\"condition\": null,\n   273→\t\t\t\"model\": {\n   274→\t\t\t\t\"model_type\": \"linear\",\n   275→\t\t\t\t\"intercept\": 200.0,\n   276→\t\t\t\t\"feature_coefficients\": {\"prefill_tokens\": 2.0, \"decode_tokens\": 8.0}\n   277→\t\t\t}\n   278→\t\t}\n   279→\t],\n   280→\t\"output_token_processing_time_us\": 1.0,\n   281→\t\"scheduling_processing_time_us\": 2.0,\n   282→\t\"preemption_processing_time_us\": 0.0\n   283→}`\n   284→\n   285→func TestStepMLLatencyModel_RegimeDispatch(t *testing.T) {\n   286→\tpath := writeArtifact(t, regimeArtifactJSON)\n   287→\tart, err := LoadStepMLArtifact(path)\n   288→\tif err != nil {\n   289→\t\tt.Fatalf(\"load regime artifact: %v\", err)\n   290→\t}\n   291→\tmodel := NewStepMLLatencyModel(art)\n   292→\n   293→\t// Decode-only batch: 2 decode requests, 1 new token each\n   294→\tdecodeBatch := []*sim.Request{\n   295→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1},\n   296→\t\t{InputTokens: make([]int, 80), OutputTokens: make([]int, 30), ProgressIndex: 110, NumNewTokens: 1},\n   297→\t}\n   298→\t// prefill_tokens=0 → decode_only regime\n   299→\t// decode_tokens=2, kv_mean=(150+110)/2=130\n   300→\t// Expected: 50 + 10*2 + 0.5*130 = 50 + 20 + 65 = 135\n   301→\tgot := model.StepTime(decodeBatch)\n   302→\tif got != 135 {\n   303→\t\tt.Errorf(\"StepTime(decode_only) = %d, want 135\", got)\n   304→\t}\n   305→\n   306→\t// Mixed batch: 1 prefill + 1 decode\n   307→\tmixedBatch := []*sim.Request{\n   308→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},  // prefill\n   309→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1}, // decode\n   310→\t}\n   311→\t// prefill_tokens=100 > 0 → mixed regime\n   312→\t// decode_tokens=1\n   313→\t// Expected: 200 + 2*100 + 8*1 = 200 + 200 + 8 = 408\n   314→\tgot = model.StepTime(mixedBatch)\n   315→\tif got != 408 {\n   316→\t\tt.Errorf(\"StepTime(mixed) = %d, want 408\", got)\n   317→\t}\n   318→}\n   319→\n   320→func TestStepMLLatencyModel_RegimeNoStepTime(t *testing.T) {\n   321→\t// Artifact with only regimes (no step_time field) should work\n   322→\tpath := writeArtifact(t, regimeArtifactJSON)\n   323→\tart, err := LoadStepMLArtifact(path)\n   324→\tif err != nil {\n   325→\t\tt.Fatalf(\"load: %v\", err)\n   326→\t}\n   327→\tif art.StepTime != nil {\n   328→\t\tt.Error(\"expected nil step_time when using regimes only\")\n   329→\t}\n   330→\tif len(art.StepTimeRegimes) != 2 {\n   331→\t\tt.Errorf(\"got %d regimes, want 2\", len(art.StepTimeRegimes))\n   332→\t}\n   333→}\n   334→\n   335→func TestExtractBatchFeatures_InteractionFeatures(t *testing.T) {\n   336→\tbatch := []*sim.Request{\n   337→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},   // prefill\n   338→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 1), ProgressIndex: 150, NumNewTokens: 1}, // decode\n   339→\t}\n   340→\n   341→\tf := extractBatchFeatures(batch)\n   342→\n   343→\t// prefill_x_decode = 100 * 1 = 100\n   344→\tif got := f[\"prefill_x_decode\"]; got != 100 {\n   345→\t\tt.Errorf(\"prefill_x_decode = %f, want 100\", got)\n   346→\t}\n   347→\t// decode_x_kv_mean = 1 * 100 = 100 (kv_mean = (50+150)/2 = 100)\n   348→\tif got := f[\"decode_x_kv_mean\"]; got != 100 {\n   349→\t\tt.Errorf(\"decode_x_kv_mean = %f, want 100\", got)\n   350→\t}\n   351→\t// prefill_sq = 100 * 100 = 10000\n   352→\tif got := f[\"prefill_sq\"]; got != 10000 {\n   353→\t\tt.Errorf(\"prefill_sq = %f, want 10000\", got)\n   354→\t}\n   355→\t// kv_std: pi values are 50 and 150, mean=100\n   356→\t// variance = ((50-100)^2 + (150-100)^2) / 2 = (2500+2500)/2 = 2500\n   357→\t// std = sqrt(2500) = 50\n   358→\tif got := f[\"kv_std\"]; got != 50 {\n   359→\t\tt.Errorf(\"kv_std = %f, want 50\", got)\n   360→\t}\n   361→}\n   362→\n   363→func TestStepMLLatencyModel_OverheadFloorAndCap(t *testing.T) {\n   364→\t// Overhead floor: prediction < overhead → use overhead.\n   365→\t// Overhead cap: prediction > 3*overhead → clamp to 3*overhead.\n   366→\tart := &StepMLArtifact{\n   367→\t\tVersion: 1,\n   368→\t\tStepTime: &LinearModel{\n   369→\t\t\tModelType:           \"linear\",\n   370→\t\t\tIntercept:           100,\n   371→\t\t\tFeatureCoefficients: map[string]float64{\"decode_tokens\": 200},\n   372→\t\t},\n   373→\t\tStepOverheadUs: 5000,\n   374→\t}\n   375→\tmodel := NewStepMLLatencyModel(art)\n   376→\n   377→\t// Small batch: 100 + 200*1 = 300 < 5000 → floored to 5000\n   378→\tsmall := []*sim.Request{\n   379→\t\t{InputTokens: make([]int, 10), OutputTokens: make([]int, 1), ProgressIndex: 10, NumNewTokens: 1},\n   380→\t}\n   381→\tgot := model.StepTime(small)\n   382→\tif got != 5000 {\n   383→\t\tt.Errorf(\"StepTime(small) = %d, want 5000 (overhead floor)\", got)\n   384→\t}\n   385→\n   386→\t// Large batch: 100 + 200*100 = 20100, cap = 3*5000 = 15000 → capped\n   387→\tvar large []*sim.Request\n   388→\tfor i := 0; i < 100; i++ {\n   389→\t\tlarge = append(large, &sim.Request{\n   390→\t\t\tInputTokens: make([]int, 10), OutputTokens: make([]int, 1),\n   391→\t\t\tProgressIndex: 10, NumNewTokens: 1,\n   392→\t\t})\n   393→\t}\n   394→\tgot = model.StepTime(large)\n   395→\tif got != 15000 {\n   396→\t\tt.Errorf(\"StepTime(large) = %d, want 15000 (overhead cap)\", got)\n   397→\t}\n   398→\n   399→\t// Medium batch: 100 + 200*30 = 6100, between floor and cap → use as-is\n   400→\tvar medium []*sim.Request\n   401→\tfor i := 0; i < 30; i++ {\n   402→\t\tmedium = append(medium, &sim.Request{\n   403→\t\t\tInputTokens: make([]int, 10), OutputTokens: make([]int, 1),\n   404→\t\t\tProgressIndex: 10, NumNewTokens: 1,\n   405→\t\t})\n   406→\t}\n   407→\tgot = model.StepTime(medium)\n   408→\tif got != 6100 {\n   409→\t\tt.Errorf(\"StepTime(medium) = %d, want 6100 (between floor and cap)\", got)\n   410→\t}\n   411→}\n   412→\n   413→func TestNewLatencyModel_StepMLInvalidPath(t *testing.T) {\n   414→\tcoeffs := sim.NewLatencyCoeffs(\n   415→\t\t[]float64{0, 0, 0},\n   416→\t\t[]float64{0, 0, 0},\n   417→\t)\n   418→\thw := sim.NewModelHardwareConfig(sim.ModelConfig{}, sim.HardwareCalib{}, \"\", \"\", 0, false).\n   419→\t\tWithStepMLModel(\"/nonexistent/model.json\")\n   420→\n   421→\t_, err := NewLatencyModel(coeffs, hw)\n   422→\tif err == nil {\n   423→\t\tt.Fatal(\"expected error for nonexistent StepML model path\")\n   424→\t}\n   425→}\n   426→\n   427→func TestNewLatencyModel_RooflineTakesPrecedence(t *testing.T) {\n   428→\t// Verify that roofline dispatch happens before StepML (isolation guarantee)\n   429→\tpath := writeArtifact(t, validArtifactJSON)\n   430→\tcoeffs := sim.NewLatencyCoeffs(\n   431→\t\t[]float64{0, 0, 0},\n   432→\t\t[]float64{0, 0, 0},\n   433→\t)\n   434→\thw := sim.NewModelHardwareConfig(\n   435→\t\tsim.ModelConfig{NumLayers: 32, HiddenDim: 4096, NumHeads: 32, NumKVHeads: 32, VocabSize: 32000, BytesPerParam: 2, IntermediateDim: 11008},\n   436→\t\tsim.HardwareCalib{TFlopsPeak: 989.5, BwPeakTBs: 3.35},\n   437→\t\t\"test-model\", \"H100\", 1, true, // Roofline=true\n   438→\t).WithStepMLModel(path)\n   439→\n   440→\t// This should fail on roofline validation (missing MFU database), NOT try StepML\n   441→\t_, err := NewLatencyModel(coeffs, hw)\n   442→\tif err == nil {\n   443→\t\tt.Fatal(\"expected roofline validation error, not StepML dispatch\")\n   444→\t}\n   445→}\n   446→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"bd5ed9c5-1b4d-451f-9c06-35b34804a62a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01VEwc1LGFc8MHJRCmARtsKz","type":"tool_result","content":"     1→// Package latency — StepML latency model.\n     2→//\n     3→// StepMLLatencyModel is a data-driven LatencyModel that loads trained model\n     4→// artifacts from a JSON file. It supports linear coefficient models and\n     5→// (future) XGBoost tree ensembles.\n     6→//\n     7→// This is the lightweight research-phase implementation (WP0). Production\n     8→// quality with full INV-M-1 through INV-M-6 validation comes in WP5.\n     9→package latency\n    10→\n    11→import (\n    12→\t\"encoding/json\"\n    13→\t\"fmt\"\n    14→\t\"math\"\n    15→\t\"os\"\n    16→\n    17→\t\"github.com/inference-sim/inference-sim/sim\"\n    18→\t\"github.com/inference-sim/inference-sim/sim/internal/util\"\n    19→)\n    20→\n    21→// StepMLArtifact is the top-level JSON schema for a StepML model artifact.\n    22→type StepMLArtifact struct {\n    23→\tVersion                      int              `json:\"version\"`\n    24→\tStepTime                     *LinearModel     `json:\"step_time\"`\n    25→\tStepTimeRegimes              []RegimeEntry    `json:\"step_time_regimes,omitempty\"`\n    26→\tQueueingTime                 *LinearModel     `json:\"queueing_time,omitempty\"`\n    27→\tStepOverheadUs               float64          `json:\"step_overhead_us\"`\n    28→\tStepOverheadPerReqUs         float64          `json:\"step_overhead_per_req_us\"`\n    29→\tOutputTokenProcessingTimeUs  float64          `json:\"output_token_processing_time_us\"`\n    30→\tSchedulingProcessingTimeUs   float64          `json:\"scheduling_processing_time_us\"`\n    31→\tPreemptionProcessingTimeUs   float64          `json:\"preemption_processing_time_us\"`\n    32→}\n    33→\n    34→// LinearModel represents a linear prediction model: intercept + Σ(coeff_i * feature_i).\n    35→// When OutputTransform is \"expm1\", the prediction is exponentiated: exp(linear) - 1.\n    36→// This supports log-linear models trained on log1p(target).\n    37→type LinearModel struct {\n    38→\tModelType           string             `json:\"model_type\"`\n    39→\tIntercept           float64            `json:\"intercept\"`\n    40→\tFeatureCoefficients map[string]float64 `json:\"feature_coefficients\"`\n    41→\tOutputTransform     string             `json:\"output_transform,omitempty\"`\n    42→}\n    43→\n    44→// RegimeEntry pairs a condition with a linear model for regime-based dispatch.\n    45→// Regimes are evaluated in order; the first matching condition wins.\n    46→// A nil Condition acts as a fallback (matches everything).\n    47→type RegimeEntry struct {\n    48→\tName      string          `json:\"name\"`\n    49→\tCondition *RegimeCondition `json:\"condition\"`\n    50→\tModel     LinearModel     `json:\"model\"`\n    51→}\n    52→\n    53→// RegimeCondition is a simple threshold condition on a batch feature.\n    54→type RegimeCondition struct {\n    55→\tFeature string  `json:\"feature\"`\n    56→\tOp      string  `json:\"op\"` // \"==\", \"<\", \"<=\", \">\", \">=\"\n    57→\tValue   float64 `json:\"value\"`\n    58→}\n    59→\n    60→// StepMLLatencyModel implements sim.LatencyModel using trained artifacts.\n    61→type StepMLLatencyModel struct {\n    62→\tartifact StepMLArtifact\n    63→}\n    64→\n    65→// LoadStepMLArtifact reads and validates a StepML JSON artifact from disk.\n    66→func LoadStepMLArtifact(path string) (*StepMLArtifact, error) {\n    67→\tdata, err := os.ReadFile(path)\n    68→\tif err != nil {\n    69→\t\treturn nil, fmt.Errorf(\"stepml: read artifact %q: %w\", path, err)\n    70→\t}\n    71→\n    72→\tvar art StepMLArtifact\n    73→\tif err := json.Unmarshal(data, &art); err != nil {\n    74→\t\treturn nil, fmt.Errorf(\"stepml: parse artifact %q: %w\", path, err)\n    75→\t}\n    76→\n    77→\tif art.Version < 1 {\n    78→\t\treturn nil, fmt.Errorf(\"stepml: unsupported artifact version %d\", art.Version)\n    79→\t}\n    80→\n    81→\thasRegimes := len(art.StepTimeRegimes) > 0\n    82→\thasSingleModel := art.StepTime != nil\n    83→\n    84→\tif !hasRegimes && !hasSingleModel {\n    85→\t\treturn nil, fmt.Errorf(\"stepml: artifact missing step_time model (provide step_time or step_time_regimes)\")\n    86→\t}\n    87→\n    88→\tif hasSingleModel {\n    89→\t\tif art.StepTime.ModelType != \"linear\" {\n    90→\t\t\treturn nil, fmt.Errorf(\"stepml: unsupported step_time model_type %q (supported: linear)\", art.StepTime.ModelType)\n    91→\t\t}\n    92→\t\tif err := validateLinearModel(\"step_time\", art.StepTime); err != nil {\n    93→\t\t\treturn nil, err\n    94→\t\t}\n    95→\t}\n    96→\n    97→\tfor i, r := range art.StepTimeRegimes {\n    98→\t\tname := fmt.Sprintf(\"step_time_regimes[%d](%s)\", i, r.Name)\n    99→\t\tif err := validateLinearModel(name, &r.Model); err != nil {\n   100→\t\t\treturn nil, err\n   101→\t\t}\n   102→\t\tif r.Condition != nil {\n   103→\t\t\tswitch r.Condition.Op {\n   104→\t\t\tcase \"==\", \"<\", \"<=\", \">\", \">=\":\n   105→\t\t\t\t// valid\n   106→\t\t\tdefault:\n   107→\t\t\t\treturn nil, fmt.Errorf(\"stepml: %s has unsupported condition op %q\", name, r.Condition.Op)\n   108→\t\t\t}\n   109→\t\t}\n   110→\t}\n   111→\n   112→\tif art.QueueingTime != nil {\n   113→\t\tif err := validateLinearModel(\"queueing_time\", art.QueueingTime); err != nil {\n   114→\t\t\treturn nil, err\n   115→\t\t}\n   116→\t}\n   117→\n   118→\treturn &art, nil\n   119→}\n   120→\n   121→func validateLinearModel(name string, m *LinearModel) error {\n   122→\tif math.IsNaN(m.Intercept) || math.IsInf(m.Intercept, 0) {\n   123→\t\treturn fmt.Errorf(\"stepml: %s intercept is NaN/Inf\", name)\n   124→\t}\n   125→\tfor feat, coeff := range m.FeatureCoefficients {\n   126→\t\tif math.IsNaN(coeff) || math.IsInf(coeff, 0) {\n   127→\t\t\treturn fmt.Errorf(\"stepml: %s coefficient %q is NaN/Inf\", name, feat)\n   128→\t\t}\n   129→\t}\n   130→\treturn nil\n   131→}\n   132→\n   133→// NewStepMLLatencyModel creates a StepML LatencyModel from a loaded artifact.\n   134→func NewStepMLLatencyModel(art *StepMLArtifact) *StepMLLatencyModel {\n   135→\treturn &StepMLLatencyModel{artifact: *art}\n   136→}\n   137→\n   138→// extractBatchFeatures computes aggregate features from a batch of requests.\n   139→// These features mirror the ground-truth step-level data schema.\n   140→func extractBatchFeatures(batch []*sim.Request) map[string]float64 {\n   141→\tvar prefillTokens, decodeTokens int64\n   142→\tvar numPrefillReqs, numDecodeReqs int64\n   143→\tvar kvSum, kvMax int64\n   144→\tvar kvCount int64\n   145→\tvar kvSumSq float64 // for kv_std computation\n   146→\n   147→\tfor _, req := range batch {\n   148→\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n   149→\t\t\t// Prefill phase\n   150→\t\t\tprefillTokens += int64(req.NumNewTokens)\n   151→\t\t\tnumPrefillReqs++\n   152→\t\t} else if len(req.OutputTokens) > 0 {\n   153→\t\t\t// Decode phase\n   154→\t\t\tdecodeTokens += int64(req.NumNewTokens)\n   155→\t\t\tnumDecodeReqs++\n   156→\t\t}\n   157→\n   158→\t\t// KV cache proxy features from ProgressIndex\n   159→\t\tpi := req.ProgressIndex\n   160→\t\tkvSum += pi\n   161→\t\tkvSumSq += float64(pi) * float64(pi)\n   162→\t\tkvCount++\n   163→\t\tif pi > kvMax {\n   164→\t\t\tkvMax = pi\n   165→\t\t}\n   166→\t}\n   167→\n   168→\tvar kvMean, kvStd float64\n   169→\tif kvCount > 0 {\n   170→\t\tkvMean = float64(kvSum) / float64(kvCount)\n   171→\t\tif kvCount > 1 {\n   172→\t\t\t// Population std: sqrt(E[X^2] - E[X]^2)\n   173→\t\t\tvariance := kvSumSq/float64(kvCount) - kvMean*kvMean\n   174→\t\t\tif variance > 0 {\n   175→\t\t\t\tkvStd = math.Sqrt(variance)\n   176→\t\t\t}\n   177→\t\t}\n   178→\t}\n   179→\n   180→\tpf := float64(prefillTokens)\n   181→\tdt := float64(decodeTokens)\n   182→\tndr := float64(numDecodeReqs)\n   183→\n   184→\treturn map[string]float64{\n   185→\t\t\"prefill_tokens\":   pf,\n   186→\t\t\"decode_tokens\":    dt,\n   187→\t\t\"num_prefill_reqs\": float64(numPrefillReqs),\n   188→\t\t\"num_decode_reqs\":  ndr,\n   189→\t\t\"scheduled_tokens\": pf + dt,\n   190→\t\t\"kv_sum\":           float64(kvSum),\n   191→\t\t\"kv_max\":           float64(kvMax),\n   192→\t\t\"kv_mean\":          kvMean,\n   193→\t\t\"kv_std\":           kvStd,\n   194→\t\t// Interaction features for regime-specific models\n   195→\t\t\"prefill_x_decode\":  pf * dt,\n   196→\t\t\"decode_x_kv_mean\":  ndr * kvMean,\n   197→\t\t\"prefill_sq\":        pf * pf,\n   198→\t}\n   199→}\n   200→\n   201→// predictLinear evaluates intercept + Σ(coeff_i * features[i]).\n   202→// Features not present in the coefficient map are ignored (zero contribution).\n   203→// When OutputTransform is \"expm1\", applies exp(result) - 1 (inverse of log1p).\n   204→func predictLinear(m *LinearModel, features map[string]float64) float64 {\n   205→\tresult := m.Intercept\n   206→\tfor feat, coeff := range m.FeatureCoefficients {\n   207→\t\tif val, ok := features[feat]; ok {\n   208→\t\t\tresult += coeff * val\n   209→\t\t}\n   210→\t}\n   211→\tif m.OutputTransform == \"expm1\" {\n   212→\t\tresult = math.Expm1(result) // exp(result) - 1\n   213→\t}\n   214→\treturn result\n   215→}\n   216→\n   217→// StepTime estimates batch step execution time in microseconds.\n   218→//\n   219→// The model predicts GPU compute time from batch features. Since the training\n   220→// data only captures GPU forward pass time (step.duration_us), the full step\n   221→// cycle time also includes CPU-side overhead (scheduling, sync, memory management).\n   222→//\n   223→// The overhead is applied as a floor (max) rather than additive because:\n   224→//   - Small batches: overhead-dominated (~4ms); compute is negligible (~100µs)\n   225→//   - Large batches: compute-dominated (~6ms); overhead is negligible\n   226→//   - The transition is at the memory↔compute bound crossover point\n   227→//\n   228→// step_overhead_per_req_us is additive (per-request scheduling cost).\n   229→//\n   230→// When StepTimeRegimes is present, evaluates regimes in order; first match wins.\n   231→// Otherwise falls back to the single StepTime linear model.\n   232→func (s *StepMLLatencyModel) StepTime(batch []*sim.Request) int64 {\n   233→\tfeatures := extractBatchFeatures(batch)\n   234→\n   235→\tvar prediction float64\n   236→\tif len(s.artifact.StepTimeRegimes) > 0 {\n   237→\t\tprediction = s.predictRegime(features)\n   238→\t} else {\n   239→\t\tprediction = predictLinear(s.artifact.StepTime, features)\n   240→\t}\n   241→\n   242→\t// Apply overhead as a floor: step_cycle = max(overhead, compute).\n   243→\t// This models the memory↔compute crossover: at small batches the overhead\n   244→\t// floor dominates; at large batches, compute exceeds the floor naturally.\n   245→\t//\n   246→\t// Also cap at 5x overhead to prevent exponential blowup from the expm1\n   247→\t// transform on outlier feature values. 5x covers the realistic range\n   248→\t// (e.g., 4ms overhead → 20ms cap, well above any real step time).\n   249→\tif s.artifact.StepOverheadUs > 0 {\n   250→\t\tif prediction < s.artifact.StepOverheadUs {\n   251→\t\t\tprediction = s.artifact.StepOverheadUs\n   252→\t\t}\n   253→\t\tmaxStep := s.artifact.StepOverheadUs * 3\n   254→\t\tif prediction > maxStep {\n   255→\t\t\tprediction = maxStep\n   256→\t\t}\n   257→\t}\n   258→\n   259→\t// Per-request overhead is always additive (scheduling cost per request).\n   260→\tif s.artifact.StepOverheadPerReqUs > 0 {\n   261→\t\tbatchSize := features[\"num_prefill_reqs\"] + features[\"num_decode_reqs\"]\n   262→\t\tprediction += s.artifact.StepOverheadPerReqUs * batchSize\n   263→\t}\n   264→\n   265→\tif prediction < 1 {\n   266→\t\tprediction = 1 // INV-M-1: positive predictions\n   267→\t}\n   268→\treturn int64(prediction)\n   269→}\n   270→\n   271→// predictRegime evaluates regime conditions in order and uses the first matching model.\n   272→func (s *StepMLLatencyModel) predictRegime(features map[string]float64) float64 {\n   273→\tfor _, r := range s.artifact.StepTimeRegimes {\n   274→\t\tif r.Condition == nil || evalCondition(r.Condition, features) {\n   275→\t\t\treturn predictLinear(&r.Model, features)\n   276→\t\t}\n   277→\t}\n   278→\t// No regime matched and no fallback — use single model if available\n   279→\tif s.artifact.StepTime != nil {\n   280→\t\treturn predictLinear(s.artifact.StepTime, features)\n   281→\t}\n   282→\treturn 1 // safety fallback\n   283→}\n   284→\n   285→// evalCondition checks a simple threshold condition against feature values.\n   286→func evalCondition(c *RegimeCondition, features map[string]float64) bool {\n   287→\tval := features[c.Feature]\n   288→\tswitch c.Op {\n   289→\tcase \"==\":\n   290→\t\treturn val == c.Value\n   291→\tcase \"<\":\n   292→\t\treturn val < c.Value\n   293→\tcase \"<=\":\n   294→\t\treturn val <= c.Value\n   295→\tcase \">\":\n   296→\t\treturn val > c.Value\n   297→\tcase \">=\":\n   298→\t\treturn val >= c.Value\n   299→\tdefault:\n   300→\t\treturn false\n   301→\t}\n   302→}\n   303→\n   304→// QueueingTime estimates arrival-to-queue delay for a request in microseconds.\n   305→func (s *StepMLLatencyModel) QueueingTime(req *sim.Request) int64 {\n   306→\tif s.artifact.QueueingTime == nil {\n   307→\t\treturn 0\n   308→\t}\n   309→\tfeatures := map[string]float64{\n   310→\t\t\"input_len\": float64(len(req.InputTokens)),\n   311→\t}\n   312→\tprediction := predictLinear(s.artifact.QueueingTime, features)\n   313→\tif prediction < 0 {\n   314→\t\tprediction = 0\n   315→\t}\n   316→\treturn int64(prediction)\n   317→}\n   318→\n   319→// OutputTokenProcessingTime estimates per-token post-processing in microseconds.\n   320→func (s *StepMLLatencyModel) OutputTokenProcessingTime() int64 {\n   321→\tv := s.artifact.OutputTokenProcessingTimeUs\n   322→\tif v < 0 {\n   323→\t\treturn 0\n   324→\t}\n   325→\treturn int64(v)\n   326→}\n   327→\n   328→// SchedulingProcessingTime estimates scheduling overhead per request in microseconds.\n   329→func (s *StepMLLatencyModel) SchedulingProcessingTime() int64 {\n   330→\tv := s.artifact.SchedulingProcessingTimeUs\n   331→\tif v < 0 {\n   332→\t\treturn 0\n   333→\t}\n   334→\treturn int64(v)\n   335→}\n   336→\n   337→// PreemptionProcessingTime estimates preemption overhead per eviction in microseconds.\n   338→func (s *StepMLLatencyModel) PreemptionProcessingTime() int64 {\n   339→\tv := s.artifact.PreemptionProcessingTimeUs\n   340→\tif v < 0 {\n   341→\t\treturn 0\n   342→\t}\n   343→\treturn int64(v)\n   344→}\n   345→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"5c3fffe7-8cc8-4bc5-9906-1702895fc47f"}
