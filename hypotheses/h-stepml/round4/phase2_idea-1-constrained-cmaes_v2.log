{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01AAcxMtuNsRBdh1x2vr8vz1","type":"tool_result","content":"     1→\"\"\"Baseline models for step-time prediction.\n     2→\n     3→Provides two baselines:\n     4→- BlackboxBaseline: re-trained 3-coefficient linear regression matching BLIS blackbox model\n     5→- NaiveMeanBaseline: always predicts the training set mean step duration\n     6→\n     7→Plus calibration and gating utilities for the StepML research workflow.\n     8→\"\"\"\n     9→\n    10→from __future__ import annotations\n    11→\n    12→import numpy as np\n    13→import pandas as pd\n    14→from scipy.optimize import nnls\n    15→\n    16→from evaluation import (\n    17→    compute_mape,\n    18→    compute_mspe,\n    19→    compute_p99_error,\n    20→    compute_pearson_r,\n    21→)\n    22→\n    23→# Feature columns used by the blackbox model\n    24→_FEATURE_COLS = [\"batch.prefill_tokens\", \"batch.decode_tokens\"]\n    25→# Target column\n    26→_TARGET_COL = \"step.duration_us\"\n    27→\n    28→\n    29→class BlackboxBaseline:\n    30→    \"\"\"Re-trained 3-coefficient non-negative linear model matching BLIS blackbox.\n    31→\n    32→    StepTime = beta0 + beta1 * batch.prefill_tokens + beta2 * batch.decode_tokens\n    33→\n    34→    All three coefficients are constrained to be >= 0 via NNLS (non-negative\n    35→    least squares). The intercept is modelled as a third feature (ones column)\n    36→    so that the non-negativity constraint applies uniformly to all betas.\n    37→\n    38→    Column normalization is applied before NNLS to avoid scale mismatch between\n    39→    the ones column (~1) and token columns (~0-2048), then coefficients are\n    40→    rescaled to original units.\n    41→    \"\"\"\n    42→\n    43→    def __init__(self) -> None:\n    44→        self._coeffs: np.ndarray | None = None  # [beta0, beta1, beta2]\n    45→\n    46→    def fit(self, train_df: pd.DataFrame) -> BlackboxBaseline:\n    47→        \"\"\"Train on step-level data using column-normalized NNLS.\n    48→\n    49→        Constructs A = [ones, prefill_tokens, decode_tokens], normalizes each\n    50→        column by its L2 norm, solves NNLS, then rescales coefficients back.\n    51→        \"\"\"\n    52→        X = train_df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n    53→        y = train_df[_TARGET_COL].to_numpy(dtype=np.float64)\n    54→\n    55→        # Build design matrix: [ones, prefill, decode]\n    56→        ones = np.ones((X.shape[0], 1), dtype=np.float64)\n    57→        A = np.hstack([ones, X])\n    58→\n    59→        # Column-normalize to fix conditioning\n    60→        col_norms = np.linalg.norm(A, axis=0)\n    61→        col_norms[col_norms == 0] = 1.0  # guard against zero columns\n    62→        A_normed = A / col_norms\n    63→\n    64→        # Solve NNLS on normalized problem\n    65→        x_normed, _ = nnls(A_normed, y)\n    66→\n    67→        # Rescale coefficients back to original units\n    68→        self._coeffs = x_normed / col_norms\n    69→        return self\n    70→\n    71→    def predict(self, df: pd.DataFrame) -> np.ndarray:\n    72→        \"\"\"Predict step.duration_us from batch features.\"\"\"\n    73→        if self._coeffs is None:\n    74→            raise RuntimeError(\"BlackboxBaseline.predict() called before fit()\")\n    75→        X = df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n    76→        return self._coeffs[0] + X @ self._coeffs[1:]\n    77→\n    78→    @property\n    79→    def coefficients(self) -> dict:\n    80→        \"\"\"Return {\"beta0\": intercept, \"beta1\": prefill_coeff, \"beta2\": decode_coeff}.\"\"\"\n    81→        if self._coeffs is None:\n    82→            raise RuntimeError(\"BlackboxBaseline.coefficients accessed before fit()\")\n    83→        return {\n    84→            \"beta0\": float(self._coeffs[0]),\n    85→            \"beta1\": float(self._coeffs[1]),\n    86→            \"beta2\": float(self._coeffs[2]),\n    87→        }\n    88→\n    89→\n    90→class NaiveMeanBaseline:\n    91→    \"\"\"Always predicts the training set mean step duration.\"\"\"\n    92→\n    93→    def __init__(self) -> None:\n    94→        self._mean: float | None = None\n    95→\n    96→    def fit(self, train_df: pd.DataFrame) -> NaiveMeanBaseline:\n    97→        \"\"\"Compute and store the training set mean of step.duration_us.\"\"\"\n    98→        self._mean = float(train_df[_TARGET_COL].mean())\n    99→        return self\n   100→\n   101→    def predict(self, df: pd.DataFrame) -> np.ndarray:\n   102→        \"\"\"Return an array of the training mean, one per input row.\"\"\"\n   103→        if self._mean is None:\n   104→            raise RuntimeError(\"NaiveMeanBaseline.predict() called before fit()\")\n   105→        return np.full(len(df), self._mean)\n   106→\n   107→\n   108→def compute_baseline_report(\n   109→    train_df: pd.DataFrame,\n   110→    test_df: pd.DataFrame,\n   111→    baselines: dict | None = None,\n   112→) -> dict:\n   113→    \"\"\"Compute evaluation metrics for all baselines.\n   114→\n   115→    Args:\n   116→        train_df: Training split DataFrame with feature and target columns.\n   117→        test_df: Test split DataFrame with feature and target columns.\n   118→        baselines: Optional dict of {name: baseline_instance}. If None, uses\n   119→            default baselines (blackbox + naive_mean).\n   120→\n   121→    Returns:\n   122→        Dict like:\n   123→        {\n   124→            \"blackbox\": {\"mape\": 15.2, \"mspe\": -3.1, \"pearson_r\": 0.89, \"p99_error\": 45.3},\n   125→            \"naive_mean\": {\"mape\": 42.1, ...},\n   126→        }\n   127→        Uses evaluation.py functions (compute_mape, compute_mspe, compute_pearson_r, compute_p99_error).\n   128→    \"\"\"\n   129→    if baselines is None:\n   130→        baselines = {\n   131→            \"blackbox\": BlackboxBaseline(),\n   132→            \"naive_mean\": NaiveMeanBaseline(),\n   133→        }\n   134→\n   135→    actual = test_df[_TARGET_COL].values\n   136→    report: dict = {}\n   137→\n   138→    for name, model in baselines.items():\n   139→        model.fit(train_df)\n   140→        predicted = model.predict(test_df)\n   141→\n   142→        pearson_r = compute_pearson_r(predicted, actual)\n   143→        # pearsonr returns NaN for constant inputs (e.g., NaiveMeanBaseline).\n   144→        # Replace with 0.0 — constant predictions have zero useful correlation.\n   145→        if np.isnan(pearson_r):\n   146→            pearson_r = 0.0\n   147→\n   148→        report[name] = {\n   149→            \"mape\": float(compute_mape(predicted, actual)),\n   150→            \"mspe\": float(compute_mspe(predicted, actual)),\n   151→            \"pearson_r\": float(pearson_r),\n   152→            \"p99_error\": float(compute_p99_error(predicted, actual)),\n   153→        }\n   154→\n   155→    return report\n   156→\n   157→\n   158→def calibrate_short_circuit_threshold(blackbox_mape: float) -> float:\n   159→    \"\"\"Determine the short-circuit threshold for StepML improvement.\n   160→\n   161→    If blackbox MAPE > 25%, threshold = blackbox_MAPE + 10%.\n   162→    Otherwise threshold = 35% (25% + 10% buffer).\n   163→\n   164→    Args:\n   165→        blackbox_mape: The blackbox baseline's MAPE as a percentage.\n   166→\n   167→    Returns:\n   168→        The threshold as a percentage.\n   169→    \"\"\"\n   170→    if blackbox_mape > 25.0:\n   171→        return blackbox_mape + 10.0\n   172→    return 35.0\n   173→\n   174→\n   175→def check_r4_gate(blackbox_e2e_mean_error: float) -> dict:\n   176→    \"\"\"Check if blackbox is already good enough (R4 risk).\n   177→\n   178→    If abs(blackbox_e2e_mean_error) < 12%, flag for research justification review.\n   179→    This means the blackbox model is already performing well at the E2E level,\n   180→    so additional ML complexity may not be justified.\n   181→\n   182→    Args:\n   183→        blackbox_e2e_mean_error: The blackbox baseline's E2E mean error as a percentage.\n   184→\n   185→    Returns:\n   186→        {\"passed\": bool, \"e2e_error\": float, \"message\": str}\n   187→        passed=True means no flag (research is justified).\n   188→        passed=False means flagged (blackbox already good enough, needs justification).\n   189→    \"\"\"\n   190→    e2e_error = float(blackbox_e2e_mean_error)\n   191→    flagged = abs(e2e_error) < 12.0\n   192→\n   193→    if flagged:\n   194→        message = (\n   195→            f\"R4 gate FLAGGED: blackbox E2E mean error = {e2e_error:.1f}% \"\n   196→            f\"(|error| < 12%). Blackbox may already be sufficient. \"\n   197→            f\"Review research justification before proceeding.\"\n   198→        )\n   199→    else:\n   200→        message = (\n   201→            f\"R4 gate passed: blackbox E2E mean error = {e2e_error:.1f}% \"\n   202→            f\"(|error| >= 12%). Step-level ML improvement is justified.\"\n   203→        )\n   204→\n   205→    return {\n   206→        \"passed\": not flagged,\n   207→        \"e2e_error\": e2e_error,\n   208→        \"message\": message,\n   209→    }\n   210→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"3d62dc73-5582-4a0d-b4ec-701cceaa839a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01X5CBYoxxgArT7ChUmCoN7t","type":"tool_result","content":"     1→\"\"\"MFU benchmark indexer for InferSim bench_data.\n     2→\n     3→Loads and indexes hardware MFU (Model FLOPs Utilization) benchmarks from\n     4→InferSim's bench_data/ directory so that research ideas can query real\n     5→hardware performance data by GPU type, matrix shape, and attention\n     6→configuration.\n     7→\n     8→Supported benchmark families:\n     9→  - GEMM: dense matrix multiply MFU by (m, k, n) shape\n    10→  - MHA decode: multi-head attention decode MFU by head config and KV length\n    11→  - MHA prefill: multi-head attention prefill MFU by head config and seq length\n    12→  - Grouped GEMM: MoE expert MFU (up_proj + down_proj) by expert config\n    13→\n    14→All data is stored as pandas DataFrames and queried with exact-match or\n    15→nearest-neighbor interpolation.\n    16→\"\"\"\n    17→\n    18→import os\n    19→import re\n    20→from typing import Optional\n    21→\n    22→import numpy as np\n    23→import pandas as pd\n    24→\n    25→# ---------------------------------------------------------------------------\n    26→# Default bench_data root: InferSim/bench_data/ relative to this file\n    27→# ---------------------------------------------------------------------------\n    28→DEFAULT_BENCH_DATA_ROOT = os.path.join(\n    29→    os.path.dirname(__file__), \"..\", \"..\", \"..\", \"InferSim\", \"bench_data\"\n    30→)\n    31→\n    32→# Regex for MHA decode filenames: {heads}-{kv_heads}-{head_dim}[-tp{N}].csv\n    33→_MHA_DECODE_PATTERN = re.compile(\n    34→    r\"^(\\d+)-(\\d+)-(\\d+)(?:-tp(\\d+))?\\.csv$\"\n    35→)\n    36→\n    37→# Regex for MHA prefill filenames: {heads}-{kv_heads}-{head_dim}.csv\n    38→_MHA_PREFILL_PATTERN = re.compile(\n    39→    r\"^(\\d+)-(\\d+)-(\\d+)\\.csv$\"\n    40→)\n    41→\n    42→\n    43→def _nearest_row(df: pd.DataFrame, columns: list[str], values: list) -> pd.Series:\n    44→    \"\"\"Find the row in *df* whose *columns* are nearest to *values*.\n    45→\n    46→    Uses Euclidean distance across the specified columns after casting\n    47→    everything to float.  Returns the first row at minimum distance.\n    48→    \"\"\"\n    49→    dist = np.zeros(len(df))\n    50→    for col, val in zip(columns, values):\n    51→        dist += (df[col].astype(float).values - float(val)) ** 2\n    52→    idx = int(np.argmin(dist))\n    53→    return df.iloc[idx]\n    54→\n    55→\n    56→class MFUBenchmarkIndex:\n    57→    \"\"\"Index and query InferSim hardware MFU benchmarks.\n    58→\n    59→    Parameters\n    60→    ----------\n    61→    bench_data_root : str, optional\n    62→        Path to the ``bench_data/`` directory.  Defaults to\n    63→        ``InferSim/bench_data/`` relative to this file.\n    64→    \"\"\"\n    65→\n    66→    def __init__(self, bench_data_root: str = None):\n    67→        if bench_data_root is None:\n    68→            bench_data_root = DEFAULT_BENCH_DATA_ROOT\n    69→        self._root = os.path.abspath(bench_data_root)\n    70→\n    71→        # Lazy-loaded caches\n    72→        self._gemm: dict[str, pd.DataFrame] = {}\n    73→        self._mha_decode: dict[str, pd.DataFrame] = {}\n    74→        self._mha_prefill: dict[str, pd.DataFrame] = {}\n    75→        self._grouped_gemm: dict[str, pd.DataFrame] = {}\n    76→        self._loaded = False\n    77→\n    78→    # ------------------------------------------------------------------\n    79→    # Public loading\n    80→    # ------------------------------------------------------------------\n    81→\n    82→    def load(self) -> \"MFUBenchmarkIndex\":\n    83→        \"\"\"Eagerly load all available benchmark data.\n    84→\n    85→        Returns *self* for chaining.\n    86→        \"\"\"\n    87→        self._load_gemm()\n    88→        self._load_mha_decode()\n    89→        self._load_mha_prefill()\n    90→        self._load_grouped_gemm()\n    91→        self._loaded = True\n    92→        return self\n    93→\n    94→    # ------------------------------------------------------------------\n    95→    # GEMM queries\n    96→    # ------------------------------------------------------------------\n    97→\n    98→    def query_gemm_mfu(self, gpu: str, m: int, k: int, n: int) -> float:\n    99→        \"\"\"Look up GEMM MFU for a given (m, k, n) matrix shape.\n   100→\n   101→        Parameters\n   102→        ----------\n   103→        gpu : str\n   104→            GPU identifier (e.g. ``\"h100\"``).\n   105→        m, k, n : int\n   106→            GEMM dimensions.\n   107→\n   108→        Returns\n   109→        -------\n   110→        float\n   111→            MFU value.  Exact match preferred; falls back to nearest\n   112→            neighbor in (m, k, n) space.\n   113→\n   114→        Raises\n   115→        ------\n   116→        ValueError\n   117→            If no GEMM data is available for *gpu*.\n   118→        \"\"\"\n   119→        self._ensure_gemm(gpu)\n   120→        df = self._gemm[gpu]\n   121→\n   122→        exact = df[(df[\"m\"] == m) & (df[\"k\"] == k) & (df[\"n\"] == n)]\n   123→        if len(exact) > 0:\n   124→            return float(exact.iloc[0][\"mfu\"])\n   125→\n   126→        row = _nearest_row(df, [\"m\", \"k\", \"n\"], [m, k, n])\n   127→        return float(row[\"mfu\"])\n   128→\n   129→    # ------------------------------------------------------------------\n   130→    # MHA decode queries\n   131→    # ------------------------------------------------------------------\n   132→\n   133→    def query_mha_decode_mfu(\n   134→        self,\n   135→        gpu: str,\n   136→        num_heads: int,\n   137→        num_kv_heads: int,\n   138→        head_dim: int,\n   139→        batch_size: int,\n   140→        kv_len: int,\n   141→        tp: int = 1,\n   142→    ) -> float:\n   143→        \"\"\"Look up MHA decode MFU.\n   144→\n   145→        Parameters\n   146→        ----------\n   147→        gpu : str\n   148→            GPU identifier.\n   149→        num_heads, num_kv_heads, head_dim : int\n   150→            Attention head configuration.\n   151→        batch_size : int\n   152→            Batch size.\n   153→        kv_len : int\n   154→            KV cache length.\n   155→        tp : int\n   156→            Tensor parallelism degree (default 1).\n   157→\n   158→        Returns\n   159→        -------\n   160→        float\n   161→            MFU value.\n   162→\n   163→        Raises\n   164→        ------\n   165→        ValueError\n   166→            If no matching benchmark file exists.\n   167→        \"\"\"\n   168→        self._ensure_mha_decode(gpu)\n   169→        key = self._mha_decode_key(gpu, num_heads, num_kv_heads, head_dim, tp)\n   170→        if key not in self._mha_decode:\n   171→            raise ValueError(\n   172→                f\"No MHA decode benchmark for gpu={gpu}, \"\n   173→                f\"heads={num_heads}-{num_kv_heads}-{head_dim}, tp={tp}\"\n   174→            )\n   175→        df = self._mha_decode[key]\n   176→\n   177→        exact = df[(df[\"batch_size\"] == batch_size) & (df[\"kv_len\"] == kv_len)]\n   178→        if len(exact) > 0:\n   179→            return float(exact.iloc[0][\"mfu\"])\n   180→\n   181→        row = _nearest_row(df, [\"batch_size\", \"kv_len\"], [batch_size, kv_len])\n   182→        return float(row[\"mfu\"])\n   183→\n   184→    # ------------------------------------------------------------------\n   185→    # MHA prefill queries\n   186→    # ------------------------------------------------------------------\n   187→\n   188→    def query_mha_prefill_mfu(\n   189→        self,\n   190→        gpu: str,\n   191→        num_heads: int,\n   192→        num_kv_heads: int,\n   193→        head_dim: int,\n   194→        seq_len: int,\n   195→    ) -> float:\n   196→        \"\"\"Look up MHA prefill MFU.\n   197→\n   198→        Parameters\n   199→        ----------\n   200→        gpu : str\n   201→            GPU identifier.\n   202→        num_heads, num_kv_heads, head_dim : int\n   203→            Attention head configuration.\n   204→        seq_len : int\n   205→            Sequence length.\n   206→\n   207→        Returns\n   208→        -------\n   209→        float\n   210→            MFU value.\n   211→\n   212→        Raises\n   213→        ------\n   214→        ValueError\n   215→            If no matching benchmark file exists.\n   216→        \"\"\"\n   217→        self._ensure_mha_prefill(gpu)\n   218→        key = self._mha_prefill_key(gpu, num_heads, num_kv_heads, head_dim)\n   219→        if key not in self._mha_prefill:\n   220→            raise ValueError(\n   221→                f\"No MHA prefill benchmark for gpu={gpu}, \"\n   222→                f\"heads={num_heads}-{num_kv_heads}-{head_dim}\"\n   223→            )\n   224→        df = self._mha_prefill[key]\n   225→\n   226→        exact = df[df[\"seq_len\"] == seq_len]\n   227→        if len(exact) > 0:\n   228→            return float(exact.iloc[0][\"mfu\"])\n   229→\n   230→        row = _nearest_row(df, [\"seq_len\"], [seq_len])\n   231→        return float(row[\"mfu\"])\n   232→\n   233→    # ------------------------------------------------------------------\n   234→    # Grouped GEMM queries (MoE)\n   235→    # ------------------------------------------------------------------\n   236→\n   237→    def query_grouped_gemm_mfu(self, gpu: str, phase: str, **kwargs) -> dict:\n   238→        \"\"\"Look up grouped GEMM (MoE) MFU.\n   239→\n   240→        Parameters\n   241→        ----------\n   242→        gpu : str\n   243→            GPU identifier.\n   244→        phase : str\n   245→            ``\"decode\"`` or ``\"prefill\"``.\n   246→        **kwargs\n   247→            Filter columns to match (e.g. ``batch_size_per_gpu=128``).\n   248→\n   249→        Returns\n   250→        -------\n   251→        dict\n   252→            Dictionary with at least ``up_mfu`` and ``down_mfu`` keys,\n   253→            plus all columns from the matched row.\n   254→\n   255→        Raises\n   256→        ------\n   257→        ValueError\n   258→            If no grouped GEMM data is available for *gpu*/*phase*, or\n   259→            *phase* is invalid.\n   260→        \"\"\"\n   261→        if phase not in (\"decode\", \"prefill\"):\n   262→            raise ValueError(f\"phase must be 'decode' or 'prefill', got {phase!r}\")\n   263→\n   264→        self._ensure_grouped_gemm(gpu, phase)\n   265→        key = f\"{gpu}/{phase}\"\n   266→        if key not in self._grouped_gemm:\n   267→            raise ValueError(\n   268→                f\"No grouped GEMM benchmark for gpu={gpu}, phase={phase}\"\n   269→            )\n   270→        df = self._grouped_gemm[key]\n   271→\n   272→        # Try exact match on all provided kwargs\n   273→        mask = pd.Series(True, index=df.index)\n   274→        filter_cols = []\n   275→        filter_vals = []\n   276→        for col, val in kwargs.items():\n   277→            if col in df.columns:\n   278→                mask = mask & (df[col] == val)\n   279→                filter_cols.append(col)\n   280→                filter_vals.append(val)\n   281→\n   282→        exact = df[mask]\n   283→        if len(exact) > 0:\n   284→            row = exact.iloc[0]\n   285→        elif filter_cols:\n   286→            row = _nearest_row(df, filter_cols, filter_vals)\n   287→        else:\n   288→            row = df.iloc[0]\n   289→\n   290→        return row.to_dict()\n   291→\n   292→    # ------------------------------------------------------------------\n   293→    # Discovery helpers\n   294→    # ------------------------------------------------------------------\n   295→\n   296→    def available_gpus(self) -> list[str]:\n   297→        \"\"\"List GPU types with any benchmark data.\n   298→\n   299→        Scans the GEMM and MHA directories for GPU subdirectories.\n   300→\n   301→        Returns\n   302→        -------\n   303→        list[str]\n   304→            Sorted list of GPU identifiers (e.g. ``[\"h100\", \"h20\", \"h800\"]``).\n   305→        \"\"\"\n   306→        gpus: set[str] = set()\n   307→        for subdir in (\"gemm\", \"mha/decode\", \"mha/prefill\",\n   308→                        \"grouped_gemm/decode\", \"grouped_gemm/prefill\"):\n   309→            path = os.path.join(self._root, subdir)\n   310→            if os.path.isdir(path):\n   311→                for name in os.listdir(path):\n   312→                    if os.path.isdir(os.path.join(path, name)):\n   313→                        gpus.add(name)\n   314→        return sorted(gpus)\n   315→\n   316→    def available_benchmarks(self) -> dict:\n   317→        \"\"\"Summarize what benchmarks are available.\n   318→\n   319→        Returns\n   320→        -------\n   321→        dict\n   322→            Mapping of benchmark family to list of GPU types that have\n   323→            data for that family.\n   324→        \"\"\"\n   325→        result = {}\n   326→        families = {\n   327→            \"gemm\": \"gemm\",\n   328→            \"mha_decode\": \"mha/decode\",\n   329→            \"mha_prefill\": \"mha/prefill\",\n   330→            \"grouped_gemm_decode\": \"grouped_gemm/decode\",\n   331→            \"grouped_gemm_prefill\": \"grouped_gemm/prefill\",\n   332→        }\n   333→        for family_name, subdir in families.items():\n   334→            path = os.path.join(self._root, subdir)\n   335→            if os.path.isdir(path):\n   336→                gpus = sorted(\n   337→                    name\n   338→                    for name in os.listdir(path)\n   339→                    if os.path.isdir(os.path.join(path, name))\n   340→                )\n   341→                if gpus:\n   342→                    result[family_name] = gpus\n   343→        return result\n   344→\n   345→    # ------------------------------------------------------------------\n   346→    # Internal loading helpers\n   347→    # ------------------------------------------------------------------\n   348→\n   349→    def _ensure_gemm(self, gpu: str) -> None:\n   350→        \"\"\"Ensure GEMM data for *gpu* is loaded.\"\"\"\n   351→        if gpu in self._gemm:\n   352→            return\n   353→        csv_path = os.path.join(self._root, \"gemm\", gpu, \"data.csv\")\n   354→        if not os.path.isfile(csv_path):\n   355→            raise ValueError(\n   356→                f\"No GEMM benchmark data for gpu={gpu!r} \"\n   357→                f\"(expected {csv_path})\"\n   358→            )\n   359→        df = pd.read_csv(csv_path)\n   360→        # Ensure numeric types\n   361→        for col in (\"m\", \"k\", \"n\"):\n   362→            df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n   363→        df[\"mfu\"] = pd.to_numeric(df[\"mfu\"], errors=\"coerce\")\n   364→        self._gemm[gpu] = df\n   365→\n   366→    def _load_gemm(self) -> None:\n   367→        \"\"\"Load GEMM data for all available GPUs.\"\"\"\n   368→        gemm_dir = os.path.join(self._root, \"gemm\")\n   369→        if not os.path.isdir(gemm_dir):\n   370→            return\n   371→        for gpu in os.listdir(gemm_dir):\n   372→            gpu_dir = os.path.join(gemm_dir, gpu)\n   373→            if os.path.isdir(gpu_dir):\n   374→                try:\n   375→                    self._ensure_gemm(gpu)\n   376→                except ValueError:\n   377→                    pass\n   378→\n   379→    @staticmethod\n   380→    def _mha_decode_key(\n   381→        gpu: str, num_heads: int, num_kv_heads: int, head_dim: int, tp: int\n   382→    ) -> str:\n   383→        if tp > 1:\n   384→            return f\"{gpu}/{num_heads}-{num_kv_heads}-{head_dim}-tp{tp}\"\n   385→        return f\"{gpu}/{num_heads}-{num_kv_heads}-{head_dim}\"\n   386→\n   387→    def _ensure_mha_decode(self, gpu: str) -> None:\n   388→        \"\"\"Load all MHA decode CSVs for *gpu* if not already loaded.\"\"\"\n   389→        # Check if we already loaded this GPU (use a sentinel)\n   390→        sentinel = f\"_loaded_mha_decode_{gpu}\"\n   391→        if hasattr(self, sentinel):\n   392→            return\n   393→\n   394→        decode_dir = os.path.join(self._root, \"mha\", \"decode\", gpu)\n   395→        if not os.path.isdir(decode_dir):\n   396→            raise ValueError(\n   397→                f\"No MHA decode benchmark data for gpu={gpu!r} \"\n   398→                f\"(expected directory {decode_dir})\"\n   399→            )\n   400→        for fname in os.listdir(decode_dir):\n   401→            m = _MHA_DECODE_PATTERN.match(fname)\n   402→            if not m:\n   403→                continue\n   404→            num_heads = int(m.group(1))\n   405→            num_kv_heads = int(m.group(2))\n   406→            head_dim = int(m.group(3))\n   407→            tp = int(m.group(4)) if m.group(4) else 1\n   408→            key = self._mha_decode_key(gpu, num_heads, num_kv_heads, head_dim, tp)\n   409→            csv_path = os.path.join(decode_dir, fname)\n   410→            df = pd.read_csv(csv_path)\n   411→            for col in (\"batch_size\", \"kv_len\"):\n   412→                if col in df.columns:\n   413→                    df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n   414→            if \"mfu\" in df.columns:\n   415→                df[\"mfu\"] = pd.to_numeric(df[\"mfu\"], errors=\"coerce\")\n   416→            self._mha_decode[key] = df\n   417→\n   418→        setattr(self, sentinel, True)\n   419→\n   420→    def _load_mha_decode(self) -> None:\n   421→        \"\"\"Load MHA decode data for all available GPUs.\"\"\"\n   422→        decode_dir = os.path.join(self._root, \"mha\", \"decode\")\n   423→        if not os.path.isdir(decode_dir):\n   424→            return\n   425→        for gpu in os.listdir(decode_dir):\n   426→            if os.path.isdir(os.path.join(decode_dir, gpu)):\n   427→                try:\n   428→                    self._ensure_mha_decode(gpu)\n   429→                except ValueError:\n   430→                    pass\n   431→\n   432→    @staticmethod\n   433→    def _mha_prefill_key(\n   434→        gpu: str, num_heads: int, num_kv_heads: int, head_dim: int\n   435→    ) -> str:\n   436→        return f\"{gpu}/{num_heads}-{num_kv_heads}-{head_dim}\"\n   437→\n   438→    def _ensure_mha_prefill(self, gpu: str) -> None:\n   439→        \"\"\"Load all MHA prefill CSVs for *gpu* if not already loaded.\"\"\"\n   440→        sentinel = f\"_loaded_mha_prefill_{gpu}\"\n   441→        if hasattr(self, sentinel):\n   442→            return\n   443→\n   444→        prefill_dir = os.path.join(self._root, \"mha\", \"prefill\", gpu)\n   445→        if not os.path.isdir(prefill_dir):\n   446→            raise ValueError(\n   447→                f\"No MHA prefill benchmark data for gpu={gpu!r} \"\n   448→                f\"(expected directory {prefill_dir})\"\n   449→            )\n   450→        for fname in os.listdir(prefill_dir):\n   451→            m = _MHA_PREFILL_PATTERN.match(fname)\n   452→            if not m:\n   453→                continue\n   454→            num_heads = int(m.group(1))\n   455→            num_kv_heads = int(m.group(2))\n   456→            head_dim = int(m.group(3))\n   457→            key = self._mha_prefill_key(gpu, num_heads, num_kv_heads, head_dim)\n   458→            csv_path = os.path.join(prefill_dir, fname)\n   459→            df = pd.read_csv(csv_path)\n   460→            if \"seq_len\" in df.columns:\n   461→                df[\"seq_len\"] = pd.to_numeric(df[\"seq_len\"], errors=\"coerce\")\n   462→            if \"mfu\" in df.columns:\n   463→                df[\"mfu\"] = pd.to_numeric(df[\"mfu\"], errors=\"coerce\")\n   464→            self._mha_prefill[key] = df\n   465→\n   466→        setattr(self, sentinel, True)\n   467→\n   468→    def _load_mha_prefill(self) -> None:\n   469→        \"\"\"Load MHA prefill data for all available GPUs.\"\"\"\n   470→        prefill_dir = os.path.join(self._root, \"mha\", \"prefill\")\n   471→        if not os.path.isdir(prefill_dir):\n   472→            return\n   473→        for gpu in os.listdir(prefill_dir):\n   474→            if os.path.isdir(os.path.join(prefill_dir, gpu)):\n   475→                try:\n   476→                    self._ensure_mha_prefill(gpu)\n   477→                except ValueError:\n   478→                    pass\n   479→\n   480→    def _ensure_grouped_gemm(self, gpu: str, phase: str) -> None:\n   481→        \"\"\"Load grouped GEMM data for *gpu*/*phase* if not already loaded.\"\"\"\n   482→        key = f\"{gpu}/{phase}\"\n   483→        if key in self._grouped_gemm:\n   484→            return\n   485→        csv_path = os.path.join(\n   486→            self._root, \"grouped_gemm\", phase, gpu, \"data.csv\"\n   487→        )\n   488→        if not os.path.isfile(csv_path):\n   489→            raise ValueError(\n   490→                f\"No grouped GEMM benchmark data for gpu={gpu!r}, \"\n   491→                f\"phase={phase!r} (expected {csv_path})\"\n   492→            )\n   493→        df = pd.read_csv(csv_path)\n   494→        # Coerce numeric columns\n   495→        for col in df.columns:\n   496→            if col not in (\"dtype\", \"kv_dtype\"):\n   497→                df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n   498→        self._grouped_gemm[key] = df\n   499→\n   500→    def _load_grouped_gemm(self) -> None:\n   501→        \"\"\"Load grouped GEMM data for all available GPUs and phases.\"\"\"\n   502→        for phase in (\"decode\", \"prefill\"):\n   503→            phase_dir = os.path.join(self._root, \"grouped_gemm\", phase)\n   504→            if not os.path.isdir(phase_dir):\n   505→                continue\n   506→            for gpu in os.listdir(phase_dir):\n   507→                if os.path.isdir(os.path.join(phase_dir, gpu)):\n   508→                    try:\n   509→                        self._ensure_grouped_gemm(gpu, phase)\n   510→                    except ValueError:\n   511→                        pass\n   512→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"7c9943cd-0f6f-4cf6-b3e9-95fde5bd1ea6"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_017j6bv4muZzs4QsvF4oj5sX","type":"tool_result","content":"     1→\"\"\"Component-level error attribution for E2E latency prediction.\n     2→\n     3→Analyzes which of the 5 LatencyModel methods contributes most to E2E\n     4→prediction error.  This informs research ideation by identifying where\n     5→to focus improvement efforts.\n     6→\n     7→E2E(request) = QueueingTime(req)              [1] arrival-to-queue delay\n     8→             + (time waiting in WaitQ)         [2] emergent from simulation dynamics\n     9→             + SchedulingProcessingTime()      [3] per-request scheduling overhead\n    10→             + sum StepTime(batch)             [4] GPU execution per batch step\n    11→             + sum OutputTokenProcessingTime() [5] per-token post-processing\n    12→             + KV transfer latency             [6] CPU<->GPU offload/reload\n    13→             + PreemptionProcessingTime()      [7] if preempted and re-queued\n    14→\n    15→The 5 LatencyModel methods and their blackbox implementations:\n    16→  1. StepTime:                     beta0 + beta1*prefill + beta2*decode\n    17→  2. QueueingTime:                 alpha0 + alpha1*input_len\n    18→  3. OutputTokenProcessingTime:    constant alpha2 (per output token)\n    19→  4. SchedulingProcessingTime:     returns 0\n    20→  5. PreemptionProcessingTime:     returns 0\n    21→\n    22→All percentage values are returned as floats where 10.0 means 10%.\n    23→All time values are in microseconds unless otherwise noted.\n    24→\"\"\"\n    25→\n    26→from __future__ import annotations\n    27→\n    28→import os\n    29→\n    30→import numpy as np\n    31→import pandas as pd\n    32→\n    33→from evaluation import compute_mape, compute_mspe, compute_p99_error, compute_pearson_r\n    34→from data_loader import DEFAULT_DATA_ROOT, load_all_experiments, load_lifecycle_data\n    35→\n    36→\n    37→def compute_blackbox_step_predictions(\n    38→    steps_df: pd.DataFrame,\n    39→    beta_coeffs: list[float],\n    40→) -> pd.Series:\n    41→    \"\"\"Predict step time using blackbox model: beta0 + beta1*prefill + beta2*decode.\n    42→\n    43→    Args:\n    44→        steps_df: DataFrame with batch.prefill_tokens and batch.decode_tokens columns.\n    45→        beta_coeffs: [beta0, beta1, beta2].\n    46→\n    47→    Returns:\n    48→        Series of predicted step times (microseconds).\n    49→    \"\"\"\n    50→    if len(beta_coeffs) != 3:\n    51→        raise ValueError(f\"Expected 3 beta coefficients, got {len(beta_coeffs)}\")\n    52→\n    53→    beta0, beta1, beta2 = beta_coeffs\n    54→    prefill = steps_df[\"batch.prefill_tokens\"].astype(np.float64)\n    55→    decode = steps_df[\"batch.decode_tokens\"].astype(np.float64)\n    56→    predicted = beta0 + beta1 * prefill + beta2 * decode\n    57→    return predicted\n    58→\n    59→\n    60→def compute_step_time_error(\n    61→    steps_df: pd.DataFrame,\n    62→    beta_coeffs: list[float],\n    63→) -> dict:\n    64→    \"\"\"Compute step time prediction error metrics.\n    65→\n    66→    Args:\n    67→        steps_df: DataFrame with batch.prefill_tokens, batch.decode_tokens,\n    68→            and step.duration_us columns.\n    69→        beta_coeffs: [beta0, beta1, beta2].\n    70→\n    71→    Returns:\n    72→        Dict with keys: mape, mspe (signed), pearson_r, p99_error,\n    73→        mean_predicted, mean_actual, total_predicted, total_actual.\n    74→    \"\"\"\n    75→    predicted = compute_blackbox_step_predictions(steps_df, beta_coeffs).values\n    76→    actual = steps_df[\"step.duration_us\"].astype(np.float64).values\n    77→\n    78→    # pearsonr requires at least 2 data points\n    79→    if len(predicted) < 2:\n    80→        pearson_r = 0.0\n    81→    else:\n    82→        pearson_r = compute_pearson_r(predicted, actual)\n    83→        if np.isnan(pearson_r):\n    84→            pearson_r = 0.0\n    85→\n    86→    return {\n    87→        \"mape\": float(compute_mape(predicted, actual)),\n    88→        \"mspe\": float(compute_mspe(predicted, actual)),\n    89→        \"pearson_r\": float(pearson_r),\n    90→        \"p99_error\": float(compute_p99_error(predicted, actual)),\n    91→        \"mean_predicted\": float(np.mean(predicted)),\n    92→        \"mean_actual\": float(np.mean(actual)),\n    93→        \"total_predicted\": float(np.sum(predicted)),\n    94→        \"total_actual\": float(np.sum(actual)),\n    95→    }\n    96→\n    97→\n    98→def estimate_queueing_contribution(\n    99→    lifecycle_df: pd.DataFrame,\n   100→    alpha_coeffs: list[float],\n   101→) -> dict:\n   102→    \"\"\"Estimate queueing time contribution.\n   103→\n   104→    For each request: queueing = alpha0 + alpha1 * input_tokens.\n   105→    Compares total predicted queueing time against total E2E time.\n   106→\n   107→    Args:\n   108→        lifecycle_df: DataFrame indexed by request_id with columns:\n   109→            start_time, end_time, input_tokens.\n   110→        alpha_coeffs: [alpha0, alpha1, alpha2] (alpha2 unused here).\n   111→\n   112→    Returns:\n   113→        Dict with keys: mean_queueing_us, total_queueing_us, fraction_of_e2e.\n   114→        fraction_of_e2e = total_queueing / total_e2e where\n   115→        e2e = end_time - start_time.\n   116→    \"\"\"\n   117→    alpha0 = alpha_coeffs[0]\n   118→    alpha1 = alpha_coeffs[1]\n   119→\n   120→    input_tokens = lifecycle_df[\"input_tokens\"].astype(np.float64).values\n   121→    queueing = alpha0 + alpha1 * input_tokens\n   122→\n   123→    e2e = (\n   124→        lifecycle_df[\"end_time\"].astype(np.float64).values\n   125→        - lifecycle_df[\"start_time\"].astype(np.float64).values\n   126→    )\n   127→    total_e2e = float(np.sum(e2e))\n   128→    total_queueing = float(np.sum(queueing))\n   129→\n   130→    if total_e2e == 0:\n   131→        fraction = 0.0\n   132→    else:\n   133→        fraction = total_queueing / total_e2e\n   134→\n   135→    return {\n   136→        \"mean_queueing_us\": float(np.mean(queueing)),\n   137→        \"total_queueing_us\": total_queueing,\n   138→        \"fraction_of_e2e\": fraction,\n   139→    }\n   140→\n   141→\n   142→def estimate_output_processing_contribution(\n   143→    lifecycle_df: pd.DataFrame,\n   144→    alpha2: float,\n   145→) -> dict:\n   146→    \"\"\"Estimate output token processing contribution.\n   147→\n   148→    For each request: output_processing = alpha2 * output_tokens.\n   149→\n   150→    Args:\n   151→        lifecycle_df: DataFrame indexed by request_id with columns:\n   152→            start_time, end_time, output_tokens.\n   153→        alpha2: Per-token processing time (microseconds).\n   154→\n   155→    Returns:\n   156→        Dict with keys: mean_output_us, total_output_us, fraction_of_e2e.\n   157→    \"\"\"\n   158→    output_tokens = lifecycle_df[\"output_tokens\"].astype(np.float64).values\n   159→    output_processing = alpha2 * output_tokens\n   160→\n   161→    e2e = (\n   162→        lifecycle_df[\"end_time\"].astype(np.float64).values\n   163→        - lifecycle_df[\"start_time\"].astype(np.float64).values\n   164→    )\n   165→    total_e2e = float(np.sum(e2e))\n   166→    total_output = float(np.sum(output_processing))\n   167→\n   168→    if total_e2e == 0:\n   169→        fraction = 0.0\n   170→    else:\n   171→        fraction = total_output / total_e2e\n   172→\n   173→    return {\n   174→        \"mean_output_us\": float(np.mean(output_processing)),\n   175→        \"total_output_us\": total_output,\n   176→        \"fraction_of_e2e\": fraction,\n   177→    }\n   178→\n   179→\n   180→def estimate_step_time_contribution(\n   181→    steps_df: pd.DataFrame,\n   182→    lifecycle_df: pd.DataFrame,\n   183→) -> dict:\n   184→    \"\"\"Estimate step time's share of total E2E time from ground truth.\n   185→\n   186→    Sums all step.duration_us and compares against total E2E from lifecycle.\n   187→\n   188→    Args:\n   189→        steps_df: DataFrame with step.duration_us column.\n   190→        lifecycle_df: DataFrame indexed by request_id with start_time, end_time.\n   191→\n   192→    Returns:\n   193→        Dict with keys: total_step_us, total_e2e_us, fraction_of_e2e,\n   194→        mean_steps_per_request (total steps / number of requests).\n   195→    \"\"\"\n   196→    total_step = float(steps_df[\"step.duration_us\"].astype(np.float64).sum())\n   197→\n   198→    e2e = (\n   199→        lifecycle_df[\"end_time\"].astype(np.float64).values\n   200→        - lifecycle_df[\"start_time\"].astype(np.float64).values\n   201→    )\n   202→    total_e2e = float(np.sum(e2e))\n   203→    n_requests = len(lifecycle_df)\n   204→    n_steps = len(steps_df)\n   205→\n   206→    if total_e2e == 0:\n   207→        fraction = 0.0\n   208→    else:\n   209→        fraction = total_step / total_e2e\n   210→\n   211→    if n_requests == 0:\n   212→        mean_steps_per_request = 0.0\n   213→    else:\n   214→        mean_steps_per_request = n_steps / n_requests\n   215→\n   216→    return {\n   217→        \"total_step_us\": total_step,\n   218→        \"total_e2e_us\": total_e2e,\n   219→        \"fraction_of_e2e\": fraction,\n   220→        \"mean_steps_per_request\": mean_steps_per_request,\n   221→    }\n   222→\n   223→\n   224→def component_error_attribution(\n   225→    steps_df: pd.DataFrame,\n   226→    lifecycle_df: pd.DataFrame,\n   227→    alpha_coeffs: list[float],\n   228→    beta_coeffs: list[float],\n   229→) -> dict:\n   230→    \"\"\"Full component-level error attribution report.\n   231→\n   232→    Combines step-time error metrics, queueing contribution, output\n   233→    processing contribution, and step-time contribution fractions into\n   234→    a unified report that identifies where E2E prediction error originates.\n   235→\n   236→    Args:\n   237→        steps_df: DataFrame with batch.prefill_tokens, batch.decode_tokens,\n   238→            step.duration_us.\n   239→        lifecycle_df: DataFrame indexed by request_id with start_time,\n   240→            end_time, input_tokens, output_tokens.\n   241→        alpha_coeffs: [alpha0, alpha1, alpha2].\n   242→        beta_coeffs: [beta0, beta1, beta2].\n   243→\n   244→    Returns:\n   245→        Dict with keys:\n   246→        - step_time: step-level error metrics + contribution fraction\n   247→        - queueing_time: predicted contribution + fraction of E2E\n   248→        - output_processing: predicted contribution + fraction of E2E\n   249→        - scheduling: current status (returns 0)\n   250→        - preemption: current status (returns 0)\n   251→        - summary: which component dominates E2E error\n   252→        - recommendation: where to focus improvement\n   253→    \"\"\"\n   254→    # Step time error metrics\n   255→    step_error = compute_step_time_error(steps_df, beta_coeffs)\n   256→\n   257→    # Step time contribution to E2E\n   258→    step_contrib = estimate_step_time_contribution(steps_df, lifecycle_df)\n   259→\n   260→    # Queueing time contribution\n   261→    queueing = estimate_queueing_contribution(lifecycle_df, alpha_coeffs)\n   262→\n   263→    # Output processing contribution\n   264→    alpha2 = alpha_coeffs[2] if len(alpha_coeffs) >= 3 else 0.0\n   265→    output = estimate_output_processing_contribution(lifecycle_df, alpha2)\n   266→\n   267→    # Identify dominant error source\n   268→    step_frac = step_contrib[\"fraction_of_e2e\"]\n   269→    queue_frac = queueing[\"fraction_of_e2e\"]\n   270→    output_frac = output[\"fraction_of_e2e\"]\n   271→\n   272→    fractions = {\n   273→        \"step_time\": step_frac,\n   274→        \"queueing_time\": queue_frac,\n   275→        \"output_processing\": output_frac,\n   276→    }\n   277→    dominant_component = max(fractions, key=fractions.get)\n   278→\n   279→    summary = (\n   280→        f\"Step time accounts for {step_frac:.1%} of total E2E, \"\n   281→        f\"with MAPE={step_error['mape']:.1f}% and MSPE={step_error['mspe']:.1f}%. \"\n   282→        f\"Queueing accounts for {queue_frac:.1%}, \"\n   283→        f\"output processing for {output_frac:.1%}. \"\n   284→        f\"Dominant component: {dominant_component}.\"\n   285→    )\n   286→\n   287→    if dominant_component == \"step_time\" and step_error[\"mape\"] > 10.0:\n   288→        recommendation = (\n   289→            \"Step time dominates E2E and has significant prediction error \"\n   290→            f\"(MAPE={step_error['mape']:.1f}%). Focus on improving StepTime \"\n   291→            \"prediction (beta coefficients or ML replacement).\"\n   292→        )\n   293→    elif dominant_component == \"queueing_time\":\n   294→        recommendation = (\n   295→            \"Queueing time dominates E2E. Focus on improving QueueingTime \"\n   296→            \"prediction (alpha0/alpha1 coefficients) or reducing actual queueing.\"\n   297→        )\n   298→    elif dominant_component == \"output_processing\":\n   299→        recommendation = (\n   300→            \"Output processing dominates E2E. Focus on improving \"\n   301→            \"OutputTokenProcessingTime (alpha2 coefficient).\"\n   302→        )\n   303→    else:\n   304→        recommendation = (\n   305→            f\"Step time dominates E2E with low error (MAPE={step_error['mape']:.1f}%). \"\n   306→            \"Consider whether other components (scheduling, preemption) are \"\n   307→            \"under-modeled.\"\n   308→        )\n   309→\n   310→    return {\n   311→        \"step_time\": {\n   312→            **step_error,\n   313→            \"fraction_of_e2e\": step_frac,\n   314→            \"mean_steps_per_request\": step_contrib[\"mean_steps_per_request\"],\n   315→        },\n   316→        \"queueing_time\": queueing,\n   317→        \"output_processing\": output,\n   318→        \"scheduling\": {\n   319→            \"current_value\": 0.0,\n   320→            \"note\": (\n   321→                \"SchedulingProcessingTime currently returns 0. \"\n   322→                \"If real scheduling overhead is non-trivial, this is an \"\n   323→                \"unmodeled error source.\"\n   324→            ),\n   325→        },\n   326→        \"preemption\": {\n   327→            \"current_value\": 0.0,\n   328→            \"note\": (\n   329→                \"PreemptionProcessingTime currently returns 0. \"\n   330→                \"If preemptions are frequent, this is an unmodeled error source.\"\n   331→            ),\n   332→        },\n   333→        \"summary\": summary,\n   334→        \"recommendation\": recommendation,\n   335→    }\n   336→\n   337→\n   338→def component_error_attribution_all_experiments(\n   339→    data_root: str = None,\n   340→    coefficients: dict = None,\n   341→) -> pd.DataFrame:\n   342→    \"\"\"Run error attribution across all experiments.\n   343→\n   344→    Iterates over experiment directories under data_root, loads step-level\n   345→    and lifecycle data for each, and computes per-experiment error\n   346→    attribution using the provided (or default zero) coefficients.\n   347→\n   348→    Args:\n   349→        data_root: Path to ground truth data directory. Defaults to\n   350→            eval/ground_truth/ relative to this file.\n   351→        coefficients: Optional dict mapping experiment_id to\n   352→            {\"alpha\": [a0, a1, a2], \"beta\": [b0, b1, b2]}.\n   353→            If None or if an experiment_id is missing, uses zeros.\n   354→\n   355→    Returns:\n   356→        DataFrame with one row per experiment, columns for each component's\n   357→        error contribution and fraction.\n   358→    \"\"\"\n   359→    if data_root is None:\n   360→        data_root = DEFAULT_DATA_ROOT\n   361→\n   362→    if coefficients is None:\n   363→        coefficients = {}\n   364→\n   365→    default_alpha = [0.0, 0.0, 0.0]\n   366→    default_beta = [0.0, 0.0, 0.0]\n   367→\n   368→    rows = []\n   369→    for dirname in sorted(os.listdir(data_root)):\n   370→        dirpath = os.path.join(data_root, dirname)\n   371→        if not os.path.isdir(dirpath):\n   372→            continue\n   373→        traces_path = os.path.join(dirpath, \"traces.json\")\n   374→        lifecycle_path = os.path.join(\n   375→            dirpath, \"results\", \"per_request_lifecycle_metrics.json\"\n   376→        )\n   377→        if not os.path.isfile(traces_path) or not os.path.isfile(lifecycle_path):\n   378→            continue\n   379→\n   380→        from data_loader import load_experiment_steps, load_lifecycle_data as _load_lc\n   381→\n   382→        steps_df = load_experiment_steps(dirpath)\n   383→        lifecycle_df = _load_lc(dirpath)\n   384→\n   385→        if steps_df.empty or lifecycle_df.empty:\n   386→            continue\n   387→\n   388→        exp_coeffs = coefficients.get(dirname, {})\n   389→        alpha = exp_coeffs.get(\"alpha\", default_alpha)\n   390→        beta = exp_coeffs.get(\"beta\", default_beta)\n   391→\n   392→        report = component_error_attribution(steps_df, lifecycle_df, alpha, beta)\n   393→\n   394→        rows.append({\n   395→            \"experiment_id\": dirname,\n   396→            \"step_mape\": report[\"step_time\"][\"mape\"],\n   397→            \"step_mspe\": report[\"step_time\"][\"mspe\"],\n   398→            \"step_pearson_r\": report[\"step_time\"][\"pearson_r\"],\n   399→            \"step_p99_error\": report[\"step_time\"][\"p99_error\"],\n   400→            \"step_fraction_of_e2e\": report[\"step_time\"][\"fraction_of_e2e\"],\n   401→            \"queueing_fraction_of_e2e\": report[\"queueing_time\"][\"fraction_of_e2e\"],\n   402→            \"output_fraction_of_e2e\": report[\"output_processing\"][\"fraction_of_e2e\"],\n   403→            \"mean_steps_per_request\": report[\"step_time\"][\"mean_steps_per_request\"],\n   404→            \"recommendation\": report[\"recommendation\"],\n   405→        })\n   406→\n   407→    if not rows:\n   408→        return pd.DataFrame()\n   409→\n   410→    return pd.DataFrame(rows)\n   411→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"a6af8637-7a24-4a4f-9350-cd7b5e41ca49"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01XbZ41ePdhEfe2C7yYmEa6k","type":"tool_result","content":"     1→\"\"\"BLIS validation harness for StepML research.\n     2→\n     3→Runs BLIS on each ground-truth experiment using the *same* vLLM args and\n     4→inference-perf profile, then compares BLIS-predicted latencies against\n     5→observed values.  Produces a per-experiment summary CSV.\n     6→\n     7→All experiment-specific parameters come from the experiment directory itself:\n     8→  - exp-config.yaml   → model, tensor_parallelism, max_model_len,\n     9→                         max_num_batched_tokens, max_num_seqs\n    10→  - profile.yaml      → inference-perf stages + shared_prefix config\n    11→  - vllm.log          → GPU KV cache size (tokens → blocks)\n    12→  - results/summary_lifecycle_metrics.json → ground-truth latencies\n    13→\n    14→Latency coefficients are passed explicitly (--alpha-coeffs / --beta-coeffs)\n    15→or via a StepML model artifact (--stepml-model).\n    16→\n    17→Usage:\n    18→    python validate_blis.py --alpha-coeffs 0,0,0 --beta-coeffs 0,0,0\n    19→    python validate_blis.py --stepml-model path/to/model.json\n    20→\"\"\"\n    21→\n    22→import argparse\n    23→import csv\n    24→import json\n    25→import os\n    26→import re\n    27→import subprocess\n    28→import sys\n    29→import tempfile\n    30→\n    31→import yaml\n    32→\n    33→# ---------------------------------------------------------------------------\n    34→# Paths\n    35→# ---------------------------------------------------------------------------\n    36→_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n    37→_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\"))\n    38→DEFAULT_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\n    39→DEFAULT_BINARY = os.path.join(_REPO_ROOT, \"simulation_worker\")\n    40→\n    41→BLOCK_SIZE_TOKENS = 16\n    42→\n    43→\n    44→# ---------------------------------------------------------------------------\n    45→# Experiment parsing helpers\n    46→# ---------------------------------------------------------------------------\n    47→def parse_experiment_dir(dirname: str) -> dict:\n    48→    \"\"\"Parse experiment metadata from directory name.\n    49→\n    50→    Expected format: <timestamp>-<model>-tp<N>-<workload>\n    51→    \"\"\"\n    52→    pattern = re.compile(r\"^(\\d{8}-\\d{6})-(.+)-tp(\\d+)-(\\w+)$\")\n    53→    m = pattern.match(dirname)\n    54→    if m:\n    55→        return {\n    56→            \"timestamp\": m.group(1),\n    57→            \"model\": m.group(2),\n    58→            \"tp\": int(m.group(3)),\n    59→            \"workload\": m.group(4),\n    60→        }\n    61→    # Fallback: find last -tp<N>-\n    62→    tp_matches = list(re.finditer(r\"-tp(\\d+)-\", dirname))\n    63→    if not tp_matches:\n    64→        raise ValueError(f\"Cannot parse experiment dir: {dirname}\")\n    65→    last_tp = tp_matches[-1]\n    66→    return {\n    67→        \"timestamp\": dirname[:15],\n    68→        \"model\": dirname[16:last_tp.start()],\n    69→        \"tp\": int(last_tp.group(1)),\n    70→        \"workload\": dirname[last_tp.end():],\n    71→    }\n    72→\n    73→\n    74→def load_ground_truth_metrics(experiment_dir: str) -> dict:\n    75→    \"\"\"Load summary latency metrics from ground-truth experiment.\"\"\"\n    76→    summary_path = os.path.join(\n    77→        experiment_dir, \"results\", \"summary_lifecycle_metrics.json\"\n    78→    )\n    79→    with open(summary_path) as f:\n    80→        data = json.load(f)\n    81→\n    82→    successes = data.get(\"successes\", {})\n    83→    latency = successes.get(\"latency\", {})\n    84→\n    85→    return {\n    86→        \"e2e_mean_s\": latency.get(\"request_latency\", {}).get(\"mean\", 0),\n    87→        \"ttft_mean_s\": latency.get(\"time_to_first_token\", {}).get(\"mean\", 0),\n    88→        \"itl_mean_s\": latency.get(\"inter_token_latency\", {}).get(\"mean\", 0),\n    89→        \"throughput_rps\": successes.get(\"throughput\", {}).get(\n    90→            \"requests_per_sec\", 0\n    91→        ),\n    92→        \"num_requests\": data.get(\"load_summary\", {}).get(\"count\", 0),\n    93→        \"prompt_len_mean\": successes.get(\"prompt_len\", {}).get(\"mean\", 0),\n    94→        \"output_len_mean\": successes.get(\"output_len\", {}).get(\"mean\", 0),\n    95→    }\n    96→\n    97→\n    98→def load_exp_config(experiment_dir: str) -> dict:\n    99→    \"\"\"Load exp-config.yaml from experiment directory.\"\"\"\n   100→    config_path = os.path.join(experiment_dir, \"exp-config.yaml\")\n   101→    with open(config_path) as f:\n   102→        return yaml.safe_load(f)\n   103→\n   104→\n   105→def load_profile(experiment_dir: str) -> dict:\n   106→    \"\"\"Load profile.yaml (inference-perf config) from experiment directory.\n   107→\n   108→    profile.yaml is JSON despite the .yaml extension.\n   109→    \"\"\"\n   110→    profile_path = os.path.join(experiment_dir, \"profile.yaml\")\n   111→    with open(profile_path) as f:\n   112→        content = f.read()\n   113→    try:\n   114→        return json.loads(content)\n   115→    except json.JSONDecodeError:\n   116→        return yaml.safe_load(content)\n   117→\n   118→\n   119→def extract_kv_blocks_from_vllm_log(experiment_dir: str) -> int | None:\n   120→    \"\"\"Parse vllm.log for 'GPU KV cache size: N tokens' and convert to blocks.\n   121→\n   122→    Returns total KV blocks (tokens / BLOCK_SIZE_TOKENS), or None if not found.\n   123→    \"\"\"\n   124→    vllm_log_path = os.path.join(experiment_dir, \"vllm.log\")\n   125→    if not os.path.isfile(vllm_log_path):\n   126→        return None\n   127→\n   128→    pattern = re.compile(r\"GPU KV cache size:\\s+([\\d,]+)\\s+tokens\")\n   129→    with open(vllm_log_path) as f:\n   130→        for line in f:\n   131→            m = pattern.search(line)\n   132→            if m:\n   133→                tokens = int(m.group(1).replace(\",\", \"\"))\n   134→                return tokens // BLOCK_SIZE_TOKENS\n   135→    return None\n   136→\n   137→\n   138→def extract_cpu_kv_blocks_from_vllm_log(experiment_dir: str) -> int:\n   139→    \"\"\"Parse vllm.log for CPU offloading config and KV cache shape.\n   140→\n   141→    Computes CPU KV blocks from:\n   142→      - cpu_bytes_to_use from kv_connector_extra_config\n   143→      - per-block size derived from the KV cache shape\n   144→        shape = (num_blocks, num_layers, 2, block_size, num_kv_heads, head_dim)\n   145→        per_block_bytes = num_layers * 2 * block_size * num_kv_heads * head_dim * 2 (fp16)\n   146→\n   147→    Returns 0 if no offloading config found.\n   148→    \"\"\"\n   149→    vllm_log_path = os.path.join(experiment_dir, \"vllm.log\")\n   150→    if not os.path.isfile(vllm_log_path):\n   151→        return 0\n   152→\n   153→    cpu_bytes = None\n   154→    kv_shape = None\n   155→    cpu_pattern = re.compile(r\"cpu_bytes_to_use['\\\"]?:\\s*([\\d.]+)\")\n   156→    shape_pattern = re.compile(\n   157→        r\"cross layer KV cache of shape \\((\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+)\\)\"\n   158→    )\n   159→\n   160→    with open(vllm_log_path) as f:\n   161→        for line in f:\n   162→            if cpu_bytes is None:\n   163→                m = cpu_pattern.search(line)\n   164→                if m:\n   165→                    cpu_bytes = float(m.group(1))\n   166→            if kv_shape is None:\n   167→                m = shape_pattern.search(line)\n   168→                if m:\n   169→                    kv_shape = tuple(int(m.group(i)) for i in range(1, 7))\n   170→            if cpu_bytes is not None and kv_shape is not None:\n   171→                break\n   172→\n   173→    if cpu_bytes is None or kv_shape is None or cpu_bytes == 0:\n   174→        return 0\n   175→\n   176→    # shape = (num_blocks, num_layers, 2, block_size, num_kv_heads, head_dim)\n   177→    _, num_layers, _, block_size, num_kv_heads, head_dim = kv_shape\n   178→    per_block_bytes = num_layers * 2 * block_size * num_kv_heads * head_dim * 2  # fp16\n   179→    return int(cpu_bytes) // per_block_bytes\n   180→\n   181→\n   182→# ---------------------------------------------------------------------------\n   183→# Workload spec construction\n   184→# ---------------------------------------------------------------------------\n   185→def build_workload_spec(profile: dict, ground_truth: dict) -> dict:\n   186→    \"\"\"Build a BLIS workload-spec YAML from inference-perf profile.\n   187→\n   188→    Extracts shared prefix parameters and stage-based load from the profile,\n   189→    then constructs a WorkloadSpec with inference_perf section.\n   190→    \"\"\"\n   191→    data = profile.get(\"data\", {})\n   192→    load_config = profile.get(\"load\", {})\n   193→    sp = data.get(\"shared_prefix\", {})\n   194→\n   195→    stages = []\n   196→    for stage in load_config.get(\"stages\", []):\n   197→        stages.append({\n   198→            \"rate\": stage[\"rate\"],\n   199→            \"duration\": stage[\"duration\"],\n   200→        })\n   201→\n   202→    # Fallback: synthesize a stage from ground-truth throughput\n   203→    if not stages:\n   204→        num_requests = ground_truth.get(\"num_requests\", 1000)\n   205→        rps = ground_truth.get(\"throughput_rps\", 10)\n   206→        duration = int(num_requests / rps) + 60\n   207→        stages.append({\"rate\": rps, \"duration\": duration})\n   208→\n   209→    total_requests = sum(s[\"rate\"] * s[\"duration\"] for s in stages)\n   210→    total_duration_s = sum(s[\"duration\"] for s in stages)\n   211→    horizon_us = int(total_duration_s * 1_000_000) + 60_000_000  # +60s buffer\n   212→\n   213→    # Compute time-weighted average rate (needed by BLIS validation before\n   214→    # InferencePerf expansion fills it in GenerateRequests).\n   215→    aggregate_rate = sum(\n   216→        s[\"rate\"] * s[\"duration\"] for s in stages\n   217→    ) / total_duration_s\n   218→\n   219→    return {\n   220→        \"version\": \"2\",\n   221→        \"seed\": 42,\n   222→        \"num_requests\": int(total_requests),\n   223→        \"horizon\": horizon_us,\n   224→        \"aggregate_rate\": aggregate_rate,\n   225→        \"inference_perf\": {\n   226→            \"stages\": stages,\n   227→            \"shared_prefix\": {\n   228→                \"num_unique_system_prompts\": sp.get(\n   229→                    \"num_unique_system_prompts\", 9\n   230→                ),\n   231→                \"num_users_per_system_prompt\": sp.get(\n   232→                    \"num_users_per_system_prompt\", 5\n   233→                ),\n   234→                \"system_prompt_len\": sp.get(\"system_prompt_len\", 100),\n   235→                \"question_len\": sp.get(\n   236→                    \"question_len\",\n   237→                    int(ground_truth.get(\"prompt_len_mean\", 500)),\n   238→                ),\n   239→                \"output_len\": sp.get(\n   240→                    \"output_len\",\n   241→                    int(ground_truth.get(\"output_len_mean\", 250)),\n   242→                ),\n   243→                \"enable_multi_turn_chat\": sp.get(\n   244→                    \"enable_multi_turn_chat\", False\n   245→                ),\n   246→            },\n   247→        },\n   248→    }\n   249→\n   250→\n   251→# ---------------------------------------------------------------------------\n   252→# BLIS execution\n   253→# ---------------------------------------------------------------------------\n   254→def run_blis(\n   255→    binary: str,\n   256→    workload_spec_path: str,\n   257→    exp_config: dict,\n   258→    total_kv_blocks: int,\n   259→    alpha_coeffs: list[float],\n   260→    beta_coeffs: list[float],\n   261→    results_path: str,\n   262→    stepml_model_path: str | None = None,\n   263→    roofline: bool = False,\n   264→    hardware: str | None = None,\n   265→    cpu_kv_blocks: int = 0,\n   266→) -> dict | None:\n   267→    \"\"\"Run BLIS with the same vLLM args as the ground-truth experiment.\n   268→\n   269→    When roofline=True, uses the analytical roofline latency model instead of\n   270→    alpha/beta coefficients.  Requires hardware (GPU type, e.g. \"H100\").\n   271→\n   272→    Returns dict with e2e_mean_ms, ttft_mean_ms, itl_mean_ms, or None on failure.\n   273→    \"\"\"\n   274→    model_name = exp_config.get(\"model\", \"unknown\")\n   275→    tp = exp_config.get(\"tensor_parallelism\", 1)\n   276→    max_model_len = exp_config.get(\"max_model_len\", 4096)\n   277→    max_num_seqs = exp_config.get(\"max_num_seqs\", 128)\n   278→    max_num_batched_tokens = exp_config.get(\"max_num_batched_tokens\", 2048)\n   279→\n   280→    cmd = [\n   281→        binary,\n   282→        \"run\",\n   283→        \"--model\", model_name,\n   284→        \"--workload-spec\", workload_spec_path,\n   285→        # --- Match vLLM serving args exactly ---\n   286→        \"--tp\", str(tp),\n   287→        \"--max-model-len\", str(max_model_len),\n   288→        \"--max-num-running-reqs\", str(max_num_seqs),\n   289→        \"--max-num-scheduled-tokens\", str(max_num_batched_tokens),\n   290→        \"--total-kv-blocks\", str(total_kv_blocks),\n   291→        \"--block-size-in-tokens\", str(BLOCK_SIZE_TOKENS),\n   292→    ]\n   293→\n   294→    if cpu_kv_blocks > 0:\n   295→        cmd.extend([\"--kv-cpu-blocks\", str(cpu_kv_blocks)])\n   296→\n   297→    if roofline:\n   298→        if not hardware:\n   299→            raise ValueError(\"roofline=True requires hardware (GPU type)\")\n   300→        cmd.extend([\"--roofline\", \"--hardware\", hardware])\n   301→    else:\n   302→        # --- Latency coefficients (use = to handle negative values) ---\n   303→        cmd.append(\"--alpha-coeffs=\" + \",\".join(str(c) for c in alpha_coeffs))\n   304→        cmd.append(\"--beta-coeffs=\" + \",\".join(str(c) for c in beta_coeffs))\n   305→\n   306→    # --- Output ---\n   307→    cmd.extend([\"--results-path\", results_path, \"--log\", \"error\"])\n   308→\n   309→    if stepml_model_path:\n   310→        cmd.extend([\"--stepml-model\", stepml_model_path])\n   311→\n   312→    try:\n   313→        result = subprocess.run(\n   314→            cmd,\n   315→            capture_output=True,\n   316→            text=True,\n   317→            timeout=600,\n   318→            cwd=os.path.dirname(binary),\n   319→        )\n   320→    except subprocess.TimeoutExpired:\n   321→        print(\"  TIMEOUT after 600s\", file=sys.stderr)\n   322→        return None\n   323→    except FileNotFoundError:\n   324→        print(f\"  Binary not found: {binary}\", file=sys.stderr)\n   325→        return None\n   326→\n   327→    if result.returncode != 0:\n   328→        print(\n   329→            f\"  BLIS failed (exit {result.returncode}): {result.stderr[:500]}\",\n   330→            file=sys.stderr,\n   331→        )\n   332→        return None\n   333→\n   334→    return parse_blis_stdout(result.stdout)\n   335→\n   336→\n   337→def parse_blis_stdout(stdout: str) -> dict | None:\n   338→    \"\"\"Parse BLIS stdout for the JSON block after '=== Simulation Metrics ==='.\"\"\"\n   339→    lines = stdout.split(\"\\n\")\n   340→    json_lines = []\n   341→    in_json = False\n   342→    brace_depth = 0\n   343→\n   344→    for line in lines:\n   345→        if \"Simulation Metrics\" in line:\n   346→            in_json = False\n   347→            json_lines = []\n   348→            continue\n   349→        if not in_json and line.strip().startswith(\"{\"):\n   350→            in_json = True\n   351→        if in_json:\n   352→            json_lines.append(line)\n   353→            brace_depth += line.count(\"{\") - line.count(\"}\")\n   354→            if brace_depth <= 0:\n   355→                break\n   356→\n   357→    if not json_lines:\n   358→        return None\n   359→\n   360→    try:\n   361→        metrics = json.loads(\"\\n\".join(json_lines))\n   362→    except json.JSONDecodeError:\n   363→        return None\n   364→\n   365→    return {\n   366→        \"e2e_mean_ms\": metrics.get(\"e2e_mean_ms\", 0),\n   367→        \"ttft_mean_ms\": metrics.get(\"ttft_mean_ms\", 0),\n   368→        \"itl_mean_ms\": metrics.get(\"itl_mean_ms\", 0),\n   369→        \"completed_requests\": metrics.get(\"completed_requests\", 0),\n   370→        \"tokens_per_sec\": metrics.get(\"tokens_per_sec\", 0),\n   371→    }\n   372→\n   373→\n   374→def compute_error(predicted: float, observed: float) -> float:\n   375→    \"\"\"Compute relative error: |predicted - observed| / observed.\"\"\"\n   376→    if observed == 0:\n   377→        return float(\"inf\") if predicted != 0 else 0.0\n   378→    return abs(predicted - observed) / observed\n   379→\n   380→\n   381→# ---------------------------------------------------------------------------\n   382→# Main validation loop\n   383→# ---------------------------------------------------------------------------\n   384→def validate_all_experiments(\n   385→    binary: str,\n   386→    data_root: str,\n   387→    output_path: str,\n   388→    alpha_coeffs: list[float],\n   389→    beta_coeffs: list[float],\n   390→    stepml_model_path: str | None = None,\n   391→    roofline: bool = False,\n   392→    hardware: str | None = None,\n   393→):\n   394→    \"\"\"Run BLIS validation across all ground-truth experiments.\"\"\"\n   395→    results = []\n   396→\n   397→    for dirname in sorted(os.listdir(data_root)):\n   398→        dirpath = os.path.join(data_root, dirname)\n   399→        if not os.path.isdir(dirpath):\n   400→            continue\n   401→\n   402→        summary_path = os.path.join(\n   403→            dirpath, \"results\", \"summary_lifecycle_metrics.json\"\n   404→        )\n   405→        if not os.path.isfile(summary_path):\n   406→            continue\n   407→\n   408→        print(f\"\\n{'='*60}\")\n   409→        print(f\"Experiment: {dirname}\")\n   410→        print(f\"{'='*60}\")\n   411→\n   412→        # Parse metadata from directory name\n   413→        try:\n   414→            meta = parse_experiment_dir(dirname)\n   415→        except ValueError as e:\n   416→            print(f\"  SKIP: {e}\", file=sys.stderr)\n   417→            continue\n   418→\n   419→        # Load ground truth metrics\n   420→        gt = load_ground_truth_metrics(dirpath)\n   421→        print(f\"  Ground truth: E2E={gt['e2e_mean_s']*1000:.1f}ms, \"\n   422→              f\"TTFT={gt['ttft_mean_s']*1000:.1f}ms, \"\n   423→              f\"ITL={gt['itl_mean_s']*1000:.2f}ms\")\n   424→\n   425→        # Load experiment config (vLLM serving args)\n   426→        exp_config = load_exp_config(dirpath)\n   427→\n   428→        # Extract KV cache blocks from vllm.log\n   429→        total_kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n   430→        if total_kv_blocks is None:\n   431→            print(\"  SKIP: Cannot parse KV blocks from vllm.log\",\n   432→                  file=sys.stderr)\n   433→            results.append({\n   434→                \"experiment\": dirname,\n   435→                \"model\": meta[\"model\"],\n   436→                \"workload\": meta[\"workload\"],\n   437→                \"tp\": meta[\"tp\"],\n   438→                \"status\": \"no_kv_blocks\",\n   439→            })\n   440→            continue\n   441→        cpu_kv_blocks = extract_cpu_kv_blocks_from_vllm_log(dirpath)\n   442→        print(f\"  KV blocks: {total_kv_blocks} GPU \"\n   443→              f\"({total_kv_blocks * BLOCK_SIZE_TOKENS:,} tokens)\"\n   444→              f\" + {cpu_kv_blocks} CPU\")\n   445→\n   446→        # Load inference-perf profile and build workload spec\n   447→        try:\n   448→            profile = load_profile(dirpath)\n   449→        except (FileNotFoundError, json.JSONDecodeError, yaml.YAMLError) as e:\n   450→            print(f\"  SKIP: Cannot load profile: {e}\", file=sys.stderr)\n   451→            results.append({\n   452→                \"experiment\": dirname,\n   453→                \"model\": meta[\"model\"],\n   454→                \"workload\": meta[\"workload\"],\n   455→                \"tp\": meta[\"tp\"],\n   456→                \"status\": \"no_profile\",\n   457→            })\n   458→            continue\n   459→\n   460→        workload_spec = build_workload_spec(profile, gt)\n   461→\n   462→        # Write workload spec and results path to temp files\n   463→        with tempfile.NamedTemporaryFile(\n   464→            mode=\"w\", suffix=\".yaml\", delete=False\n   465→        ) as f:\n   466→            yaml.dump(workload_spec, f, default_flow_style=False)\n   467→            spec_path = f.name\n   468→\n   469→        with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n   470→            results_json_path = f.name\n   471→\n   472→        try:\n   473→            blis_metrics = run_blis(\n   474→                binary=binary,\n   475→                workload_spec_path=spec_path,\n   476→                exp_config=exp_config,\n   477→                total_kv_blocks=total_kv_blocks,\n   478→                alpha_coeffs=alpha_coeffs,\n   479→                beta_coeffs=beta_coeffs,\n   480→                results_path=results_json_path,\n   481→                stepml_model_path=stepml_model_path,\n   482→                roofline=roofline,\n   483→                hardware=hardware,\n   484→                cpu_kv_blocks=cpu_kv_blocks,\n   485→            )\n   486→        finally:\n   487→            os.unlink(spec_path)\n   488→            if os.path.exists(results_json_path):\n   489→                os.unlink(results_json_path)\n   490→\n   491→        if blis_metrics is None:\n   492→            results.append({\n   493→                \"experiment\": dirname,\n   494→                \"model\": meta[\"model\"],\n   495→                \"workload\": meta[\"workload\"],\n   496→                \"tp\": meta[\"tp\"],\n   497→                \"status\": \"blis_failed\",\n   498→            })\n   499→            continue\n   500→\n   501→        # Compute errors (ground truth is in seconds, BLIS outputs ms)\n   502→        e2e_error = compute_error(\n   503→            blis_metrics[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000\n   504→        )\n   505→        ttft_error = compute_error(\n   506→            blis_metrics[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000\n   507→        )\n   508→        itl_error = compute_error(\n   509→            blis_metrics[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000\n   510→        )\n   511→\n   512→        print(f\"  BLIS:         E2E={blis_metrics['e2e_mean_ms']:.1f}ms, \"\n   513→              f\"TTFT={blis_metrics['ttft_mean_ms']:.1f}ms, \"\n   514→              f\"ITL={blis_metrics['itl_mean_ms']:.2f}ms\")\n   515→        print(f\"  Errors:       E2E={e2e_error*100:.1f}%, \"\n   516→              f\"TTFT={ttft_error*100:.1f}%, \"\n   517→              f\"ITL={itl_error*100:.1f}%\")\n   518→\n   519→        results.append({\n   520→            \"experiment\": dirname,\n   521→            \"model\": meta[\"model\"],\n   522→            \"workload\": meta[\"workload\"],\n   523→            \"tp\": meta[\"tp\"],\n   524→            \"status\": \"ok\",\n   525→            \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n   526→            \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n   527→            \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n   528→            \"blis_e2e_ms\": blis_metrics[\"e2e_mean_ms\"],\n   529→            \"blis_ttft_ms\": blis_metrics[\"ttft_mean_ms\"],\n   530→            \"blis_itl_ms\": blis_metrics[\"itl_mean_ms\"],\n   531→            \"e2e_error\": e2e_error,\n   532→            \"ttft_error\": ttft_error,\n   533→            \"itl_error\": itl_error,\n   534→            \"blis_completed\": blis_metrics[\"completed_requests\"],\n   535→            \"gt_requests\": gt[\"num_requests\"],\n   536→        })\n   537→\n   538→    # Write summary CSV\n   539→    if results:\n   540→        all_keys = set()\n   541→        for r in results:\n   542→            all_keys.update(r.keys())\n   543→        fieldnames = sorted(all_keys)\n   544→\n   545→        with open(output_path, \"w\", newline=\"\") as f:\n   546→            writer = csv.DictWriter(f, fieldnames=fieldnames)\n   547→            writer.writeheader()\n   548→            writer.writerows(results)\n   549→\n   550→        print(f\"\\n{'='*60}\")\n   551→        print(f\"Summary written to: {output_path}\")\n   552→        print(f\"{'='*60}\")\n   553→\n   554→        ok_results = [r for r in results if r.get(\"status\") == \"ok\"]\n   555→        if ok_results:\n   556→            e2e_errors = [r[\"e2e_error\"] for r in ok_results]\n   557→            ttft_errors = [r[\"ttft_error\"] for r in ok_results]\n   558→            itl_errors = [r[\"itl_error\"] for r in ok_results]\n   559→\n   560→            print(f\"\\nExperiments: {len(ok_results)} completed, \"\n   561→                  f\"{len(results) - len(ok_results)} skipped/failed\")\n   562→            print(f\"E2E  mean error: \"\n   563→                  f\"{sum(e2e_errors)/len(e2e_errors)*100:.1f}%\")\n   564→            print(f\"TTFT mean error: \"\n   565→                  f\"{sum(ttft_errors)/len(ttft_errors)*100:.1f}%\")\n   566→            print(f\"ITL  mean error: \"\n   567→                  f\"{sum(itl_errors)/len(itl_errors)*100:.1f}%\")\n   568→\n   569→            passing = sum(1 for e in e2e_errors if e < 0.10)\n   570→            print(f\"E2E < 10%: {passing}/{len(ok_results)} experiments\")\n   571→\n   572→\n   573→def main():\n   574→    parser = argparse.ArgumentParser(\n   575→        description=\"BLIS validation harness for StepML research\"\n   576→    )\n   577→    parser.add_argument(\n   578→        \"--binary\",\n   579→        default=DEFAULT_BINARY,\n   580→        help=f\"Path to simulation_worker binary (default: {DEFAULT_BINARY})\",\n   581→    )\n   582→    parser.add_argument(\n   583→        \"--data-root\",\n   584→        default=DEFAULT_DATA_ROOT,\n   585→        help=f\"Path to eval/ground_truth/ (default: {DEFAULT_DATA_ROOT})\",\n   586→    )\n   587→    parser.add_argument(\n   588→        \"--output\",\n   589→        default=os.path.join(_SCRIPT_DIR, \"blis_validation_results.csv\"),\n   590→        help=\"Output CSV path\",\n   591→    )\n   592→    parser.add_argument(\n   593→        \"--alpha-coeffs\",\n   594→        default=\"0,0,0\",\n   595→        help=\"Comma-separated alpha coefficients (default: 0,0,0)\",\n   596→    )\n   597→    parser.add_argument(\n   598→        \"--beta-coeffs\",\n   599→        default=\"0,0,0\",\n   600→        help=\"Comma-separated beta coefficients (default: 0,0,0)\",\n   601→    )\n   602→    parser.add_argument(\n   603→        \"--stepml-model\",\n   604→        default=None,\n   605→        help=\"Path to StepML model artifact JSON (optional)\",\n   606→    )\n   607→    parser.add_argument(\n   608→        \"--roofline\",\n   609→        action=\"store_true\",\n   610→        help=\"Use analytical roofline latency model instead of alpha/beta coefficients\",\n   611→    )\n   612→    parser.add_argument(\n   613→        \"--hardware\",\n   614→        default=None,\n   615→        help=\"GPU type for roofline mode (e.g. H100). Required when --roofline is set.\",\n   616→    )\n   617→    args = parser.parse_args()\n   618→\n   619→    if args.roofline and not args.hardware:\n   620→        parser.error(\"--roofline requires --hardware (GPU type, e.g. H100)\")\n   621→\n   622→    alpha_coeffs = [float(x) for x in args.alpha_coeffs.split(\",\")]\n   623→    beta_coeffs = [float(x) for x in args.beta_coeffs.split(\",\")]\n   624→\n   625→    if not args.roofline:\n   626→        if len(alpha_coeffs) < 3:\n   627→            parser.error(\"--alpha-coeffs requires at least 3 values\")\n   628→        if len(beta_coeffs) < 3:\n   629→            parser.error(\"--beta-coeffs requires at least 3 values\")\n   630→\n   631→    # Build binary if needed\n   632→    if not os.path.isfile(args.binary):\n   633→        print(\"Building simulation_worker...\", file=sys.stderr)\n   634→        build_result = subprocess.run(\n   635→            [\"go\", \"build\", \"-o\", args.binary, \"main.go\"],\n   636→            cwd=_REPO_ROOT,\n   637→            capture_output=True,\n   638→            text=True,\n   639→        )\n   640→        if build_result.returncode != 0:\n   641→            print(f\"Build failed: {build_result.stderr}\", file=sys.stderr)\n   642→            sys.exit(1)\n   643→\n   644→    validate_all_experiments(\n   645→        binary=args.binary,\n   646→        data_root=args.data_root,\n   647→        output_path=args.output,\n   648→        alpha_coeffs=alpha_coeffs,\n   649→        beta_coeffs=beta_coeffs,\n   650→        stepml_model_path=args.stepml_model,\n   651→        roofline=args.roofline,\n   652→        hardware=args.hardware,\n   653→    )\n   654→\n   655→\n   656→if __name__ == \"__main__\":\n   657→    main()\n   658→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"4122cf8f-b828-49f3-abfd-830cd6a4dda8"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01GbCrwAAx3Jy2qqiqCSYioi","type":"tool_result","content":"     1→\"\"\"Establish baselines for StepML research.\n     2→\n     3→Runs two baselines through BLIS E2E validation and measures E2E/TTFT/ITL error\n     4→against ground truth.  These are the accuracy bars that StepML models must beat.\n     5→\n     6→Baseline 1 — Roofline (analytical):\n     7→    Uses the analytical FLOPs/bandwidth roofline model.  Zero calibration data\n     8→    needed — step time is estimated from model architecture (HuggingFace\n     9→    config.json) and GPU specs (hardware_config.json).\n    10→\n    11→Baseline 2 — Per-model linear regression:\n    12→    Trains a separate 3-coefficient linear regression per model+TP on\n    13→    ground-truth step traces (step_time = beta0 + beta1*prefill + beta2*decode),\n    14→    pooling all workloads for a given model.  Requires training data.\n    15→\n    16→Usage:\n    17→    python establish_baseline.py [--data-root PATH] [--output-dir PATH]\n    18→    python establish_baseline.py --skip-linear              # roofline only\n    19→    python establish_baseline.py --skip-roofline            # linear only\n    20→    python establish_baseline.py --hardware A100            # non-default GPU\n    21→\"\"\"\n    22→\n    23→import argparse\n    24→import csv as csv_mod\n    25→import json\n    26→import os\n    27→import subprocess\n    28→import sys\n    29→import tempfile\n    30→from concurrent.futures import ThreadPoolExecutor, as_completed\n    31→\n    32→import numpy as np\n    33→import pandas as pd\n    34→\n    35→# Add shared/ to path for imports\n    36→_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n    37→sys.path.insert(0, _SCRIPT_DIR)\n    38→\n    39→import yaml\n    40→\n    41→from baselines import BlackboxBaseline, check_r4_gate\n    42→from data_loader import load_all_experiments, load_experiment_steps, parse_experiment_metadata\n    43→from evaluation import compute_mape, compute_mspe, compute_pearson_r, compute_p99_error\n    44→from validate_blis import (\n    45→    build_workload_spec,\n    46→    compute_error,\n    47→    extract_cpu_kv_blocks_from_vllm_log,\n    48→    extract_kv_blocks_from_vllm_log,\n    49→    load_exp_config,\n    50→    load_ground_truth_metrics,\n    51→    load_profile,\n    52→    parse_experiment_dir,\n    53→    run_blis,\n    54→)\n    55→\n    56→_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\"))\n    57→DEFAULT_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\n    58→_DEFAULT_WORKERS = min((os.cpu_count() or 4) // 2, 4)\n    59→\n    60→\n    61→def _build_canonical_model_map(data_root: str) -> dict:\n    62→    \"\"\"Build a map from experiment_id to canonical (model, tp) from exp-config.yaml.\n    63→\n    64→    Directory names have inconsistencies (e.g. \"llama-2-70b\" vs \"llama-2-70b-hf\"\n    65→    for the same model).  exp-config.yaml has the authoritative HF model name.\n    66→    \"\"\"\n    67→    mapping = {}\n    68→    for dirname in sorted(os.listdir(data_root)):\n    69→        config_path = os.path.join(data_root, dirname, \"exp-config.yaml\")\n    70→        if not os.path.isfile(config_path):\n    71→            continue\n    72→        with open(config_path) as f:\n    73→            cfg = yaml.safe_load(f)\n    74→        # Canonical model name from HF (e.g. \"meta-llama/Llama-2-70b-hf\")\n    75→        model = cfg.get(\"model\", \"\")\n    76→        tp = cfg.get(\"tensor_parallelism\", 1)\n    77→        mapping[dirname] = (model, tp)\n    78→    return mapping\n    79→\n    80→\n    81→def train_per_model_coefficients(data_root: str) -> dict:\n    82→    \"\"\"Train a linear regression per model+TP and return fitted coefficients.\n    83→\n    84→    Groups experiments by canonical (model, tp) from exp-config.yaml, trains\n    85→    one linear regression per group, and returns the coefficients.\n    86→\n    87→    Returns:\n    88→        dict keyed by (model, tp) with values:\n    89→        {\n    90→            \"beta0\": float, \"beta1\": float, \"beta2\": float,\n    91→            \"n_steps\": int, \"n_experiments\": int,\n    92→            \"train_mape\": float, \"train_r\": float,\n    93→            \"experiments\": [list of experiment_ids],\n    94→        }\n    95→    \"\"\"\n    96→    if data_root is None:\n    97→        data_root = DEFAULT_DATA_ROOT\n    98→\n    99→    # Build canonical model map from exp-config.yaml\n   100→    canon_map = _build_canonical_model_map(data_root)\n   101→\n   102→    all_steps = load_all_experiments(data_root)\n   103→    if all_steps.empty:\n   104→        raise ValueError(f\"No step data found in {data_root}\")\n   105→\n   106→    # Replace parsed model/tp with canonical values from exp-config.yaml\n   107→    all_steps[\"canonical_model\"] = all_steps[\"experiment_id\"].map(\n   108→        lambda eid: canon_map.get(eid, (\"unknown\", 0))[0]\n   109→    )\n   110→    all_steps[\"canonical_tp\"] = all_steps[\"experiment_id\"].map(\n   111→        lambda eid: canon_map.get(eid, (\"unknown\", 0))[1]\n   112→    )\n   113→\n   114→    # Group by canonical model+tp\n   115→    results = {}\n   116→    for (model, tp), group_df in all_steps.groupby([\"canonical_model\", \"canonical_tp\"]):\n   117→        tp_val = int(tp)\n   118→        baseline = BlackboxBaseline().fit(group_df)\n   119→        coeffs = baseline.coefficients\n   120→\n   121→        predicted = baseline.predict(group_df)\n   122→        actual = group_df[\"step.duration_us\"].values\n   123→\n   124→        train_mape = compute_mape(predicted, actual)\n   125→        train_r = compute_pearson_r(predicted, actual)\n   126→        train_mspe = compute_mspe(predicted, actual)\n   127→\n   128→        experiments = sorted(group_df[\"experiment_id\"].unique().tolist())\n   129→\n   130→        results[(model, tp_val)] = {\n   131→            \"beta0\": coeffs[\"beta0\"],\n   132→            \"beta1\": coeffs[\"beta1\"],\n   133→            \"beta2\": coeffs[\"beta2\"],\n   134→            \"n_steps\": len(group_df),\n   135→            \"n_experiments\": len(experiments),\n   136→            \"train_mape\": train_mape,\n   137→            \"train_mspe\": train_mspe,\n   138→            \"train_r\": train_r,\n   139→            \"experiments\": experiments,\n   140→        }\n   141→\n   142→    return results\n   143→\n   144→\n   145→def _ensure_binary() -> str:\n   146→    \"\"\"Return path to the simulation_worker binary, building if needed.\"\"\"\n   147→    binary = os.path.join(_REPO_ROOT, \"simulation_worker\")\n   148→    if not os.path.isfile(binary):\n   149→        print(\"Building simulation_worker...\", file=sys.stderr)\n   150→        subprocess.run(\n   151→            [\"go\", \"build\", \"-o\", binary, \"main.go\"],\n   152→            cwd=_REPO_ROOT, check=True,\n   153→        )\n   154→    return binary\n   155→\n   156→\n   157→def _run_single_experiment(\n   158→    binary: str,\n   159→    dirname: str,\n   160→    dirpath: str,\n   161→    alpha_coeffs: list[float],\n   162→    beta_coeffs: list[float],\n   163→    roofline: bool = False,\n   164→    hardware: str | None = None,\n   165→    extra_fields: dict | None = None,\n   166→) -> dict:\n   167→    \"\"\"Run BLIS for a single experiment and return a result row.\n   168→\n   169→    This is the unit of work dispatched to the thread pool.\n   170→    \"\"\"\n   171→    try:\n   172→        meta = parse_experiment_dir(dirname)\n   173→    except ValueError:\n   174→        return {\"experiment\": dirname, \"status\": \"parse_failed\"}\n   175→\n   176→    gt = load_ground_truth_metrics(dirpath)\n   177→    exp_config = load_exp_config(dirpath)\n   178→    total_kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n   179→    if total_kv_blocks is None:\n   180→        return {\n   181→            \"experiment\": dirname, \"model\": meta[\"model\"],\n   182→            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   183→            \"status\": \"no_kv_blocks\",\n   184→        }\n   185→    cpu_kv_blocks = extract_cpu_kv_blocks_from_vllm_log(dirpath)\n   186→\n   187→    try:\n   188→        profile = load_profile(dirpath)\n   189→    except Exception:\n   190→        return {\n   191→            \"experiment\": dirname, \"model\": meta[\"model\"],\n   192→            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   193→            \"status\": \"no_profile\",\n   194→        }\n   195→\n   196→    workload_spec = build_workload_spec(profile, gt)\n   197→\n   198→    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".yaml\", delete=False) as f:\n   199→        yaml.dump(workload_spec, f, default_flow_style=False)\n   200→        spec_path = f.name\n   201→\n   202→    with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n   203→        results_json_path = f.name\n   204→\n   205→    try:\n   206→        blis_metrics = run_blis(\n   207→            binary=binary,\n   208→            workload_spec_path=spec_path,\n   209→            exp_config=exp_config,\n   210→            total_kv_blocks=total_kv_blocks,\n   211→            alpha_coeffs=alpha_coeffs,\n   212→            beta_coeffs=beta_coeffs,\n   213→            results_path=results_json_path,\n   214→            roofline=roofline,\n   215→            hardware=hardware,\n   216→            cpu_kv_blocks=cpu_kv_blocks,\n   217→        )\n   218→    finally:\n   219→        os.unlink(spec_path)\n   220→        if os.path.exists(results_json_path):\n   221→            os.unlink(results_json_path)\n   222→\n   223→    if blis_metrics is None:\n   224→        return {\n   225→            \"experiment\": dirname, \"model\": meta[\"model\"],\n   226→            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   227→            \"status\": \"blis_failed\",\n   228→        }\n   229→\n   230→    e2e_err = compute_error(blis_metrics[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n   231→    ttft_err = compute_error(blis_metrics[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000)\n   232→    itl_err = compute_error(blis_metrics[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n   233→\n   234→    marker = \" <10%\" if e2e_err < 0.10 else \"\"\n   235→    print(f\"  {dirname}: GT={gt['e2e_mean_s']*1000:.0f}ms  \"\n   236→          f\"BLIS={blis_metrics['e2e_mean_ms']:.0f}ms  \"\n   237→          f\"E2E={e2e_err*100:.1f}%{marker}\")\n   238→\n   239→    row = {\n   240→        \"experiment\": dirname, \"model\": meta[\"model\"],\n   241→        \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   242→        \"status\": \"ok\",\n   243→        \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n   244→        \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n   245→        \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n   246→        \"blis_e2e_ms\": blis_metrics[\"e2e_mean_ms\"],\n   247→        \"blis_ttft_ms\": blis_metrics[\"ttft_mean_ms\"],\n   248→        \"blis_itl_ms\": blis_metrics[\"itl_mean_ms\"],\n   249→        \"e2e_error\": e2e_err, \"ttft_error\": ttft_err, \"itl_error\": itl_err,\n   250→        \"blis_completed\": blis_metrics[\"completed_requests\"],\n   251→        \"gt_requests\": gt[\"num_requests\"],\n   252→    }\n   253→    if extra_fields:\n   254→        row.update(extra_fields)\n   255→    return row\n   256→\n   257→\n   258→def _write_results_csv(rows: list[dict], output_csv: str) -> None:\n   259→    \"\"\"Write result rows to CSV.\"\"\"\n   260→    if not rows:\n   261→        return\n   262→    all_keys = set()\n   263→    for r in rows:\n   264→        all_keys.update(r.keys())\n   265→    fieldnames = sorted(all_keys)\n   266→    with open(output_csv, \"w\", newline=\"\") as f:\n   267→        writer = csv_mod.DictWriter(f, fieldnames=fieldnames)\n   268→        writer.writeheader()\n   269→        writer.writerows(rows)\n   270→\n   271→\n   272→def _discover_experiments(data_root: str) -> list[tuple[str, str]]:\n   273→    \"\"\"Return list of (dirname, dirpath) for valid experiment directories.\"\"\"\n   274→    experiments = []\n   275→    for dirname in sorted(os.listdir(data_root)):\n   276→        dirpath = os.path.join(data_root, dirname)\n   277→        if not os.path.isdir(dirpath):\n   278→            continue\n   279→        summary_path = os.path.join(dirpath, \"results\", \"summary_lifecycle_metrics.json\")\n   280→        if not os.path.isfile(summary_path):\n   281→            continue\n   282→        experiments.append((dirname, dirpath))\n   283→    return experiments\n   284→\n   285→\n   286→def run_blis_validation(\n   287→    coefficients: dict,\n   288→    data_root: str,\n   289→    output_csv: str,\n   290→    max_workers: int = _DEFAULT_WORKERS,\n   291→) -> str:\n   292→    \"\"\"Run BLIS for each experiment using its model+TP-specific coefficients.\n   293→\n   294→    All experiments run in parallel via ThreadPoolExecutor.\n   295→\n   296→    Returns path to the output CSV.\n   297→    \"\"\"\n   298→    # Build experiment → coefficients lookup\n   299→    exp_to_coeffs = {}\n   300→    for (_model, _tp), coeffs in coefficients.items():\n   301→        for exp_id in coeffs[\"experiments\"]:\n   302→            exp_to_coeffs[exp_id] = coeffs\n   303→\n   304→    binary = _ensure_binary()\n   305→    experiments = _discover_experiments(data_root)\n   306→\n   307→    futures = {}\n   308→    with ThreadPoolExecutor(max_workers=max_workers) as pool:\n   309→        for dirname, dirpath in experiments:\n   310→            coeffs = exp_to_coeffs.get(dirname)\n   311→            if coeffs is None:\n   312→                continue\n   313→            beta = [coeffs[\"beta0\"], coeffs[\"beta1\"], coeffs[\"beta2\"]]\n   314→            extra = {\n   315→                \"beta0\": coeffs[\"beta0\"], \"beta1\": coeffs[\"beta1\"],\n   316→                \"beta2\": coeffs[\"beta2\"], \"train_mape\": coeffs[\"train_mape\"],\n   317→            }\n   318→            fut = pool.submit(\n   319→                _run_single_experiment,\n   320→                binary=binary, dirname=dirname, dirpath=dirpath,\n   321→                alpha_coeffs=[0.0, 0.0, 0.0], beta_coeffs=beta,\n   322→                extra_fields=extra,\n   323→            )\n   324→            futures[fut] = dirname\n   325→\n   326→        all_rows = []\n   327→        for fut in as_completed(futures):\n   328→            all_rows.append(fut.result())\n   329→\n   330→    # Sort by experiment name for deterministic output\n   331→    all_rows.sort(key=lambda r: r[\"experiment\"])\n   332→    _write_results_csv(all_rows, output_csv)\n   333→    return output_csv\n   334→\n   335→\n   336→def run_roofline_validation(\n   337→    data_root: str,\n   338→    output_csv: str,\n   339→    hardware: str = \"H100\",\n   340→    max_workers: int = _DEFAULT_WORKERS,\n   341→) -> str:\n   342→    \"\"\"Run BLIS in roofline mode for all experiments in parallel.\n   343→\n   344→    The roofline model is analytical — no training step.  It estimates step\n   345→    time from FLOPs/bandwidth using HuggingFace model config + GPU hardware\n   346→    specs.  Zero calibration data needed.\n   347→\n   348→    Returns path to the output CSV.\n   349→    \"\"\"\n   350→    print(f\"\\n{'='*60}\")\n   351→    print(f\"  Roofline baseline: hardware={hardware}\")\n   352→    print(f\"  (analytical FLOPs/bandwidth — no trained coefficients)\")\n   353→    print(f\"{'='*60}\")\n   354→\n   355→    binary = _ensure_binary()\n   356→    experiments = _discover_experiments(data_root)\n   357→\n   358→    futures = {}\n   359→    with ThreadPoolExecutor(max_workers=max_workers) as pool:\n   360→        for dirname, dirpath in experiments:\n   361→            fut = pool.submit(\n   362→                _run_single_experiment,\n   363→                binary=binary, dirname=dirname, dirpath=dirpath,\n   364→                alpha_coeffs=[0, 0, 0], beta_coeffs=[0, 0, 0],\n   365→                roofline=True, hardware=hardware,\n   366→            )\n   367→            futures[fut] = dirname\n   368→\n   369→        all_rows = []\n   370→        for fut in as_completed(futures):\n   371→            all_rows.append(fut.result())\n   372→\n   373→    all_rows.sort(key=lambda r: r[\"experiment\"])\n   374→    _write_results_csv(all_rows, output_csv)\n   375→    return output_csv\n   376→\n   377→\n   378→def print_roofline_summary(output_csv: str):\n   379→    \"\"\"Print a human-readable summary of the roofline baseline results.\"\"\"\n   380→    if not os.path.isfile(output_csv):\n   381→        print(\"No roofline results to summarize.\")\n   382→        return\n   383→\n   384→    df = pd.read_csv(output_csv)\n   385→    ok = df[df[\"status\"] == \"ok\"]\n   386→\n   387→    if ok.empty:\n   388→        print(\"\\nNo successful roofline experiments. Check BLIS binary and data.\")\n   389→        return\n   390→\n   391→    print(f\"\\n{'='*70}\")\n   392→    print(\"  ROOFLINE BASELINE RESULTS (analytical — no training)\")\n   393→    print(f\"{'='*70}\")\n   394→\n   395→    print(f\"\\n  Experiments: {len(ok)} completed, \"\n   396→          f\"{len(df) - len(ok)} skipped/failed\")\n   397→\n   398→    print(f\"\\n  {'Experiment':<55s} {'E2E%':>6s} {'TTFT%':>6s} {'ITL%':>6s}\")\n   399→    print(f\"  {'-'*55} {'-'*6} {'-'*6} {'-'*6}\")\n   400→    for _, row in ok.iterrows():\n   401→        e2e_pct = row[\"e2e_error\"] * 100\n   402→        ttft_pct = row[\"ttft_error\"] * 100\n   403→        itl_pct = row[\"itl_error\"] * 100\n   404→        marker = \" <10%\" if e2e_pct < 10 else \"\"\n   405→        print(f\"  {row['experiment']:<55s} \"\n   406→              f\"{e2e_pct:>5.1f}% {ttft_pct:>5.1f}% {itl_pct:>5.1f}%{marker}\")\n   407→\n   408→    e2e_errors = ok[\"e2e_error\"].values * 100\n   409→    ttft_errors = ok[\"ttft_error\"].values * 100\n   410→    itl_errors = ok[\"itl_error\"].values * 100\n   411→\n   412→    print(f\"\\n  Mean E2E error:  {e2e_errors.mean():.1f}%\")\n   413→    print(f\"  Mean TTFT error: {ttft_errors.mean():.1f}%\")\n   414→    print(f\"  Mean ITL error:  {itl_errors.mean():.1f}%\")\n   415→\n   416→    passing = (e2e_errors < 10).sum()\n   417→    print(f\"\\n  E2E < 10%: {passing}/{len(ok)} experiments\")\n   418→\n   419→    # Save summary JSON\n   420→    summary = {\n   421→        \"model\": \"roofline (analytical)\",\n   422→        \"e2e_validation\": {\n   423→            \"mean_e2e_error_pct\": float(e2e_errors.mean()),\n   424→            \"mean_ttft_error_pct\": float(ttft_errors.mean()),\n   425→            \"mean_itl_error_pct\": float(itl_errors.mean()),\n   426→            \"experiments_below_10pct\": int(passing),\n   427→            \"total_experiments\": len(ok),\n   428→        },\n   429→    }\n   430→    summary_path = output_csv.replace(\".csv\", \"_summary.json\")\n   431→    with open(summary_path, \"w\") as f:\n   432→        json.dump(summary, f, indent=2)\n   433→    print(f\"\\n  Summary JSON: {summary_path}\")\n   434→\n   435→\n   436→def print_summary(output_csv: str, coefficients: dict):\n   437→    \"\"\"Print a human-readable summary of the baseline results.\"\"\"\n   438→    if not os.path.isfile(output_csv):\n   439→        print(\"No results to summarize.\")\n   440→        return\n   441→\n   442→    df = pd.read_csv(output_csv)\n   443→    ok = df[df[\"status\"] == \"ok\"]\n   444→\n   445→    if ok.empty:\n   446→        print(\"\\nNo successful experiments. Check BLIS binary and data.\")\n   447→        return\n   448→\n   449→    print(f\"\\n{'='*70}\")\n   450→    print(\"  PER-MODEL LINEAR REGRESSION BASELINE RESULTS\")\n   451→    print(f\"{'='*70}\")\n   452→\n   453→    print(f\"\\n  Experiments: {len(ok)} completed, \"\n   454→          f\"{len(df) - len(ok)} skipped/failed\")\n   455→\n   456→    # Per-step training metrics\n   457→    print(f\"\\n  --- Per-Step Training Metrics (linear regression on step traces) ---\")\n   458→    for (model, tp), coeffs in sorted(coefficients.items()):\n   459→        print(f\"  {model} TP={tp}: \"\n   460→              f\"MAPE={coeffs['train_mape']:.1f}%, \"\n   461→              f\"MSPE={coeffs['train_mspe']:+.1f}%, \"\n   462→              f\"r={coeffs['train_r']:.3f}, \"\n   463→              f\"n_steps={coeffs['n_steps']:,}\")\n   464→        print(f\"    beta = [{coeffs['beta0']:.2f}, \"\n   465→              f\"{coeffs['beta1']:.4f}, {coeffs['beta2']:.4f}]\")\n   466→\n   467→    # E2E validation metrics\n   468→    print(f\"\\n  --- BLIS E2E Validation (simulator vs ground truth) ---\")\n   469→    print(f\"  {'Experiment':<55s} {'E2E%':>6s} {'TTFT%':>6s} {'ITL%':>6s}\")\n   470→    print(f\"  {'-'*55} {'-'*6} {'-'*6} {'-'*6}\")\n   471→    for _, row in ok.iterrows():\n   472→        e2e_pct = row[\"e2e_error\"] * 100\n   473→        ttft_pct = row[\"ttft_error\"] * 100\n   474→        itl_pct = row[\"itl_error\"] * 100\n   475→        marker = \" <10%\" if e2e_pct < 10 else \"\"\n   476→        print(f\"  {row['experiment']:<55s} \"\n   477→              f\"{e2e_pct:>5.1f}% {ttft_pct:>5.1f}% {itl_pct:>5.1f}%{marker}\")\n   478→\n   479→    e2e_errors = ok[\"e2e_error\"].values * 100\n   480→    ttft_errors = ok[\"ttft_error\"].values * 100\n   481→    itl_errors = ok[\"itl_error\"].values * 100\n   482→\n   483→    print(f\"\\n  Mean E2E error:  {e2e_errors.mean():.1f}%\")\n   484→    print(f\"  Mean TTFT error: {ttft_errors.mean():.1f}%\")\n   485→    print(f\"  Mean ITL error:  {itl_errors.mean():.1f}%\")\n   486→\n   487→    passing = (e2e_errors < 10).sum()\n   488→    print(f\"\\n  E2E < 10%: {passing}/{len(ok)} experiments\")\n   489→\n   490→    # R4 gate check\n   491→    print(f\"\\n  --- R4 Gate (is linear regression already good enough?) ---\")\n   492→    r4 = check_r4_gate(e2e_errors.mean())\n   493→    print(f\"  {r4['message']}\")\n   494→\n   495→    # Save summary JSON\n   496→    summary = {\n   497→        \"per_model_coefficients\": {\n   498→            f\"{m}_tp{tp}\": {k: v for k, v in coeffs.items()\n   499→                            if k != \"experiments\"}\n   500→            for (m, tp), coeffs in coefficients.items()\n   501→        },\n   502→        \"e2e_validation\": {\n   503→            \"mean_e2e_error_pct\": float(e2e_errors.mean()),\n   504→            \"mean_ttft_error_pct\": float(ttft_errors.mean()),\n   505→            \"mean_itl_error_pct\": float(itl_errors.mean()),\n   506→            \"experiments_below_10pct\": int(passing),\n   507→            \"total_experiments\": len(ok),\n   508→        },\n   509→        \"r4_gate\": r4,\n   510→    }\n   511→    summary_path = output_csv.replace(\".csv\", \"_summary.json\")\n   512→    with open(summary_path, \"w\") as f:\n   513→        json.dump(summary, f, indent=2)\n   514→    print(f\"\\n  Summary JSON: {summary_path}\")\n   515→\n   516→\n   517→def main():\n   518→    parser = argparse.ArgumentParser(\n   519→        description=\"Establish per-model linear regression baseline\"\n   520→    )\n   521→    parser.add_argument(\n   522→        \"--data-root\",\n   523→        default=DEFAULT_DATA_ROOT,\n   524→        help=\"Path to eval/ground_truth/\",\n   525→    )\n   526→    parser.add_argument(\n   527→        \"--output-dir\",\n   528→        default=os.path.join(_SCRIPT_DIR, \"baseline_results\"),\n   529→        help=\"Directory for output files\",\n   530→    )\n   531→    parser.add_argument(\n   532→        \"--hardware\",\n   533→        default=\"H100\",\n   534→        help=\"GPU type for roofline baseline (default: H100)\",\n   535→    )\n   536→    parser.add_argument(\n   537→        \"--skip-roofline\",\n   538→        action=\"store_true\",\n   539→        help=\"Skip the roofline baseline (only run linear regression)\",\n   540→    )\n   541→    parser.add_argument(\n   542→        \"--skip-linear\",\n   543→        action=\"store_true\",\n   544→        help=\"Skip the linear regression baseline (only run roofline)\",\n   545→    )\n   546→    parser.add_argument(\n   547→        \"--workers\",\n   548→        type=int,\n   549→        default=_DEFAULT_WORKERS,\n   550→        help=f\"Max parallel BLIS runs (default: {_DEFAULT_WORKERS})\",\n   551→    )\n   552→    args = parser.parse_args()\n   553→\n   554→    os.makedirs(args.output_dir, exist_ok=True)\n   555→\n   556→    # --- Baseline 1: Roofline (analytical, no training) ---\n   557→    if not args.skip_roofline:\n   558→        roofline_csv = os.path.join(args.output_dir, \"roofline_baseline.csv\")\n   559→\n   560→        print(f\"Step 1: Running roofline baseline \"\n   561→              f\"(hardware={args.hardware}, workers={args.workers})...\")\n   562→        run_roofline_validation(\n   563→            args.data_root, roofline_csv, args.hardware,\n   564→            max_workers=args.workers,\n   565→        )\n   566→\n   567→        print_roofline_summary(roofline_csv)\n   568→\n   569→    # --- Baseline 2: Per-model linear regression ---\n   570→    if not args.skip_linear:\n   571→        linear_csv = os.path.join(args.output_dir, \"per_model_linear_baseline.csv\")\n   572→\n   573→        step_num = \"2\" if not args.skip_roofline else \"1\"\n   574→        print(f\"\\nStep {step_num}: Training per-model linear regression on step traces...\")\n   575→        coefficients = train_per_model_coefficients(args.data_root)\n   576→        print(f\"  Trained {len(coefficients)} model+TP groups\")\n   577→\n   578→        print(f\"\\nStep {int(step_num)+1}: Running BLIS E2E validation \"\n   579→              f\"(workers={args.workers})...\")\n   580→        run_blis_validation(\n   581→            coefficients, args.data_root, linear_csv,\n   582→            max_workers=args.workers,\n   583→        )\n   584→\n   585→        print_summary(linear_csv, coefficients)\n   586→\n   587→\n   588→if __name__ == \"__main__\":\n   589→    main()\n   590→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"c082992a-fb35-4fb8-a07a-2f2a84e1be13"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01LA9sHVRRohCFdHc2sPMFTN","type":"tool_result","content":"     1→\"\"\"Per-request KV cache length extractor for step-level feature enrichment.\n     2→\n     3→Bridges the gap between step-level batch summaries (which lack per-request KV\n     4→cache lengths) and per-request lifecycle data (which has token timestamps).\n     5→By joining these two data sources, we derive per-step KV statistics\n     6→(kv_mean, kv_max, kv_sum, kv_count) needed for accurate roofline step-time\n     7→prediction.\n     8→\n     9→Background: Round 1 H8 showed a 12.96x overestimate when using batch-level\n    10→kv_max (the max across the whole experiment) instead of per-request KV lengths.\n    11→This module computes the actual per-step KV distribution from lifecycle data.\n    12→\"\"\"\n    13→\n    14→from __future__ import annotations\n    15→\n    16→import os\n    17→\n    18→import numpy as np\n    19→import pandas as pd\n    20→\n    21→from data_loader import (\n    22→    DEFAULT_DATA_ROOT,\n    23→    load_all_experiments,\n    24→    load_experiment_steps,\n    25→    load_lifecycle_data,\n    26→    parse_experiment_metadata,\n    27→)\n    28→\n    29→\n    30→def _estimate_kv_length(request_row: pd.Series, step_start_ns: int) -> int:\n    31→    \"\"\"Estimate KV cache length for a request at a given step timestamp.\n    32→\n    33→    KV length = input_tokens + number of output tokens generated before\n    34→    step_start_ns. This mirrors the simulator's Request.ProgressIndex\n    35→    (input_tokens_processed + output_tokens_generated).\n    36→\n    37→    Args:\n    38→        request_row: A row from the lifecycle DataFrame with columns:\n    39→            input_tokens (int), output_token_times (list of float, epoch seconds).\n    40→        step_start_ns: Step start timestamp in nanoseconds.\n    41→\n    42→    Returns:\n    43→        Estimated KV cache length (non-negative integer).\n    44→    \"\"\"\n    45→    input_tokens = int(request_row[\"input_tokens\"])\n    46→    output_token_times = request_row[\"output_token_times\"]\n    47→\n    48→    if not output_token_times:\n    49→        return input_tokens\n    50→\n    51→    # Convert step_start_ns to seconds for comparison with output_token_times\n    52→    step_start_s = step_start_ns / 1e9\n    53→\n    54→    # Count output tokens generated before step_start_ns\n    55→    tokens_generated = 0\n    56→    for t in output_token_times:\n    57→        if t < step_start_s:\n    58→            tokens_generated += 1\n    59→        else:\n    60→            # output_token_times are chronologically ordered; once we pass\n    61→            # the step boundary, no further tokens qualify.\n    62→            break\n    63→\n    64→    return input_tokens + tokens_generated\n    65→\n    66→\n    67→def extract_kv_features(\n    68→    steps_df: pd.DataFrame, lifecycle_df: pd.DataFrame\n    69→) -> pd.DataFrame:\n    70→    \"\"\"Join step-level data with lifecycle data to derive per-step KV features.\n    71→\n    72→    For each step, identifies active requests (those whose time window overlaps\n    73→    the step window), estimates each request's KV cache length at step start,\n    74→    and computes aggregate statistics.\n    75→\n    76→    Args:\n    77→        steps_df: Step-level DataFrame from data_loader.load_experiment_steps().\n    78→            Must have columns: step.id, step.ts_start_ns, step.ts_end_ns,\n    79→            experiment_id.\n    80→        lifecycle_df: Per-request DataFrame from data_loader.load_lifecycle_data().\n    81→            Must have columns: start_time, end_time, input_tokens,\n    82→            output_tokens, output_token_times. Index is request_id.\n    83→\n    84→    Returns:\n    85→        DataFrame with same index as steps_df plus new columns:\n    86→        kv_mean, kv_max, kv_sum, kv_count.\n    87→    \"\"\"\n    88→    # Pre-convert lifecycle timestamps from seconds to nanoseconds for\n    89→    # efficient comparison with step timestamps.\n    90→    lc_start_ns = (lifecycle_df[\"start_time\"].values * 1e9).astype(np.int64)\n    91→    lc_end_ns = (lifecycle_df[\"end_time\"].values * 1e9).astype(np.int64)\n    92→\n    93→    kv_means = np.zeros(len(steps_df), dtype=np.float64)\n    94→    kv_maxes = np.zeros(len(steps_df), dtype=np.float64)\n    95→    kv_sums = np.zeros(len(steps_df), dtype=np.float64)\n    96→    kv_stds = np.zeros(len(steps_df), dtype=np.float64)\n    97→    kv_counts = np.zeros(len(steps_df), dtype=np.int64)\n    98→\n    99→    for i, (_, step_row) in enumerate(steps_df.iterrows()):\n   100→        step_start_ns = int(step_row[\"step.ts_start_ns\"])\n   101→        step_end_ns = int(step_row[\"step.ts_end_ns\"])\n   102→\n   103→        # Active requests: start_time < step.ts_end AND end_time > step.ts_start\n   104→        # (overlapping time windows)\n   105→        active_mask = (lc_start_ns < step_end_ns) & (lc_end_ns > step_start_ns)\n   106→        active_indices = np.where(active_mask)[0]\n   107→\n   108→        if len(active_indices) == 0:\n   109→            # No active requests -> all zeros (already initialized)\n   110→            continue\n   111→\n   112→        kv_lengths = np.array(\n   113→            [\n   114→                _estimate_kv_length(lifecycle_df.iloc[idx], step_start_ns)\n   115→                for idx in active_indices\n   116→            ],\n   117→            dtype=np.float64,\n   118→        )\n   119→\n   120→        kv_means[i] = np.mean(kv_lengths)\n   121→        kv_maxes[i] = np.max(kv_lengths)\n   122→        kv_sums[i] = np.sum(kv_lengths)\n   123→        kv_stds[i] = np.std(kv_lengths) if len(kv_lengths) > 1 else 0.0\n   124→        kv_counts[i] = len(kv_lengths)\n   125→\n   126→    result = steps_df.copy()\n   127→    result[\"kv_mean\"] = kv_means\n   128→    result[\"kv_max\"] = kv_maxes\n   129→    result[\"kv_sum\"] = kv_sums\n   130→    result[\"kv_std\"] = kv_stds\n   131→    result[\"kv_count\"] = kv_counts\n   132→\n   133→    return result\n   134→\n   135→\n   136→def extract_all_experiments_kv_features(\n   137→    data_root: str | None = None,\n   138→) -> pd.DataFrame:\n   139→    \"\"\"Load all experiments and extract KV features for every step.\n   140→\n   141→    Convenience wrapper that iterates over experiment directories, loads both\n   142→    step data and lifecycle data for each, calls extract_kv_features, and\n   143→    concatenates all results.\n   144→\n   145→    Args:\n   146→        data_root: Path to the ground truth data directory. Defaults to\n   147→            eval/ground_truth/ relative to this file.\n   148→\n   149→    Returns:\n   150→        Concatenated DataFrame with step data enriched with KV columns,\n   151→        plus metadata columns (model, tp, workload, timestamp).\n   152→    \"\"\"\n   153→    if data_root is None:\n   154→        data_root = DEFAULT_DATA_ROOT\n   155→\n   156→    frames = []\n   157→    for dirname in sorted(os.listdir(data_root)):\n   158→        dirpath = os.path.join(data_root, dirname)\n   159→        if not os.path.isdir(dirpath):\n   160→            continue\n   161→\n   162→        # Skip directories that lack required files\n   163→        traces_path = os.path.join(dirpath, \"traces.json\")\n   164→        lifecycle_path = os.path.join(\n   165→            dirpath, \"results\", \"per_request_lifecycle_metrics.json\"\n   166→        )\n   167→        if not os.path.isfile(traces_path) or not os.path.isfile(lifecycle_path):\n   168→            continue\n   169→\n   170→        steps_df = load_experiment_steps(dirpath)\n   171→        lifecycle_df = load_lifecycle_data(dirpath)\n   172→\n   173→        enriched = extract_kv_features(steps_df, lifecycle_df)\n   174→\n   175→        meta = parse_experiment_metadata(dirname)\n   176→        enriched[\"model\"] = meta[\"model\"]\n   177→        enriched[\"tp\"] = meta[\"tp\"]\n   178→        enriched[\"workload\"] = meta[\"workload\"]\n   179→        enriched[\"timestamp\"] = meta[\"timestamp\"]\n   180→\n   181→        frames.append(enriched)\n   182→\n   183→    if not frames:\n   184→        return pd.DataFrame()\n   185→\n   186→    result = pd.concat(frames, ignore_index=True)\n   187→    result[\"tp\"] = result[\"tp\"].astype(\"Int64\")\n   188→\n   189→    return result\n   190→"}]},"parent_tool_use_id":"toolu_bdrk_017vgie1jSaXiJSc9cebn2B7","session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"fbfeda31-08a0-40ae-ba14-455d8ddfcd96"}
