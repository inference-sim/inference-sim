{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01EDPzDJYmF44nP1tqpSmZSx","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"Round 4, Idea 1: Multi-Objective Constrained CMA-ES with ITL Penalty.\n     3→\n     4→Implements all 4 sub-hypotheses:\n     5→  H1: Constrained CMA-ES with dual E2E+ITL objective\n     6→  H2: Pareto sweep across alpha values\n     7→  H3: LOMO (leave-one-model-out) generalization\n     8→  H4: LOWO (leave-one-workload-out) generalization\n     9→\n    10→Uses the shared infrastructure from hypotheses/h-stepml/shared/ for data loading,\n    11→BLIS validation, and evaluation.\n    12→\"\"\"\n    13→\n    14→import copy\n    15→import json\n    16→import os\n    17→import re\n    18→import subprocess\n    19→import sys\n    20→import tempfile\n    21→import time\n    22→\n    23→import numpy as np\n    24→\n    25→# ---------------------------------------------------------------------------\n    26→# Paths\n    27→# ---------------------------------------------------------------------------\n    28→_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n    29→_SHARED_DIR = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"shared\"))\n    30→_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\", \"..\"))\n    31→# Ground truth lives in the main BLIS-research repo (not the worktree)\n    32→# Worktree root is stepml-worktrees/round4-idea-1-constrained-cmaes/\n    33→# BLIS-research is at inference-sim-package/BLIS-research/\n    34→_INFERENCE_SIM_PKG = os.path.abspath(os.path.join(_REPO_ROOT, \"..\", \"..\"))\n    35→_DATA_ROOT = os.path.join(_INFERENCE_SIM_PKG, \"BLIS-research\", \"eval\", \"ground_truth\")\n    36→_R3_ARTIFACTS_DIR = os.path.join(\n    37→    _INFERENCE_SIM_PKG, \"BLIS-research\", \"hypotheses\", \"h-stepml\",\n    38→    \"round3\", \"idea-3-e2e-calibration\", \"h1-trace-e2e-opt\", \"artifacts\"\n    39→)\n    40→BINARY_PATH = os.path.join(_REPO_ROOT, \"simulation_worker\")\n    41→BLOCK_SIZE_TOKENS = 16\n    42→\n    43→sys.path.insert(0, _SHARED_DIR)\n    44→\n    45→import yaml\n    46→from convert_lifecycle_to_traces import convert_experiment\n    47→from validate_blis import (\n    48→    extract_cpu_kv_blocks_from_vllm_log,\n    49→    extract_kv_blocks_from_vllm_log,\n    50→    load_exp_config,\n    51→    load_ground_truth_metrics,\n    52→    parse_blis_stdout,\n    53→    parse_experiment_dir,\n    54→)\n    55→\n    56→# ---------------------------------------------------------------------------\n    57→# TTFT corrections from R3 H3 (per-model additive corrections in ms)\n    58→# ---------------------------------------------------------------------------\n    59→TTFT_CORRECTIONS_MS = {\n    60→    \"llama-2-7b\": 16.49,\n    61→    \"llama-2-70b\": 60.98,\n    62→    \"llama-2-70b-hf\": 37.57,\n    63→    \"mixtral-8x7b-v0-1\": 40.16,\n    64→    \"codellama-34b\": 32.48,\n    65→}\n    66→\n    67→# ---------------------------------------------------------------------------\n    68→# Model group mapping (experiment dir model name -> group)\n    69→# ---------------------------------------------------------------------------\n    70→# For CMA-ES optimization, group experiments by shared optimizer.\n    71→# 70b and 70b-hf share the same optimizer (both are 70B models).\n    72→# Each experiment's specific artifact is loaded from R3 by exact model name.\n    73→MODEL_GROUPS = {\n    74→    \"llama-2-7b\": \"llama-2-7b\",\n    75→    \"llama-2-70b\": \"llama-2-70b\",\n    76→    \"llama-2-70b-hf\": \"llama-2-70b\",  # Same optimization group as 70b\n    77→    \"codellama-34b\": \"codellama-34b\",\n    78→    \"mixtral-8x7b-v0-1\": \"mixtral-8x7b-v0-1\",\n    79→}\n    80→\n    81→# For LOMO, we group 70b and 70b-hf as one model\n    82→LOMO_MODEL_GROUPS = {\n    83→    \"llama-2-7b\": \"llama-2-7b\",\n    84→    \"llama-2-70b\": \"llama-2-70b\",\n    85→    \"llama-2-70b-hf\": \"llama-2-70b\",\n    86→    \"codellama-34b\": \"codellama-34b\",\n    87→    \"mixtral-8x7b-v0-1\": \"mixtral-8x7b-v0-1\",\n    88→}\n    89→\n    90→\n    91→# ---------------------------------------------------------------------------\n    92→# Experiment discovery\n    93→# ---------------------------------------------------------------------------\n    94→def discover_experiments():\n    95→    \"\"\"Discover all valid experiments in the ground truth directory.\"\"\"\n    96→    experiments = []\n    97→    for dirname in sorted(os.listdir(_DATA_ROOT)):\n    98→        dirpath = os.path.join(_DATA_ROOT, dirname)\n    99→        if not os.path.isdir(dirpath):\n   100→            continue\n   101→        summary_path = os.path.join(dirpath, \"results\", \"summary_lifecycle_metrics.json\")\n   102→        if not os.path.isfile(summary_path):\n   103→            continue\n   104→\n   105→        meta = parse_experiment_dir(dirname)\n   106→        gt = load_ground_truth_metrics(dirpath)\n   107→        exp_config = load_exp_config(dirpath)\n   108→        kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n   109→        cpu_kv_blocks = extract_cpu_kv_blocks_from_vllm_log(dirpath)\n   110→\n   111→        if kv_blocks is None:\n   112→            continue\n   113→\n   114→        model_group = MODEL_GROUPS.get(meta[\"model\"], meta[\"model\"])\n   115→\n   116→        experiments.append({\n   117→            \"dirname\": dirname,\n   118→            \"dirpath\": dirpath,\n   119→            \"model\": meta[\"model\"],\n   120→            \"model_group\": model_group,\n   121→            \"workload\": meta[\"workload\"],\n   122→            \"tp\": meta[\"tp\"],\n   123→            \"gt\": gt,\n   124→            \"exp_config\": exp_config,\n   125→            \"kv_blocks\": kv_blocks,\n   126→            \"cpu_kv_blocks\": cpu_kv_blocks,\n   127→        })\n   128→\n   129→    return experiments\n   130→\n   131→\n   132→# ---------------------------------------------------------------------------\n   133→# Trace CSV generation (cached)\n   134→# ---------------------------------------------------------------------------\n   135→_TRACE_CACHE = {}\n   136→\n   137→\n   138→def get_trace_csv(exp):\n   139→    \"\"\"Get or create trace CSV for an experiment.\"\"\"\n   140→    dirname = exp[\"dirname\"]\n   141→    if dirname in _TRACE_CACHE:\n   142→        return _TRACE_CACHE[dirname]\n   143→\n   144→    trace_dir = os.path.join(_SCRIPT_DIR, \"traces\")\n   145→    csv_path = os.path.join(trace_dir, f\"{dirname}.csv\")\n   146→    if not os.path.isfile(csv_path):\n   147→        csv_path = convert_experiment(exp[\"dirpath\"], trace_dir)\n   148→\n   149→    _TRACE_CACHE[dirname] = csv_path\n   150→    return csv_path\n   151→\n   152→\n   153→# ---------------------------------------------------------------------------\n   154→# BLIS execution (trace replay mode)\n   155→# ---------------------------------------------------------------------------\n   156→def run_blis_trace(trace_csv, exp_config, kv_blocks, artifact_path, horizon_us,\n   157→                   cpu_kv_blocks=0):\n   158→    \"\"\"Run BLIS in trace replay mode with a StepML artifact.\"\"\"\n   159→    with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n   160→        results_path = f.name\n   161→\n   162→    cmd = [\n   163→        BINARY_PATH, \"run\",\n   164→        \"--model\", exp_config.get(\"model\", \"unknown\"),\n   165→        \"--workload\", \"traces\",\n   166→        \"--workload-traces-filepath\", trace_csv,\n   167→        \"--tp\", str(exp_config.get(\"tensor_parallelism\", 1)),\n   168→        \"--max-model-len\", str(exp_config.get(\"max_model_len\", 4096)),\n   169→        \"--max-num-running-reqs\", str(exp_config.get(\"max_num_seqs\", 128)),\n   170→        \"--max-num-scheduled-tokens\", str(exp_config.get(\"max_num_batched_tokens\", 2048)),\n   171→        \"--total-kv-blocks\", str(kv_blocks),\n   172→        \"--block-size-in-tokens\", str(BLOCK_SIZE_TOKENS),\n   173→        \"--horizon\", str(horizon_us),\n   174→        \"--alpha-coeffs=1,0,0\",\n   175→        \"--beta-coeffs=1,0,0\",\n   176→        \"--stepml-model\", artifact_path,\n   177→        \"--results-path\", results_path,\n   178→        \"--log\", \"error\",\n   179→    ]\n   180→    if cpu_kv_blocks > 0:\n   181→        cmd.extend([\"--kv-cpu-blocks\", str(cpu_kv_blocks)])\n   182→\n   183→    try:\n   184→        result = subprocess.run(\n   185→            cmd, capture_output=True, text=True, timeout=300,\n   186→            cwd=os.path.dirname(BINARY_PATH),\n   187→        )\n   188→    except (subprocess.TimeoutExpired, FileNotFoundError):\n   189→        return None\n   190→    finally:\n   191→        if os.path.exists(results_path):\n   192→            os.unlink(results_path)\n   193→\n   194→    if result.returncode != 0:\n   195→        return None\n   196→    return parse_blis_stdout(result.stdout)\n   197→\n   198→\n   199→def compute_error(predicted, observed):\n   200→    \"\"\"Compute relative error: |predicted - observed| / observed.\"\"\"\n   201→    if observed == 0:\n   202→        return float(\"inf\") if predicted != 0 else 0.0\n   203→    return abs(predicted - observed) / observed\n   204→\n   205→\n   206→def compute_horizon(exp):\n   207→    \"\"\"Compute a horizon that covers all requests.\"\"\"\n   208→    gt = exp[\"gt\"]\n   209→    e2e_s = gt[\"e2e_mean_s\"]\n   210→    n_requests = gt[\"num_requests\"]\n   211→    rps = gt[\"throughput_rps\"]\n   212→    if rps > 0:\n   213→        duration_s = n_requests / rps\n   214→    else:\n   215→        duration_s = 600\n   216→    return int((duration_s + e2e_s * 3 + 120) * 1_000_000)\n   217→\n   218→\n   219→# ---------------------------------------------------------------------------\n   220→# Artifact manipulation\n   221→# ---------------------------------------------------------------------------\n   222→def load_r3_artifact(model_group):\n   223→    \"\"\"Load the R3 CMA-ES optimized artifact for a model group.\n   224→\n   225→    For the llama-2-70b group, loads the 70b artifact (not 70b-hf).\n   226→    \"\"\"\n   227→    filename = f\"{model_group}_optimized.json\"\n   228→    path = os.path.join(_R3_ARTIFACTS_DIR, filename)\n   229→    if not os.path.isfile(path):\n   230→        # Try without -hf suffix\n   231→        alt = f\"{model_group.replace('-hf', '')}_optimized.json\"\n   232→        alt_path = os.path.join(_R3_ARTIFACTS_DIR, alt)\n   233→        if os.path.isfile(alt_path):\n   234→            path = alt_path\n   235→        else:\n   236→            raise FileNotFoundError(f\"R3 artifact not found: {path}\")\n   237→    with open(path) as f:\n   238→        return json.load(f)\n   239→\n   240→\n   241→def artifact_to_param_vector(artifact):\n   242→    \"\"\"Extract optimizable parameters from a StepML artifact.\"\"\"\n   243→    params = {}\n   244→    params[\"step_overhead_us\"] = artifact.get(\"step_overhead_us\", 4000)\n   245→    params[\"step_overhead_per_req_us\"] = artifact.get(\"step_overhead_per_req_us\", 0)\n   246→    params[\"output_token_processing_time_us\"] = artifact.get(\"output_token_processing_time_us\", 0)\n   247→    params[\"scheduling_processing_time_us\"] = artifact.get(\"scheduling_processing_time_us\", 0)\n   248→    params[\"preemption_processing_time_us\"] = artifact.get(\"preemption_processing_time_us\", 0)\n   249→\n   250→    qt = artifact.get(\"queueing_time\")\n   251→    if qt:\n   252→        params[\"queueing_intercept\"] = qt.get(\"intercept\", 0)\n   253→\n   254→    for regime in artifact.get(\"step_time_regimes\", []):\n   255→        prefix = regime[\"name\"]\n   256→        model = regime[\"model\"]\n   257→        params[f\"{prefix}_intercept\"] = model.get(\"intercept\", 0)\n   258→        for feat, coeff in model.get(\"feature_coefficients\", {}).items():\n   259→            params[f\"{prefix}_{feat}\"] = coeff\n   260→\n   261→    return params\n   262→\n   263→\n   264→def param_vector_to_artifact(params, base_artifact):\n   265→    \"\"\"Reconstruct a StepML artifact from optimized parameters.\"\"\"\n   266→    art = copy.deepcopy(base_artifact)\n   267→    art[\"step_overhead_us\"] = params[\"step_overhead_us\"]\n   268→    art[\"step_overhead_per_req_us\"] = params.get(\"step_overhead_per_req_us\", 0)\n   269→    art[\"output_token_processing_time_us\"] = params[\"output_token_processing_time_us\"]\n   270→    art[\"scheduling_processing_time_us\"] = params[\"scheduling_processing_time_us\"]\n   271→    art[\"preemption_processing_time_us\"] = params[\"preemption_processing_time_us\"]\n   272→\n   273→    if \"queueing_intercept\" in params:\n   274→        if art.get(\"queueing_time\") is None:\n   275→            art[\"queueing_time\"] = {\n   276→                \"model_type\": \"linear\",\n   277→                \"intercept\": 0,\n   278→                \"feature_coefficients\": {},\n   279→            }\n   280→        art[\"queueing_time\"][\"intercept\"] = params[\"queueing_intercept\"]\n   281→\n   282→    for regime in art.get(\"step_time_regimes\", []):\n   283→        prefix = regime[\"name\"]\n   284→        key = f\"{prefix}_intercept\"\n   285→        if key in params:\n   286→            regime[\"model\"][\"intercept\"] = params[key]\n   287→        for feat in list(regime[\"model\"].get(\"feature_coefficients\", {}).keys()):\n   288→            key = f\"{prefix}_{feat}\"\n   289→            if key in params:\n   290→                regime[\"model\"][\"feature_coefficients\"][feat] = params[key]\n   291→\n   292→    return art\n   293→\n   294→\n   295→# ---------------------------------------------------------------------------\n   296→# Constrained parameter bounds (the key R4 innovation)\n   297→# ---------------------------------------------------------------------------\n   298→def compute_bounds(params, base_overhead):\n   299→    \"\"\"Compute constrained parameter bounds.\n   300→\n   301→    Key constraints vs R3:\n   302→    - output_token_processing_time_us: [0, 500] (was [0, 5000+])\n   303→    - scheduling_processing_time_us: [0, 2000] (was unbounded)\n   304→    - step_overhead_us: [base*0.8, base*3.0] (was [base*0.3, base*5.0])\n   305→    - Regime coefficients: tighter bounds (+/- 2x instead of +/- 5x)\n   306→    \"\"\"\n   307→    lower = {}\n   308→    upper = {}\n   309→\n   310→    for name, val in params.items():\n   311→        if name == \"output_token_processing_time_us\":\n   312→            lower[name] = 0\n   313→            upper[name] = 500  # Hard cap (was up to 5000+ in R3)\n   314→        elif name == \"scheduling_processing_time_us\":\n   315→            lower[name] = 0\n   316→            upper[name] = 2000\n   317→        elif name == \"preemption_processing_time_us\":\n   318→            lower[name] = 0\n   319→            upper[name] = 1000\n   320→        elif name == \"step_overhead_us\":\n   321→            lower[name] = max(1000, base_overhead * 0.8)\n   322→            upper[name] = base_overhead * 3.0\n   323→        elif name == \"step_overhead_per_req_us\":\n   324→            lower[name] = 0\n   325→            upper[name] = max(200, abs(val) * 3)\n   326→        elif name == \"queueing_intercept\":\n   327→            lower[name] = -1000\n   328→            upper[name] = 2000\n   329→        elif \"intercept\" in name:\n   330→            lower[name] = val - abs(val) * 2 - 2000\n   331→            upper[name] = val + abs(val) * 2 + 2000\n   332→        else:\n   333→            # Regime coefficients: +/- 2x (tighter than R3's +/- 5x)\n   334→            lower[name] = val - abs(val) * 2 - 50\n   335→            upper[name] = val + abs(val) * 2 + 50\n   336→\n   337→    return lower, upper\n   338→\n   339→\n   340→# ---------------------------------------------------------------------------\n   341→# Constrained CMA-ES objective function\n   342→# ---------------------------------------------------------------------------\n   343→def evaluate_artifact(artifact, exps, ttft_correction_ms=0):\n   344→    \"\"\"Evaluate a StepML artifact across experiments.\n   345→\n   346→    Returns dict with per-experiment E2E, TTFT, ITL errors.\n   347→    \"\"\"\n   348→    # Write artifact to temp file\n   349→    with tempfile.NamedTemporaryFile(\n   350→        mode=\"w\", suffix=\".json\", delete=False\n   351→    ) as f:\n   352→        json.dump(artifact, f)\n   353→        artifact_path = f.name\n   354→\n   355→    results = []\n   356→    try:\n   357→        for exp in exps:\n   358→            trace_csv = get_trace_csv(exp)\n   359→            horizon_us = compute_horizon(exp)\n   360→\n   361→            blis = run_blis_trace(\n   362→                trace_csv, exp[\"exp_config\"], exp[\"kv_blocks\"],\n   363→                artifact_path, horizon_us, exp[\"cpu_kv_blocks\"],\n   364→            )\n   365→\n   366→            if blis is None:\n   367→                results.append({\n   368→                    \"experiment\": exp[\"dirname\"],\n   369→                    \"e2e_error\": 5.0,  # penalty\n   370→                    \"ttft_error\": 5.0,\n   371→                    \"itl_error\": 5.0,\n   372→                    \"status\": \"failed\",\n   373→                })\n   374→                continue\n   375→\n   376→            # Apply TTFT additive correction\n   377→            corrected_ttft = blis[\"ttft_mean_ms\"] + ttft_correction_ms\n   378→\n   379→            gt = exp[\"gt\"]\n   380→            e2e_err = compute_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n   381→            ttft_err = compute_error(corrected_ttft, gt[\"ttft_mean_s\"] * 1000)\n   382→            itl_err = compute_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n   383→\n   384→            results.append({\n   385→                \"experiment\": exp[\"dirname\"],\n   386→                \"model\": exp[\"model\"],\n   387→                \"workload\": exp[\"workload\"],\n   388→                \"e2e_error\": e2e_err,\n   389→                \"ttft_error\": ttft_err,\n   390→                \"itl_error\": itl_err,\n   391→                \"blis_e2e_ms\": blis[\"e2e_mean_ms\"],\n   392→                \"blis_ttft_ms\": corrected_ttft,\n   393→                \"blis_itl_ms\": blis[\"itl_mean_ms\"],\n   394→                \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n   395→                \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n   396→                \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n   397→                \"status\": \"ok\",\n   398→            })\n   399→    finally:\n   400→        os.unlink(artifact_path)\n   401→\n   402→    return results\n   403→\n   404→\n   405→def make_objective(base_artifact, param_names, exps, alpha, ttft_correction_ms):\n   406→    \"\"\"Create a CMA-ES objective function with dual E2E+ITL penalty.\n   407→\n   408→    objective = alpha * mean_e2e + (1-alpha) * mean_itl\n   409→              + 10 * max(0, mean_itl - 0.20)  # hard penalty for ITL > 20%\n   410→    \"\"\"\n   411→    eval_count = [0]\n   412→\n   413→    def objective(x):\n   414→        eval_count[0] += 1\n   415→        params = dict(zip(param_names, x))\n   416→        artifact = param_vector_to_artifact(params, base_artifact)\n   417→\n   418→        results = evaluate_artifact(artifact, exps, ttft_correction_ms)\n   419→        e2e_errors = [r[\"e2e_error\"] for r in results]\n   420→        itl_errors = [r[\"itl_error\"] for r in results]\n   421→\n   422→        mean_e2e = np.mean(e2e_errors)\n   423→        mean_itl = np.mean(itl_errors)\n   424→\n   425→        # Dual objective with ITL penalty\n   426→        obj = alpha * mean_e2e + (1 - alpha) * mean_itl\n   427→        # Penalty for ITL > 20%\n   428→        itl_penalty = 10.0 * max(0, mean_itl - 0.20)\n   429→        obj += itl_penalty\n   430→\n   431→        if eval_count[0] % 5 == 0 or eval_count[0] == 1:\n   432→            print(f\"  Eval {eval_count[0]:3d}: E2E={mean_e2e*100:.1f}% \"\n   433→                  f\"ITL={mean_itl*100:.1f}% obj={obj:.4f}\")\n   434→\n   435→        return obj\n   436→\n   437→    return objective, eval_count\n   438→\n   439→\n   440→# ---------------------------------------------------------------------------\n   441→# H1: Run constrained CMA-ES per model group\n   442→# ---------------------------------------------------------------------------\n   443→def run_h1(experiments, alpha=0.5, max_evals=100, output_dir=None):\n   444→    \"\"\"Run constrained CMA-ES per model group with dual E2E+ITL objective.\"\"\"\n   445→    import cma\n   446→\n   447→    if output_dir is None:\n   448→        output_dir = os.path.join(_SCRIPT_DIR, \"h1-constrained-cmaes\")\n   449→    os.makedirs(output_dir, exist_ok=True)\n   450→    artifacts_dir = os.path.join(output_dir, \"artifacts\")\n   451→    os.makedirs(artifacts_dir, exist_ok=True)\n   452→\n   453→    # Group experiments by model\n   454→    model_exps = {}\n   455→    for exp in experiments:\n   456→        group = exp[\"model_group\"]\n   457→        model_exps.setdefault(group, []).append(exp)\n   458→\n   459→    all_results = []\n   460→    optimization_logs = {}\n   461→\n   462→    for model_group in sorted(model_exps.keys()):\n   463→        exps = model_exps[model_group]\n   464→        print(f\"\\n{'='*60}\")\n   465→        print(f\"  Optimizing: {model_group} ({len(exps)} experiments)\")\n   466→        print(f\"  Alpha={alpha} (E2E weight)\")\n   467→        print(f\"{'='*60}\")\n   468→\n   469→        # Load R3 artifact as starting point\n   470→        r3_art = load_r3_artifact(model_group)\n   471→        params = artifact_to_param_vector(r3_art)\n   472→        param_names = sorted(params.keys())\n   473→        x0 = [params[n] for n in param_names]\n   474→\n   475→        # Get TTFT correction\n   476→        model_for_ttft = model_group\n   477→        if model_group == \"llama-2-70b\":\n   478→            model_for_ttft = \"llama-2-70b\"\n   479→        ttft_ms = TTFT_CORRECTIONS_MS.get(model_for_ttft, 0)\n   480→\n   481→        # Compute initial objective\n   482→        initial_results = evaluate_artifact(r3_art, exps, ttft_ms)\n   483→        initial_e2e = np.mean([r[\"e2e_error\"] for r in initial_results])\n   484→        initial_itl = np.mean([r[\"itl_error\"] for r in initial_results])\n   485→        print(f\"  Initial: E2E={initial_e2e*100:.1f}% ITL={initial_itl*100:.1f}%\")\n   486→\n   487→        # Compute base overhead for bounds\n   488→        base_overhead = r3_art.get(\"step_overhead_us\", 5000)\n   489→        lower, upper = compute_bounds(params, base_overhead)\n   490→\n   491→        lower_list = [lower[n] for n in param_names]\n   492→        upper_list = [upper[n] for n in param_names]\n   493→\n   494→        # Clip x0 to bounds\n   495→        x0_clipped = [max(lo, min(hi, v)) for v, lo, hi in zip(x0, lower_list, upper_list)]\n   496→\n   497→        # CMA-ES configuration\n   498→        sigma0 = 0.1 * np.mean([abs(hi - lo) for lo, hi in zip(lower_list, upper_list)])\n   499→        sigma0 = max(sigma0, 10)\n   500→\n   501→        objective_fn, eval_count = make_objective(\n   502→            r3_art, param_names, exps, alpha, ttft_ms\n   503→        )\n   504→\n   505→        t0 = time.time()\n   506→        opts = cma.CMAOptions()\n   507→        opts[\"maxfevals\"] = max_evals\n   508→        opts[\"timeout\"] = 1800  # 30 min timeout\n   509→        opts[\"bounds\"] = [lower_list, upper_list]\n   510→        opts[\"verbose\"] = -1\n   511→        opts[\"seed\"] = 42\n   512→        opts[\"popsize\"] = 8\n   513→\n   514→        es = cma.CMAEvolutionStrategy(x0_clipped, sigma0, opts)\n   515→        convergence = []\n   516→\n   517→        while not es.stop():\n   518→            solutions = es.ask()\n   519→            fitnesses = [objective_fn(s) for s in solutions]\n   520→            es.tell(solutions, fitnesses)\n   521→            convergence.append(float(es.result.fbest))\n   522→\n   523→        elapsed = time.time() - t0\n   524→        best_x = es.result.xbest\n   525→        best_params = dict(zip(param_names, best_x))\n   526→        best_artifact = param_vector_to_artifact(best_params, r3_art)\n   527→\n   528→        # Evaluate final artifact\n   529→        final_results = evaluate_artifact(best_artifact, exps, ttft_ms)\n   530→        final_e2e = np.mean([r[\"e2e_error\"] for r in final_results])\n   531→        final_itl = np.mean([r[\"itl_error\"] for r in final_results])\n   532→\n   533→        print(f\"\\n  Final:   E2E={final_e2e*100:.1f}% ITL={final_itl*100:.1f}%\")\n   534→        print(f\"  Evals: {eval_count[0]}, Time: {elapsed:.0f}s\")\n   535→\n   536→        # Save artifact\n   537→        art_path = os.path.join(artifacts_dir, f\"{model_group}_optimized.json\")\n   538→        with open(art_path, \"w\") as f:\n   539→            json.dump(best_artifact, f, indent=2)\n   540→\n   541→        for r in final_results:\n   542→            r[\"model_group\"] = model_group\n   543→            r[\"initial_e2e_error\"] = initial_e2e\n   544→            r[\"initial_itl_error\"] = initial_itl\n   545→            r[\"alpha\"] = alpha\n   546→        all_results.extend(final_results)\n   547→\n   548→        optimization_logs[model_group] = {\n   549→            \"n_evals\": eval_count[0],\n   550→            \"elapsed_s\": elapsed,\n   551→            \"initial_mean_e2e\": float(initial_e2e),\n   552→            \"initial_mean_itl\": float(initial_itl),\n   553→            \"best_mean_e2e\": float(final_e2e),\n   554→            \"best_mean_itl\": float(final_itl),\n   555→            \"convergence\": convergence,\n   556→            \"alpha\": alpha,\n   557→        }\n   558→\n   559→    # Compute summary\n   560→    ok_results = [r for r in all_results if r.get(\"status\") == \"ok\"]\n   561→    mean_e2e = np.mean([r[\"e2e_error\"] for r in ok_results]) * 100\n   562→    mean_itl = np.mean([r[\"itl_error\"] for r in ok_results]) * 100\n   563→    mean_ttft = np.mean([r[\"ttft_error\"] for r in ok_results]) * 100\n   564→\n   565→    summary = {\n   566→        \"alpha\": alpha,\n   567→        \"n_experiments\": len(ok_results),\n   568→        \"mean_e2e_error_pct\": float(mean_e2e),\n   569→        \"mean_ttft_error_pct\": float(mean_ttft),\n   570→        \"mean_itl_error_pct\": float(mean_itl),\n   571→        \"e2e_under_10pct\": sum(1 for r in ok_results if r[\"e2e_error\"] < 0.10),\n   572→        \"e2e_under_15pct\": sum(1 for r in ok_results if r[\"e2e_error\"] < 0.15),\n   573→        \"optimization_logs\": optimization_logs,\n   574→        \"per_experiment\": ok_results,\n   575→    }\n   576→\n   577→    summary_path = os.path.join(output_dir, \"summary.json\")\n   578→    with open(summary_path, \"w\") as f:\n   579→        json.dump(summary, f, indent=2, default=str)\n   580→\n   581→    print(f\"\\n{'='*60}\")\n   582→    print(f\"  H1 Results (alpha={alpha}):\")\n   583→    print(f\"  Mean E2E:  {mean_e2e:.1f}%\")\n   584→    print(f\"  Mean TTFT: {mean_ttft:.1f}%\")\n   585→    print(f\"  Mean ITL:  {mean_itl:.1f}%\")\n   586→    print(f\"  E2E < 10%: {summary['e2e_under_10pct']}/{len(ok_results)}\")\n   587→    print(f\"{'='*60}\")\n   588→\n   589→    return summary, all_results\n   590→\n   591→\n   592→# ---------------------------------------------------------------------------\n   593→# H2: Pareto sweep\n   594→# ---------------------------------------------------------------------------\n   595→def run_h2(experiments, output_dir=None):\n   596→    \"\"\"Run H1 with different alpha values to explore Pareto frontier.\"\"\"\n   597→    if output_dir is None:\n   598→        output_dir = os.path.join(_SCRIPT_DIR, \"h2-pareto-sweep\")\n   599→    os.makedirs(output_dir, exist_ok=True)\n   600→\n   601→    alphas = [0.7, 0.5, 0.3]\n   602→    pareto_points = []\n   603→\n   604→    for alpha in alphas:\n   605→        print(f\"\\n{'#'*60}\")\n   606→        print(f\"  PARETO SWEEP: alpha = {alpha}\")\n   607→        print(f\"{'#'*60}\")\n   608→\n   609→        alpha_dir = os.path.join(output_dir, f\"alpha_{alpha}\")\n   610→        summary, results = run_h1(\n   611→            experiments, alpha=alpha, max_evals=100, output_dir=alpha_dir\n   612→        )\n   613→\n   614→        pareto_points.append({\n   615→            \"alpha\": alpha,\n   616→            \"mean_e2e_pct\": summary[\"mean_e2e_error_pct\"],\n   617→            \"mean_itl_pct\": summary[\"mean_itl_error_pct\"],\n   618→            \"mean_ttft_pct\": summary[\"mean_ttft_error_pct\"],\n   619→            \"e2e_under_10\": summary[\"e2e_under_10pct\"],\n   620→            \"n_experiments\": summary[\"n_experiments\"],\n   621→        })\n   622→\n   623→    # Find knee point (closest to origin in E2E-ITL space)\n   624→    best_idx = 0\n   625→    best_dist = float(\"inf\")\n   626→    for i, pt in enumerate(pareto_points):\n   627→        # Normalize: E2E target 10%, ITL target 15%\n   628→        dist = (pt[\"mean_e2e_pct\"] / 10) ** 2 + (pt[\"mean_itl_pct\"] / 15) ** 2\n   629→        if dist < best_dist:\n   630→            best_dist = dist\n   631→            best_idx = i\n   632→\n   633→    pareto_summary = {\n   634→        \"pareto_points\": pareto_points,\n   635→        \"best_alpha\": pareto_points[best_idx][\"alpha\"],\n   636→        \"best_point\": pareto_points[best_idx],\n   637→        \"knee_distance\": float(best_dist),\n   638→    }\n   639→\n   640→    summary_path = os.path.join(output_dir, \"pareto_summary.json\")\n   641→    with open(summary_path, \"w\") as f:\n   642→        json.dump(pareto_summary, f, indent=2)\n   643→\n   644→    print(f\"\\n{'='*60}\")\n   645→    print(f\"  PARETO FRONTIER:\")\n   646→    print(f\"  {'Alpha':>6s} {'E2E%':>8s} {'ITL%':>8s} {'TTFT%':>8s} {'<10%':>5s}\")\n   647→    for pt in pareto_points:\n   648→        marker = \" ← KNEE\" if pt[\"alpha\"] == pareto_points[best_idx][\"alpha\"] else \"\"\n   649→        print(f\"  {pt['alpha']:>6.1f} {pt['mean_e2e_pct']:>7.1f}% \"\n   650→              f\"{pt['mean_itl_pct']:>7.1f}% {pt['mean_ttft_pct']:>7.1f}% \"\n   651→              f\"{pt['e2e_under_10']:>4d}{marker}\")\n   652→    print(f\"{'='*60}\")\n   653→\n   654→    return pareto_summary\n   655→\n   656→\n   657→# ---------------------------------------------------------------------------\n   658→# H3: LOMO (leave-one-model-out)\n   659→# ---------------------------------------------------------------------------\n   660→def run_h3(experiments, best_alpha, output_dir=None):\n   661→    \"\"\"Leave-one-model-out cross-validation with CMA-ES artifacts.\"\"\"\n   662→    if output_dir is None:\n   663→        output_dir = os.path.join(_SCRIPT_DIR, \"h3-lomo\")\n   664→    os.makedirs(output_dir, exist_ok=True)\n   665→\n   666→    # Get unique model groups\n   667→    model_groups = sorted(set(e[\"model_group\"] for e in experiments))\n   668→    print(f\"\\n{'='*60}\")\n   669→    print(f\"  H3: LOMO ({len(model_groups)} folds)\")\n   670→    print(f\"{'='*60}\")\n   671→\n   672→    # Load best artifacts (from H2's best alpha)\n   673→    best_artifacts_dir = os.path.join(\n   674→        _SCRIPT_DIR, \"h2-pareto-sweep\", f\"alpha_{best_alpha}\", \"artifacts\"\n   675→    )\n   676→\n   677→    folds = []\n   678→    for holdout_model in model_groups:\n   679→        print(f\"\\n  Fold: holdout={holdout_model}\")\n   680→        holdout_exps = [e for e in experiments if e[\"model_group\"] == holdout_model]\n   681→        # For each donor model, try its artifact on the holdout\n   682→        donor_results = []\n   683→        for donor_model in model_groups:\n   684→            if donor_model == holdout_model:\n   685→                continue\n   686→            art_path = os.path.join(best_artifacts_dir, f\"{donor_model}_optimized.json\")\n   687→            if not os.path.isfile(art_path):\n   688→                continue\n   689→\n   690→            with open(art_path) as f:\n   691→                donor_art = json.load(f)\n   692→\n   693→            ttft_ms = TTFT_CORRECTIONS_MS.get(holdout_model, 0)\n   694→            results = evaluate_artifact(donor_art, holdout_exps, ttft_ms)\n   695→            ok_results = [r for r in results if r.get(\"status\") == \"ok\"]\n   696→            if ok_results:\n   697→                mean_e2e = np.mean([r[\"e2e_error\"] for r in ok_results])\n   698→                mean_itl = np.mean([r[\"itl_error\"] for r in ok_results])\n   699→                donor_results.append({\n   700→                    \"donor\": donor_model,\n   701→                    \"mean_e2e_pct\": float(mean_e2e * 100),\n   702→                    \"mean_itl_pct\": float(mean_itl * 100),\n   703→                    \"per_experiment\": ok_results,\n   704→                })\n   705→                print(f\"    Donor {donor_model}: E2E={mean_e2e*100:.1f}% ITL={mean_itl*100:.1f}%\")\n   706→\n   707→        # Best donor for this fold\n   708→        if donor_results:\n   709→            best_donor = min(donor_results, key=lambda x: x[\"mean_e2e_pct\"])\n   710→        else:\n   711→            best_donor = {\"donor\": \"none\", \"mean_e2e_pct\": 999, \"mean_itl_pct\": 999}\n   712→\n   713→        folds.append({\n   714→            \"holdout_model\": holdout_model,\n   715→            \"best_donor\": best_donor[\"donor\"],\n   716→            \"best_donor_e2e_pct\": best_donor[\"mean_e2e_pct\"],\n   717→            \"best_donor_itl_pct\": best_donor.get(\"mean_itl_pct\", 999),\n   718→            \"all_donors\": donor_results,\n   719→        })\n   720→\n   721→    # Summary\n   722→    mean_best_donor_e2e = np.mean([f[\"best_donor_e2e_pct\"] for f in folds])\n   723→    lomo_summary = {\n   724→        \"folds\": folds,\n   725→        \"mean_best_donor_e2e_pct\": float(mean_best_donor_e2e),\n   726→        \"target\": \"<80% MAPE per fold (E2E proxy)\",\n   727→        \"alpha_used\": best_alpha,\n   728→    }\n   729→\n   730→    summary_path = os.path.join(output_dir, \"lomo_summary.json\")\n   731→    with open(summary_path, \"w\") as f:\n   732→        json.dump(lomo_summary, f, indent=2, default=str)\n   733→\n   734→    print(f\"\\n  LOMO Summary:\")\n   735→    print(f\"  {'Holdout':<25s} {'Best Donor':<25s} {'E2E%':>8s} {'ITL%':>8s}\")\n   736→    for fold in folds:\n   737→        print(f\"  {fold['holdout_model']:<25s} {fold['best_donor']:<25s} \"\n   738→              f\"{fold['best_donor_e2e_pct']:>7.1f}% {fold['best_donor_itl_pct']:>7.1f}%\")\n   739→    print(f\"  Mean best-donor E2E: {mean_best_donor_e2e:.1f}%\")\n   740→\n   741→    return lomo_summary\n   742→\n   743→\n   744→# ---------------------------------------------------------------------------\n   745→# H4: LOWO (leave-one-workload-out)\n   746→# ---------------------------------------------------------------------------\n   747→def run_h4(experiments, best_alpha, output_dir=None):\n   748→    \"\"\"Leave-one-workload-out: check per-model workload variance.\"\"\"\n   749→    if output_dir is None:\n   750→        output_dir = os.path.join(_SCRIPT_DIR, \"h4-lowo\")\n   751→    os.makedirs(output_dir, exist_ok=True)\n   752→\n   753→    # Load best artifacts\n   754→    best_artifacts_dir = os.path.join(\n   755→        _SCRIPT_DIR, \"h2-pareto-sweep\", f\"alpha_{best_alpha}\", \"artifacts\"\n   756→    )\n   757→\n   758→    # Get unique workloads and models\n   759→    workloads = sorted(set(e[\"workload\"] for e in experiments))\n   760→    model_groups = sorted(set(e[\"model_group\"] for e in experiments))\n   761→\n   762→    print(f\"\\n{'='*60}\")\n   763→    print(f\"  H4: LOWO ({len(workloads)} workloads)\")\n   764→    print(f\"{'='*60}\")\n   765→\n   766→    # Evaluate each experiment with its model's best artifact\n   767→    per_exp_results = []\n   768→    for exp in experiments:\n   769→        art_path = os.path.join(best_artifacts_dir, f\"{exp['model_group']}_optimized.json\")\n   770→        if not os.path.isfile(art_path):\n   771→            continue\n   772→        with open(art_path) as f:\n   773→            art = json.load(f)\n   774→        ttft_ms = TTFT_CORRECTIONS_MS.get(exp[\"model\"], 0)\n   775→        results = evaluate_artifact(art, [exp], ttft_ms)\n   776→        if results and results[0].get(\"status\") == \"ok\":\n   777→            per_exp_results.append(results[0])\n   778→\n   779→    # Compute per-model workload range\n   780→    model_workload_map = {}\n   781→    for r in per_exp_results:\n   782→        group = MODEL_GROUPS.get(r.get(\"model\", \"\"), r.get(\"model\", \"\"))\n   783→        model_workload_map.setdefault(group, []).append(r)\n   784→\n   785→    model_stats = {}\n   786→    for model, results in sorted(model_workload_map.items()):\n   787→        e2e_errors = [r[\"e2e_error\"] * 100 for r in results]\n   788→        model_stats[model] = {\n   789→            \"workloads\": [r.get(\"workload\", \"?\") for r in results],\n   790→            \"e2e_errors\": e2e_errors,\n   791→            \"e2e_range\": max(e2e_errors) - min(e2e_errors),\n   792→            \"e2e_mean\": np.mean(e2e_errors),\n   793→        }\n   794→\n   795→    # Aggregate E2E across all experiments\n   796→    agg_e2e = np.mean([r[\"e2e_error\"] for r in per_exp_results])\n   797→    within_2x = sum(\n   798→        1 for r in per_exp_results if r[\"e2e_error\"] <= agg_e2e * 2\n   799→    )\n   800→\n   801→    lowo_summary = {\n   802→        \"per_model_stats\": {m: s for m, s in model_stats.items()},\n   803→        \"aggregate_e2e_pct\": float(agg_e2e * 100),\n   804→        \"within_2x_aggregate\": within_2x,\n   805→        \"total_experiments\": len(per_exp_results),\n   806→        \"alpha_used\": best_alpha,\n   807→    }\n   808→\n   809→    summary_path = os.path.join(output_dir, \"lowo_summary.json\")\n   810→    with open(summary_path, \"w\") as f:\n   811→        json.dump(lowo_summary, f, indent=2, default=str)\n   812→\n   813→    print(f\"\\n  LOWO Summary:\")\n   814→    print(f\"  {'Model':<25s} {'Range (pp)':>10s} {'Mean E2E%':>10s} {'Workloads'}\")\n   815→    for model, stats in sorted(model_stats.items()):\n   816→        wl_str = \", \".join(f\"{w}={e:.1f}%\" for w, e in zip(stats[\"workloads\"], stats[\"e2e_errors\"]))\n   817→        print(f\"  {model:<25s} {stats['e2e_range']:>9.1f}pp {stats['e2e_mean']:>9.1f}% {wl_str}\")\n   818→    print(f\"\\n  Aggregate E2E: {agg_e2e*100:.1f}%\")\n   819→    print(f\"  Within 2x aggregate: {within_2x}/{len(per_exp_results)}\")\n   820→\n   821→    return lowo_summary\n   822→\n   823→\n   824→# ---------------------------------------------------------------------------\n   825→# Main\n   826→# ---------------------------------------------------------------------------\n   827→def main():\n   828→    print(\"=\" * 60)\n   829→    print(\"  Round 4, Idea 1: Constrained CMA-ES with ITL Penalty\")\n   830→    print(\"=\" * 60)\n   831→\n   832→    # Discover experiments\n   833→    experiments = discover_experiments()\n   834→    print(f\"\\nDiscovered {len(experiments)} experiments\")\n   835→    for exp in experiments:\n   836→        print(f\"  {exp['dirname']}: model={exp['model_group']}, wl={exp['workload']}\")\n   837→\n   838→    if not experiments:\n   839→        print(\"ERROR: No experiments found. Check _DATA_ROOT path.\")\n   840→        sys.exit(1)\n   841→\n   842→    # H1: Run with default alpha=0.5 first to verify infrastructure\n   843→    print(f\"\\n{'#'*60}\")\n   844→    print(\"  H1: Constrained CMA-ES (alpha=0.5)\")\n   845→    print(f\"{'#'*60}\")\n   846→    h1_summary, h1_results = run_h1(experiments, alpha=0.5, max_evals=100)\n   847→\n   848→    # Short-circuit check\n   849→    if h1_summary[\"mean_e2e_error_pct\"] > 25:\n   850→        print(f\"\\nSHORT-CIRCUIT: Mean E2E {h1_summary['mean_e2e_error_pct']:.1f}% > 25%\")\n   851→        print(\"Constrained CMA-ES is significantly worse than R3. Aborting.\")\n   852→        return\n   853→\n   854→    # H2: Pareto sweep\n   855→    print(f\"\\n{'#'*60}\")\n   856→    print(\"  H2: Pareto Sweep\")\n   857→    print(f\"{'#'*60}\")\n   858→    h2_summary = run_h2(experiments)\n   859→    best_alpha = h2_summary[\"best_alpha\"]\n   860→\n   861→    # H3: LOMO\n   862→    print(f\"\\n{'#'*60}\")\n   863→    print(f\"  H3: LOMO (using best alpha={best_alpha})\")\n   864→    print(f\"{'#'*60}\")\n   865→    h3_summary = run_h3(experiments, best_alpha)\n   866→\n   867→    # H4: LOWO\n   868→    print(f\"\\n{'#'*60}\")\n   869→    print(f\"  H4: LOWO (using best alpha={best_alpha})\")\n   870→    print(f\"{'#'*60}\")\n   871→    h4_summary = run_h4(experiments, best_alpha)\n   872→\n   873→    # Final summary\n   874→    print(f\"\\n{'='*60}\")\n   875→    print(\"  FINAL SUMMARY\")\n   876→    print(f\"{'='*60}\")\n   877→    print(f\"  H1 (alpha=0.5): E2E={h1_summary['mean_e2e_error_pct']:.1f}% \"\n   878→          f\"ITL={h1_summary['mean_itl_error_pct']:.1f}%\")\n   879→    print(f\"  H2 best alpha={best_alpha}: \"\n   880→          f\"E2E={h2_summary['best_point']['mean_e2e_pct']:.1f}% \"\n   881→          f\"ITL={h2_summary['best_point']['mean_itl_pct']:.1f}%\")\n   882→    print(f\"  H3 LOMO mean best-donor E2E: {h3_summary['mean_best_donor_e2e_pct']:.1f}%\")\n   883→    print(f\"  H4 LOWO within 2x: {h4_summary['within_2x_aggregate']}/{h4_summary['total_experiments']}\")\n   884→\n   885→\n   886→if __name__ == \"__main__\":\n   887→    main()\n   888→"}]},"parent_tool_use_id":null,"session_id":"6c146fd0-2769-4d18-b481-0819d4602c26","uuid":"a12404c6-9d1e-48f6-8562-5da84806a2d8","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round4-idea-1-constrained-cmaes/hypotheses/h-stepml/round4/idea-1-constrained-cmaes/run_experiment.py","content":"#!/usr/bin/env python3\n\"\"\"Round 4, Idea 1: Multi-Objective Constrained CMA-ES with ITL Penalty.\n\nImplements all 4 sub-hypotheses:\n  H1: Constrained CMA-ES with dual E2E+ITL objective\n  H2: Pareto sweep across alpha values\n  H3: LOMO (leave-one-model-out) generalization\n  H4: LOWO (leave-one-workload-out) generalization\n\nUses the shared infrastructure from hypotheses/h-stepml/shared/ for data loading,\nBLIS validation, and evaluation.\n\"\"\"\n\nimport copy\nimport json\nimport os\nimport re\nimport subprocess\nimport sys\nimport tempfile\nimport time\n\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# Paths\n# ---------------------------------------------------------------------------\n_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n_SHARED_DIR = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"shared\"))\n_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\", \"..\"))\n# Ground truth lives in the main BLIS-research repo (not the worktree)\n# Worktree root is stepml-worktrees/round4-idea-1-constrained-cmaes/\n# BLIS-research is at inference-sim-package/BLIS-research/\n_INFERENCE_SIM_PKG = os.path.abspath(os.path.join(_REPO_ROOT, \"..\", \"..\"))\n_DATA_ROOT = os.path.join(_INFERENCE_SIM_PKG, \"BLIS-research\", \"eval\", \"ground_truth\")\n_R3_ARTIFACTS_DIR = os.path.join(\n    _INFERENCE_SIM_PKG, \"BLIS-research\", \"hypotheses\", \"h-stepml\",\n    \"round3\", \"idea-3-e2e-calibration\", \"h1-trace-e2e-opt\", \"artifacts\"\n)\nBINARY_PATH = os.path.join(_REPO_ROOT, \"simulation_worker\")\nBLOCK_SIZE_TOKENS = 16\n\nsys.path.insert(0, _SHARED_DIR)\n\nimport yaml\nfrom convert_lifecycle_to_traces import convert_experiment\nfrom validate_blis import (\n    extract_cpu_kv_blocks_from_vllm_log,\n    extract_kv_blocks_from_vllm_log,\n    load_exp_config,\n    load_ground_truth_metrics,\n    parse_blis_stdout,\n    parse_experiment_dir,\n)\n\n# ---------------------------------------------------------------------------\n# TTFT corrections from R3 H3 (per-model additive corrections in ms)\n# ---------------------------------------------------------------------------\nTTFT_CORRECTIONS_MS = {\n    \"llama-2-7b\": 16.49,\n    \"llama-2-70b\": 60.98,\n    \"llama-2-70b-hf\": 37.57,\n    \"mixtral-8x7b-v0-1\": 40.16,\n    \"codellama-34b\": 32.48,\n}\n\n# ---------------------------------------------------------------------------\n# Model group mapping (experiment dir model name -> group)\n# ---------------------------------------------------------------------------\n# For CMA-ES optimization, group experiments by shared optimizer.\n# 70b and 70b-hf share the same optimizer (both are 70B models).\n# Each experiment's specific artifact is loaded from R3 by exact model name.\nMODEL_GROUPS = {\n    \"llama-2-7b\": \"llama-2-7b\",\n    \"llama-2-70b\": \"llama-2-70b\",\n    \"llama-2-70b-hf\": \"llama-2-70b\",  # Same optimization group as 70b\n    \"codellama-34b\": \"codellama-34b\",\n    \"mixtral-8x7b-v0-1\": \"mixtral-8x7b-v0-1\",\n}\n\n# For LOMO, we group 70b and 70b-hf as one model\nLOMO_MODEL_GROUPS = {\n    \"llama-2-7b\": \"llama-2-7b\",\n    \"llama-2-70b\": \"llama-2-70b\",\n    \"llama-2-70b-hf\": \"llama-2-70b\",\n    \"codellama-34b\": \"codellama-34b\",\n    \"mixtral-8x7b-v0-1\": \"mixtral-8x7b-v0-1\",\n}\n\n\n# ---------------------------------------------------------------------------\n# Experiment discovery\n# ---------------------------------------------------------------------------\ndef discover_experiments():\n    \"\"\"Discover all valid experiments in the ground truth directory.\"\"\"\n    experiments = []\n    for dirname in sorted(os.listdir(_DATA_ROOT)):\n        dirpath = os.path.join(_DATA_ROOT, dirname)\n        if not os.path.isdir(dirpath):\n            continue\n        summary_path = os.path.join(dirpath, \"results\", \"summary_lifecycle_metrics.json\")\n        if not os.path.isfile(summary_path):\n            continue\n\n        meta = parse_experiment_dir(dirname)\n        gt = load_ground_truth_metrics(dirpath)\n        exp_config = load_exp_config(dirpath)\n        kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n        cpu_kv_blocks = extract_cpu_kv_blocks_from_vllm_log(dirpath)\n\n        if kv_blocks is None:\n            continue\n\n        model_group = MODEL_GROUPS.get(meta[\"model\"], meta[\"model\"])\n\n        experiments.append({\n            \"dirname\": dirname,\n            \"dirpath\": dirpath,\n            \"model\": meta[\"model\"],\n            \"model_group\": model_group,\n            \"workload\": meta[\"workload\"],\n            \"tp\": meta[\"tp\"],\n            \"gt\": gt,\n            \"exp_config\": exp_config,\n            \"kv_blocks\": kv_blocks,\n            \"cpu_kv_blocks\": cpu_kv_blocks,\n        })\n\n    return experiments\n\n\n# ---------------------------------------------------------------------------\n# Trace CSV generation (cached)\n# ---------------------------------------------------------------------------\n_TRACE_CACHE = {}\n\n\ndef get_trace_csv(exp):\n    \"\"\"Get or create trace CSV for an experiment.\"\"\"\n    dirname = exp[\"dirname\"]\n    if dirname in _TRACE_CACHE:\n        return _TRACE_CACHE[dirname]\n\n    trace_dir = os.path.join(_SCRIPT_DIR, \"traces\")\n    csv_path = os.path.join(trace_dir, f\"{dirname}.csv\")\n    if not os.path.isfile(csv_path):\n        csv_path = convert_experiment(exp[\"dirpath\"], trace_dir)\n\n    _TRACE_CACHE[dirname] = csv_path\n    return csv_path\n\n\n# ---------------------------------------------------------------------------\n# BLIS execution (trace replay mode)\n# ---------------------------------------------------------------------------\ndef run_blis_trace(trace_csv, exp_config, kv_blocks, artifact_path, horizon_us,\n                   cpu_kv_blocks=0):\n    \"\"\"Run BLIS in trace replay mode with a StepML artifact.\"\"\"\n    with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n        results_path = f.name\n\n    cmd = [\n        BINARY_PATH, \"run\",\n        \"--model\", exp_config.get(\"model\", \"unknown\"),\n        \"--workload\", \"traces\",\n        \"--workload-traces-filepath\", trace_csv,\n        \"--tp\", str(exp_config.get(\"tensor_parallelism\", 1)),\n        \"--max-model-len\", str(exp_config.get(\"max_model_len\", 4096)),\n        \"--max-num-running-reqs\", str(exp_config.get(\"max_num_seqs\", 128)),\n        \"--max-num-scheduled-tokens\", str(exp_config.get(\"max_num_batched_tokens\", 2048)),\n        \"--total-kv-blocks\", str(kv_blocks),\n        \"--block-size-in-tokens\", str(BLOCK_SIZE_TOKENS),\n        \"--horizon\", str(horizon_us),\n        \"--alpha-coeffs=1,0,0\",\n        \"--beta-coeffs=1,0,0\",\n        \"--stepml-model\", artifact_path,\n        \"--results-path\", results_path,\n        \"--log\", \"error\",\n    ]\n    if cpu_kv_blocks > 0:\n        cmd.extend([\"--kv-cpu-blocks\", str(cpu_kv_blocks)])\n\n    try:\n        result = subprocess.run(\n            cmd, capture_output=True, text=True, timeout=300,\n            cwd=os.path.dirname(BINARY_PATH),\n        )\n    except (subprocess.TimeoutExpired, FileNotFoundError):\n        return None\n    finally:\n        if os.path.exists(results_path):\n            os.unlink(results_path)\n\n    if result.returncode != 0:\n        return None\n    return parse_blis_stdout(result.stdout)\n\n\ndef compute_error(predicted, observed):\n    \"\"\"Compute relative error: |predicted - observed| / observed.\"\"\"\n    if observed == 0:\n        return float(\"inf\") if predicted != 0 else 0.0\n    return abs(predicted - observed) / observed\n\n\ndef compute_horizon(exp):\n    \"\"\"Compute a horizon that covers all requests.\"\"\"\n    gt = exp[\"gt\"]\n    e2e_s = gt[\"e2e_mean_s\"]\n    n_requests = gt[\"num_requests\"]\n    rps = gt[\"throughput_rps\"]\n    if rps > 0:\n        duration_s = n_requests / rps\n    else:\n        duration_s = 600\n    return int((duration_s + e2e_s * 3 + 120) * 1_000_000)\n\n\n# ---------------------------------------------------------------------------\n# Artifact manipulation\n# ---------------------------------------------------------------------------\ndef load_r3_artifact(model_group):\n    \"\"\"Load the R3 CMA-ES optimized artifact for a model group.\n\n    For the llama-2-70b group, loads the 70b artifact (not 70b-hf).\n    \"\"\"\n    filename = f\"{model_group}_optimized.json\"\n    path = os.path.join(_R3_ARTIFACTS_DIR, filename)\n    if not os.path.isfile(path):\n        # Try without -hf suffix\n        alt = f\"{model_group.replace('-hf', '')}_optimized.json\"\n        alt_path = os.path.join(_R3_ARTIFACTS_DIR, alt)\n        if os.path.isfile(alt_path):\n            path = alt_path\n        else:\n            raise FileNotFoundError(f\"R3 artifact not found: {path}\")\n    with open(path) as f:\n        return json.load(f)\n\n\ndef artifact_to_param_vector(artifact):\n    \"\"\"Extract optimizable parameters from a StepML artifact.\"\"\"\n    params = {}\n    params[\"step_overhead_us\"] = artifact.get(\"step_overhead_us\", 4000)\n    params[\"step_overhead_per_req_us\"] = artifact.get(\"step_overhead_per_req_us\", 0)\n    params[\"output_token_processing_time_us\"] = artifact.get(\"output_token_processing_time_us\", 0)\n    params[\"scheduling_processing_time_us\"] = artifact.get(\"scheduling_processing_time_us\", 0)\n    params[\"preemption_processing_time_us\"] = artifact.get(\"preemption_processing_time_us\", 0)\n\n    qt = artifact.get(\"queueing_time\")\n    if qt:\n        params[\"queueing_intercept\"] = qt.get(\"intercept\", 0)\n\n    for regime in artifact.get(\"step_time_regimes\", []):\n        prefix = regime[\"name\"]\n        model = regime[\"model\"]\n        params[f\"{prefix}_intercept\"] = model.get(\"intercept\", 0)\n        for feat, coeff in model.get(\"feature_coefficients\", {}).items():\n            params[f\"{prefix}_{feat}\"] = coeff\n\n    return params\n\n\ndef param_vector_to_artifact(params, base_artifact):\n    \"\"\"Reconstruct a StepML artifact from optimized parameters.\"\"\"\n    art = copy.deepcopy(base_artifact)\n    art[\"step_overhead_us\"] = params[\"step_overhead_us\"]\n    art[\"step_overhead_per_req_us\"] = params.get(\"step_overhead_per_req_us\", 0)\n    art[\"output_token_processing_time_us\"] = params[\"output_token_processing_time_us\"]\n    art[\"scheduling_processing_time_us\"] = params[\"scheduling_processing_time_us\"]\n    art[\"preemption_processing_time_us\"] = params[\"preemption_processing_time_us\"]\n\n    if \"queueing_intercept\" in params:\n        if art.get(\"queueing_time\") is None:\n            art[\"queueing_time\"] = {\n                \"model_type\": \"linear\",\n                \"intercept\": 0,\n                \"feature_coefficients\": {},\n            }\n        art[\"queueing_time\"][\"intercept\"] = params[\"queueing_intercept\"]\n\n    for regime in art.get(\"step_time_regimes\", []):\n        prefix = regime[\"name\"]\n        key = f\"{prefix}_intercept\"\n        if key in params:\n            regime[\"model\"][\"intercept\"] = params[key]\n        for feat in list(regime[\"model\"].get(\"feature_coefficients\", {}).keys()):\n            key = f\"{prefix}_{feat}\"\n            if key in params:\n                regime[\"model\"][\"feature_coefficients\"][feat] = params[key]\n\n    return art\n\n\n# ---------------------------------------------------------------------------\n# Constrained parameter bounds (the key R4 innovation)\n# ---------------------------------------------------------------------------\ndef compute_bounds(params, base_overhead):\n    \"\"\"Compute constrained parameter bounds.\n\n    Key constraints vs R3:\n    - output_token_processing_time_us: [0, 500] (was [0, 5000+])\n    - scheduling_processing_time_us: [0, 2000] (was unbounded)\n    - step_overhead_us: [base*0.8, base*3.0] (was [base*0.3, base*5.0])\n    - Regime coefficients: tighter bounds (+/- 2x instead of +/- 5x)\n    \"\"\"\n    lower = {}\n    upper = {}\n\n    for name, val in params.items():\n        if name == \"output_token_processing_time_us\":\n            lower[name] = 0\n            upper[name] = 500  # Hard cap (was up to 5000+ in R3)\n        elif name == \"scheduling_processing_time_us\":\n            lower[name] = 0\n            upper[name] = 2000\n        elif name == \"preemption_processing_time_us\":\n            lower[name] = 0\n            upper[name] = 1000\n        elif name == \"step_overhead_us\":\n            lower[name] = max(1000, base_overhead * 0.8)\n            upper[name] = base_overhead * 3.0\n        elif name == \"step_overhead_per_req_us\":\n            lower[name] = 0\n            upper[name] = max(200, abs(val) * 3)\n        elif name == \"queueing_intercept\":\n            lower[name] = -1000\n            upper[name] = 2000\n        elif \"intercept\" in name:\n            lower[name] = val - abs(val) * 2 - 2000\n            upper[name] = val + abs(val) * 2 + 2000\n        else:\n            # Regime coefficients: +/- 2x (tighter than R3's +/- 5x)\n            lower[name] = val - abs(val) * 2 - 50\n            upper[name] = val + abs(val) * 2 + 50\n\n    return lower, upper\n\n\n# ---------------------------------------------------------------------------\n# Constrained CMA-ES objective function\n# ---------------------------------------------------------------------------\ndef evaluate_artifact(artifact, exps, ttft_correction_ms=0):\n    \"\"\"Evaluate a StepML artifact across experiments.\n\n    Returns dict with per-experiment E2E, TTFT, ITL errors.\n    \"\"\"\n    # Write artifact to temp file\n    with tempfile.NamedTemporaryFile(\n        mode=\"w\", suffix=\".json\", delete=False\n    ) as f:\n        json.dump(artifact, f)\n        artifact_path = f.name\n\n    results = []\n    try:\n        for exp in exps:\n            trace_csv = get_trace_csv(exp)\n            horizon_us = compute_horizon(exp)\n\n            blis = run_blis_trace(\n                trace_csv, exp[\"exp_config\"], exp[\"kv_blocks\"],\n                artifact_path, horizon_us, exp[\"cpu_kv_blocks\"],\n            )\n\n            if blis is None:\n                results.append({\n                    \"experiment\": exp[\"dirname\"],\n                    \"e2e_error\": 5.0,  # penalty\n                    \"ttft_error\": 5.0,\n                    \"itl_error\": 5.0,\n                    \"status\": \"failed\",\n                })\n                continue\n\n            # Apply TTFT additive correction\n            corrected_ttft = blis[\"ttft_mean_ms\"] + ttft_correction_ms\n\n            gt = exp[\"gt\"]\n            e2e_err = compute_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n            ttft_err = compute_error(corrected_ttft, gt[\"ttft_mean_s\"] * 1000)\n            itl_err = compute_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n\n            results.append({\n                \"experiment\": exp[\"dirname\"],\n                \"model\": exp[\"model\"],\n                \"workload\": exp[\"workload\"],\n                \"e2e_error\": e2e_err,\n                \"ttft_error\": ttft_err,\n                \"itl_error\": itl_err,\n                \"blis_e2e_ms\": blis[\"e2e_mean_ms\"],\n                \"blis_ttft_ms\": corrected_ttft,\n                \"blis_itl_ms\": blis[\"itl_mean_ms\"],\n                \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n                \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n                \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n                \"status\": \"ok\",\n            })\n    finally:\n        os.unlink(artifact_path)\n\n    return results\n\n\ndef make_objective(base_artifact, param_names, exps, alpha, ttft_correction_ms):\n    \"\"\"Create a CMA-ES objective function with dual E2E+ITL penalty.\n\n    objective = alpha * mean_e2e + (1-alpha) * mean_itl\n              + 10 * max(0, mean_itl - 0.20)  # hard penalty for ITL > 20%\n    \"\"\"\n    eval_count = [0]\n\n    def objective(x):\n        eval_count[0] += 1\n        params = dict(zip(param_names, x))\n        artifact = param_vector_to_artifact(params, base_artifact)\n\n        results = evaluate_artifact(artifact, exps, ttft_correction_ms)\n        e2e_errors = [r[\"e2e_error\"] for r in results]\n        itl_errors = [r[\"itl_error\"] for r in results]\n\n        mean_e2e = np.mean(e2e_errors)\n        mean_itl = np.mean(itl_errors)\n\n        # Dual objective with ITL penalty\n        obj = alpha * mean_e2e + (1 - alpha) * mean_itl\n        # Penalty for ITL > 20%\n        itl_penalty = 10.0 * max(0, mean_itl - 0.20)\n        obj += itl_penalty\n\n        if eval_count[0] % 5 == 0 or eval_count[0] == 1:\n            print(f\"  Eval {eval_count[0]:3d}: E2E={mean_e2e*100:.1f}% \"\n                  f\"ITL={mean_itl*100:.1f}% obj={obj:.4f}\")\n\n        return obj\n\n    return objective, eval_count\n\n\n# ---------------------------------------------------------------------------\n# H1: Run constrained CMA-ES per model group\n# ---------------------------------------------------------------------------\ndef run_h1(experiments, alpha=0.5, max_evals=100, output_dir=None):\n    \"\"\"Run constrained CMA-ES per model group with dual E2E+ITL objective.\"\"\"\n    import cma\n\n    if output_dir is None:\n        output_dir = os.path.join(_SCRIPT_DIR, \"h1-constrained-cmaes\")\n    os.makedirs(output_dir, exist_ok=True)\n    artifacts_dir = os.path.join(output_dir, \"artifacts\")\n    os.makedirs(artifacts_dir, exist_ok=True)\n\n    # Group experiments by model\n    model_exps = {}\n    for exp in experiments:\n        group = exp[\"model_group\"]\n        model_exps.setdefault(group, []).append(exp)\n\n    all_results = []\n    optimization_logs = {}\n\n    for model_group in sorted(model_exps.keys()):\n        exps = model_exps[model_group]\n        print(f\"\\n{'='*60}\")\n        print(f\"  Optimizing: {model_group} ({len(exps)} experiments)\")\n        print(f\"  Alpha={alpha} (E2E weight)\")\n        print(f\"{'='*60}\")\n\n        # Load R3 artifact as starting point\n        r3_art = load_r3_artifact(model_group)\n        params = artifact_to_param_vector(r3_art)\n        param_names = sorted(params.keys())\n        x0 = [params[n] for n in param_names]\n\n        # Get TTFT correction\n        model_for_ttft = model_group\n        if model_group == \"llama-2-70b\":\n            model_for_ttft = \"llama-2-70b\"\n        ttft_ms = TTFT_CORRECTIONS_MS.get(model_for_ttft, 0)\n\n        # Compute initial objective\n        initial_results = evaluate_artifact(r3_art, exps, ttft_ms)\n        initial_e2e = np.mean([r[\"e2e_error\"] for r in initial_results])\n        initial_itl = np.mean([r[\"itl_error\"] for r in initial_results])\n        print(f\"  Initial: E2E={initial_e2e*100:.1f}% ITL={initial_itl*100:.1f}%\")\n\n        # Compute base overhead for bounds\n        base_overhead = r3_art.get(\"step_overhead_us\", 5000)\n        lower, upper = compute_bounds(params, base_overhead)\n\n        lower_list = [lower[n] for n in param_names]\n        upper_list = [upper[n] for n in param_names]\n\n        # Clip x0 to bounds\n        x0_clipped = [max(lo, min(hi, v)) for v, lo, hi in zip(x0, lower_list, upper_list)]\n\n        # CMA-ES configuration\n        sigma0 = 0.1 * np.mean([abs(hi - lo) for lo, hi in zip(lower_list, upper_list)])\n        sigma0 = max(sigma0, 10)\n\n        objective_fn, eval_count = make_objective(\n            r3_art, param_names, exps, alpha, ttft_ms\n        )\n\n        t0 = time.time()\n        opts = cma.CMAOptions()\n        opts[\"maxfevals\"] = max_evals\n        opts[\"timeout\"] = 1800  # 30 min timeout\n        opts[\"bounds\"] = [lower_list, upper_list]\n        opts[\"verbose\"] = -1\n        opts[\"seed\"] = 42\n        opts[\"popsize\"] = 8\n\n        es = cma.CMAEvolutionStrategy(x0_clipped, sigma0, opts)\n        convergence = []\n\n        while not es.stop():\n            solutions = es.ask()\n            fitnesses = [objective_fn(s) for s in solutions]\n            es.tell(solutions, fitnesses)\n            convergence.append(float(es.result.fbest))\n\n        elapsed = time.time() - t0\n        best_x = es.result.xbest\n        best_params = dict(zip(param_names, best_x))\n        best_artifact = param_vector_to_artifact(best_params, r3_art)\n\n        # Evaluate final artifact\n        final_results = evaluate_artifact(best_artifact, exps, ttft_ms)\n        final_e2e = np.mean([r[\"e2e_error\"] for r in final_results])\n        final_itl = np.mean([r[\"itl_error\"] for r in final_results])\n\n        print(f\"\\n  Final:   E2E={final_e2e*100:.1f}% ITL={final_itl*100:.1f}%\")\n        print(f\"  Evals: {eval_count[0]}, Time: {elapsed:.0f}s\")\n\n        # Save artifact\n        art_path = os.path.join(artifacts_dir, f\"{model_group}_optimized.json\")\n        with open(art_path, \"w\") as f:\n            json.dump(best_artifact, f, indent=2)\n\n        for r in final_results:\n            r[\"model_group\"] = model_group\n            r[\"initial_e2e_error\"] = initial_e2e\n            r[\"initial_itl_error\"] = initial_itl\n            r[\"alpha\"] = alpha\n        all_results.extend(final_results)\n\n        optimization_logs[model_group] = {\n            \"n_evals\": eval_count[0],\n            \"elapsed_s\": elapsed,\n            \"initial_mean_e2e\": float(initial_e2e),\n            \"initial_mean_itl\": float(initial_itl),\n            \"best_mean_e2e\": float(final_e2e),\n            \"best_mean_itl\": float(final_itl),\n            \"convergence\": convergence,\n            \"alpha\": alpha,\n        }\n\n    # Compute summary\n    ok_results = [r for r in all_results if r.get(\"status\") == \"ok\"]\n    mean_e2e = np.mean([r[\"e2e_error\"] for r in ok_results]) * 100\n    mean_itl = np.mean([r[\"itl_error\"] for r in ok_results]) * 100\n    mean_ttft = np.mean([r[\"ttft_error\"] for r in ok_results]) * 100\n\n    summary = {\n        \"alpha\": alpha,\n        \"n_experiments\": len(ok_results),\n        \"mean_e2e_error_pct\": float(mean_e2e),\n        \"mean_ttft_error_pct\": float(mean_ttft),\n        \"mean_itl_error_pct\": float(mean_itl),\n        \"e2e_under_10pct\": sum(1 for r in ok_results if r[\"e2e_error\"] < 0.10),\n        \"e2e_under_15pct\": sum(1 for r in ok_results if r[\"e2e_error\"] < 0.15),\n        \"optimization_logs\": optimization_logs,\n        \"per_experiment\": ok_results,\n    }\n\n    summary_path = os.path.join(output_dir, \"summary.json\")\n    with open(summary_path, \"w\") as f:\n        json.dump(summary, f, indent=2, default=str)\n\n    print(f\"\\n{'='*60}\")\n    print(f\"  H1 Results (alpha={alpha}):\")\n    print(f\"  Mean E2E:  {mean_e2e:.1f}%\")\n    print(f\"  Mean TTFT: {mean_ttft:.1f}%\")\n    print(f\"  Mean ITL:  {mean_itl:.1f}%\")\n    print(f\"  E2E < 10%: {summary['e2e_under_10pct']}/{len(ok_results)}\")\n    print(f\"{'='*60}\")\n\n    return summary, all_results\n\n\n# ---------------------------------------------------------------------------\n# H2: Pareto sweep\n# ---------------------------------------------------------------------------\ndef run_h2(experiments, output_dir=None):\n    \"\"\"Run H1 with different alpha values to explore Pareto frontier.\"\"\"\n    if output_dir is None:\n        output_dir = os.path.join(_SCRIPT_DIR, \"h2-pareto-sweep\")\n    os.makedirs(output_dir, exist_ok=True)\n\n    alphas = [0.7, 0.5, 0.3]\n    pareto_points = []\n\n    for alpha in alphas:\n        print(f\"\\n{'#'*60}\")\n        print(f\"  PARETO SWEEP: alpha = {alpha}\")\n        print(f\"{'#'*60}\")\n\n        alpha_dir = os.path.join(output_dir, f\"alpha_{alpha}\")\n        summary, results = run_h1(\n            experiments, alpha=alpha, max_evals=100, output_dir=alpha_dir\n        )\n\n        pareto_points.append({\n            \"alpha\": alpha,\n            \"mean_e2e_pct\": summary[\"mean_e2e_error_pct\"],\n            \"mean_itl_pct\": summary[\"mean_itl_error_pct\"],\n            \"mean_ttft_pct\": summary[\"mean_ttft_error_pct\"],\n            \"e2e_under_10\": summary[\"e2e_under_10pct\"],\n            \"n_experiments\": summary[\"n_experiments\"],\n        })\n\n    # Find knee point (closest to origin in E2E-ITL space)\n    best_idx = 0\n    best_dist = float(\"inf\")\n    for i, pt in enumerate(pareto_points):\n        # Normalize: E2E target 10%, ITL target 15%\n        dist = (pt[\"mean_e2e_pct\"] / 10) ** 2 + (pt[\"mean_itl_pct\"] / 15) ** 2\n        if dist < best_dist:\n            best_dist = dist\n            best_idx = i\n\n    pareto_summary = {\n        \"pareto_points\": pareto_points,\n        \"best_alpha\": pareto_points[best_idx][\"alpha\"],\n        \"best_point\": pareto_points[best_idx],\n        \"knee_distance\": float(best_dist),\n    }\n\n    summary_path = os.path.join(output_dir, \"pareto_summary.json\")\n    with open(summary_path, \"w\") as f:\n        json.dump(pareto_summary, f, indent=2)\n\n    print(f\"\\n{'='*60}\")\n    print(f\"  PARETO FRONTIER:\")\n    print(f\"  {'Alpha':>6s} {'E2E%':>8s} {'ITL%':>8s} {'TTFT%':>8s} {'<10%':>5s}\")\n    for pt in pareto_points:\n        marker = \" ← KNEE\" if pt[\"alpha\"] == pareto_points[best_idx][\"alpha\"] else \"\"\n        print(f\"  {pt['alpha']:>6.1f} {pt['mean_e2e_pct']:>7.1f}% \"\n              f\"{pt['mean_itl_pct']:>7.1f}% {pt['mean_ttft_pct']:>7.1f}% \"\n              f\"{pt['e2e_under_10']:>4d}{marker}\")\n    print(f\"{'='*60}\")\n\n    return pareto_summary\n\n\n# ---------------------------------------------------------------------------\n# H3: LOMO (leave-one-model-out)\n# ---------------------------------------------------------------------------\ndef run_h3(experiments, best_alpha, output_dir=None):\n    \"\"\"Leave-one-model-out cross-validation with CMA-ES artifacts.\"\"\"\n    if output_dir is None:\n        output_dir = os.path.join(_SCRIPT_DIR, \"h3-lomo\")\n    os.makedirs(output_dir, exist_ok=True)\n\n    # Get unique model groups\n    model_groups = sorted(set(e[\"model_group\"] for e in experiments))\n    print(f\"\\n{'='*60}\")\n    print(f\"  H3: LOMO ({len(model_groups)} folds)\")\n    print(f\"{'='*60}\")\n\n    # Load best artifacts (from H2's best alpha)\n    best_artifacts_dir = os.path.join(\n        _SCRIPT_DIR, \"h2-pareto-sweep\", f\"alpha_{best_alpha}\", \"artifacts\"\n    )\n\n    folds = []\n    for holdout_model in model_groups:\n        print(f\"\\n  Fold: holdout={holdout_model}\")\n        holdout_exps = [e for e in experiments if e[\"model_group\"] == holdout_model]\n        # For each donor model, try its artifact on the holdout\n        donor_results = []\n        for donor_model in model_groups:\n            if donor_model == holdout_model:\n                continue\n            art_path = os.path.join(best_artifacts_dir, f\"{donor_model}_optimized.json\")\n            if not os.path.isfile(art_path):\n                continue\n\n            with open(art_path) as f:\n                donor_art = json.load(f)\n\n            ttft_ms = TTFT_CORRECTIONS_MS.get(holdout_model, 0)\n            results = evaluate_artifact(donor_art, holdout_exps, ttft_ms)\n            ok_results = [r for r in results if r.get(\"status\") == \"ok\"]\n            if ok_results:\n                mean_e2e = np.mean([r[\"e2e_error\"] for r in ok_results])\n                mean_itl = np.mean([r[\"itl_error\"] for r in ok_results])\n                donor_results.append({\n                    \"donor\": donor_model,\n                    \"mean_e2e_pct\": float(mean_e2e * 100),\n                    \"mean_itl_pct\": float(mean_itl * 100),\n                    \"per_experiment\": ok_results,\n                })\n                print(f\"    Donor {donor_model}: E2E={mean_e2e*100:.1f}% ITL={mean_itl*100:.1f}%\")\n\n        # Best donor for this fold\n        if donor_results:\n            best_donor = min(donor_results, key=lambda x: x[\"mean_e2e_pct\"])\n        else:\n            best_donor = {\"donor\": \"none\", \"mean_e2e_pct\": 999, \"mean_itl_pct\": 999}\n\n        folds.append({\n            \"holdout_model\": holdout_model,\n            \"best_donor\": best_donor[\"donor\"],\n            \"best_donor_e2e_pct\": best_donor[\"mean_e2e_pct\"],\n            \"best_donor_itl_pct\": best_donor.get(\"mean_itl_pct\", 999),\n            \"all_donors\": donor_results,\n        })\n\n    # Summary\n    mean_best_donor_e2e = np.mean([f[\"best_donor_e2e_pct\"] for f in folds])\n    lomo_summary = {\n        \"folds\": folds,\n        \"mean_best_donor_e2e_pct\": float(mean_best_donor_e2e),\n        \"target\": \"<80% MAPE per fold (E2E proxy)\",\n        \"alpha_used\": best_alpha,\n    }\n\n    summary_path = os.path.join(output_dir, \"lomo_summary.json\")\n    with open(summary_path, \"w\") as f:\n        json.dump(lomo_summary, f, indent=2, default=str)\n\n    print(f\"\\n  LOMO Summary:\")\n    print(f\"  {'Holdout':<25s} {'Best Donor':<25s} {'E2E%':>8s} {'ITL%':>8s}\")\n    for fold in folds:\n        print(f\"  {fold['holdout_model']:<25s} {fold['best_donor']:<25s} \"\n              f\"{fold['best_donor_e2e_pct']:>7.1f}% {fold['best_donor_itl_pct']:>7.1f}%\")\n    print(f\"  Mean best-donor E2E: {mean_best_donor_e2e:.1f}%\")\n\n    return lomo_summary\n\n\n# ---------------------------------------------------------------------------\n# H4: LOWO (leave-one-workload-out)\n# ---------------------------------------------------------------------------\ndef run_h4(experiments, best_alpha, output_dir=None):\n    \"\"\"Leave-one-workload-out: check per-model workload variance.\"\"\"\n    if output_dir is None:\n        output_dir = os.path.join(_SCRIPT_DIR, \"h4-lowo\")\n    os.makedirs(output_dir, exist_ok=True)\n\n    # Load best artifacts\n    best_artifacts_dir = os.path.join(\n        _SCRIPT_DIR, \"h2-pareto-sweep\", f\"alpha_{best_alpha}\", \"artifacts\"\n    )\n\n    # Get unique workloads and models\n    workloads = sorted(set(e[\"workload\"] for e in experiments))\n    model_groups = sorted(set(e[\"model_group\"] for e in experiments))\n\n    print(f\"\\n{'='*60}\")\n    print(f\"  H4: LOWO ({len(workloads)} workloads)\")\n    print(f\"{'='*60}\")\n\n    # Evaluate each experiment with its model's best artifact\n    per_exp_results = []\n    for exp in experiments:\n        art_path = os.path.join(best_artifacts_dir, f\"{exp['model_group']}_optimized.json\")\n        if not os.path.isfile(art_path):\n            continue\n        with open(art_path) as f:\n            art = json.load(f)\n        ttft_ms = TTFT_CORRECTIONS_MS.get(exp[\"model\"], 0)\n        results = evaluate_artifact(art, [exp], ttft_ms)\n        if results and results[0].get(\"status\") == \"ok\":\n            per_exp_results.append(results[0])\n\n    # Compute per-model workload range\n    model_workload_map = {}\n    for r in per_exp_results:\n        group = MODEL_GROUPS.get(r.get(\"model\", \"\"), r.get(\"model\", \"\"))\n        model_workload_map.setdefault(group, []).append(r)\n\n    model_stats = {}\n    for model, results in sorted(model_workload_map.items()):\n        e2e_errors = [r[\"e2e_error\"] * 100 for r in results]\n        model_stats[model] = {\n            \"workloads\": [r.get(\"workload\", \"?\") for r in results],\n            \"e2e_errors\": e2e_errors,\n            \"e2e_range\": max(e2e_errors) - min(e2e_errors),\n            \"e2e_mean\": np.mean(e2e_errors),\n        }\n\n    # Aggregate E2E across all experiments\n    agg_e2e = np.mean([r[\"e2e_error\"] for r in per_exp_results])\n    within_2x = sum(\n        1 for r in per_exp_results if r[\"e2e_error\"] <= agg_e2e * 2\n    )\n\n    lowo_summary = {\n        \"per_model_stats\": {m: s for m, s in model_stats.items()},\n        \"aggregate_e2e_pct\": float(agg_e2e * 100),\n        \"within_2x_aggregate\": within_2x,\n        \"total_experiments\": len(per_exp_results),\n        \"alpha_used\": best_alpha,\n    }\n\n    summary_path = os.path.join(output_dir, \"lowo_summary.json\")\n    with open(summary_path, \"w\") as f:\n        json.dump(lowo_summary, f, indent=2, default=str)\n\n    print(f\"\\n  LOWO Summary:\")\n    print(f\"  {'Model':<25s} {'Range (pp)':>10s} {'Mean E2E%':>10s} {'Workloads'}\")\n    for model, stats in sorted(model_stats.items()):\n        wl_str = \", \".join(f\"{w}={e:.1f}%\" for w, e in zip(stats[\"workloads\"], stats[\"e2e_errors\"]))\n        print(f\"  {model:<25s} {stats['e2e_range']:>9.1f}pp {stats['e2e_mean']:>9.1f}% {wl_str}\")\n    print(f\"\\n  Aggregate E2E: {agg_e2e*100:.1f}%\")\n    print(f\"  Within 2x aggregate: {within_2x}/{len(per_exp_results)}\")\n\n    return lowo_summary\n\n\n# ---------------------------------------------------------------------------\n# Main\n# ---------------------------------------------------------------------------\ndef main():\n    print(\"=\" * 60)\n    print(\"  Round 4, Idea 1: Constrained CMA-ES with ITL Penalty\")\n    print(\"=\" * 60)\n\n    # Discover experiments\n    experiments = discover_experiments()\n    print(f\"\\nDiscovered {len(experiments)} experiments\")\n    for exp in experiments:\n        print(f\"  {exp['dirname']}: model={exp['model_group']}, wl={exp['workload']}\")\n\n    if not experiments:\n        print(\"ERROR: No experiments found. Check _DATA_ROOT path.\")\n        sys.exit(1)\n\n    # H1: Run with default alpha=0.5 first to verify infrastructure\n    print(f\"\\n{'#'*60}\")\n    print(\"  H1: Constrained CMA-ES (alpha=0.5)\")\n    print(f\"{'#'*60}\")\n    h1_summary, h1_results = run_h1(experiments, alpha=0.5, max_evals=100)\n\n    # Short-circuit check\n    if h1_summary[\"mean_e2e_error_pct\"] > 25:\n        print(f\"\\nSHORT-CIRCUIT: Mean E2E {h1_summary['mean_e2e_error_pct']:.1f}% > 25%\")\n        print(\"Constrained CMA-ES is significantly worse than R3. Aborting.\")\n        return\n\n    # H2: Pareto sweep\n    print(f\"\\n{'#'*60}\")\n    print(\"  H2: Pareto Sweep\")\n    print(f\"{'#'*60}\")\n    h2_summary = run_h2(experiments)\n    best_alpha = h2_summary[\"best_alpha\"]\n\n    # H3: LOMO\n    print(f\"\\n{'#'*60}\")\n    print(f\"  H3: LOMO (using best alpha={best_alpha})\")\n    print(f\"{'#'*60}\")\n    h3_summary = run_h3(experiments, best_alpha)\n\n    # H4: LOWO\n    print(f\"\\n{'#'*60}\")\n    print(f\"  H4: LOWO (using best alpha={best_alpha})\")\n    print(f\"{'#'*60}\")\n    h4_summary = run_h4(experiments, best_alpha)\n\n    # Final summary\n    print(f\"\\n{'='*60}\")\n    print(\"  FINAL SUMMARY\")\n    print(f\"{'='*60}\")\n    print(f\"  H1 (alpha=0.5): E2E={h1_summary['mean_e2e_error_pct']:.1f}% \"\n          f\"ITL={h1_summary['mean_itl_error_pct']:.1f}%\")\n    print(f\"  H2 best alpha={best_alpha}: \"\n          f\"E2E={h2_summary['best_point']['mean_e2e_pct']:.1f}% \"\n          f\"ITL={h2_summary['best_point']['mean_itl_pct']:.1f}%\")\n    print(f\"  H3 LOMO mean best-donor E2E: {h3_summary['mean_best_donor_e2e_pct']:.1f}%\")\n    print(f\"  H4 LOWO within 2x: {h4_summary['within_2x_aggregate']}/{h4_summary['total_experiments']}\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":888,"startLine":1,"totalLines":888}}}
