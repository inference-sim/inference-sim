{"type":"assistant","message":{"id":"msg_bdrk_01J37sHqU6JjaTjM9z3c6ZHT","type":"message","role":"assistant","model":"claude-opus-4-6","content":[{"type":"tool_use","id":"toolu_bdrk_014NiBQyVqmPYsbKShktJc56","name":"Bash","input":{"command":"python3 -c \"\nimport json, os, re, subprocess, sys, tempfile, random\nimport numpy as np\nimport pandas as pd\nfrom sklearn.linear_model import LinearRegression\nimport yaml\n\nsys.path.insert(0, os.path.join(os.path.dirname('.'), '..', '..', 'shared'))\nsys.path.insert(0, '/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round3-idea-2-total-context-model/hypotheses/h-stepml/shared')\n\nfrom lifecycle_kv_extractor import extract_all_experiments_kv_features\nfrom splits import temporal_split\n\nDATA_ROOT = '/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/BLIS-research/eval/ground_truth'\nBINARY = '/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round3-idea-2-total-context-model/simulation_worker'\nARTIFACT_DIR = '/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/BLIS-research/hypotheses/h-stepml/round2/idea-2-regime-ensemble/h3-secondary-method-calibration/output/calibrated_artifacts'\nOUT = 'h3-blis-e2e-34b/output'\nos.makedirs(os.path.join(OUT, 'artifacts'), exist_ok=True)\n\n# Load data and train models\ndf = extract_all_experiments_kv_features(DATA_ROOT)\ndf['model_tp'] = df['model'] + '_tp' + df['tp'].astype(str)\nsplits = temporal_split(df)\n\n# Train 4-coeff OLS per model\ntrained = {}\nfor mt in sorted(df['model_tp'].unique()):\n    mask = df['model_tp'] == mt\n    tr = df[mask & df.index.isin(splits['train'])]\n    X = tr[['batch.prefill_tokens', 'batch.decode_tokens', 'kv_sum']].values.astype(np.float64)\n    y = tr['step.duration_us'].values.astype(np.float64)\n    ols = LinearRegression().fit(X, y)\n    \n    # Get overhead\n    fname = os.path.join(ARTIFACT_DIR, f'{mt}_regime.json')\n    overhead = 0\n    if os.path.isfile(fname):\n        with open(fname) as f:\n            overhead = json.load(f).get('step_overhead_us', 0)\n    \n    trained[mt] = {'ols': ols, 'overhead': overhead}\n    \n    # Export artifact\n    art = {\n        'version': 2,\n        'step_time': {\n            'model_type': 'linear',\n            'intercept': float(ols.intercept_),\n            'feature_coefficients': {\n                'prefill_tokens': float(ols.coef_[0]),\n                'decode_tokens': float(ols.coef_[1]),\n                'kv_sum': float(ols.coef_[2]),\n            }\n        },\n        'step_overhead_us': float(overhead),\n        'output_token_processing_time_us': 0,\n        'scheduling_processing_time_us': 0,\n        'preemption_processing_time_us': 0,\n    }\n    art_path = os.path.join(OUT, 'artifacts', f'{mt}_total_context.json')\n    with open(art_path, 'w') as f:\n        json.dump(art, f, indent=2)\n\n# Run BLIS for each experiment using trace replay\nresults = []\nfor dirname in sorted(os.listdir(DATA_ROOT)):\n    dirpath = os.path.join(DATA_ROOT, dirname)\n    if not os.path.isdir(dirpath):\n        continue\n    \n    # Parse metadata\n    tp_matches = list(re.finditer(r'-tp(\\d+)-', dirname))\n    if not tp_matches:\n        continue\n    last_tp = tp_matches[-1]\n    model = dirname[16:last_tp.start()]\n    tp = int(last_tp.group(1))\n    workload = dirname[last_tp.end():]\n    model_tp = model + '_tp' + str(tp)\n    \n    if model_tp not in trained:\n        continue\n    \n    # Load exp config\n    with open(os.path.join(dirpath, 'exp-config.yaml')) as f:\n        exp_cfg = yaml.safe_load(f)\n    model_name = exp_cfg.get('model', 'unknown')\n    \n    # Extract KV blocks\n    vllm_log = os.path.join(dirpath, 'vllm.log')\n    kv_blocks = None\n    if os.path.isfile(vllm_log):\n        with open(vllm_log) as f:\n            for line in f:\n                m = re.search(r'GPU KV cache size:\\s+([\\d,]+)\\s+tokens', line)\n                if m:\n                    kv_blocks = int(m.group(1).replace(',', '')) // 16\n                    break\n    if kv_blocks is None:\n        continue\n    \n    # Load ground truth\n    with open(os.path.join(dirpath, 'results', 'summary_lifecycle_metrics.json')) as f:\n        gt_data = json.load(f)\n    succ = gt_data.get('successes', {}).get('latency', {})\n    gt_e2e = succ.get('request_latency', {}).get('mean', 0) * 1000\n    gt_ttft = succ.get('time_to_first_token', {}).get('mean', 0) * 1000\n    gt_itl = succ.get('inter_token_latency', {}).get('mean', 0) * 1000\n    \n    # Convert lifecycle to trace CSV\n    lc_path = os.path.join(dirpath, 'results', 'per_request_lifecycle_metrics.json')\n    with open(lc_path) as f:\n        lc_data = json.load(f)\n    \n    rng = random.Random(42)\n    base_time = min(e['start_time'] for e in lc_data)\n    rows = []\n    for i, entry in enumerate(lc_data):\n        info = entry.get('info', {})\n        ic = info.get('input_tokens', 0)\n        oc = info.get('output_tokens', 0)\n        arr = entry['start_time'] - base_time\n        inp = [rng.randint(0, 31999) for _ in range(ic)]\n        out = [rng.randint(0, 31999) for _ in range(oc)]\n        rows.append((arr, i, model_name, inp, out))\n    rows.sort(key=lambda x: x[0])\n    \n    trace_csv = tempfile.NamedTemporaryFile(suffix='.csv', delete=False).name\n    with open(trace_csv, 'w') as f:\n        f.write('arrival_time,request_id,model,prefill_tokens,decode_tokens\\n')\n        for arr, rid, mdl, inp, out in rows:\n            f.write(f'{arr:.6f},request_{rid},{mdl},\\\"{json.dumps(inp)}\\\",\\\"{json.dumps(out)}\\\"\\n')\n    \n    duration_s = (rows[-1][0] - rows[0][0]) if len(rows) > 1 else 0\n    horizon_us = int(duration_s * 1_000_000) + 120_000_000\n    \n    art_path = os.path.join(OUT, 'artifacts', f'{model_tp}_total_context.json')\n    \n    cmd = [\n        BINARY, 'run',\n        '--model', model_name,\n        '--workload', 'traces',\n        '--workload-traces-filepath', trace_csv,\n        '--tp', str(exp_cfg.get('tensor_parallelism', 1)),\n        '--max-model-len', str(exp_cfg.get('max_model_len', 4096)),\n        '--max-num-running-reqs', str(exp_cfg.get('max_num_seqs', 128)),\n        '--max-num-scheduled-tokens', str(exp_cfg.get('max_num_batched_tokens', 2048)),\n        '--total-kv-blocks', str(kv_blocks),\n        '--block-size-in-tokens', '16',\n        '--horizon', str(horizon_us),\n        '--stepml-model', art_path,\n        '--alpha-coeffs=1,0,0',\n        '--beta-coeffs=1,0,0',\n        '--log', 'error',\n    ]\n    \n    try:\n        r = subprocess.run(cmd, capture_output=True, text=True, timeout=300)\n    except Exception as e:\n        print(f'  {dirname}: ERROR {e}')\n        os.unlink(trace_csv)\n        continue\n    \n    os.unlink(trace_csv)\n    \n    if r.returncode != 0:\n        print(f'  {dirname}: FAILED - {r.stderr[:200]}')\n        results.append({'experiment': dirname, 'model': model, 'workload': workload, 'status': 'failed'})\n        continue\n    \n    # Parse metrics\n    metrics = None\n    lines = r.stdout.split('\\n')\n    jlines = []\n    in_json = False\n    bd = 0\n    for line in lines:\n        if 'Simulation Metrics' in line:\n            in_json = False; jlines = []; continue\n        if not in_json and line.strip().startswith('{'):\n            in_json = True\n        if in_json:\n            jlines.append(line)\n            bd += line.count('{') - line.count('}')\n            if bd <= 0:\n                break\n    if jlines:\n        try:\n            metrics = json.loads('\\n'.join(jlines))\n        except:\n            pass\n    \n    if not metrics:\n        print(f'  {dirname}: NO METRICS')\n        continue\n    \n    blis_e2e = metrics.get('e2e_mean_ms', 0)\n    blis_ttft = metrics.get('ttft_mean_ms', 0)\n    blis_itl = metrics.get('itl_mean_ms', 0)\n    \n    e2e_err = abs(blis_e2e - gt_e2e) / gt_e2e if gt_e2e > 0 else 0\n    ttft_err = abs(blis_ttft - gt_ttft) / gt_ttft if gt_ttft > 0 else 0\n    itl_err = abs(blis_itl - gt_itl) / gt_itl if gt_itl > 0 else 0\n    \n    res = {\n        'experiment': dirname, 'model': model, 'workload': workload,\n        'status': 'ok',\n        'gt_e2e_ms': gt_e2e, 'gt_ttft_ms': gt_ttft, 'gt_itl_ms': gt_itl,\n        'blis_e2e_ms': blis_e2e, 'blis_ttft_ms': blis_ttft, 'blis_itl_ms': blis_itl,\n        'e2e_error': e2e_err, 'ttft_error': ttft_err, 'itl_error': itl_err,\n        'completed': metrics.get('completed_requests', 0),\n    }\n    results.append(res)\n    print(f'  {dirname}: E2E={e2e_err*100:.1f}% TTFT={ttft_err*100:.1f}% ITL={itl_err*100:.1f}%')\n\n# Summary\nok = [r for r in results if r.get('status') == 'ok']\nprint(f'\\n=== SUMMARY ({len(ok)}/{len(results)} experiments) ===')\nif ok:\n    print(f'Mean E2E:  {np.mean([r[\\\"e2e_error\\\"] for r in ok])*100:.1f}%')\n    print(f'Mean TTFT: {np.mean([r[\\\"ttft_error\\\"] for r in ok])*100:.1f}%')\n    print(f'Mean ITL:  {np.mean([r[\\\"itl_error\\\"] for r in ok])*100:.1f}%')\n    print(f'E2E < 10%: {sum(1 for r in ok if r[\\\"e2e_error\\\"] < 0.10)}/{len(ok)}')\n    print(f'ITL < 10%: {sum(1 for r in ok if r[\\\"itl_error\\\"] < 0.10)}/{len(ok)}')\n\nwith open(os.path.join(OUT, 'h3_blis_results.json'), 'w') as f:\n    json.dump(results, f, indent=2)\nprint('Saved to h3-blis-e2e-34b/output/h3_blis_results.json')\n\" 2>&1 | grep -v \"RuntimeWarning\\|ConstantInput\\|ret = a\\|return X\"","description":"Run H3 BLIS E2E validation inline","timeout":600000}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"output_tokens":0},"context_management":null},"parent_tool_use_id":null,"session_id":"27497e41-6ff8-42ab-aee1-66206c73fdbf","uuid":"8a1b03db-11fa-4386-9fcb-d79a243ff817"}
