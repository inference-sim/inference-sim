{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01MEq4tNjqJcZKgwASFzH728","type":"tool_result","content":"     1→\"\"\"Per-request KV cache length extractor for step-level feature enrichment.\n     2→\n     3→Bridges the gap between step-level batch summaries (which lack per-request KV\n     4→cache lengths) and per-request lifecycle data (which has token timestamps).\n     5→By joining these two data sources, we derive per-step KV statistics\n     6→(kv_mean, kv_max, kv_sum, kv_count) needed for accurate roofline step-time\n     7→prediction.\n     8→\n     9→Background: Round 1 H8 showed a 12.96x overestimate when using batch-level\n    10→kv_max (the max across the whole experiment) instead of per-request KV lengths.\n    11→This module computes the actual per-step KV distribution from lifecycle data.\n    12→\"\"\"\n    13→\n    14→from __future__ import annotations\n    15→\n    16→import os\n    17→\n    18→import numpy as np\n    19→import pandas as pd\n    20→\n    21→from data_loader import (\n    22→    DEFAULT_DATA_ROOT,\n    23→    load_all_experiments,\n    24→    load_experiment_steps,\n    25→    load_lifecycle_data,\n    26→    parse_experiment_metadata,\n    27→)\n    28→\n    29→\n    30→def _estimate_kv_length(request_row: pd.Series, step_start_ns: int) -> int:\n    31→    \"\"\"Estimate KV cache length for a request at a given step timestamp.\n    32→\n    33→    KV length = input_tokens + number of output tokens generated before\n    34→    step_start_ns. This mirrors the simulator's Request.ProgressIndex\n    35→    (input_tokens_processed + output_tokens_generated).\n    36→\n    37→    Args:\n    38→        request_row: A row from the lifecycle DataFrame with columns:\n    39→            input_tokens (int), output_token_times (list of float, epoch seconds).\n    40→        step_start_ns: Step start timestamp in nanoseconds.\n    41→\n    42→    Returns:\n    43→        Estimated KV cache length (non-negative integer).\n    44→    \"\"\"\n    45→    input_tokens = int(request_row[\"input_tokens\"])\n    46→    output_token_times = request_row[\"output_token_times\"]\n    47→\n    48→    if not output_token_times:\n    49→        return input_tokens\n    50→\n    51→    # Convert step_start_ns to seconds for comparison with output_token_times\n    52→    step_start_s = step_start_ns / 1e9\n    53→\n    54→    # Count output tokens generated before step_start_ns\n    55→    tokens_generated = 0\n    56→    for t in output_token_times:\n    57→        if t < step_start_s:\n    58→            tokens_generated += 1\n    59→        else:\n    60→            # output_token_times are chronologically ordered; once we pass\n    61→            # the step boundary, no further tokens qualify.\n    62→            break\n    63→\n    64→    return input_tokens + tokens_generated\n    65→\n    66→\n    67→def extract_kv_features(\n    68→    steps_df: pd.DataFrame, lifecycle_df: pd.DataFrame\n    69→) -> pd.DataFrame:\n    70→    \"\"\"Join step-level data with lifecycle data to derive per-step KV features.\n    71→\n    72→    For each step, identifies active requests (those whose time window overlaps\n    73→    the step window), estimates each request's KV cache length at step start,\n    74→    and computes aggregate statistics.\n    75→\n    76→    Args:\n    77→        steps_df: Step-level DataFrame from data_loader.load_experiment_steps().\n    78→            Must have columns: step.id, step.ts_start_ns, step.ts_end_ns,\n    79→            experiment_id.\n    80→        lifecycle_df: Per-request DataFrame from data_loader.load_lifecycle_data().\n    81→            Must have columns: start_time, end_time, input_tokens,\n    82→            output_tokens, output_token_times. Index is request_id.\n    83→\n    84→    Returns:\n    85→        DataFrame with same index as steps_df plus new columns:\n    86→        kv_mean, kv_max, kv_sum, kv_count.\n    87→    \"\"\"\n    88→    # Pre-convert lifecycle timestamps from seconds to nanoseconds for\n    89→    # efficient comparison with step timestamps.\n    90→    lc_start_ns = (lifecycle_df[\"start_time\"].values * 1e9).astype(np.int64)\n    91→    lc_end_ns = (lifecycle_df[\"end_time\"].values * 1e9).astype(np.int64)\n    92→\n    93→    kv_means = np.zeros(len(steps_df), dtype=np.float64)\n    94→    kv_maxes = np.zeros(len(steps_df), dtype=np.float64)\n    95→    kv_sums = np.zeros(len(steps_df), dtype=np.float64)\n    96→    kv_stds = np.zeros(len(steps_df), dtype=np.float64)\n    97→    kv_counts = np.zeros(len(steps_df), dtype=np.int64)\n    98→\n    99→    for i, (_, step_row) in enumerate(steps_df.iterrows()):\n   100→        step_start_ns = int(step_row[\"step.ts_start_ns\"])\n   101→        step_end_ns = int(step_row[\"step.ts_end_ns\"])\n   102→\n   103→        # Active requests: start_time < step.ts_end AND end_time > step.ts_start\n   104→        # (overlapping time windows)\n   105→        active_mask = (lc_start_ns < step_end_ns) & (lc_end_ns > step_start_ns)\n   106→        active_indices = np.where(active_mask)[0]\n   107→\n   108→        if len(active_indices) == 0:\n   109→            # No active requests -> all zeros (already initialized)\n   110→            continue\n   111→\n   112→        kv_lengths = np.array(\n   113→            [\n   114→                _estimate_kv_length(lifecycle_df.iloc[idx], step_start_ns)\n   115→                for idx in active_indices\n   116→            ],\n   117→            dtype=np.float64,\n   118→        )\n   119→\n   120→        kv_means[i] = np.mean(kv_lengths)\n   121→        kv_maxes[i] = np.max(kv_lengths)\n   122→        kv_sums[i] = np.sum(kv_lengths)\n   123→        kv_stds[i] = np.std(kv_lengths) if len(kv_lengths) > 1 else 0.0\n   124→        kv_counts[i] = len(kv_lengths)\n   125→\n   126→    result = steps_df.copy()\n   127→    result[\"kv_mean\"] = kv_means\n   128→    result[\"kv_max\"] = kv_maxes\n   129→    result[\"kv_sum\"] = kv_sums\n   130→    result[\"kv_std\"] = kv_stds\n   131→    result[\"kv_count\"] = kv_counts\n   132→\n   133→    return result\n   134→\n   135→\n   136→def extract_all_experiments_kv_features(\n   137→    data_root: str | None = None,\n   138→) -> pd.DataFrame:\n   139→    \"\"\"Load all experiments and extract KV features for every step.\n   140→\n   141→    Convenience wrapper that iterates over experiment directories, loads both\n   142→    step data and lifecycle data for each, calls extract_kv_features, and\n   143→    concatenates all results.\n   144→\n   145→    Args:\n   146→        data_root: Path to the ground truth data directory. Defaults to\n   147→            eval/ground_truth/ relative to this file.\n   148→\n   149→    Returns:\n   150→        Concatenated DataFrame with step data enriched with KV columns,\n   151→        plus metadata columns (model, tp, workload, timestamp).\n   152→    \"\"\"\n   153→    if data_root is None:\n   154→        data_root = DEFAULT_DATA_ROOT\n   155→\n   156→    frames = []\n   157→    for dirname in sorted(os.listdir(data_root)):\n   158→        dirpath = os.path.join(data_root, dirname)\n   159→        if not os.path.isdir(dirpath):\n   160→            continue\n   161→\n   162→        # Skip directories that lack required files\n   163→        traces_path = os.path.join(dirpath, \"traces.json\")\n   164→        lifecycle_path = os.path.join(\n   165→            dirpath, \"results\", \"per_request_lifecycle_metrics.json\"\n   166→        )\n   167→        if not os.path.isfile(traces_path) or not os.path.isfile(lifecycle_path):\n   168→            continue\n   169→\n   170→        steps_df = load_experiment_steps(dirpath)\n   171→        lifecycle_df = load_lifecycle_data(dirpath)\n   172→\n   173→        enriched = extract_kv_features(steps_df, lifecycle_df)\n   174→\n   175→        meta = parse_experiment_metadata(dirname)\n   176→        enriched[\"model\"] = meta[\"model\"]\n   177→        enriched[\"tp\"] = meta[\"tp\"]\n   178→        enriched[\"workload\"] = meta[\"workload\"]\n   179→        enriched[\"timestamp\"] = meta[\"timestamp\"]\n   180→\n   181→        frames.append(enriched)\n   182→\n   183→    if not frames:\n   184→        return pd.DataFrame()\n   185→\n   186→    result = pd.concat(frames, ignore_index=True)\n   187→    result[\"tp\"] = result[\"tp\"].astype(\"Int64\")\n   188→\n   189→    return result\n   190→"}]},"parent_tool_use_id":null,"session_id":"27497e41-6ff8-42ab-aee1-66206c73fdbf","uuid":"d9c582ec-a832-49cd-8e77-21cd683cd7cd","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round3-idea-2-total-context-model/hypotheses/h-stepml/shared/lifecycle_kv_extractor.py","content":"\"\"\"Per-request KV cache length extractor for step-level feature enrichment.\n\nBridges the gap between step-level batch summaries (which lack per-request KV\ncache lengths) and per-request lifecycle data (which has token timestamps).\nBy joining these two data sources, we derive per-step KV statistics\n(kv_mean, kv_max, kv_sum, kv_count) needed for accurate roofline step-time\nprediction.\n\nBackground: Round 1 H8 showed a 12.96x overestimate when using batch-level\nkv_max (the max across the whole experiment) instead of per-request KV lengths.\nThis module computes the actual per-step KV distribution from lifecycle data.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\n\nimport numpy as np\nimport pandas as pd\n\nfrom data_loader import (\n    DEFAULT_DATA_ROOT,\n    load_all_experiments,\n    load_experiment_steps,\n    load_lifecycle_data,\n    parse_experiment_metadata,\n)\n\n\ndef _estimate_kv_length(request_row: pd.Series, step_start_ns: int) -> int:\n    \"\"\"Estimate KV cache length for a request at a given step timestamp.\n\n    KV length = input_tokens + number of output tokens generated before\n    step_start_ns. This mirrors the simulator's Request.ProgressIndex\n    (input_tokens_processed + output_tokens_generated).\n\n    Args:\n        request_row: A row from the lifecycle DataFrame with columns:\n            input_tokens (int), output_token_times (list of float, epoch seconds).\n        step_start_ns: Step start timestamp in nanoseconds.\n\n    Returns:\n        Estimated KV cache length (non-negative integer).\n    \"\"\"\n    input_tokens = int(request_row[\"input_tokens\"])\n    output_token_times = request_row[\"output_token_times\"]\n\n    if not output_token_times:\n        return input_tokens\n\n    # Convert step_start_ns to seconds for comparison with output_token_times\n    step_start_s = step_start_ns / 1e9\n\n    # Count output tokens generated before step_start_ns\n    tokens_generated = 0\n    for t in output_token_times:\n        if t < step_start_s:\n            tokens_generated += 1\n        else:\n            # output_token_times are chronologically ordered; once we pass\n            # the step boundary, no further tokens qualify.\n            break\n\n    return input_tokens + tokens_generated\n\n\ndef extract_kv_features(\n    steps_df: pd.DataFrame, lifecycle_df: pd.DataFrame\n) -> pd.DataFrame:\n    \"\"\"Join step-level data with lifecycle data to derive per-step KV features.\n\n    For each step, identifies active requests (those whose time window overlaps\n    the step window), estimates each request's KV cache length at step start,\n    and computes aggregate statistics.\n\n    Args:\n        steps_df: Step-level DataFrame from data_loader.load_experiment_steps().\n            Must have columns: step.id, step.ts_start_ns, step.ts_end_ns,\n            experiment_id.\n        lifecycle_df: Per-request DataFrame from data_loader.load_lifecycle_data().\n            Must have columns: start_time, end_time, input_tokens,\n            output_tokens, output_token_times. Index is request_id.\n\n    Returns:\n        DataFrame with same index as steps_df plus new columns:\n        kv_mean, kv_max, kv_sum, kv_count.\n    \"\"\"\n    # Pre-convert lifecycle timestamps from seconds to nanoseconds for\n    # efficient comparison with step timestamps.\n    lc_start_ns = (lifecycle_df[\"start_time\"].values * 1e9).astype(np.int64)\n    lc_end_ns = (lifecycle_df[\"end_time\"].values * 1e9).astype(np.int64)\n\n    kv_means = np.zeros(len(steps_df), dtype=np.float64)\n    kv_maxes = np.zeros(len(steps_df), dtype=np.float64)\n    kv_sums = np.zeros(len(steps_df), dtype=np.float64)\n    kv_stds = np.zeros(len(steps_df), dtype=np.float64)\n    kv_counts = np.zeros(len(steps_df), dtype=np.int64)\n\n    for i, (_, step_row) in enumerate(steps_df.iterrows()):\n        step_start_ns = int(step_row[\"step.ts_start_ns\"])\n        step_end_ns = int(step_row[\"step.ts_end_ns\"])\n\n        # Active requests: start_time < step.ts_end AND end_time > step.ts_start\n        # (overlapping time windows)\n        active_mask = (lc_start_ns < step_end_ns) & (lc_end_ns > step_start_ns)\n        active_indices = np.where(active_mask)[0]\n\n        if len(active_indices) == 0:\n            # No active requests -> all zeros (already initialized)\n            continue\n\n        kv_lengths = np.array(\n            [\n                _estimate_kv_length(lifecycle_df.iloc[idx], step_start_ns)\n                for idx in active_indices\n            ],\n            dtype=np.float64,\n        )\n\n        kv_means[i] = np.mean(kv_lengths)\n        kv_maxes[i] = np.max(kv_lengths)\n        kv_sums[i] = np.sum(kv_lengths)\n        kv_stds[i] = np.std(kv_lengths) if len(kv_lengths) > 1 else 0.0\n        kv_counts[i] = len(kv_lengths)\n\n    result = steps_df.copy()\n    result[\"kv_mean\"] = kv_means\n    result[\"kv_max\"] = kv_maxes\n    result[\"kv_sum\"] = kv_sums\n    result[\"kv_std\"] = kv_stds\n    result[\"kv_count\"] = kv_counts\n\n    return result\n\n\ndef extract_all_experiments_kv_features(\n    data_root: str | None = None,\n) -> pd.DataFrame:\n    \"\"\"Load all experiments and extract KV features for every step.\n\n    Convenience wrapper that iterates over experiment directories, loads both\n    step data and lifecycle data for each, calls extract_kv_features, and\n    concatenates all results.\n\n    Args:\n        data_root: Path to the ground truth data directory. Defaults to\n            eval/ground_truth/ relative to this file.\n\n    Returns:\n        Concatenated DataFrame with step data enriched with KV columns,\n        plus metadata columns (model, tp, workload, timestamp).\n    \"\"\"\n    if data_root is None:\n        data_root = DEFAULT_DATA_ROOT\n\n    frames = []\n    for dirname in sorted(os.listdir(data_root)):\n        dirpath = os.path.join(data_root, dirname)\n        if not os.path.isdir(dirpath):\n            continue\n\n        # Skip directories that lack required files\n        traces_path = os.path.join(dirpath, \"traces.json\")\n        lifecycle_path = os.path.join(\n            dirpath, \"results\", \"per_request_lifecycle_metrics.json\"\n        )\n        if not os.path.isfile(traces_path) or not os.path.isfile(lifecycle_path):\n            continue\n\n        steps_df = load_experiment_steps(dirpath)\n        lifecycle_df = load_lifecycle_data(dirpath)\n\n        enriched = extract_kv_features(steps_df, lifecycle_df)\n\n        meta = parse_experiment_metadata(dirname)\n        enriched[\"model\"] = meta[\"model\"]\n        enriched[\"tp\"] = meta[\"tp\"]\n        enriched[\"workload\"] = meta[\"workload\"]\n        enriched[\"timestamp\"] = meta[\"timestamp\"]\n\n        frames.append(enriched)\n\n    if not frames:\n        return pd.DataFrame()\n\n    result = pd.concat(frames, ignore_index=True)\n    result[\"tp\"] = result[\"tp\"].astype(\"Int64\")\n\n    return result\n","numLines":190,"startLine":1,"totalLines":190}}}
