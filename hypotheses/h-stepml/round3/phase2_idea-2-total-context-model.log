truct\")\n-\tGPU         string        // GPU type (e.g., \"H100\")\n-\tTP          int           // tensor parallelism degree\n-\tRoofline    bool          // true = analytical roofline mode, false = blackbox regression\n+\tModelConfig      ModelConfig   // HuggingFace model parameters (for roofline mode)\n+\tHWConfig         HardwareCalib // GPU specifications (for roofline mode)\n+\tMFUDatabase      *MFUDatabase  // MFU benchmark database (for roofline v2 mode, optional)\n+\tModel            string        // model name (e.g., \"meta-llama/llama-3.1-8b-instruct\")\n+\tGPU              string        // GPU type (e.g., \"H100\")\n+\tTP               int           // tensor parallelism degree\n+\tRoofline         bool          // true = analytical roofline mode, false = blackbox regression\n+\tStepMLModelPath  string        // path to StepML model artifact JSON (empty = disabled)\n }\n \n // NewModelHardwareConfig creates a ModelHardwareConfig with all fields explicitly set.\n@@ -92,6 +93,13 @@ func (m ModelHardwareConfig) WithMFUDatabase(mfuDB *MFUDatabase) ModelHardwareCo\n \treturn m\n }\n \n+// WithStepMLModel returns a copy of ModelHardwareConfig with StepML artifact path set.\n+// When set and Roofline is false, the factory creates a StepMLLatencyModel instead of blackbox.\n+func (m ModelHardwareConfig) WithStepMLModel(path string) ModelHardwareConfig {\n+\tm.StepMLModelPath = path\n+\treturn m\n+}\n+\n // PolicyConfig groups scheduling and priority policy selection.\n type PolicyConfig struct {\n \tPriorityPolicy string // \"constant\" (default) or \"slo-based\"\ndiff --git a/sim/latency/latency.go b/sim/latency/latency.go\nindex 25fc6c3..bb80001 100644\n--- a/sim/latency/latency.go\n+++ b/sim/latency/latency.go\n@@ -153,6 +153,14 @@ func NewLatencyModel(coeffs sim.LatencyCoeffs, hw sim.ModelHardwareConfig) (sim.\n \t\t\talphaCoeffs: coeffs.AlphaCoeffs,\n \t\t}, nil\n \t}\n+\t// StepML dispatch: if artifact path is set, load and use StepML model.\n+\tif hw.StepMLModelPath != \"\" {\n+\t\tart, err := LoadStepMLArtifact(hw.StepMLModelPath)\n+\t\tif err != nil {\n+\t\t\treturn nil, fmt.Errorf(\"latency model: %w\", err)\n+\t\t}\n+\t\treturn NewStepMLLatencyModel(art), nil\n+\t}\n \t// BlackboxLatencyModel indexes betaCoeffs[0..2]; validate upfront.\n \tif len(coeffs.BetaCoeffs) < 3 {\n \t\treturn nil, fmt.Errorf(\"latency model: BetaCoeffs requires at least 3 elements, got %d\", len(coeffs.BetaCoeffs))\n","numLines":94,"startLine":1,"totalLines":94}}}
