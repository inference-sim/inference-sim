{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01YSJpNLNrjWWjEFL8JZFhwv","type":"tool_result","content":"     1→\"\"\"Establish baselines for StepML research.\n     2→\n     3→Runs two baselines through BLIS E2E validation and measures E2E/TTFT/ITL error\n     4→against ground truth.  These are the accuracy bars that StepML models must beat.\n     5→\n     6→Baseline 1 — Roofline (analytical):\n     7→    Uses the analytical FLOPs/bandwidth roofline model.  Zero calibration data\n     8→    needed — step time is estimated from model architecture (HuggingFace\n     9→    config.json) and GPU specs (hardware_config.json).\n    10→\n    11→Baseline 2 — Per-model linear regression:\n    12→    Trains a separate 3-coefficient linear regression per model+TP on\n    13→    ground-truth step traces (step_time = beta0 + beta1*prefill + beta2*decode),\n    14→    pooling all workloads for a given model.  Requires training data.\n    15→\n    16→Usage:\n    17→    python establish_baseline.py [--data-root PATH] [--output-dir PATH]\n    18→    python establish_baseline.py --skip-linear              # roofline only\n    19→    python establish_baseline.py --skip-roofline            # linear only\n    20→    python establish_baseline.py --hardware A100            # non-default GPU\n    21→\"\"\"\n    22→\n    23→import argparse\n    24→import csv as csv_mod\n    25→import json\n    26→import os\n    27→import subprocess\n    28→import sys\n    29→import tempfile\n    30→from concurrent.futures import ThreadPoolExecutor, as_completed\n    31→\n    32→import numpy as np\n    33→import pandas as pd\n    34→\n    35→# Add shared/ to path for imports\n    36→_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n    37→sys.path.insert(0, _SCRIPT_DIR)\n    38→\n    39→import yaml\n    40→\n    41→from baselines import BlackboxBaseline, check_r4_gate\n    42→from data_loader import load_all_experiments, load_experiment_steps, parse_experiment_metadata\n    43→from evaluation import compute_mape, compute_mspe, compute_pearson_r, compute_p99_error\n    44→from validate_blis import (\n    45→    build_workload_spec,\n    46→    compute_error,\n    47→    extract_cpu_kv_blocks_from_vllm_log,\n    48→    extract_kv_blocks_from_vllm_log,\n    49→    load_exp_config,\n    50→    load_ground_truth_metrics,\n    51→    load_profile,\n    52→    parse_experiment_dir,\n    53→    run_blis,\n    54→)\n    55→\n    56→_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\"))\n    57→DEFAULT_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\n    58→_DEFAULT_WORKERS = min((os.cpu_count() or 4) // 2, 4)\n    59→\n    60→\n    61→def _build_canonical_model_map(data_root: str) -> dict:\n    62→    \"\"\"Build a map from experiment_id to canonical (model, tp) from exp-config.yaml.\n    63→\n    64→    Directory names have inconsistencies (e.g. \"llama-2-70b\" vs \"llama-2-70b-hf\"\n    65→    for the same model).  exp-config.yaml has the authoritative HF model name.\n    66→    \"\"\"\n    67→    mapping = {}\n    68→    for dirname in sorted(os.listdir(data_root)):\n    69→        config_path = os.path.join(data_root, dirname, \"exp-config.yaml\")\n    70→        if not os.path.isfile(config_path):\n    71→            continue\n    72→        with open(config_path) as f:\n    73→            cfg = yaml.safe_load(f)\n    74→        # Canonical model name from HF (e.g. \"meta-llama/Llama-2-70b-hf\")\n    75→        model = cfg.get(\"model\", \"\")\n    76→        tp = cfg.get(\"tensor_parallelism\", 1)\n    77→        mapping[dirname] = (model, tp)\n    78→    return mapping\n    79→\n    80→\n    81→def train_per_model_coefficients(data_root: str) -> dict:\n    82→    \"\"\"Train a linear regression per model+TP and return fitted coefficients.\n    83→\n    84→    Groups experiments by canonical (model, tp) from exp-config.yaml, trains\n    85→    one linear regression per group, and returns the coefficients.\n    86→\n    87→    Returns:\n    88→        dict keyed by (model, tp) with values:\n    89→        {\n    90→            \"beta0\": float, \"beta1\": float, \"beta2\": float,\n    91→            \"n_steps\": int, \"n_experiments\": int,\n    92→            \"train_mape\": float, \"train_r\": float,\n    93→            \"experiments\": [list of experiment_ids],\n    94→        }\n    95→    \"\"\"\n    96→    if data_root is None:\n    97→        data_root = DEFAULT_DATA_ROOT\n    98→\n    99→    # Build canonical model map from exp-config.yaml\n   100→    canon_map = _build_canonical_model_map(data_root)"}]},"parent_tool_use_id":null,"session_id":"27497e41-6ff8-42ab-aee1-66206c73fdbf","uuid":"489c4a58-d26a-4bd1-b38a-fdd9f54d9ebb","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round3-idea-2-total-context-model/hypotheses/h-stepml/shared/establish_baseline.py","content":"\"\"\"Establish baselines for StepML research.\n\nRuns two baselines through BLIS E2E validation and measures E2E/TTFT/ITL error\nagainst ground truth.  These are the accuracy bars that StepML models must beat.\n\nBaseline 1 — Roofline (analytical):\n    Uses the analytical FLOPs/bandwidth roofline model.  Zero calibration data\n    needed — step time is estimated from model architecture (HuggingFace\n    config.json) and GPU specs (hardware_config.json).\n\nBaseline 2 — Per-model linear regression:\n    Trains a separate 3-coefficient linear regression per model+TP on\n    ground-truth step traces (step_time = beta0 + beta1*prefill + beta2*decode),\n    pooling all workloads for a given model.  Requires training data.\n\nUsage:\n    python establish_baseline.py [--data-root PATH] [--output-dir PATH]\n    python establish_baseline.py --skip-linear              # roofline only\n    python establish_baseline.py --skip-roofline            # linear only\n    python establish_baseline.py --hardware A100            # non-default GPU\n\"\"\"\n\nimport argparse\nimport csv as csv_mod\nimport json\nimport os\nimport subprocess\nimport sys\nimport tempfile\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\n\nimport numpy as np\nimport pandas as pd\n\n# Add shared/ to path for imports\n_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\nsys.path.insert(0, _SCRIPT_DIR)\n\nimport yaml\n\nfrom baselines import BlackboxBaseline, check_r4_gate\nfrom data_loader import load_all_experiments, load_experiment_steps, parse_experiment_metadata\nfrom evaluation import compute_mape, compute_mspe, compute_pearson_r, compute_p99_error\nfrom validate_blis import (\n    build_workload_spec,\n    compute_error,\n    extract_cpu_kv_blocks_from_vllm_log,\n    extract_kv_blocks_from_vllm_log,\n    load_exp_config,\n    load_ground_truth_metrics,\n    load_profile,\n    parse_experiment_dir,\n    run_blis,\n)\n\n_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\"))\nDEFAULT_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\n_DEFAULT_WORKERS = min((os.cpu_count() or 4) // 2, 4)\n\n\ndef _build_canonical_model_map(data_root: str) -> dict:\n    \"\"\"Build a map from experiment_id to canonical (model, tp) from exp-config.yaml.\n\n    Directory names have inconsistencies (e.g. \"llama-2-70b\" vs \"llama-2-70b-hf\"\n    for the same model).  exp-config.yaml has the authoritative HF model name.\n    \"\"\"\n    mapping = {}\n    for dirname in sorted(os.listdir(data_root)):\n        config_path = os.path.join(data_root, dirname, \"exp-config.yaml\")\n        if not os.path.isfile(config_path):\n            continue\n        with open(config_path) as f:\n            cfg = yaml.safe_load(f)\n        # Canonical model name from HF (e.g. \"meta-llama/Llama-2-70b-hf\")\n        model = cfg.get(\"model\", \"\")\n        tp = cfg.get(\"tensor_parallelism\", 1)\n        mapping[dirname] = (model, tp)\n    return mapping\n\n\ndef train_per_model_coefficients(data_root: str) -> dict:\n    \"\"\"Train a linear regression per model+TP and return fitted coefficients.\n\n    Groups experiments by canonical (model, tp) from exp-config.yaml, trains\n    one linear regression per group, and returns the coefficients.\n\n    Returns:\n        dict keyed by (model, tp) with values:\n        {\n            \"beta0\": float, \"beta1\": float, \"beta2\": float,\n            \"n_steps\": int, \"n_experiments\": int,\n            \"train_mape\": float, \"train_r\": float,\n            \"experiments\": [list of experiment_ids],\n        }\n    \"\"\"\n    if data_root is None:\n        data_root = DEFAULT_DATA_ROOT\n\n    # Build canonical model map from exp-config.yaml\n    canon_map = _build_canonical_model_map(data_root)","numLines":100,"startLine":1,"totalLines":590}}}
