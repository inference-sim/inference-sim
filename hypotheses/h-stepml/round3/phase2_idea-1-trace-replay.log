ataPath string) (*TraceV2, error) {\n   147→\t// Load header\n   148→\theaderData, err := os.ReadFile(headerPath)\n   149→\tif err != nil {\n   150→\t\treturn nil, fmt.Errorf(\"reading trace header: %w\", err)\n   151→\t}\n   152→\tvar header TraceHeader\n   153→\tdecoder := yaml.NewDecoder(bytes.NewReader(headerData))\n   154→\tdecoder.KnownFields(true)\n   155→\tif err := decoder.Decode(&header); err != nil {\n   156→\t\treturn nil, fmt.Errorf(\"parsing trace header: %w\", err)\n   157→\t}\n   158→\n   159→\t// Load data CSV\n   160→\tfile, err := os.Open(dataPath)\n   161→\tif err != nil {\n   162→\t\treturn nil, fmt.Errorf(\"opening trace data: %w\", err)\n   163→\t}\n   164→\tdefer func() { _ = file.Close() }()\n   165→\n   166→\treader := csv.NewReader(file)\n   167→\n   168→\t// Skip header row\n   169→\tif _, err := reader.Read(); err != nil {\n   170→\t\treturn nil, fmt.Errorf(\"reading CSV header: %w\", err)\n   171→\t}\n   172→\n   173→\tvar records []TraceRecord\n   174→\tfor {\n   175→\t\trow, err := reader.Read()\n   176→\t\tif err == io.EOF {\n   177→\t\t\tbreak\n   178→\t\t}\n   179→\t\tif err != nil {\n   180→\t\t\treturn nil, fmt.Errorf(\"reading CSV row: %w\", err)\n   181→\t\t}\n   182→\t\tif len(row) < len(traceV2Columns) {\n   183→\t\t\treturn nil, fmt.Errorf(\"CSV row has %d columns, expected %d\", len(row), len(traceV2Columns))\n   184→\t\t}\n   185→\n   186→\t\tr, err := parseTraceRecord(row)\n   187→\t\tif err != nil {\n   188→\t\t\treturn nil, err\n   189→\t\t}\n   190→\t\trecords = append(records, *r)\n   191→\t}\n   192→\n   193→\treturn &TraceV2{Header: header, Records: records}, nil\n   194→}\n   195→\n   196→func parseTraceRecord(row []string) (*TraceRecord, error) {\n   197→\trequestID, err := strconv.Atoi(row[0])\n   198→\tif err != nil {\n   199→\t\treturn nil, fmt.Errorf(\"parsing request_id %q: %w\", row[0], err)\n   200→\t}\n   201→\troundIndex, err := strconv.Atoi(row[5])\n   202→\tif err != nil {\n   203→\t\treturn nil, fmt.Er