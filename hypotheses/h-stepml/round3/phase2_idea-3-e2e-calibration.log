{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01YEZ2am5c1TpXQDWUusDuY4","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"Round 3, Idea 1: Trace-Driven Simulation with Lifecycle Replay.\n     3→\n     4→Runs all three sub-hypotheses:\n     5→  H1: Trace replay reduces TTFT error (vs workload-spec mode)\n     6→  H2: Error attribution with trace replay (TTFT vs ITL decomposition)\n     7→  H3: Workload-spec parameter diagnosis (which parameter is wrong)\n     8→\n     9→Uses the legacy CSV trace path: --workload traces --workload-traces-filepath <csv>\n    10→with Round 2's best StepML artifacts (regime ensemble + calibrated overheads).\n    11→\"\"\"\n    12→\n    13→import csv\n    14→import json\n    15→import os\n    16→import subprocess\n    17→import sys\n    18→import tempfile\n    19→\n    20→import yaml\n    21→\n    22→# ---------------------------------------------------------------------------\n    23→# Paths\n    24→# ---------------------------------------------------------------------------\n    25→SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n    26→REPO_ROOT = os.path.abspath(os.path.join(SCRIPT_DIR, \"..\", \"..\", \"..\", \"..\"))\n    27→SHARED_DIR = os.path.join(SCRIPT_DIR, \"..\", \"..\", \"shared\")\n    28→\n    29→# The worktree is under stepml-worktrees/ — use absolute path to package root\n    30→PACKAGE_ROOT = \"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package\"\n    31→\n    32→# Ground truth data in BLIS-research repo (has per_request_lifecycle_metrics.json)\n    33→BLIS_RESEARCH_ROOT = os.path.join(PACKAGE_ROOT, \"BLIS-research\")\n    34→GT_DATA_ROOT = os.path.join(BLIS_RESEARCH_ROOT, \"eval\", \"ground_truth\")\n    35→\n    36→# Round 2 best artifacts (calibrated regime ensemble)\n    37→R2_ARTIFACTS_DIR = os.path.join(\n    38→    BLIS_RESEARCH_ROOT,\n    39→    \"hypotheses\", \"h-stepml\", \"round2\",\n    40→    \"idea-2-regime-ensemble\", \"h3-secondary-method-calibration\",\n    41→    \"output\", \"calibrated_artifacts\",\n    42→)\n    43→\n    44→# Original eval data (inference-sim repo, has profile.yaml for workload-spec comparison)\n    45→ORIG_GT_ROOT = os.path.join(PACKAGE_ROOT, \"inference-sim\", \"eval\", \"ground_truth\")\n    46→\n    47→BINARY_PATH = os.path.join(REPO_ROOT, \"simulation_worker\")\n    48→BLOCK_SIZE_TOKENS = 16\n    49→\n    50→# Model name → artifact mapping\n    51→MODEL_ARTIFACT_MAP = {\n    52→    \"llama-2-7b\": \"llama-2-7b_tp1_regime.json\",\n    53→    \"llama-2-70b\": \"llama-2-70b_tp4_regime.json\",\n    54→    \"llama-2-70b-hf\": \"llama-2-70b-hf_tp4_regime.json\",\n    55→    \"codellama-34b\": \"codellama-34b_tp2_regime.json\",\n    56→    \"mixtral-8x7b-v0-1\": \"mixtral-8x7b-v0-1_tp2_regime.json\",\n    57→}\n    58→\n    59→# Round 2 workload-spec results (from FINDINGS_ROUND2.md / e2e_summary_regime.json)\n    60→R2_WORKLOAD_SPEC_RESULTS = {\n    61→    \"mean_e2e_error_pct\": 427.81,\n    62→    \"mean_ttft_error_pct\": 31905.77,\n    63→    \"mean_itl_error_pct\": 33.64,\n    64→    \"experiments_below_10pct_e2e\": 1,\n    65→}\n    66→\n    67→\n    68→# ---------------------------------------------------------------------------\n    69→# Helpers\n    70→# ---------------------------------------------------------------------------\n    71→def parse_experiment_dir(dirname):\n    72→    \"\"\"Parse model, tp, workload from directory name.\"\"\"\n    73→    import re\n    74→    # Try new format: YYYYMMDD-HHMMSS-model-tpN-workload\n    75→    # or old format: YYYYMMDD-model-tpN-workload\n    76→    tp_matches = list(re.finditer(r\"-tp(\\d+)-\", dirname))\n    77→    if not tp_matches:\n    78→        raise ValueError(f\"Cannot parse experiment dir: {dirname}\")\n    79→    last_tp = tp_matches[-1]\n    80→    # Check if starts with full timestamp (YYYYMMDD-HHMMSS)\n    81→    if re.match(r\"^\\d{8}-\\d{6}-\", dirname):\n    82→        model = dirname[16:last_tp.start()]\n    83→    elif re.match(r\"^\\d{8}-\", dirname):\n    84→        model = dirname[9:last_tp.start()]\n    85→    else:\n    86→        model = dirname[:last_tp.start()]\n    87→    return {\n    88→        \"model\": model,\n    89→        \"tp\": int(last_tp.group(1)),\n    90→        \"workload\": dirname[last_tp.end():],\n    91→    }\n    92→\n    93→\n    94→def load_ground_truth(experiment_dir):\n    95→    \"\"\"Load ground-truth latency metrics.\"\"\"\n    96→    summary_path = os.path.join(\n    97→        experiment_dir, \"results\", \"summary_lifecycle_metrics.json\"\n    98→    )\n    99→    with open(summary_path) as f:\n   100→        data = json.load(f)\n   101→    successes = data.get(\"successes\", {})\n   102→    latency = successes.get(\"latency\", {})\n   103→    return {\n   104→        \"e2e_mean_s\": latency.get(\"request_latency\", {}).get(\"mean\", 0),\n   105→        \"ttft_mean_s\": latency.get(\"time_to_first_token\", {}).get(\"mean\", 0),\n   106→        \"itl_mean_s\": latency.get(\"inter_token_latency\", {}).get(\"mean\", 0),\n   107→        \"num_requests\": data.get(\"load_summary\", {}).get(\"count\", 0),\n   108→        \"prompt_len_mean\": successes.get(\"prompt_len\", {}).get(\"mean\", 0),\n   109→        \"output_len_mean\": successes.get(\"output_len\", {}).get(\"mean\", 0),\n   110→        \"throughput_rps\": successes.get(\"throughput\", {}).get(\n   111→            \"requests_per_sec\", 0\n   112→        ),\n   113→    }\n   114→\n   115→\n   116→def load_exp_config(experiment_dir):\n   117→    \"\"\"Load exp-config.yaml.\"\"\"\n   118→    config_path = os.path.join(experiment_dir, \"exp-config.yaml\")\n   119→    with open(config_path) as f:\n   120→        return yaml.safe_load(f)\n   121→\n   122→\n   123→def extract_kv_blocks(experiment_dir):\n   124→    \"\"\"Extract GPU KV cache blocks from vllm.log.\"\"\"\n   125→    import re\n   126→    vllm_log = os.path.join(experiment_dir, \"vllm.log\")\n   127→    if not os.path.isfile(vllm_log):\n   128→        return None\n   129→    pattern = re.compile(r\"GPU KV cache size:\\s+([\\d,]+)\\s+tokens\")\n   130→    with open(vllm_log) as f:\n   131→        for line in f:\n   132→            m = pattern.search(line)\n   133→            if m:\n   134→                tokens = int(m.group(1).replace(\",\", \"\"))\n   135→                return tokens // BLOCK_SIZE_TOKENS\n   136→    return None\n   137→\n   138→\n   139→def extract_cpu_kv_blocks(experiment_dir):\n   140→    \"\"\"Extract CPU KV blocks from vllm.log for tiered caching.\"\"\"\n   141→    import re\n   142→    vllm_log = os.path.join(experiment_dir, \"vllm.log\")\n   143→    if not os.path.isfile(vllm_log):\n   144→        return 0\n   145→    cpu_bytes = None\n   146→    kv_shape = None\n   147→    with open(vllm_log) as f:\n   148→        for line in f:\n   149→            m = re.search(r\"cpu_bytes_to_use['\\\"]?:\\s*([\\d.]+)\", line)\n   150→            if m and cpu_bytes is None:\n   151→                cpu_bytes = float(m.group(1))\n   152→            m = re.search(\n   153→                r\"cross layer KV cache of shape \\((\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+)\\)\",\n   154→                line,\n   155→            )\n   156→            if m and kv_shape is None:\n   157→                kv_shape = tuple(int(m.group(i)) for i in range(1, 7))\n   158→    if cpu_bytes is None or kv_shape is None or cpu_bytes == 0:\n   159→        return 0\n   160→    _, num_layers, _, block_size, num_kv_heads, head_dim = kv_shape\n   161→    per_block_bytes = num_layers * 2 * block_size * num_kv_heads * head_dim * 2\n   162→    return int(cpu_bytes) // per_block_bytes\n   163→\n   164→\n   165→def convert_lifecycle_to_csv(lifecycle_path, output_csv, model_name, seed=42):\n   166→    \"\"\"Convert per_request_lifecycle_metrics.json to BLIS legacy trace CSV.\"\"\"\n   167→    import random\n   168→    with open(lifecycle_path) as f:\n   169→        data = json.load(f)\n   170→    if not data:\n   171→        raise ValueError(f\"Empty lifecycle data: {lifecycle_path}\")\n   172→    rng = random.Random(seed)\n   173→    base_time = min(entry[\"start_time\"] for entry in data)\n   174→    rows = []\n   175→    for i, entry in enumerate(data):\n   176→        info = entry.get(\"info\", {})\n   177→        input_count = info.get(\"input_tokens\", 0)\n   178→        output_count = info.get(\"output_tokens\", 0)\n   179→        arrival_s = entry[\"start_time\"] - base_time\n   180→        input_tokens = [rng.randint(0, 31999) for _ in range(input_count)]\n   181→        output_tokens = [rng.randint(0, 31999) for _ in range(output_count)]\n   182→        rows.append((arrival_s, i, model_name, input_tokens, output_tokens))\n   183→    rows.sort(key=lambda x: x[0])\n   184→    with open(output_csv, \"w\") as f:\n   185→        f.write(\"arrival_time,request_id,model,prefill_tokens,decode_tokens\\n\")\n   186→        for arrival_s, req_id, model, inp, out in rows:\n   187→            f.write(\n   188→                f\"{arrival_s:.6f},request_{req_id},{model},\"\n   189→                f'\"{json.dumps(inp)}\",\"{json.dumps(out)}\"\\n'\n   190→            )\n   191→    return {\n   192→        \"num_requests\": len(rows),\n   193→        \"min_arrival_s\": rows[0][0] if rows else 0,\n   194→        \"max_arrival_s\": rows[-1][0] if rows else 0,\n   195→        \"duration_s\": (rows[-1][0] - rows[0][0]) if len(rows) > 1 else 0,\n   196→        \"mean_input_tokens\": sum(len(r[3]) for r in rows) / len(rows) if rows else 0,\n   197→        \"mean_output_tokens\": sum(len(r[4]) for r in rows) / len(rows) if rows else 0,\n   198→    }\n   199→\n   200→\n   201→def compute_error(predicted, observed):\n   202→    \"\"\"Relative error: |predicted - observed| / observed.\"\"\"\n   203→    if observed == 0:\n   204→        return float(\"inf\") if predicted != 0 else 0.0\n   205→    return abs(predicted - observed) / observed\n   206→\n   207→\n   208→def parse_blis_stdout(stdout):\n   209→    \"\"\"Parse BLIS JSON output from stdout.\"\"\"\n   210→    lines = stdout.split(\"\\n\")\n   211→    json_lines = []\n   212→    in_json = False\n   213→    brace_depth = 0\n   214→    for line in lines:\n   215→        if \"Simulation Metrics\" in line:\n   216→            in_json = False\n   217→            json_lines = []\n   218→            continue\n   219→        if not in_json and line.strip().startswith(\"{\"):\n   220→            in_json = True\n   221→        if in_json:\n   222→            json_lines.append(line)\n   223→            brace_depth += line.count(\"{\") - line.count(\"}\")\n   224→            if brace_depth <= 0:\n   225→                break\n   226→    if not json_lines:\n   227→        return None\n   228→    try:\n   229→        metrics = json.loads(\"\\n\".join(json_lines))\n   230→    except json.JSONDecodeError:\n   231→        return None\n   232→    return {\n   233→        \"e2e_mean_ms\": metrics.get(\"e2e_mean_ms\", 0),\n   234→        \"ttft_mean_ms\": metrics.get(\"ttft_mean_ms\", 0),\n   235→        \"itl_mean_ms\": metrics.get(\"itl_mean_ms\", 0),\n   236→        \"completed_requests\": metrics.get(\"completed_requests\", 0),\n   237→        \"tokens_per_sec\": metrics.get(\"tokens_per_sec\", 0),\n   238→    }\n   239→\n   240→\n   241→def run_blis_trace_replay(\n   242→    trace_csv_path, exp_config, total_kv_blocks, stepml_artifact_path,\n   243→    horizon_us, cpu_kv_blocks=0,\n   244→):\n   245→    \"\"\"Run BLIS with legacy trace CSV replay + StepML artifact.\"\"\"\n   246→    model_name = exp_config.get(\"model\", \"unknown\")\n   247→    tp = exp_config.get(\"tensor_parallelism\", 1)\n   248→    max_model_len = exp_config.get(\"max_model_len\", 4096)\n   249→    max_num_seqs = exp_config.get(\"max_num_seqs\", 128)\n   250→    max_num_batched_tokens = exp_config.get(\"max_num_batched_tokens\", 2048)\n   251→\n   252→    with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n   253→        results_path = f.name\n   254→\n   255→    cmd = [\n   256→        BINARY_PATH, \"run\",\n   257→        \"--model\", model_name,\n   258→        \"--workload\", \"traces\",\n   259→        \"--workload-traces-filepath\", trace_csv_path,\n   260→        \"--tp\", str(tp),\n   261→        \"--max-model-len\", str(max_model_len),\n   262→        \"--max-num-running-reqs\", str(max_num_seqs),\n   263→        \"--max-num-scheduled-tokens\", str(max_num_batched_tokens),\n   264→        \"--total-kv-blocks\", str(total_kv_blocks),\n   265→        \"--block-size-in-tokens\", str(BLOCK_SIZE_TOKENS),\n   266→        \"--horizon\", str(horizon_us),\n   267→        \"--alpha-coeffs=1,0,0\",\n   268→        \"--beta-coeffs=1,0,0\",\n   269→        \"--stepml-model\", stepml_artifact_path,\n   270→        \"--results-path\", results_path,\n   271→        \"--log\", \"error\",\n   272→    ]\n   273→\n   274→    if cpu_kv_blocks > 0:\n   275→        cmd.extend([\"--kv-cpu-blocks\", str(cpu_kv_blocks)])\n   276→\n   277→    try:\n   278→        result = subprocess.run(\n   279→            cmd, capture_output=True, text=True, timeout=600,\n   280→            cwd=os.path.dirname(BINARY_PATH),\n   281→        )\n   282→    except subprocess.TimeoutExpired:\n   283→        print(\"  TIMEOUT after 600s\", file=sys.stderr)\n   284→        return None\n   285→    except FileNotFoundError:\n   286→        print(f\"  Binary not found: {BINARY_PATH}\", file=sys.stderr)\n   287→        return None\n   288→    finally:\n   289→        if os.path.exists(results_path):\n   290→            os.unlink(results_path)\n   291→\n   292→    if result.returncode != 0:\n   293→        print(f\"  BLIS failed (exit {result.returncode})\", file=sys.stderr)\n   294→        print(f\"  stderr: {result.stderr[:1000]}\", file=sys.stderr)\n   295→        return None\n   296→\n   297→    return parse_blis_stdout(result.stdout)\n   298→\n   299→\n   300→def load_profile_data(experiment_dir):\n   301→    \"\"\"Load profile.yaml (JSON format) for workload-spec parameter comparison.\"\"\"\n   302→    profile_path = os.path.join(experiment_dir, \"profile.yaml\")\n   303→    if not os.path.isfile(profile_path):\n   304→        return None\n   305→    with open(profile_path) as f:\n   306→        content = f.read()\n   307→    try:\n   308→        return json.loads(content)\n   309→    except json.JSONDecodeError:\n   310→        try:\n   311→            return yaml.safe_load(content)\n   312→        except yaml.YAMLError:\n   313→            return None\n   314→\n   315→\n   316→def extract_lifecycle_stats(lifecycle_path):\n   317→    \"\"\"Extract ground-truth workload statistics from lifecycle data.\"\"\"\n   318→    with open(lifecycle_path) as f:\n   319→        data = json.load(f)\n   320→    if not data:\n   321→        return None\n   322→    arrivals = [e[\"start_time\"] for e in data]\n   323→    input_tokens = [e.get(\"info\", {}).get(\"input_tokens\", 0) for e in data]\n   324→    output_tokens = [e.get(\"info\", {}).get(\"output_tokens\", 0) for e in data]\n   325→\n   326→    import numpy as np\n   327→    arrivals_arr = np.array(arrivals)\n   328→    duration_s = arrivals_arr.max() - arrivals_arr.min()\n   329→    arrival_rate = (len(data) - 1) / duration_s if duration_s > 0 else 0\n   330→\n   331→    return {\n   332→        \"num_requests\": len(data),\n   333→        \"duration_s\": duration_s,\n   334→        \"arrival_rate_rps\": arrival_rate,\n   335→        \"input_tokens_mean\": np.mean(input_tokens),\n   336→        \"input_tokens_std\": np.std(input_tokens),\n   337→        \"output_tokens_mean\": np.mean(output_tokens),\n   338→        \"output_tokens_std\": np.std(output_tokens),\n   339→    }\n   340→\n   341→\n   342→def extract_workload_spec_stats(profile):\n   343→    \"\"\"Extract workload-spec parameters from profile.yaml.\"\"\"\n   344→    if profile is None:\n   345→        return None\n   346→    load_config = profile.get(\"load\", {})\n   347→    data = profile.get(\"data\", {})\n   348→    sp = data.get(\"shared_prefix\", {})\n   349→\n   350→    stages = load_config.get(\"stages\", [])\n   351→    if not stages:\n   352→        return None\n   353→\n   354→    total_duration = sum(s[\"duration\"] for s in stages)\n   355→    total_requests = sum(s[\"rate\"] * s[\"duration\"] for s in stages)\n   356→    avg_rate = total_requests / total_duration if total_duration > 0 else 0\n   357→\n   358→    return {\n   359→        \"num_requests\": int(total_requests),\n   360→        \"duration_s\": total_duration,\n   361→        \"arrival_rate_rps\": avg_rate,\n   362→        \"question_len\": sp.get(\"question_len\", 0),\n   363→        \"output_len\": sp.get(\"output_len\", 0),\n   364→        \"stages\": stages,\n   365→    }\n   366→\n   367→\n   368→# ---------------------------------------------------------------------------\n   369→# Main experiment\n   370→# ---------------------------------------------------------------------------\n   371→def main():\n   372→    print(\"=\" * 70)\n   373→    print(\"Round 3, Idea 1: Trace-Driven Simulation with Lifecycle Replay\")\n   374→    print(\"=\" * 70)\n   375→\n   376→    # Step 0: Build BLIS binary\n   377→    if not os.path.isfile(BINARY_PATH):\n   378→        print(\"\\nBuilding simulation_worker...\")\n   379→        build = subprocess.run(\n   380→            [\"go\", \"build\", \"-o\", BINARY_PATH, \"main.go\"],\n   381→            cwd=REPO_ROOT, capture_output=True, text=True,\n   382→        )\n   383→        if build.returncode != 0:\n   384→            print(f\"Build failed: {build.stderr}\", file=sys.stderr)\n   385→            sys.exit(1)\n   386→        print(\"  Build successful.\")\n   387→    else:\n   388→        print(f\"\\nUsing existing binary: {BINARY_PATH}\")\n   389→\n   390→    # Step 1: Discover experiments\n   391→    if not os.path.isdir(GT_DATA_ROOT):\n   392→        print(f\"ERROR: Ground truth data not found at {GT_DATA_ROOT}\", file=sys.stderr)\n   393→        sys.exit(1)\n   394→\n   395→    experiments = []\n   396→    for dirname in sorted(os.listdir(GT_DATA_ROOT)):\n   397→        dirpath = os.path.join(GT_DATA_ROOT, dirname)\n   398→        if not os.path.isdir(dirpath):\n   399→            continue\n   400→        lifecycle_path = os.path.join(dirpath, \"results\", \"per_request_lifecycle_metrics.json\")\n   401→        if not os.path.isfile(lifecycle_path):\n   402→            continue\n   403→        try:\n   404→            meta = parse_experiment_dir(dirname)\n   405→        except ValueError:\n   406→            continue\n   407→        experiments.append({\n   408→            \"dirname\": dirname,\n   409→            \"dirpath\": dirpath,\n   410→            \"meta\": meta,\n   411→            \"lifecycle_path\": lifecycle_path,\n   412→        })\n   413→\n   414→    print(f\"\\nFound {len(experiments)} experiments with lifecycle data.\")\n   415→\n   416→    # Step 2: Run BLIS with trace replay for each experiment\n   417→    h1_results = []\n   418→    h2_results = []\n   419→    h3_results = []\n   420→\n   421→    with tempfile.TemporaryDirectory() as tmpdir:\n   422→        for exp in experiments:\n   423→            dirname = exp[\"dirname\"]\n   424→            dirpath = exp[\"dirpath\"]\n   425→            meta = exp[\"meta\"]\n   426→            model = meta[\"model\"]\n   427→            workload = meta[\"workload\"]\n   428→\n   429→            print(f\"\\n{'=' * 60}\")\n   430→            print(f\"Experiment: {dirname}\")\n   431→            print(f\"  Model: {model}, TP: {meta['tp']}, Workload: {workload}\")\n   432→            print(f\"{'=' * 60}\")\n   433→\n   434→            # Load ground truth\n   435→            gt = load_ground_truth(dirpath)\n   436→            print(f\"  GT: E2E={gt['e2e_mean_s']*1000:.1f}ms, \"\n   437→                  f\"TTFT={gt['ttft_mean_s']*1000:.1f}ms, \"\n   438→                  f\"ITL={gt['itl_mean_s']*1000:.2f}ms, \"\n   439→                  f\"N={gt['num_requests']}\")\n   440→\n   441→            # Load experiment config\n   442→            exp_config = load_exp_config(dirpath)\n   443→\n   444→            # Extract KV blocks\n   445→            total_kv_blocks = extract_kv_blocks(dirpath)\n   446→            if total_kv_blocks is None:\n   447→                print(\"  SKIP: Cannot parse KV blocks\", file=sys.stderr)\n   448→                continue\n   449→            cpu_kv_blocks = extract_cpu_kv_blocks(dirpath)\n   450→            print(f\"  KV blocks: {total_kv_blocks} GPU + {cpu_kv_blocks} CPU\")\n   451→\n   452→            # Find StepML artifact for this model\n   453→            artifact_file = MODEL_ARTIFACT_MAP.get(model)\n   454→            if artifact_file is None:\n   455→                print(f\"  SKIP: No artifact for model '{model}'\", file=sys.stderr)\n   456→                continue\n   457→            artifact_path = os.path.join(R2_ARTIFACTS_DIR, artifact_file)\n   458→            if not os.path.isfile(artifact_path):\n   459→                print(f\"  SKIP: Artifact not found: {artifact_path}\", file=sys.stderr)\n   460→                continue\n   461→            print(f\"  Artifact: {artifact_file}\")\n   462→\n   463→            # Convert lifecycle data to trace CSV\n   464→            csv_path = os.path.join(tmpdir, f\"{dirname}.csv\")\n   465→            trace_stats = convert_lifecycle_to_csv(\n   466→                exp[\"lifecycle_path\"], csv_path,\n   467→                model_name=exp_config.get(\"model\", model),\n   468→            )\n   469→            print(f\"  Trace: {trace_stats['num_requests']} requests, \"\n   470→                  f\"{trace_stats['duration_s']:.1f}s duration, \"\n   471→                  f\"mean input={trace_stats['mean_input_tokens']:.0f}, \"\n   472→                  f\"mean output={trace_stats['mean_output_tokens']:.0f}\")\n   473→\n   474→            # Set horizon: trace duration + 120s buffer (in microseconds)\n   475→            horizon_us = int((trace_stats[\"duration_s\"] + 120) * 1_000_000)\n   476→\n   477→            # Run BLIS with trace replay\n   478→            blis = run_blis_trace_replay(\n   479→                trace_csv_path=csv_path,\n   480→                exp_config=exp_config,\n   481→                total_kv_blocks=total_kv_blocks,\n   482→                stepml_artifact_path=artifact_path,\n   483→                horizon_us=horizon_us,\n   484→                cpu_kv_blocks=cpu_kv_blocks,\n   485→            )\n   486→\n   487→            if blis is None:\n   488→                print(\"  BLIS run failed!\")\n   489→                h1_results.append({\n   490→                    \"experiment\": dirname, \"model\": model,\n   491→                    \"workload\": workload, \"tp\": meta[\"tp\"],\n   492→                    \"status\": \"blis_failed\",\n   493→                })\n   494→                continue\n   495→\n   496→            # Compute errors\n   497→            e2e_err = compute_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n   498→            ttft_err = compute_error(blis[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000)\n   499→            itl_err = compute_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n   500→\n   501→            print(f\"  BLIS: E2E={blis['e2e_mean_ms']:.1f}ms, \"\n   502→                  f\"TTFT={blis['ttft_mean_ms']:.1f}ms, \"\n   503→                  f\"ITL={blis['itl_mean_ms']:.2f}ms, \"\n   504→                  f\"completed={blis['completed_requests']}\")\n   505→            print(f\"  Errors: E2E={e2e_err*100:.1f}%, \"\n   506→                  f\"TTFT={ttft_err*100:.1f}%, \"\n   507→                  f\"ITL={itl_err*100:.1f}%\")\n   508→\n   509→            row = {\n   510→                \"experiment\": dirname,\n   511→                \"model\": model,\n   512→                \"workload\": workload,\n   513→                \"tp\": meta[\"tp\"],\n   514→                \"status\": \"ok\",\n   515→                \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n   516→                \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n   517→                \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n   518→                \"gt_requests\": gt[\"num_requests\"],\n   519→                \"blis_e2e_ms\": blis[\"e2e_mean_ms\"],\n   520→                \"blis_ttft_ms\": blis[\"ttft_mean_ms\"],\n   521→                \"blis_itl_ms\": blis[\"itl_mean_ms\"],\n   522→                \"blis_completed\": blis[\"completed_requests\"],\n   523→                \"e2e_error\": e2e_err,\n   524→                \"ttft_error\": ttft_err,\n   525→                \"itl_error\": itl_err,\n   526→            }\n   527→            h1_results.append(row)\n   528→\n   529→            # H2: Error attribution\n   530→            if row[\"status\"] == \"ok\":\n   531→                h2_row = dict(row)\n   532→                # Decompose: is E2E error TTFT-dominated or ITL-dominated?\n   533→                h2_row[\"ttft_contribution_ms\"] = blis[\"ttft_mean_ms\"] - gt[\"ttft_mean_s\"] * 1000\n   534→                itl_contribution_ms = (\n   535→                    (blis[\"itl_mean_ms\"] - gt[\"itl_mean_s\"] * 1000) *\n   536→                    gt.get(\"output_len_mean\", 0)\n   537→                )\n   538→                h2_row[\"itl_contribution_ms\"] = itl_contribution_ms\n   539→                h2_row[\"ttft_abs_error_ms\"] = abs(blis[\"ttft_mean_ms\"] - gt[\"ttft_mean_s\"] * 1000)\n   540→                h2_row[\"itl_abs_error_ms\"] = abs(blis[\"itl_mean_ms\"] - gt[\"itl_mean_s\"] * 1000)\n   541→                h2_results.append(h2_row)\n   542→\n   543→            # H3: Workload-spec parameter diagnosis\n   544→            lifecycle_stats = extract_lifecycle_stats(exp[\"lifecycle_path\"])\n   545→            # Try to load profile from original eval directory\n   546→            orig_exp_dir = os.path.join(ORIG_GT_ROOT, dirname) if ORIG_GT_ROOT else None\n   547→            profile = None\n   548→            if orig_exp_dir and os.path.isdir(orig_exp_dir):\n   549→                profile = load_profile_data(orig_exp_dir)\n   550→            # Also try BLIS-research ground truth\n   551→            if profile is None:\n   552→                profile = load_profile_data(dirpath)\n   553→\n   554→            spec_stats = extract_workload_spec_stats(profile) if profile else None\n   555→\n   556→            h3_row = {\n   557→                \"experiment\": dirname,\n   558→                \"model\": model,\n   559→                \"workload\": workload,\n   560→            }\n   561→            if lifecycle_stats:\n   562→                h3_row[\"gt_num_requests\"] = lifecycle_stats[\"num_requests\"]\n   563→                h3_row[\"gt_duration_s\"] = lifecycle_stats[\"duration_s\"]\n   564→                h3_row[\"gt_arrival_rate_rps\"] = lifecycle_stats[\"arrival_rate_rps\"]\n   565→                h3_row[\"gt_input_mean\"] = lifecycle_stats[\"input_tokens_mean\"]\n   566→                h3_row[\"gt_output_mean\"] = lifecycle_stats[\"output_tokens_mean\"]\n   567→\n   568→            if spec_stats:\n   569→                h3_row[\"spec_num_requests\"] = spec_stats[\"num_requests\"]\n   570→                h3_row[\"spec_duration_s\"] = spec_stats[\"duration_s\"]\n   571→                h3_row[\"spec_arrival_rate_rps\"] = spec_stats[\"arrival_rate_rps\"]\n   572→                h3_row[\"spec_question_len\"] = spec_stats[\"question_len\"]\n   573→                h3_row[\"spec_output_len\"] = spec_stats[\"output_len\"]\n   574→\n   575→                # Compute relative errors on each parameter\n   576→                if lifecycle_stats:\n   577→                    gt_rate = lifecycle_stats[\"arrival_rate_rps\"]\n   578→                    sp_rate = spec_stats[\"arrival_rate_rps\"]\n   579→                    h3_row[\"rate_error\"] = compute_error(sp_rate, gt_rate)\n   580→\n   581→                    h3_row[\"request_count_error\"] = compute_error(\n   582→                        spec_stats[\"num_requests\"], lifecycle_stats[\"num_requests\"]\n   583→                    )\n   584→                    h3_row[\"duration_error\"] = compute_error(\n   585→                        spec_stats[\"duration_s\"], lifecycle_stats[\"duration_s\"]\n   586→                    )\n   587→            else:\n   588→                h3_row[\"spec_status\"] = \"no_profile\"\n   589→\n   590→            h3_results.append(h3_row)\n   591→\n   592→    # ---------------------------------------------------------------------------\n   593→    # Write results\n   594→    # ---------------------------------------------------------------------------\n   595→    print(\"\\n\" + \"=\" * 70)\n   596→    print(\"RESULTS SUMMARY\")\n   597→    print(\"=\" * 70)\n   598→\n   599→    # H1 summary\n   600→    ok_results = [r for r in h1_results if r.get(\"status\") == \"ok\"]\n   601→    h1_output_dir = os.path.join(SCRIPT_DIR, \"h1-trace-replay\")\n   602→    os.makedirs(h1_output_dir, exist_ok=True)\n   603→\n   604→    if ok_results:\n   605→        e2e_errors = [r[\"e2e_error\"] for r in ok_results]\n   606→        ttft_errors = [r[\"ttft_error\"] for r in ok_results]\n   607→        itl_errors = [r[\"itl_error\"] for r in ok_results]\n   608→\n   609→        mean_e2e = sum(e2e_errors) / len(e2e_errors) * 100\n   610→        mean_ttft = sum(ttft_errors) / len(ttft_errors) * 100\n   611→        mean_itl = sum(itl_errors) / len(itl_errors) * 100\n   612→        e2e_under_10 = sum(1 for e in e2e_errors if e < 0.10)\n   613→\n   614→        print(f\"\\nH1: Trace Replay Results ({len(ok_results)} experiments)\")\n   615→        print(f\"  Mean E2E  error: {mean_e2e:.1f}% (was {R2_WORKLOAD_SPEC_RESULTS['mean_e2e_error_pct']:.1f}% with workload-spec)\")\n   616→        print(f\"  Mean TTFT error: {mean_ttft:.1f}% (was {R2_WORKLOAD_SPEC_RESULTS['mean_ttft_error_pct']:.1f}% with workload-spec)\")\n   617→        print(f\"  Mean ITL  error: {mean_itl:.1f}% (was {R2_WORKLOAD_SPEC_RESULTS['mean_itl_error_pct']:.1f}% with workload-spec)\")\n   618→        print(f\"  E2E < 10%: {e2e_under_10}/{len(ok_results)}\")\n   619→\n   620→        # Write CSV\n   621→        csv_path = os.path.join(h1_output_dir, \"trace_replay_results.csv\")\n   622→        fieldnames = sorted(set().union(*(r.keys() for r in h1_results)))\n   623→        with open(csv_path, \"w\", newline=\"\") as f:\n   624→            writer = csv.DictWriter(f, fieldnames=fieldnames)\n   625→            writer.writeheader()\n   626→            writer.writerows(h1_results)\n   627→\n   628→        # Write summary JSON\n   629→        summary = {\n   630→            \"n_experiments\": len(ok_results),\n   631→            \"n_failed\": len(h1_results) - len(ok_results),\n   632→            \"mean_e2e_error_pct\": mean_e2e,\n   633→            \"mean_ttft_error_pct\": mean_ttft,\n   634→            \"mean_itl_error_pct\": mean_itl,\n   635→            \"e2e_under_10pct\": e2e_under_10,\n   636→            \"r2_comparison\": R2_WORKLOAD_SPEC_RESULTS,\n   637→            \"e2e_reduction_factor\": R2_WORKLOAD_SPEC_RESULTS[\"mean_e2e_error_pct\"] / mean_e2e if mean_e2e > 0 else float(\"inf\"),\n   638→            \"ttft_reduction_factor\": R2_WORKLOAD_SPEC_RESULTS[\"mean_ttft_error_pct\"] / mean_ttft if mean_ttft > 0 else float(\"inf\"),\n   639→            \"per_experiment\": ok_results,\n   640→        }\n   641→        with open(os.path.join(h1_output_dir, \"summary.json\"), \"w\") as f:\n   642→            json.dump(summary, f, indent=2)\n   643→\n   644→    # H2 summary\n   645→    h2_output_dir = os.path.join(SCRIPT_DIR, \"h2-error-attribution\")\n   646→    os.makedirs(h2_output_dir, exist_ok=True)\n   647→    if h2_results:\n   648→        csv_path = os.path.join(h2_output_dir, \"error_attribution.csv\")\n   649→        fieldnames = sorted(set().union(*(r.keys() for r in h2_results)))\n   650→        with open(csv_path, \"w\", newline=\"\") as f:\n   651→            writer = csv.DictWriter(f, fieldnames=fieldnames)\n   652→            writer.writeheader()\n   653→            writer.writerows(h2_results)\n   654→\n   655→        e2e_errors = [r[\"e2e_error\"] for r in h2_results]\n   656→        mean_e2e_h2 = sum(e2e_errors) / len(e2e_errors) * 100\n   657→        under_10 = sum(1 for e in e2e_errors if e < 0.10)\n   658→        under_25 = sum(1 for e in e2e_errors if e < 0.25)\n   659→\n   660→        summary_h2 = {\n   661→            \"n_experiments\": len(h2_results),\n   662→            \"mean_e2e_error_pct\": mean_e2e_h2,\n   663→            \"e2e_under_10pct\": under_10,\n   664→            \"e2e_under_25pct\": under_25,\n   665→            \"per_experiment\": h2_results,\n   666→        }\n   667→        with open(os.path.join(h2_output_dir, \"summary.json\"), \"w\") as f:\n   668→            json.dump(summary_h2, f, indent=2)\n   669→\n   670→        print(f\"\\nH2: Error Attribution ({len(h2_results)} experiments)\")\n   671→        print(f\"  Mean E2E error with trace replay: {mean_e2e_h2:.1f}%\")\n   672→        print(f\"  E2E < 10%: {under_10}/{len(h2_results)}\")\n   673→        print(f\"  E2E < 25%: {under_25}/{len(h2_results)}\")\n   674→\n   675→    # H3 summary\n   676→    h3_output_dir = os.path.join(SCRIPT_DIR, \"h3-workload-diagnosis\")\n   677→    os.makedirs(h3_output_dir, exist_ok=True)\n   678→    if h3_results:\n   679→        csv_path = os.path.join(h3_output_dir, \"workload_diagnosis.csv\")\n   680→        fieldnames = sorted(set().union(*(r.keys() for r in h3_results)))\n   681→        with open(csv_path, \"w\", newline=\"\") as f:\n   682→            writer = csv.DictWriter(f, fieldnames=fieldnames)\n   683→            writer.writeheader()\n   684→            writer.writerows(h3_results)\n   685→\n   686→        with open(os.path.join(h3_output_dir, \"summary.json\"), \"w\") as f:\n   687→            json.dump({\"per_experiment\": h3_results}, f, indent=2)\n   688→\n   689→        print(f\"\\nH3: Workload-Spec Diagnosis ({len(h3_results)} experiments)\")\n   690→        for r in h3_results:\n   691→            if \"rate_error\" in r:\n   692→                print(f\"  {r['experiment']}: \"\n   693→                      f\"rate_err={r['rate_error']*100:.0f}%, \"\n   694→                      f\"count_err={r.get('request_count_error', 0)*100:.0f}%, \"\n   695→                      f\"dur_err={r.get('duration_error', 0)*100:.0f}%\")\n   696→            else:\n   697→                print(f\"  {r['experiment']}: no profile.yaml for comparison\")\n   698→\n   699→    print(\"\\nDone! Results written to h1-trace-replay/, h2-error-attribution/, h3-workload-diagnosis/\")\n   700→\n   701→\n   702→if __name__ == \"__main__\":\n   703→    main()\n   704→"}]},"parent_tool_use_id":null,"session_id":"5cda49b4-0eac-4d7d-a6da-e3880a46a823","uuid":"e3ebffd5-cd30-46e9-9d32-d986af4136e9","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round3-idea-3-e2e-calibration/hypotheses/h-stepml/round3/idea-1-trace-replay/run_experiment.py","content":"#!/usr/bin/env python3\n\"\"\"Round 3, Idea 1: Trace-Driven Simulation with Lifecycle Replay.\n\nRuns all three sub-hypotheses:\n  H1: Trace replay reduces TTFT error (vs workload-spec mode)\n  H2: Error attribution with trace replay (TTFT vs ITL decomposition)\n  H3: Workload-spec parameter diagnosis (which parameter is wrong)\n\nUses the legacy CSV trace path: --workload traces --workload-traces-filepath <csv>\nwith Round 2's best StepML artifacts (regime ensemble + calibrated overheads).\n\"\"\"\n\nimport csv\nimport json\nimport os\nimport subprocess\nimport sys\nimport tempfile\n\nimport yaml\n\n# ---------------------------------------------------------------------------\n# Paths\n# ---------------------------------------------------------------------------\nSCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\nREPO_ROOT = os.path.abspath(os.path.join(SCRIPT_DIR, \"..\", \"..\", \"..\", \"..\"))\nSHARED_DIR = os.path.join(SCRIPT_DIR, \"..\", \"..\", \"shared\")\n\n# The worktree is under stepml-worktrees/ — use absolute path to package root\nPACKAGE_ROOT = \"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package\"\n\n# Ground truth data in BLIS-research repo (has per_request_lifecycle_metrics.json)\nBLIS_RESEARCH_ROOT = os.path.join(PACKAGE_ROOT, \"BLIS-research\")\nGT_DATA_ROOT = os.path.join(BLIS_RESEARCH_ROOT, \"eval\", \"ground_truth\")\n\n# Round 2 best artifacts (calibrated regime ensemble)\nR2_ARTIFACTS_DIR = os.path.join(\n    BLIS_RESEARCH_ROOT,\n    \"hypotheses\", \"h-stepml\", \"round2\",\n    \"idea-2-regime-ensemble\", \"h3-secondary-method-calibration\",\n    \"output\", \"calibrated_artifacts\",\n)\n\n# Original eval data (inference-sim repo, has profile.yaml for workload-spec comparison)\nORIG_GT_ROOT = os.path.join(PACKAGE_ROOT, \"inference-sim\", \"eval\", \"ground_truth\")\n\nBINARY_PATH = os.path.join(REPO_ROOT, \"simulation_worker\")\nBLOCK_SIZE_TOKENS = 16\n\n# Model name → artifact mapping\nMODEL_ARTIFACT_MAP = {\n    \"llama-2-7b\": \"llama-2-7b_tp1_regime.json\",\n    \"llama-2-70b\": \"llama-2-70b_tp4_regime.json\",\n    \"llama-2-70b-hf\": \"llama-2-70b-hf_tp4_regime.json\",\n    \"codellama-34b\": \"codellama-34b_tp2_regime.json\",\n    \"mixtral-8x7b-v0-1\": \"mixtral-8x7b-v0-1_tp2_regime.json\",\n}\n\n# Round 2 workload-spec results (from FINDINGS_ROUND2.md / e2e_summary_regime.json)\nR2_WORKLOAD_SPEC_RESULTS = {\n    \"mean_e2e_error_pct\": 427.81,\n    \"mean_ttft_error_pct\": 31905.77,\n    \"mean_itl_error_pct\": 33.64,\n    \"experiments_below_10pct_e2e\": 1,\n}\n\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\ndef parse_experiment_dir(dirname):\n    \"\"\"Parse model, tp, workload from directory name.\"\"\"\n    import re\n    # Try new format: YYYYMMDD-HHMMSS-model-tpN-workload\n    # or old format: YYYYMMDD-model-tpN-workload\n    tp_matches = list(re.finditer(r\"-tp(\\d+)-\", dirname))\n    if not tp_matches:\n        raise ValueError(f\"Cannot parse experiment dir: {dirname}\")\n    last_tp = tp_matches[-1]\n    # Check if starts with full timestamp (YYYYMMDD-HHMMSS)\n    if re.match(r\"^\\d{8}-\\d{6}-\", dirname):\n        model = dirname[16:last_tp.start()]\n    elif re.match(r\"^\\d{8}-\", dirname):\n        model = dirname[9:last_tp.start()]\n    else:\n        model = dirname[:last_tp.start()]\n    return {\n        \"model\": model,\n        \"tp\": int(last_tp.group(1)),\n        \"workload\": dirname[last_tp.end():],\n    }\n\n\ndef load_ground_truth(experiment_dir):\n    \"\"\"Load ground-truth latency metrics.\"\"\"\n    summary_path = os.path.join(\n        experiment_dir, \"results\", \"summary_lifecycle_metrics.json\"\n    )\n    with open(summary_path) as f:\n        data = json.load(f)\n    successes = data.get(\"successes\", {})\n    latency = successes.get(\"latency\", {})\n    return {\n        \"e2e_mean_s\": latency.get(\"request_latency\", {}).get(\"mean\", 0),\n        \"ttft_mean_s\": latency.get(\"time_to_first_token\", {}).get(\"mean\", 0),\n        \"itl_mean_s\": latency.get(\"inter_token_latency\", {}).get(\"mean\", 0),\n        \"num_requests\": data.get(\"load_summary\", {}).get(\"count\", 0),\n        \"prompt_len_mean\": successes.get(\"prompt_len\", {}).get(\"mean\", 0),\n        \"output_len_mean\": successes.get(\"output_len\", {}).get(\"mean\", 0),\n        \"throughput_rps\": successes.get(\"throughput\", {}).get(\n            \"requests_per_sec\", 0\n        ),\n    }\n\n\ndef load_exp_config(experiment_dir):\n    \"\"\"Load exp-config.yaml.\"\"\"\n    config_path = os.path.join(experiment_dir, \"exp-config.yaml\")\n    with open(config_path) as f:\n        return yaml.safe_load(f)\n\n\ndef extract_kv_blocks(experiment_dir):\n    \"\"\"Extract GPU KV cache blocks from vllm.log.\"\"\"\n    import re\n    vllm_log = os.path.join(experiment_dir, \"vllm.log\")\n    if not os.path.isfile(vllm_log):\n        return None\n    pattern = re.compile(r\"GPU KV cache size:\\s+([\\d,]+)\\s+tokens\")\n    with open(vllm_log) as f:\n        for line in f:\n            m = pattern.search(line)\n            if m:\n                tokens = int(m.group(1).replace(\",\", \"\"))\n                return tokens // BLOCK_SIZE_TOKENS\n    return None\n\n\ndef extract_cpu_kv_blocks(experiment_dir):\n    \"\"\"Extract CPU KV blocks from vllm.log for tiered caching.\"\"\"\n    import re\n    vllm_log = os.path.join(experiment_dir, \"vllm.log\")\n    if not os.path.isfile(vllm_log):\n        return 0\n    cpu_bytes = None\n    kv_shape = None\n    with open(vllm_log) as f:\n        for line in f:\n            m = re.search(r\"cpu_bytes_to_use['\\\"]?:\\s*([\\d.]+)\", line)\n            if m and cpu_bytes is None:\n                cpu_bytes = float(m.group(1))\n            m = re.search(\n                r\"cross layer KV cache of shape \\((\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+)\\)\",\n                line,\n            )\n            if m and kv_shape is None:\n                kv_shape = tuple(int(m.group(i)) for i in range(1, 7))\n    if cpu_bytes is None or kv_shape is None or cpu_bytes == 0:\n        return 0\n    _, num_layers, _, block_size, num_kv_heads, head_dim = kv_shape\n    per_block_bytes = num_layers * 2 * block_size * num_kv_heads * head_dim * 2\n    return int(cpu_bytes) // per_block_bytes\n\n\ndef convert_lifecycle_to_csv(lifecycle_path, output_csv, model_name, seed=42):\n    \"\"\"Convert per_request_lifecycle_metrics.json to BLIS legacy trace CSV.\"\"\"\n    import random\n    with open(lifecycle_path) as f:\n        data = json.load(f)\n    if not data:\n        raise ValueError(f\"Empty lifecycle data: {lifecycle_path}\")\n    rng = random.Random(seed)\n    base_time = min(entry[\"start_time\"] for entry in data)\n    rows = []\n    for i, entry in enumerate(data):\n        info = entry.get(\"info\", {})\n        input_count = info.get(\"input_tokens\", 0)\n        output_count = info.get(\"output_tokens\", 0)\n        arrival_s = entry[\"start_time\"] - base_time\n        input_tokens = [rng.randint(0, 31999) for _ in range(input_count)]\n        output_tokens = [rng.randint(0, 31999) for _ in range(output_count)]\n        rows.append((arrival_s, i, model_name, input_tokens, output_tokens))\n    rows.sort(key=lambda x: x[0])\n    with open(output_csv, \"w\") as f:\n        f.write(\"arrival_time,request_id,model,prefill_tokens,decode_tokens\\n\")\n        for arrival_s, req_id, model, inp, out in rows:\n            f.write(\n                f\"{arrival_s:.6f},request_{req_id},{model},\"\n                f'\"{json.dumps(inp)}\",\"{json.dumps(out)}\"\\n'\n            )\n    return {\n        \"num_requests\": len(rows),\n        \"min_arrival_s\": rows[0][0] if rows else 0,\n        \"max_arrival_s\": rows[-1][0] if rows else 0,\n        \"duration_s\": (rows[-1][0] - rows[0][0]) if len(rows) > 1 else 0,\n        \"mean_input_tokens\": sum(len(r[3]) for r in rows) / len(rows) if rows else 0,\n        \"mean_output_tokens\": sum(len(r[4]) for r in rows) / len(rows) if rows else 0,\n    }\n\n\ndef compute_error(predicted, observed):\n    \"\"\"Relative error: |predicted - observed| / observed.\"\"\"\n    if observed == 0:\n        return float(\"inf\") if predicted != 0 else 0.0\n    return abs(predicted - observed) / observed\n\n\ndef parse_blis_stdout(stdout):\n    \"\"\"Parse BLIS JSON output from stdout.\"\"\"\n    lines = stdout.split(\"\\n\")\n    json_lines = []\n    in_json = False\n    brace_depth = 0\n    for line in lines:\n        if \"Simulation Metrics\" in line:\n            in_json = False\n            json_lines = []\n            continue\n        if not in_json and line.strip().startswith(\"{\"):\n            in_json = True\n        if in_json:\n            json_lines.append(line)\n            brace_depth += line.count(\"{\") - line.count(\"}\")\n            if brace_depth <= 0:\n                break\n    if not json_lines:\n        return None\n    try:\n        metrics = json.loads(\"\\n\".join(json_lines))\n    except json.JSONDecodeError:\n        return None\n    return {\n        \"e2e_mean_ms\": metrics.get(\"e2e_mean_ms\", 0),\n        \"ttft_mean_ms\": metrics.get(\"ttft_mean_ms\", 0),\n        \"itl_mean_ms\": metrics.get(\"itl_mean_ms\", 0),\n        \"completed_requests\": metrics.get(\"completed_requests\", 0),\n        \"tokens_per_sec\": metrics.get(\"tokens_per_sec\", 0),\n    }\n\n\ndef run_blis_trace_replay(\n    trace_csv_path, exp_config, total_kv_blocks, stepml_artifact_path,\n    horizon_us, cpu_kv_blocks=0,\n):\n    \"\"\"Run BLIS with legacy trace CSV replay + StepML artifact.\"\"\"\n    model_name = exp_config.get(\"model\", \"unknown\")\n    tp = exp_config.get(\"tensor_parallelism\", 1)\n    max_model_len = exp_config.get(\"max_model_len\", 4096)\n    max_num_seqs = exp_config.get(\"max_num_seqs\", 128)\n    max_num_batched_tokens = exp_config.get(\"max_num_batched_tokens\", 2048)\n\n    with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n        results_path = f.name\n\n    cmd = [\n        BINARY_PATH, \"run\",\n        \"--model\", model_name,\n        \"--workload\", \"traces\",\n        \"--workload-traces-filepath\", trace_csv_path,\n        \"--tp\", str(tp),\n        \"--max-model-len\", str(max_model_len),\n        \"--max-num-running-reqs\", str(max_num_seqs),\n        \"--max-num-scheduled-tokens\", str(max_num_batched_tokens),\n        \"--total-kv-blocks\", str(total_kv_blocks),\n        \"--block-size-in-tokens\", str(BLOCK_SIZE_TOKENS),\n        \"--horizon\", str(horizon_us),\n        \"--alpha-coeffs=1,0,0\",\n        \"--beta-coeffs=1,0,0\",\n        \"--stepml-model\", stepml_artifact_path,\n        \"--results-path\", results_path,\n        \"--log\", \"error\",\n    ]\n\n    if cpu_kv_blocks > 0:\n        cmd.extend([\"--kv-cpu-blocks\", str(cpu_kv_blocks)])\n\n    try:\n        result = subprocess.run(\n            cmd, capture_output=True, text=True, timeout=600,\n            cwd=os.path.dirname(BINARY_PATH),\n        )\n    except subprocess.TimeoutExpired:\n        print(\"  TIMEOUT after 600s\", file=sys.stderr)\n        return None\n    except FileNotFoundError:\n        print(f\"  Binary not found: {BINARY_PATH}\", file=sys.stderr)\n        return None\n    finally:\n        if os.path.exists(results_path):\n            os.unlink(results_path)\n\n    if result.returncode != 0:\n        print(f\"  BLIS failed (exit {result.returncode})\", file=sys.stderr)\n        print(f\"  stderr: {result.stderr[:1000]}\", file=sys.stderr)\n        return None\n\n    return parse_blis_stdout(result.stdout)\n\n\ndef load_profile_data(experiment_dir):\n    \"\"\"Load profile.yaml (JSON format) for workload-spec parameter comparison.\"\"\"\n    profile_path = os.path.join(experiment_dir, \"profile.yaml\")\n    if not os.path.isfile(profile_path):\n        return None\n    with open(profile_path) as f:\n        content = f.read()\n    try:\n        return json.loads(content)\n    except json.JSONDecodeError:\n        try:\n            return yaml.safe_load(content)\n        except yaml.YAMLError:\n            return None\n\n\ndef extract_lifecycle_stats(lifecycle_path):\n    \"\"\"Extract ground-truth workload statistics from lifecycle data.\"\"\"\n    with open(lifecycle_path) as f:\n        data = json.load(f)\n    if not data:\n        return None\n    arrivals = [e[\"start_time\"] for e in data]\n    input_tokens = [e.get(\"info\", {}).get(\"input_tokens\", 0) for e in data]\n    output_tokens = [e.get(\"info\", {}).get(\"output_tokens\", 0) for e in data]\n\n    import numpy as np\n    arrivals_arr = np.array(arrivals)\n    duration_s = arrivals_arr.max() - arrivals_arr.min()\n    arrival_rate = (len(data) - 1) / duration_s if duration_s > 0 else 0\n\n    return {\n        \"num_requests\": len(data),\n        \"duration_s\": duration_s,\n        \"arrival_rate_rps\": arrival_rate,\n        \"input_tokens_mean\": np.mean(input_tokens),\n        \"input_tokens_std\": np.std(input_tokens),\n        \"output_tokens_mean\": np.mean(output_tokens),\n        \"output_tokens_std\": np.std(output_tokens),\n    }\n\n\ndef extract_workload_spec_stats(profile):\n    \"\"\"Extract workload-spec parameters from profile.yaml.\"\"\"\n    if profile is None:\n        return None\n    load_config = profile.get(\"load\", {})\n    data = profile.get(\"data\", {})\n    sp = data.get(\"shared_prefix\", {})\n\n    stages = load_config.get(\"stages\", [])\n    if not stages:\n        return None\n\n    total_duration = sum(s[\"duration\"] for s in stages)\n    total_requests = sum(s[\"rate\"] * s[\"duration\"] for s in stages)\n    avg_rate = total_requests / total_duration if total_duration > 0 else 0\n\n    return {\n        \"num_requests\": int(total_requests),\n        \"duration_s\": total_duration,\n        \"arrival_rate_rps\": avg_rate,\n        \"question_len\": sp.get(\"question_len\", 0),\n        \"output_len\": sp.get(\"output_len\", 0),\n        \"stages\": stages,\n    }\n\n\n# ---------------------------------------------------------------------------\n# Main experiment\n# ---------------------------------------------------------------------------\ndef main():\n    print(\"=\" * 70)\n    print(\"Round 3, Idea 1: Trace-Driven Simulation with Lifecycle Replay\")\n    print(\"=\" * 70)\n\n    # Step 0: Build BLIS binary\n    if not os.path.isfile(BINARY_PATH):\n        print(\"\\nBuilding simulation_worker...\")\n        build = subprocess.run(\n            [\"go\", \"build\", \"-o\", BINARY_PATH, \"main.go\"],\n            cwd=REPO_ROOT, capture_output=True, text=True,\n        )\n        if build.returncode != 0:\n            print(f\"Build failed: {build.stderr}\", file=sys.stderr)\n            sys.exit(1)\n        print(\"  Build successful.\")\n    else:\n        print(f\"\\nUsing existing binary: {BINARY_PATH}\")\n\n    # Step 1: Discover experiments\n    if not os.path.isdir(GT_DATA_ROOT):\n        print(f\"ERROR: Ground truth data not found at {GT_DATA_ROOT}\", file=sys.stderr)\n        sys.exit(1)\n\n    experiments = []\n    for dirname in sorted(os.listdir(GT_DATA_ROOT)):\n        dirpath = os.path.join(GT_DATA_ROOT, dirname)\n        if not os.path.isdir(dirpath):\n            continue\n        lifecycle_path = os.path.join(dirpath, \"results\", \"per_request_lifecycle_metrics.json\")\n        if not os.path.isfile(lifecycle_path):\n            continue\n        try:\n            meta = parse_experiment_dir(dirname)\n        except ValueError:\n            continue\n        experiments.append({\n            \"dirname\": dirname,\n            \"dirpath\": dirpath,\n            \"meta\": meta,\n            \"lifecycle_path\": lifecycle_path,\n        })\n\n    print(f\"\\nFound {len(experiments)} experiments with lifecycle data.\")\n\n    # Step 2: Run BLIS with trace replay for each experiment\n    h1_results = []\n    h2_results = []\n    h3_results = []\n\n    with tempfile.TemporaryDirectory() as tmpdir:\n        for exp in experiments:\n            dirname = exp[\"dirname\"]\n            dirpath = exp[\"dirpath\"]\n            meta = exp[\"meta\"]\n            model = meta[\"model\"]\n            workload = meta[\"workload\"]\n\n            print(f\"\\n{'=' * 60}\")\n            print(f\"Experiment: {dirname}\")\n            print(f\"  Model: {model}, TP: {meta['tp']}, Workload: {workload}\")\n            print(f\"{'=' * 60}\")\n\n            # Load ground truth\n            gt = load_ground_truth(dirpath)\n            print(f\"  GT: E2E={gt['e2e_mean_s']*1000:.1f}ms, \"\n                  f\"TTFT={gt['ttft_mean_s']*1000:.1f}ms, \"\n                  f\"ITL={gt['itl_mean_s']*1000:.2f}ms, \"\n                  f\"N={gt['num_requests']}\")\n\n            # Load experiment config\n            exp_config = load_exp_config(dirpath)\n\n            # Extract KV blocks\n            total_kv_blocks = extract_kv_blocks(dirpath)\n            if total_kv_blocks is None:\n                print(\"  SKIP: Cannot parse KV blocks\", file=sys.stderr)\n                continue\n            cpu_kv_blocks = extract_cpu_kv_blocks(dirpath)\n            print(f\"  KV blocks: {total_kv_blocks} GPU + {cpu_kv_blocks} CPU\")\n\n            # Find StepML artifact for this model\n            artifact_file = MODEL_ARTIFACT_MAP.get(model)\n            if artifact_file is None:\n                print(f\"  SKIP: No artifact for model '{model}'\", file=sys.stderr)\n                continue\n            artifact_path = os.path.join(R2_ARTIFACTS_DIR, artifact_file)\n            if not os.path.isfile(artifact_path):\n                print(f\"  SKIP: Artifact not found: {artifact_path}\", file=sys.stderr)\n                continue\n            print(f\"  Artifact: {artifact_file}\")\n\n            # Convert lifecycle data to trace CSV\n            csv_path = os.path.join(tmpdir, f\"{dirname}.csv\")\n            trace_stats = convert_lifecycle_to_csv(\n                exp[\"lifecycle_path\"], csv_path,\n                model_name=exp_config.get(\"model\", model),\n            )\n            print(f\"  Trace: {trace_stats['num_requests']} requests, \"\n                  f\"{trace_stats['duration_s']:.1f}s duration, \"\n                  f\"mean input={trace_stats['mean_input_tokens']:.0f}, \"\n                  f\"mean output={trace_stats['mean_output_tokens']:.0f}\")\n\n            # Set horizon: trace duration + 120s buffer (in microseconds)\n            horizon_us = int((trace_stats[\"duration_s\"] + 120) * 1_000_000)\n\n            # Run BLIS with trace replay\n            blis = run_blis_trace_replay(\n                trace_csv_path=csv_path,\n                exp_config=exp_config,\n                total_kv_blocks=total_kv_blocks,\n                stepml_artifact_path=artifact_path,\n                horizon_us=horizon_us,\n                cpu_kv_blocks=cpu_kv_blocks,\n            )\n\n            if blis is None:\n                print(\"  BLIS run failed!\")\n                h1_results.append({\n                    \"experiment\": dirname, \"model\": model,\n                    \"workload\": workload, \"tp\": meta[\"tp\"],\n                    \"status\": \"blis_failed\",\n                })\n                continue\n\n            # Compute errors\n            e2e_err = compute_error(blis[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n            ttft_err = compute_error(blis[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000)\n            itl_err = compute_error(blis[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n\n            print(f\"  BLIS: E2E={blis['e2e_mean_ms']:.1f}ms, \"\n                  f\"TTFT={blis['ttft_mean_ms']:.1f}ms, \"\n                  f\"ITL={blis['itl_mean_ms']:.2f}ms, \"\n                  f\"completed={blis['completed_requests']}\")\n            print(f\"  Errors: E2E={e2e_err*100:.1f}%, \"\n                  f\"TTFT={ttft_err*100:.1f}%, \"\n                  f\"ITL={itl_err*100:.1f}%\")\n\n            row = {\n                \"experiment\": dirname,\n                \"model\": model,\n                \"workload\": workload,\n                \"tp\": meta[\"tp\"],\n                \"status\": \"ok\",\n                \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n                \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n                \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n                \"gt_requests\": gt[\"num_requests\"],\n                \"blis_e2e_ms\": blis[\"e2e_mean_ms\"],\n                \"blis_ttft_ms\": blis[\"ttft_mean_ms\"],\n                \"blis_itl_ms\": blis[\"itl_mean_ms\"],\n                \"blis_completed\": blis[\"completed_requests\"],\n                \"e2e_error\": e2e_err,\n                \"ttft_error\": ttft_err,\n                \"itl_error\": itl_err,\n            }\n            h1_results.append(row)\n\n            # H2: Error attribution\n            if row[\"status\"] == \"ok\":\n                h2_row = dict(row)\n                # Decompose: is E2E error TTFT-dominated or ITL-dominated?\n                h2_row[\"ttft_contribution_ms\"] = blis[\"ttft_mean_ms\"] - gt[\"ttft_mean_s\"] * 1000\n                itl_contribution_ms = (\n                    (blis[\"itl_mean_ms\"] - gt[\"itl_mean_s\"] * 1000) *\n                    gt.get(\"output_len_mean\", 0)\n                )\n                h2_row[\"itl_contribution_ms\"] = itl_contribution_ms\n                h2_row[\"ttft_abs_error_ms\"] = abs(blis[\"ttft_mean_ms\"] - gt[\"ttft_mean_s\"] * 1000)\n                h2_row[\"itl_abs_error_ms\"] = abs(blis[\"itl_mean_ms\"] - gt[\"itl_mean_s\"] * 1000)\n                h2_results.append(h2_row)\n\n            # H3: Workload-spec parameter diagnosis\n            lifecycle_stats = extract_lifecycle_stats(exp[\"lifecycle_path\"])\n            # Try to load profile from original eval directory\n            orig_exp_dir = os.path.join(ORIG_GT_ROOT, dirname) if ORIG_GT_ROOT else None\n            profile = None\n            if orig_exp_dir and os.path.isdir(orig_exp_dir):\n                profile = load_profile_data(orig_exp_dir)\n            # Also try BLIS-research ground truth\n            if profile is None:\n                profile = load_profile_data(dirpath)\n\n            spec_stats = extract_workload_spec_stats(profile) if profile else None\n\n            h3_row = {\n                \"experiment\": dirname,\n                \"model\": model,\n                \"workload\": workload,\n            }\n            if lifecycle_stats:\n                h3_row[\"gt_num_requests\"] = lifecycle_stats[\"num_requests\"]\n                h3_row[\"gt_duration_s\"] = lifecycle_stats[\"duration_s\"]\n                h3_row[\"gt_arrival_rate_rps\"] = lifecycle_stats[\"arrival_rate_rps\"]\n                h3_row[\"gt_input_mean\"] = lifecycle_stats[\"input_tokens_mean\"]\n                h3_row[\"gt_output_mean\"] = lifecycle_stats[\"output_tokens_mean\"]\n\n            if spec_stats:\n                h3_row[\"spec_num_requests\"] = spec_stats[\"num_requests\"]\n                h3_row[\"spec_duration_s\"] = spec_stats[\"duration_s\"]\n                h3_row[\"spec_arrival_rate_rps\"] = spec_stats[\"arrival_rate_rps\"]\n                h3_row[\"spec_question_len\"] = spec_stats[\"question_len\"]\n                h3_row[\"spec_output_len\"] = spec_stats[\"output_len\"]\n\n                # Compute relative errors on each parameter\n                if lifecycle_stats:\n                    gt_rate = lifecycle_stats[\"arrival_rate_rps\"]\n                    sp_rate = spec_stats[\"arrival_rate_rps\"]\n                    h3_row[\"rate_error\"] = compute_error(sp_rate, gt_rate)\n\n                    h3_row[\"request_count_error\"] = compute_error(\n                        spec_stats[\"num_requests\"], lifecycle_stats[\"num_requests\"]\n                    )\n                    h3_row[\"duration_error\"] = compute_error(\n                        spec_stats[\"duration_s\"], lifecycle_stats[\"duration_s\"]\n                    )\n            else:\n                h3_row[\"spec_status\"] = \"no_profile\"\n\n            h3_results.append(h3_row)\n\n    # ---------------------------------------------------------------------------\n    # Write results\n    # ---------------------------------------------------------------------------\n    print(\"\\n\" + \"=\" * 70)\n    print(\"RESULTS SUMMARY\")\n    print(\"=\" * 70)\n\n    # H1 summary\n    ok_results = [r for r in h1_results if r.get(\"status\") == \"ok\"]\n    h1_output_dir = os.path.join(SCRIPT_DIR, \"h1-trace-replay\")\n    os.makedirs(h1_output_dir, exist_ok=True)\n\n    if ok_results:\n        e2e_errors = [r[\"e2e_error\"] for r in ok_results]\n        ttft_errors = [r[\"ttft_error\"] for r in ok_results]\n        itl_errors = [r[\"itl_error\"] for r in ok_results]\n\n        mean_e2e = sum(e2e_errors) / len(e2e_errors) * 100\n        mean_ttft = sum(ttft_errors) / len(ttft_errors) * 100\n        mean_itl = sum(itl_errors) / len(itl_errors) * 100\n        e2e_under_10 = sum(1 for e in e2e_errors if e < 0.10)\n\n        print(f\"\\nH1: Trace Replay Results ({len(ok_results)} experiments)\")\n        print(f\"  Mean E2E  error: {mean_e2e:.1f}% (was {R2_WORKLOAD_SPEC_RESULTS['mean_e2e_error_pct']:.1f}% with workload-spec)\")\n        print(f\"  Mean TTFT error: {mean_ttft:.1f}% (was {R2_WORKLOAD_SPEC_RESULTS['mean_ttft_error_pct']:.1f}% with workload-spec)\")\n        print(f\"  Mean ITL  error: {mean_itl:.1f}% (was {R2_WORKLOAD_SPEC_RESULTS['mean_itl_error_pct']:.1f}% with workload-spec)\")\n        print(f\"  E2E < 10%: {e2e_under_10}/{len(ok_results)}\")\n\n        # Write CSV\n        csv_path = os.path.join(h1_output_dir, \"trace_replay_results.csv\")\n        fieldnames = sorted(set().union(*(r.keys() for r in h1_results)))\n        with open(csv_path, \"w\", newline=\"\") as f:\n            writer = csv.DictWriter(f, fieldnames=fieldnames)\n            writer.writeheader()\n            writer.writerows(h1_results)\n\n        # Write summary JSON\n        summary = {\n            \"n_experiments\": len(ok_results),\n            \"n_failed\": len(h1_results) - len(ok_results),\n            \"mean_e2e_error_pct\": mean_e2e,\n            \"mean_ttft_error_pct\": mean_ttft,\n            \"mean_itl_error_pct\": mean_itl,\n            \"e2e_under_10pct\": e2e_under_10,\n            \"r2_comparison\": R2_WORKLOAD_SPEC_RESULTS,\n            \"e2e_reduction_factor\": R2_WORKLOAD_SPEC_RESULTS[\"mean_e2e_error_pct\"] / mean_e2e if mean_e2e > 0 else float(\"inf\"),\n            \"ttft_reduction_factor\": R2_WORKLOAD_SPEC_RESULTS[\"mean_ttft_error_pct\"] / mean_ttft if mean_ttft > 0 else float(\"inf\"),\n            \"per_experiment\": ok_results,\n        }\n        with open(os.path.join(h1_output_dir, \"summary.json\"), \"w\") as f:\n            json.dump(summary, f, indent=2)\n\n    # H2 summary\n    h2_output_dir = os.path.join(SCRIPT_DIR, \"h2-error-attribution\")\n    os.makedirs(h2_output_dir, exist_ok=True)\n    if h2_results:\n        csv_path = os.path.join(h2_output_dir, \"error_attribution.csv\")\n        fieldnames = sorted(set().union(*(r.keys() for r in h2_results)))\n        with open(csv_path, \"w\", newline=\"\") as f:\n            writer = csv.DictWriter(f, fieldnames=fieldnames)\n            writer.writeheader()\n            writer.writerows(h2_results)\n\n        e2e_errors = [r[\"e2e_error\"] for r in h2_results]\n        mean_e2e_h2 = sum(e2e_errors) / len(e2e_errors) * 100\n        under_10 = sum(1 for e in e2e_errors if e < 0.10)\n        under_25 = sum(1 for e in e2e_errors if e < 0.25)\n\n        summary_h2 = {\n            \"n_experiments\": len(h2_results),\n            \"mean_e2e_error_pct\": mean_e2e_h2,\n            \"e2e_under_10pct\": under_10,\n            \"e2e_under_25pct\": under_25,\n            \"per_experiment\": h2_results,\n        }\n        with open(os.path.join(h2_output_dir, \"summary.json\"), \"w\") as f:\n            json.dump(summary_h2, f, indent=2)\n\n        print(f\"\\nH2: Error Attribution ({len(h2_results)} experiments)\")\n        print(f\"  Mean E2E error with trace replay: {mean_e2e_h2:.1f}%\")\n        print(f\"  E2E < 10%: {under_10}/{len(h2_results)}\")\n        print(f\"  E2E < 25%: {under_25}/{len(h2_results)}\")\n\n    # H3 summary\n    h3_output_dir = os.path.join(SCRIPT_DIR, \"h3-workload-diagnosis\")\n    os.makedirs(h3_output_dir, exist_ok=True)\n    if h3_results:\n        csv_path = os.path.join(h3_output_dir, \"workload_diagnosis.csv\")\n        fieldnames = sorted(set().union(*(r.keys() for r in h3_results)))\n        with open(csv_path, \"w\", newline=\"\") as f:\n            writer = csv.DictWriter(f, fieldnames=fieldnames)\n            writer.writeheader()\n            writer.writerows(h3_results)\n\n        with open(os.path.join(h3_output_dir, \"summary.json\"), \"w\") as f:\n            json.dump({\"per_experiment\": h3_results}, f, indent=2)\n\n        print(f\"\\nH3: Workload-Spec Diagnosis ({len(h3_results)} experiments)\")\n        for r in h3_results:\n            if \"rate_error\" in r:\n                print(f\"  {r['experiment']}: \"\n                      f\"rate_err={r['rate_error']*100:.0f}%, \"\n                      f\"count_err={r.get('request_count_error', 0)*100:.0f}%, \"\n                      f\"dur_err={r.get('duration_error', 0)*100:.0f}%\")\n            else:\n                print(f\"  {r['experiment']}: no profile.yaml for comparison\")\n\n    print(\"\\nDone! Results written to h1-trace-replay/, h2-error-attribution/, h3-workload-diagnosis/\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":704,"startLine":1,"totalLines":704}}}
