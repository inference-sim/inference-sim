\"train_mape\": 24.12545456050223,\n      \"train_mspe\": 10.598333136654226,\n      \"train_r\": 0.6241549029307345\n    }\n  },\n  \"e2e_validation\": {\n    \"mean_e2e_error_pct\": 99.37622247041648,\n    \"mean_ttft_error_pct\": 98.899849284533,\n    \"mean_itl_error_pct\": 98.76040372648576,\n    \"experiments_below_10pct\": 0,\n    \"total_experiments\": 10\n  },\n  \"r4_gate\": {\n    \"passed\": true,\n    \"e2e_error\": 99.37622247041648,\n    \"message\": \"R4 gate passed: blackbox E2E mean error = 99.4% (|error| >= 12%). Step-level ML improvement is justified.\"\n  }\n}","numLines":56,"startLine":1,"totalLines":56}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01KSDDp9Xj4dTD3ztiusoyK7","type":"tool_result","content":"     1→// Package latency — StepML latency model.\n     2→//\n     3→// StepMLLatencyModel is a data-driven LatencyModel that loads trained model\n     4→// artifacts from a JSON file. It supports linear coefficient models and\n     5→// (future) XGBoost tree ensembles.\n     6→//\n     7→// This is the lightweight research-phase implementation (WP0). Production\n     8→// quality with full INV-M-1 through INV-M-6 validation comes in WP5.\n     9→package latency\n    10→\n    11→import (\n    12→\t\"encoding/json\"\n    13→\t\"fmt\"\n    14→\t\"math\"\n    15→\t\"os\"\n    16→\n    17→\t\"github.com/inference-sim/inference-sim/sim\"\n    18→\t\"github.com/inference-sim/inference-sim/sim/internal/util\"\n    19→)\n    20→\n    21→// StepMLArtifact is the top-level JSON schema for a StepML model artifact.\n    22→type StepMLArtifact struct {\n    23→\tVersion                      int              `json:\"version\"`\n    24→\tStepTime                     *LinearModel     `json:\"step_time\"`\n    25→\tStepTimeRegimes              []RegimeEntry    `json:\"step_time_regimes,omitempty\"`\n    26→\tQueueingTime                 *LinearModel     `json:\"queueing_time,omitempty\"`\n    27→\tStepOverheadUs               float64          `json:\"step_overhead_us\"`\n    28→\tStepOverheadPerReqUs         float64          `json:\"step_overhead_per_req_us\"`\n    29→\tOutputTokenProcessingTimeUs  float64          `json:\"output_token_processing_time_us\"`\n    30→\tSchedulingProcessingTimeUs   float64          `json:\"scheduling_processing_time_us\"`\n    31→\tPreemptionProcessingTimeUs   float64          `json:\"preemption_processing_time_us\"`\n    32→}\n    33→\n    34→// LinearModel represents a linear prediction model: intercept + Σ(coeff_i * feature_i).\n    35→// When OutputTransform is \"expm1\", the prediction is exponentiated: exp(linear) - 1.\n    36→// This supports log-linear models trained on log1p(target).\n    37→type LinearModel struct {\n    38→\tModelType           string             `json:\"model_type\"`\n    39→\tIntercept           float64            `json:\"intercept\"`\n    40→\tFeatureCoefficients map[string]float64 `json:\"feature_coefficients\"`\n    41→\tOutputTransform     string             `json:\"output_transform,omitempty\"`\n    42→}\n    43→\n    44→// RegimeEntry pairs a condition with a linear model for regime-based dispatch.\n    45→// Regimes are evaluated in order; the first matching condition wins.\n    46→// A nil Condition acts as a fallback (matches everything).\n    47→type RegimeEntry struct {\n    48→\tName      string          `json:\"name\"`\n    49→\tCondition *RegimeCondition `json:\"condition\"`\n    50→\tModel     LinearModel     `json:\"model\"`\n    51→}\n    52→\n    53→// RegimeCondition is a simple threshold condition on a batch feature.\n    54→type RegimeCondition struct {\n    55→\tFeature string  `json:\"feature\"`\n    56→\tOp      string  `json:\"op\"` // \"==\", \"<\", \"<=\", \">\", \">=\"\n    57→\tValue   float64 `json:\"value\"`\n    58→}\n    59→\n    60→// StepMLLatencyModel implements sim.LatencyModel using trained artifacts.\n    61→type StepMLLatencyModel struct {\n    62→\tartifact StepMLArtifact\n    63→}\n    64→\n    65→// LoadStepMLArtifact reads and validates a StepML JSON artifact from disk.\n    66→func LoadStepMLArtifact(path string) (*StepMLArtifact, error) {\n    67→\tdata, err := os.ReadFile(path)\n    68→\tif err != nil {\n    69→\t\treturn nil, fmt.Errorf(\"stepml: read artifact %q: %w\", path, err)\n    70→\t}\n    71→\n    72→\tvar art StepMLArtifact\n    73→\tif err := json.Unmarshal(data, &art); err != nil {\n    74→\t\treturn nil, fmt.Errorf(\"stepml: parse artifact %q: %w\", path, err)\n    75→\t}\n    76→\n    77→\tif art.Version < 1 {\n    78→\t\treturn nil, fmt.Errorf(\"stepml: unsupported artifact version %d\", art.Version)\n    79→\t}\n    80→\n    81→\thasRegimes := len(art.StepTimeRegimes) > 0\n    82→\thasSingleModel := art.StepTime != nil\n    83→\n    84→\tif !hasRegimes && !hasSingleModel {\n    85→\t\treturn nil, fmt.Errorf(\"stepml: artifact missing step_time model (provide step_time or step_time_regimes)\")\n    86→\t}\n    87→\n    88→\tif hasSingleModel {\n    89→\t\tif art.StepTime.ModelType != \"linear\" {\n    90→\t\t\treturn nil, fmt.Errorf(\"stepml: unsupported step_time model_type %q (supported: linear)\", art.StepTime.ModelType)\n    91→\t\t}\n    92→\t\tif err := validateLinearModel(\"step_time\", art.StepTime); err != nil {\n    93→\t\t\treturn nil, err\n    94→\t\t}\n    95→\t}\n    96→\n    97→\tfor i, r := range art.StepTimeRegimes {\n    98→\t\tname := fmt.Sprintf(\"step_time_regimes[%d](%s)\", i, r.Name)\n    99→\t\tif err := validateLinearModel(name, &r.Model); err != nil {\n   100→\t\t\treturn nil, err\n   101→\t\t}\n   102→\t\tif r.Condition != nil {\n   103→\t\t\tswitch r.Condition.Op {\n   104→\t\t\tcase \"==\", \"<\", \"<=\", \">\", \">=\":\n   105→\t\t\t\t// valid\n   106→\t\t\tdefault:\n   107→\t\t\t\treturn nil, fmt.Errorf(\"stepml: %s has unsupported condition op %q\", name, r.Condition.Op)\n   108→\t\t\t}\n   109→\t\t}\n   110→\t}\n   111→\n   112→\tif art.QueueingTime != nil {\n   113→\t\tif err := validateLinearModel(\"queueing_time\", art.QueueingTime); err != nil {\n   114→\t\t\treturn nil, err\n   115→\t\t}\n   116→\t}\n   117→\n   118→\treturn &art, nil\n   119→}\n   120→\n   121→func validateLinearModel(name string, m *LinearModel) error {\n   122→\tif math.IsNaN(m.Intercept) || math.IsInf(m.Intercept, 0) {\n   123→\t\treturn fmt.Errorf(\"stepml: %s intercept is NaN/Inf\", name)\n   124→\t}\n   125→\tfor feat, coeff := range m.FeatureCoefficients {\n   126→\t\tif math.IsNaN(coeff) || math.IsInf(coeff, 0) {\n   127→\t\t\treturn fmt.Errorf(\"stepml: %s coefficient %q is NaN/Inf\", name, feat)\n   128→\t\t}\n   129→\t}\n   130→\treturn nil\n   131→}\n   132→\n   133→// NewStepMLLatencyModel creates a StepML LatencyModel from a loaded artifact.\n   134→func NewStepMLLatencyModel(art *StepMLArtifact) *StepMLLatencyModel {\n   135→\treturn &StepMLLatencyModel{artifact: *art}\n   136→}\n   137→\n   138→// extractBatchFeatures computes aggregate features from a batch of requests.\n   139→// These features mirror the ground-truth step-level data schema.\n   140→func extractBatchFeatures(batch []*sim.Request) map[string]float64 {\n   141→\tvar prefillTokens, decodeTokens int64\n   142→\tvar numPrefillReqs, numDecodeReqs int64\n   143→\tvar kvSum, kvMax int64\n   144→\tvar kvCount int64\n   145→\tvar kvSumSq float64 // for kv_std computation\n   146→\n   147→\tfor _, req := range batch {\n   148→\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n   149→\t\t\t// Prefill phase\n   150→\t\t\tprefillTokens += int64(req.NumNewTokens)\n   151→\t\t\tnumPrefillReqs++\n   152→\t\t} else if len(req.OutputTokens) > 0 {\n   153→\t\t\t// Decode phase\n   154→\t\t\tdecodeTokens += int64(req.NumNewTokens)\n   155→\t\t\tnumDecodeReqs++\n   156→\t\t}\n   157→\n   158→\t\t// KV cache proxy features from ProgressIndex\n   159→\t\tpi := req.ProgressIndex\n   160→\t\tkvSum += pi\n   161→\t\tkvSumSq += float64(pi) * float64(pi)\n   162→\t\tkvCount++\n   163→\t\tif pi > kvMax {\n   164→\t\t\tkvMax = pi\n   165→\t\t}\n   166→\t}\n   167→\n   168→\tvar kvMean, kvStd float64\n   169→\tif kvCount > 0 {\n   170→\t\tkvMean = float64(kvSum) / float64(kvCount)\n   171→\t\tif kvCount > 1 {\n   172→\t\t\t// Population std: sqrt(E[X^2] - E[X]^2)\n   173→\t\t\tvariance := kvSumSq/float64(kvCount) - kvMean*kvMean\n   174→\t\t\tif variance > 0 {\n   175→\t\t\t\tkvStd = math.Sqrt(variance)\n   176→\t\t\t}\n   177→\t\t}\n   178→\t}\n   179→\n   180→\tpf := float64(prefillTokens)\n   181→\tdt := float64(decodeTokens)\n   182→\tndr := float64(numDecodeReqs)\n   183→\n   184→\treturn map[string]float64{\n   185→\t\t\"prefill_tokens\":   pf,\n   186→\t\t\"decode_tokens\":    dt,\n   187→\t\t\"num_prefill_reqs\": float64(numPrefillReqs),\n   188→\t\t\"num_decode_reqs\":  ndr,\n   189→\t\t\"scheduled_tokens\": pf + dt,\n   190→\t\t\"kv_sum\":           float64(kvSum),\n   191→\t\t\"kv_max\":           float64(kvMax),\n   192→\t\t\"kv_mean\":          kvMean,\n   193→\t\t\"kv_std\":           kvStd,\n   194→\t\t// Interaction features for regime-specific models\n   195→\t\t\"prefill_x_decode\":  pf * dt,\n   196→\t\t\"decode_x_kv_mean\":  ndr * kvMean,\n   197→\t\t\"prefill_sq\":        pf * pf,\n   198→\t}\n   199→}\n   200→\n   201→// predictLinear evaluates intercept + Σ(coeff_i * features[i]).\n   202→// Features not present in the coefficient map are ignored (zero contribution).\n   203→// When OutputTransform is \"expm1\", applies exp(result) - 1 (inverse of log1p).\n   204→func predictLinear(m *LinearModel, features map[string]float64) float64 {\n   205→\tresult := m.Intercept\n   206→\tfor feat, coeff := range m.FeatureCoefficients {\n   207→\t\tif val, ok := features[feat]; ok {\n   208→\t\t\tresult += coeff * val\n   209→\t\t}\n   210→\t}\n   211→\tif m.OutputTransform == \"expm1\" {\n   212→\t\tresult = math.Expm1(result) // exp(result) - 1\n   213→\t}\n   214→\treturn result\n   215→}\n   216→\n   217→// StepTime estimates batch step execution time in microseconds.\n   218→//\n   219→// The model predicts GPU compute time from batch features. Since the training\n   220→// data only captures GPU forward pass time (step.duration_us), the full step\n   221→// cycle time also includes CPU-side overhead (scheduling, sync, memory management).\n   222→//\n   223→// The overhead is applied as a floor (max) rather than additive because:\n   224→//   - Small batches: overhead-dominated (~4ms); compute is negligible (~100µs)\n   225→//   - Large batches: compute-dominated (~6ms); overhead is negligible\n   226→//   - The transition is at the memory↔compute bound crossover point\n   227→//\n   228→// step_overhead_per_req_us is additive (per-request scheduling cost).\n   229→//\n   230→// When StepTimeRegimes is present, evaluates regimes in order; first match wins.\n   231→// Otherwise falls back to the single StepTime linear model.\n   232→func (s *StepMLLatencyModel) StepTime(batch []*sim.Request) int64 {\n   233→\tfeatures := extractBatchFeatures(batch)\n   234→\n   235→\tvar prediction float64\n   236→\tif len(s.artifact.StepTimeRegimes) > 0 {\n   237→\t\tprediction = s.predictRegime(features)\n   238→\t} else {\n   239→\t\tprediction = predictLinear(s.artifact.StepTime, features)\n   240→\t}\n   241→\n   242→\t// Apply overhead as a floor: step_cycle = max(overhead, compute).\n   243→\t// This models the memory↔compute crossover: at small batches the overhead\n   244→\t// floor dominates; at large batches, compute exceeds the floor naturally.\n   245→\t//\n   246→\t// Also cap at 5x overhead to prevent exponential blowup from the expm1\n   247→\t// transform on outlier feature values. 5x covers the realistic range\n   248→\t// (e.g., 4ms overhead → 20ms cap, well above any real step time).\n   249→\tif s.artifact.StepOverheadUs > 0 {\n   250→\t\tif prediction < s.artifact.StepOverheadUs {\n   251→\t\t\tprediction = s.artifact.StepOverheadUs\n   252→\t\t}\n   253→\t\tmaxStep := s.artifact.StepOverheadUs * 3\n   254→\t\tif prediction > maxStep {\n   255→\t\t\tprediction = maxStep\n   256→\t\t}\n   257→\t}\n   258→\n   259→\t// Per-request overhead is always additive (scheduling cost per request).\n   260→\tif s.artifact.StepOverheadPerReqUs > 0 {\n   261→\t\tbatchSize := features[\"num_prefill_reqs\"] + features[\"num_decode_reqs\"]\n   262→\t\tprediction += s.artifact.StepOverheadPerReqUs * batchSize\n   263→\t}\n   264→\n   265→\tif prediction < 1 {\n   266→\t\tprediction = 1 // INV-M-1: positive predictions\n   267→\t}\n   268→\treturn int64(prediction)\n   269→}\n   270→\n   271→// predictRegime evaluates regime conditions in order and uses the first matching model.\n   272→func (s *StepMLLatencyModel) predictRegime(features map[string]float64) float64 {\n   273→\tfor _, r := range s.artifact.StepTimeRegimes {\n   274→\t\tif r.Condition == nil || evalCondition(r.Condition, features) {\n   275→\t\t\treturn predictLinear(&r.Model, features)\n   276→\t\t}\n   277→\t}\n   278→\t// No regime matched and no fallback — use single model if available\n   279→\tif s.artifact.StepTime != nil {\n   280→\t\treturn predictLinear(s.artifact.StepTime, features)\n   281→\t}\n   282→\treturn 1 // safety fallback\n   283→}\n   284→\n   285→// evalCondition checks a simple threshold condition against feature values.\n   286→func evalCondition(c *RegimeCondition, features map[string]float64) bool {\n   287→\tval := features[c.Feature]\n   288→\tswitch c.Op {\n   289→\tcase \"==\":\n   290→\t\treturn val == c.Value\n   291→\tcase \"<\":\n   292→\t\treturn val < c.Value\n   293→\tcase \"<=\":\n   294→\t\treturn val <= c.Value\n   295→\tcase \">\":\n   296→\t\treturn val > c.Value\n   297→\tcase \">=\":\n   298→\t\treturn val >= c.Value\n   299→\tdefault:\n   300→\t\treturn false\n   301→\t}\n   302→}\n   303→\n   304→// QueueingTime estimates arrival-to-queue delay for a request in microseconds.\n   305→func (s *StepMLLatencyModel) QueueingTime(req *sim.Request) int64 {\n   306→\tif s.artifact.QueueingTime == nil {\n   307→\t\treturn 0\n   308→\t}\n   309→\tfeatures := map[string]float64{\n   310→\t\t\"input_len\": float64(len(req.InputTokens)),\n   311→\t}\n   312→\tprediction := predictLinear(s.artifact.QueueingTime, features)\n   313→\tif prediction < 0 {\n   314→\t\tprediction = 0\n   315→\t}\n   316→\treturn int64(prediction)\n   317→}\n   318→\n   319→// OutputTokenProcessingTime estimates per-token post-processing in microseconds.\n   320→func (s *StepMLLatencyModel) OutputTokenProcessingTime() int64 {\n   321→\tv := s.artifact.OutputTokenProcessingTimeUs\n   322→\tif v < 0 {\n   323→\t\treturn 0\n   324→\t}\n   325→\treturn int64(v)\n   326→}\n   327→\n   328→// SchedulingProcessingTime estimates scheduling overhead per request in microseconds.\n   329→func (s *StepMLLatencyModel) SchedulingProcessingTime() int64 {\n   330→\tv := s.artifact.SchedulingProcessingTimeUs\n   331→\tif v < 0 {\n   332→\t\treturn 0\n   333→\t}\n   334→\treturn int64(v)\n   335→}\n   336→\n   337→// PreemptionProcessingTime estimates preemption overhead per eviction in microseconds.\n   338→func (s *StepMLLatencyModel) PreemptionProcessingTime() int64 {\n   339→\tv := s.artifact.PreemptionProcessingTimeUs\n   340→\tif v < 0 {\n   341→\t\treturn 0\n   342→\t}\n   343→\treturn int64(v)\n   344→}\n   345→"}]},"parent_tool_use_id":null,"session_id":"5cda49b4-0eac-4d7d-a6da-e3880a46a823","uuid":"acd472d1-8312-48ec-92f5-ada903e8e153","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round3-idea-3-e2e-calibration/sim/latency/stepml.go","content":"// Package latency — StepML latency model.\n//\n// StepMLLatencyModel is a data-driven LatencyModel that loads trained model\n// artifacts from a JSON file. It supports linear coefficient models and\n// (future) XGBoost tree ensembles.\n//\n// This is the lightweight research-phase implementation (WP0). Production\n// quality with full INV-M-1 through INV-M-6 validation comes in WP5.\npackage latency\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"math\"\n\t\"os\"\n\n\t\"github.com/inference-sim/inference-sim/sim\"\n\t\"github.com/inference-sim/inference-sim/sim/internal/util\"\n)\n\n// StepMLArtifact is the top-level JSON schema for a StepML model artifact.\ntype StepMLArtifact struct {\n\tVersion                      int              `json:\"version\"`\n\tStepTime                     *LinearModel     `json:\"step_time\"`\n\tStepTimeRegimes              []RegimeEntry    `json:\"step_time_regimes,omitempty\"`\n\tQueueingTime                 *LinearModel     `json:\"queueing_time,omitempty\"`\n\tStepOverheadUs               float64          `json:\"step_overhead_us\"`\n\tStepOverheadPerReqUs         float64          `json:\"step_overhead_per_req_us\"`\n\tOutputTokenProcessingTimeUs  float64          `json:\"output_token_processing_time_us\"`\n\tSchedulingProcessingTimeUs   float64          `json:\"scheduling_processing_time_us\"`\n\tPreemptionProcessingTimeUs   float64          `json:\"preemption_processing_time_us\"`\n}\n\n// LinearModel represents a linear prediction model: intercept + Σ(coeff_i * feature_i).\n// When OutputTransform is \"expm1\", the prediction is exponentiated: exp(linear) - 1.\n// This supports log-linear models trained on log1p(target).\ntype LinearModel struct {\n\tModelType           string             `json:\"model_type\"`\n\tIntercept           float64            `json:\"intercept\"`\n\tFeatureCoefficients map[string]float64 `json:\"feature_coefficients\"`\n\tOutputTransform     string             `json:\"output_transform,omitempty\"`\n}\n\n// RegimeEntry pairs a condition with a linear model for regime-based dispatch.\n// Regimes are evaluated in order; the first matching condition wins.\n// A nil Condition acts as a fallback (matches everything).\ntype RegimeEntry struct {\n\tName      string          `json:\"name\"`\n\tCondition *RegimeCondition `json:\"condition\"`\n\tModel     LinearModel     `json:\"model\"`\n}\n\n// RegimeCondition is a simple threshold condition on a batch feature.\ntype RegimeCondition struct {\n\tFeature string  `json:\"feature\"`\n\tOp      string  `json:\"op\"` // \"==\", \"<\", \"<=\", \">\", \">=\"\n\tValue   float64 `json:\"value\"`\n}\n\n// StepMLLatencyModel implements sim.LatencyModel using trained artifacts.\ntype StepMLLatencyModel struct {\n\tartifact StepMLArtifact\n}\n\n// LoadStepMLArtifact reads and validates a StepML JSON artifact from disk.\nfunc LoadStepMLArtifact(path string) (*StepMLArtifact, error) {\n\tdata, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"stepml: read artifact %q: %w\", path, err)\n\t}\n\n\tvar art StepMLArtifact\n\tif err := json.Unmarshal(data, &art); err != nil {\n\t\treturn nil, fmt.Errorf(\"stepml: parse artifact %q: %w\", path, err)\n\t}\n\n\tif art.Version < 1 {\n\t\treturn nil, fmt.Errorf(\"stepml: unsupported artifact version %d\", art.Version)\n\t}\n\n\thasRegimes := len(art.StepTimeRegimes) > 0\n\thasSingleModel := art.StepTime != nil\n\n\tif !hasRegimes && !hasSingleModel {\n\t\treturn nil, fmt.Errorf(\"stepml: artifact missing step_time model (provide step_time or step_time_regimes)\")\n\t}\n\n\tif hasSingleModel {\n\t\tif art.StepTime.ModelType != \"linear\" {\n\t\t\treturn nil, fmt.Errorf(\"stepml: unsupported step_time model_type %q (supported: linear)\", art.StepTime.ModelType)\n\t\t}\n\t\tif err := validateLinearModel(\"step_time\", art.StepTime); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tfor i, r := range art.StepTimeRegimes {\n\t\tname := fmt.Sprintf(\"step_time_regimes[%d](%s)\", i, r.Name)\n\t\tif err := validateLinearModel(name, &r.Model); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tif r.Condition != nil {\n\t\t\tswitch r.Condition.Op {\n\t\t\tcase \"==\", \"<\", \"<=\", \">\", \">=\":\n\t\t\t\t// valid\n\t\t\tdefault:\n\t\t\t\treturn nil, fmt.Errorf(\"stepml: %s has unsupported condition op %q\", name, r.Condition.Op)\n\t\t\t}\n\t\t}\n\t}\n\n\tif art.QueueingTime != nil {\n\t\tif err := validateLinearModel(\"queueing_time\", art.QueueingTime); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn &art, nil\n}\n\nfunc validateLinearModel(name string, m *LinearModel) error {\n\tif math.IsNaN(m.Intercept) || math.IsInf(m.Intercept, 0) {\n\t\treturn fmt.Errorf(\"stepml: %s intercept is NaN/Inf\", name)\n\t}\n\tfor feat, coeff := range m.FeatureCoefficients {\n\t\tif math.IsNaN(coeff) || math.IsInf(coeff, 0) {\n\t\t\treturn fmt.Errorf(\"stepml: %s coefficient %q is NaN/Inf\", name, feat)\n\t\t}\n\t}\n\treturn nil\n}\n\n// NewStepMLLatencyModel creates a StepML LatencyModel from a loaded artifact.\nfunc NewStepMLLatencyModel(art *StepMLArtifact) *StepMLLatencyModel {\n\treturn &StepMLLatencyModel{artifact: *art}\n}\n\n// extractBatchFeatures computes aggregate features from a batch of requests.\n// These features mirror the ground-truth step-level data schema.\nfunc extractBatchFeatures(batch []*sim.Request) map[string]float64 {\n\tvar prefillTokens, decodeTokens int64\n\tvar numPrefillReqs, numDecodeReqs int64\n\tvar kvSum, kvMax int64\n\tvar kvCount int64\n\tvar kvSumSq float64 // for kv_std computation\n\n\tfor _, req := range batch {\n\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n\t\t\t// Prefill phase\n\t\t\tprefillTokens += int64(req.NumNewTokens)\n\t\t\tnumPrefillReqs++\n\t\t} else if len(req.OutputTokens) > 0 {\n\t\t\t// Decode phase\n\t\t\tdecodeTokens += int64(req.NumNewTokens)\n\t\t\tnumDecodeReqs++\n\t\t}\n\n\t\t// KV cache proxy features from ProgressIndex\n\t\tpi := req.ProgressIndex\n\t\tkvSum += pi\n\t\tkvSumSq += float64(pi) * float64(pi)\n\t\tkvCount++\n\t\tif pi > kvMax {\n\t\t\tkvMax = pi\n\t\t}\n\t}\n\n\tvar kvMean, kvStd float64\n\tif kvCount > 0 {\n\t\tkvMean = float64(kvSum) / float64(kvCount)\n\t\tif kvCount > 1 {\n\t\t\t// Population std: sqrt(E[X^2] - E[X]^2)\n\t\t\tvariance := kvSumSq/float64(kvCount) - kvMean*kvMean\n\t\t\tif variance > 0 {\n\t\t\t\tkvStd = math.Sqrt(variance)\n\t\t\t}\n\t\t}\n\t}\n\n\tpf := float64(prefillTokens)\n\tdt := float64(decodeTokens)\n\tndr := float64(numDecodeReqs)\n\n\treturn map[string]float64{\n\t\t\"prefill_tokens\":   pf,\n\t\t\"decode_tokens\":    dt,\n\t\t\"num_prefill_reqs\": float64(numPrefillReqs),\n\t\t\"num_decode_reqs\":  ndr,\n\t\t\"scheduled_tokens\": pf + dt,\n\t\t\"kv_sum\":           float64(kvSum),\n\t\t\"kv_max\":           float64(kvMax),\n\t\t\"kv_mean\":          kvMean,\n\t\t\"kv_std\":           kvStd,\n\t\t// Interaction features for regime-specific models\n\t\t\"prefill_x_decode\":  pf * dt,\n\t\t\"decode_x_kv_mean\":  ndr * kvMean,\n\t\t\"prefill_sq\":        pf * pf,\n\t}\n}\n\n// predictLinear evaluates intercept + Σ(coeff_i * features[i]).\n// Features not present in the coefficient map are ignored (zero contribution).\n// When OutputTransform is \"expm1\", applies exp(result) - 1 (inverse of log1p).\nfunc predictLinear(m *LinearModel, features map[string]float64) float64 {\n\tresult := m.Intercept\n\tfor feat, coeff := range m.FeatureCoefficients {\n\t\tif val, ok := features[feat]; ok {\n\t\t\tresult += coeff * val\n\t\t}\n\t}\n\tif m.OutputTransform == \"expm1\" {\n\t\tresult = math.Expm1(result) // exp(result) - 1\n\t}\n\treturn result\n}\n\n// StepTime estimates batch step execution time in microseconds.\n//\n// The model predicts GPU compute time from batch features. Since the training\n// data only captures GPU forward pass time (step.duration_us), the full step\n// cycle time also includes CPU-side overhead (scheduling, sync, memory management).\n//\n// The overhead is applied as a floor (max) rather than additive because:\n//   - Small batches: overhead-dominated (~4ms); compute is negligible (~100µs)\n//   - Large batches: compute-dominated (~6ms); overhead is negligible\n//   - The transition is at the memory↔compute bound crossover point\n//\n// step_overhead_per_req_us is additive (per-request scheduling cost).\n//\n// When StepTimeRegimes is present, evaluates regimes in order; first match wins.\n// Otherwise falls back to the single StepTime linear model.\nfunc (s *StepMLLatencyModel) StepTime(batch []*sim.Request) int64 {\n\tfeatures := extractBatchFeatures(batch)\n\n\tvar prediction float64\n\tif len(s.artifact.StepTimeRegimes) > 0 {\n\t\tprediction = s.predictRegime(features)\n\t} else {\n\t\tprediction = predictLinear(s.artifact.StepTime, features)\n\t}\n\n\t// Apply overhead as a floor: step_cycle = max(overhead, compute).\n\t// This models the memory↔compute crossover: at small batches the overhead\n\t// floor dominates; at large batches, compute exceeds the floor naturally.\n\t//\n\t// Also cap at 5x overhead to prevent exponential blowup from the expm1\n\t// transform on outlier feature values. 5x covers the realistic range\n\t// (e.g., 4ms overhead → 20ms cap, well above any real step time).\n\tif s.artifact.StepOverheadUs > 0 {\n\t\tif prediction < s.artifact.StepOverheadUs {\n\t\t\tprediction = s.artifact.StepOverheadUs\n\t\t}\n\t\tmaxStep := s.artifact.StepOverheadUs * 3\n\t\tif prediction > maxStep {\n\t\t\tprediction = maxStep\n\t\t}\n\t}\n\n\t// Per-request overhead is always additive (scheduling cost per request).\n\tif s.artifact.StepOverheadPerReqUs > 0 {\n\t\tbatchSize := features[\"num_prefill_reqs\"] + features[\"num_decode_reqs\"]\n\t\tprediction += s.artifact.StepOverheadPerReqUs * batchSize\n\t}\n\n\tif prediction < 1 {\n\t\tprediction = 1 // INV-M-1: positive predictions\n\t}\n\treturn int64(prediction)\n}\n\n// predictRegime evaluates regime conditions in order and uses the first matching model.\nfunc (s *StepMLLatencyModel) predictRegime(features map[string]float64) float64 {\n\tfor _, r := range s.artifact.StepTimeRegimes {\n\t\tif r.Condition == nil || evalCondition(r.Condition, features) {\n\t\t\treturn predictLinear(&r.Model, features)\n\t\t}\n\t}\n\t// No regime matched and no fallback — use single model if available\n\tif s.artifact.StepTime != nil {\n\t\treturn predictLinear(s.artifact.StepTime, features)\n\t}\n\treturn 1 // safety fallback\n}\n\n// evalCondition checks a simple threshold condition against feature values.\nfunc evalCondition(c *RegimeCondition, features map[string]float64) bool {\n\tval := features[c.Feature]\n\tswitch c.Op {\n\tcase \"==\":\n\t\treturn val == c.Value\n\tcase \"<\":\n\t\treturn val < c.Value\n\tcase \"<=\":\n\t\treturn val <= c.Value\n\tcase \">\":\n\t\treturn val > c.Value\n\tcase \">=\":\n\t\treturn val >= c.Value\n\tdefault:\n\t\treturn false\n\t}\n}\n\n// QueueingTime estimates arrival-to-queue delay for a request in microseconds.\nfunc (s *StepMLLatencyModel) QueueingTime(req *sim.Request) int64 {\n\tif s.artifact.QueueingTime == nil {\n\t\treturn 0\n\t}\n\tfeatures := map[string]float64{\n\t\t\"input_len\": float64(len(req.InputTokens)),\n\t}\n\tprediction := predictLinear(s.artifact.QueueingTime, features)\n\tif prediction < 0 {\n\t\tprediction = 0\n\t}\n\treturn int64(prediction)\n}\n\n// OutputTokenProcessingTime estimates per-token post-processing in microseconds.\nfunc (s *StepMLLatencyModel) OutputTokenProcessingTime() int64 {\n\tv := s.artifact.OutputTokenProcessingTimeUs\n\tif v < 0 {\n\t\treturn 0\n\t}\n\treturn int64(v)\n}\n\n// SchedulingProcessingTime estimates scheduling overhead per request in microseconds.\nfunc (s *StepMLLatencyModel) SchedulingProcessingTime() int64 {\n\tv := s.artifact.SchedulingProcessingTimeUs\n\tif v < 0 {\n\t\treturn 0\n\t}\n\treturn int64(v)\n}\n\n// PreemptionProcessingTime estimates preemption overhead per eviction in microseconds.\nfunc (s *StepMLLatencyModel) PreemptionProcessingTime() int64 {\n\tv := s.artifact.PreemptionProcessingTimeUs\n\tif v < 0 {\n\t\treturn 0\n\t}\n\treturn int64(v)\n}\n","numLines":345,"startLine":1,"totalLines":345}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Rj1KgqsMKBGQGqKBD9X9Mv","type":"tool_result","content":"     1→\"\"\"Baseline models for step-time prediction.\n     2→\n     3→Provides two baselines:\n     4→- BlackboxBaseline: re-trained 3-coefficient linear regression matching BLIS blackbox model\n     5→- NaiveMeanBaseline: always predicts the training set mean step duration\n     6→\n     7→Plus calibration and gating utilities for the StepML research workflow.\n     8→\"\"\"\n     9→\n    10→from __future__ import annotations\n    11→\n    12→import numpy as np\n    13→import pandas as pd\n    14→from scipy.optimize import nnls\n    15→\n    16→from evaluation import (\n    17→    compute_mape,\n    18→    compute_mspe,\n    19→    compute_p99_error,\n    20→    compute_pearson_r,\n    21→)\n    22→\n    23→# Feature columns used by the blackbox model\n    24→_FEATURE_COLS = [\"batch.prefill_tokens\", \"batch.decode_tokens\"]\n    25→# Target column\n    26→_TARGET_COL = \"step.duration_us\"\n    27→\n    28→\n    29→class BlackboxBaseline:\n    30→    \"\"\"Re-trained 3-coefficient non-negative linear model matching BLIS blackbox.\n    31→\n    32→    StepTime = beta0 + beta1 * batch.prefill_tokens + beta2 * batch.decode_tokens\n    33→\n    34→    All three coefficients are constrained to be >= 0 via NNLS (non-negative\n    35→    least squares). The intercept is modelled as a third feature (ones column)\n    36→    so that the non-negativity constraint applies uniformly to all betas.\n    37→\n    38→    Column normalization is applied before NNLS to avoid scale mismatch between\n    39→    the ones column (~1) and token columns (~0-2048), then coefficients are\n    40→    rescaled to original units.\n    41→    \"\"\"\n    42→\n    43→    def __init__(self) -> None:\n    44→        self._coeffs: np.ndarray | None = None  # [beta0, beta1, beta2]\n    45→\n    46→    def fit(self, train_df: pd.DataFrame) -> BlackboxBaseline:\n    47→        \"\"\"Train on step-level data using column-normalized NNLS.\n    48→\n    49→        Constructs A = [ones, prefill_tokens, decode_tokens], normalizes each\n    50→        column by its L2 norm, solves NNLS, then rescales coefficients back.\n    51→        \"\"\"\n    52→        X = train_df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n    53→        y = train_df[_TARGET_COL].to_numpy(dtype=np.float64)\n    54→\n    55→        # Build design matrix: [ones, prefill, decode]\n    56→        ones = np.ones((X.shape[0], 1), dtype=np.float64)\n    57→        A = np.hstack([ones, X])\n    58→\n    59→        # Column-normalize to fix conditioning\n    60→        col_norms = np.linalg.norm(A, axis=0)\n    61→        col_norms[col_norms == 0] = 1.0  # guard against zero columns\n    62→        A_normed = A / col_norms\n    63→\n    64→        # Solve NNLS on normalized problem\n    65→        x_normed, _ = nnls(A_normed, y)\n    66→\n    67→        # Rescale coefficients back to original units\n    68→        self._coeffs = x_normed / col_norms\n    69→        return self\n    70→\n    71→    def predict(self, df: pd.DataFrame) -> np.ndarray:\n    72→        \"\"\"Predict step.duration_us from batch features.\"\"\"\n    73→        if self._coeffs is None:\n    74→            raise RuntimeError(\"BlackboxBaseline.predict() called before fit()\")\n    75→        X = df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n    76→        return self._coeffs[0] + X @ self._coeffs[1:]\n    77→\n    78→    @property\n    79→    def coefficients(self) -> dict:\n    80→        \"\"\"Return {\"beta0\": intercept, \"beta1\": prefill_coeff, \"beta2\": decode_coeff}.\"\"\"\n    81→        if self._coeffs is None:\n    82→            raise RuntimeError(\"BlackboxBaseline.coefficients accessed before fit()\")\n    83→        return {\n    84→            \"beta0\": float(self._coeffs[0]),\n    85→            \"beta1\": float(self._coeffs[1]),\n    86→            \"beta2\": float(self._coeffs[2]),\n    87→        }\n    88→\n    89→\n    90→class NaiveMeanBaseline:\n    91→    \"\"\"Always predicts the training set mean step duration.\"\"\"\n    92→\n    93→    def __init__(self) -> None:\n    94→        self._mean: float | None = None\n    95→\n    96→    def fit(self, train_df: pd.DataFrame) -> NaiveMeanBaseline:\n    97→        \"\"\"Compute and store the training set mean of step.duration_us.\"\"\"\n    98→        self._mean = float(train_df[_TARGET_COL].mean())\n    99→        return self\n   100→\n   101→    def predict(self, df: pd.DataFrame) -> np.ndarray:\n   102→        \"\"\"Return an array of the training mean, one per input row.\"\"\"\n   103→        if self._mean is None:\n   104→            raise RuntimeError(\"NaiveMeanBaseline.predict() called before fit()\")\n   105→        return np.full(len(df), self._mean)\n   106→\n   107→\n   108→def compute_baseline_report(\n   109→    train_df: pd.DataFrame,\n   110→    test_df: pd.DataFrame,\n   111→    baselines: dict | None = None,\n   112→) -> dict:\n   113→    \"\"\"Compute evaluation metrics for all baselines.\n   114→\n   115→    Args:\n   116→        train_df: Training split DataFrame with feature and target columns.\n   117→        test_df: Test split DataFrame with feature and target columns.\n   118→        baselines: Optional dict of {name: baseline_instance}. If None, uses\n   119→            default baselines (blackbox + naive_mean).\n   120→\n   121→    Returns:\n   122→        Dict like:\n   123→        {\n   124→            \"blackbox\": {\"mape\": 15.2, \"mspe\": -3.1, \"pearson_r\": 0.89, \"p99_error\": 45.3},\n   125→            \"naive_mean\": {\"mape\": 42.1, ...},\n   126→        }\n   127→        Uses evaluation.py functions (compute_mape, compute_mspe, compute_pearson_r, compute_p99_error).\n   128→    \"\"\"\n   129→    if baselines is None:\n   130→        baselines = {\n   131→            \"blackbox\": BlackboxBaseline(),\n   132→            \"naive_mean\": NaiveMeanBaseline(),\n   133→        }\n   134→\n   135→    actual = test_df[_TARGET_COL].values\n   136→    report: dict = {}\n   137→\n   138→    for name, model in baselines.items():\n   139→        model.fit(train_df)\n   140→        predicted = model.predict(test_df)\n   141→\n   142→        pearson_r = compute_pearson_r(predicted, actual)\n   143→        # pearsonr returns NaN for constant inputs (e.g., NaiveMeanBaseline).\n   144→        # Replace with 0.0 — constant predictions have zero useful correlation.\n   145→        if np.isnan(pearson_r):\n   146→            pearson_r = 0.0\n   147→\n   148→        report[name] = {\n   149→            \"mape\": float(compute_mape(predicted, actual)),\n   150→            \"mspe\": float(compute_mspe(predicted, actual)),\n   151→            \"pearson_r\": float(pearson_r),\n   152→            \"p99_error\": float(compute_p99_error(predicted, actual)),\n   153→        }\n   154→\n   155→    return report\n   156→\n   157→\n   158→def calibrate_short_circuit_threshold(blackbox_mape: float) -> float:\n   159→    \"\"\"Determine the short-circuit threshold for StepML improvement.\n   160→\n   161→    If blackbox MAPE > 25%, threshold = blackbox_MAPE + 10%.\n   162→    Otherwise threshold = 35% (25% + 10% buffer).\n   163→\n   164→    Args:\n   165→        blackbox_mape: The blackbox baseline's MAPE as a percentage.\n   166→\n   167→    Returns:\n   168→        The threshold as a percentage.\n   169→    \"\"\"\n   170→    if blackbox_mape > 25.0:\n   171→        return blackbox_mape + 10.0\n   172→    return 35.0\n   173→\n   174→\n   175→def check_r4_gate(blackbox_e2e_mean_error: float) -> dict:\n   176→    \"\"\"Check if blackbox is already good enough (R4 risk).\n   177→\n   178→    If abs(blackbox_e2e_mean_error) < 12%, flag for research justification review.\n   179→    This means the blackbox model is already performing well at the E2E level,\n   180→    so additional ML complexity may not be justified.\n   181→\n   182→    Args:\n   183→        blackbox_e2e_mean_error: The blackbox baseline's E2E mean error as a percentage.\n   184→\n   185→    Returns:\n   186→        {\"passed\": bool, \"e2e_error\": float, \"message\": str}\n   187→        passed=True means no flag (research is justified).\n   188→        passed=False means flagged (blackbox already good enough, needs justification).\n   189→    \"\"\"\n   190→    e2e_error = float(blackbox_e2e_mean_error)\n   191→    flagged = abs(e2e_error) < 12.0\n   192→\n   193→    if flagged:\n   194→        message = (\n   195→            f\"R4 gate FLAGGED: blackbox E2E mean error = {e2e_error:.1f}% \"\n   196→            f\"(|error| < 12%). Blackbox may already be sufficient. \"\n   197→            f\"Review research justification before proceeding.\"\n   198→        )\n   199→    else:\n   200→        message = (\n   201→            f\"R4 gate passed: blackbox E2E mean error = {e2e_error:.1f}% \"\n   202→            f\"(|error| >= 12%). Step-level ML improvement is justified.\"\n   203→        )\n   204→\n   205→    return {\n   206→        \"passed\": not flagged,\n   207→        \"e2e_error\": e2e_error,\n   208→        \"message\": message,\n   209→    }\n   210→"}]},"parent_tool_use_id":null,"session_id":"5cda49b4-0eac-4d7d-a6da-e3880a46a823","uuid":"af4a02c0-7f72-431a-a294-473a90f4a2b3","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round3-idea-3-e2e-calibration/hypotheses/h-stepml/shared/baselines.py","content":"\"\"\"Baseline models for step-time prediction.\n\nProvides two baselines:\n- BlackboxBaseline: re-trained 3-coefficient linear regression matching BLIS blackbox model\n- NaiveMeanBaseline: always predicts the training set mean step duration\n\nPlus calibration and gating utilities for the StepML research workflow.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport numpy as np\nimport pandas as pd\nfrom scipy.optimize import nnls\n\nfrom evaluation import (\n    compute_mape,\n    compute_mspe,\n    compute_p99_error,\n    compute_pearson_r,\n)\n\n# Feature columns used by the blackbox model\n_FEATURE_COLS = [\"batch.prefill_tokens\", \"batch.decode_tokens\"]\n# Target column\n_TARGET_COL = \"step.duration_us\"\n\n\nclass BlackboxBaseline:\n    \"\"\"Re-trained 3-coefficient non-negative linear model matching BLIS blackbox.\n\n    StepTime = beta0 + beta1 * batch.prefill_tokens + beta2 * batch.decode_tokens\n\n    All three coefficients are constrained to be >= 0 via NNLS (non-negative\n    least squares). The intercept is modelled as a third feature (ones column)\n    so that the non-negativity constraint applies uniformly to all betas.\n\n    Column normalization is applied before NNLS to avoid scale mismatch between\n    the ones column (~1) and token columns (~0-2048), then coefficients are\n    rescaled to original units.\n    \"\"\"\n\n    def __init__(self) -> None:\n        self._coeffs: np.ndarray | None = None  # [beta0, beta1, beta2]\n\n    def fit(self, train_df: pd.DataFrame) -> BlackboxBaseline:\n        \"\"\"Train on step-level data using column-normalized NNLS.\n\n        Constructs A = [ones, prefill_tokens, decode_tokens], normalizes each\n        column by its L2 norm, solves NNLS, then rescales coefficients back.\n        \"\"\"\n        X = train_df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n        y = train_df[_TARGET_COL].to_numpy(dtype=np.float64)\n\n        # Build design matrix: [ones, prefill, decode]\n        ones = np.ones((X.shape[0], 1), dtype=np.float64)\n        A = np.hstack([ones, X])\n\n        # Column-normalize to fix conditioning\n        col_norms = np.linalg.norm(A, axis=0)\n        col_norms[col_norms == 0] = 1.0  # guard against zero columns\n        A_normed = A / col_norms\n\n        # Solve NNLS on normalized problem\n        x_normed, _ = nnls(A_normed, y)\n\n        # Rescale coefficients back to original units\n        self._coeffs = x_normed / col_norms\n        return self\n\n    def predict(self, df: pd.DataFrame) -> np.ndarray:\n        \"\"\"Predict step.duration_us from batch features.\"\"\"\n        if self._coeffs is None:\n            raise RuntimeError(\"BlackboxBaseline.predict() called before fit()\")\n        X = df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n        return self._coeffs[0] + X @ self._coeffs[1:]\n\n    @property\n    def coefficients(self) -> dict:\n        \"\"\"Return {\"beta0\": intercept, \"beta1\": prefill_coeff, \"beta2\": decode_coeff}.\"\"\"\n        if self._coeffs is None:\n            raise RuntimeError(\"BlackboxBaseline.coefficients accessed before fit()\")\n        return {\n            \"beta0\": float(self._coeffs[0]),\n            \"beta1\": float(self._coeffs[1]),\n            \"beta2\": float(self._coeffs[2]),\n        }\n\n\nclass NaiveMeanBaseline:\n    \"\"\"Always predicts the training set mean step duration.\"\"\"\n\n    def __init__(self) -> None:\n        self._mean: float | None = None\n\n    def fit(self, train_df: pd.DataFrame) -> NaiveMeanBaseline:\n        \"\"\"Compute and store the training set mean of step.duration_us.\"\"\"\n        self._mean = float(train_df[_TARGET_COL].mean())\n        return self\n\n    def predict(self, df: pd.DataFrame) -> np.ndarray:\n        \"\"\"Return an array of the training mean, one per input row.\"\"\"\n        if self._mean is None:\n            raise RuntimeError(\"NaiveMeanBaseline.predict() called before fit()\")\n        return np.full(len(df), self._mean)\n\n\ndef compute_baseline_report(\n    train_df: pd.DataFrame,\n    test_df: pd.DataFrame,\n    baselines: dict | None = None,\n) -> dict:\n    \"\"\"Compute evaluation metrics for all baselines.\n\n    Args:\n        train_df: Training split DataFrame with feature and target columns.\n        test_df: Test split DataFrame with feature and target columns.\n        baselines: Optional dict of {name: baseline_instance}. If None, uses\n            default baselines (blackbox + naive_mean).\n\n    Returns:\n        Dict like:\n        {\n            \"blackbox\": {\"mape\": 15.2, \"mspe\": -3.1, \"pearson_r\": 0.89, \"p99_error\": 45.3},\n            \"naive_mean\": {\"mape\": 42.1, ...},\n        }\n        Uses evaluation.py functions (compute_mape, compute_mspe, compute_pearson_r, compute_p99_error).\n    \"\"\"\n    if baselines is None:\n        baselines = {\n            \"blackbox\": BlackboxBaseline(),\n            \"naive_mean\": NaiveMeanBaseline(),\n        }\n\n    actual = test_df[_TARGET_COL].values\n    report: dict = {}\n\n    for name, model in baselines.items():\n        model.fit(train_df)\n        predicted = model.predict(test_df)\n\n        pearson_r = compute_pearson_r(predicted, actual)\n        # pearsonr returns NaN for constant inputs (e.g., NaiveMeanBaseline).\n        # Replace with 0.0 — constant predictions have zero useful correlation.\n        if np.isnan(pearson_r):\n            pearson_r = 0.0\n\n        report[name] = {\n            \"mape\": float(compute_mape(predicted, actual)),\n            \"mspe\": float(compute_mspe(predicted, actual)),\n            \"pearson_r\": float(pearson_r),\n            \"p99_error\": float(compute_p99_error(predicted, actual)),\n        }\n\n    return report\n\n\ndef calibrate_short_circuit_threshold(blackbox_mape: float) -> float:\n    \"\"\"Determine the short-circuit threshold for StepML improvement.\n\n    If blackbox MAPE > 25%, threshold = blackbox_MAPE + 10%.\n    Otherwise threshold = 35% (25% + 10% buffer).\n\n    Args:\n        blackbox_mape: The blackbox baseline's MAPE as a percentage.\n\n    Returns:\n        The threshold as a percentage.\n    \"\"\"\n    if blackbox_mape > 25.0:\n        return blackbox_mape + 10.0\n    return 35.0\n\n\ndef check_r4_gate(blackbox_e2e_mean_error: float) -> dict:\n    \"\"\"Check if blackbox is already good enough (R4 risk).\n\n    If abs(blackbox_e2e_mean_error) < 12%, flag for research justification review.\n    This means the blackbox model is already performing well at the E2E level,\n    so additional ML complexity may not be justified.\n\n    Args:\n        blackbox_e2e_mean_error: The blackbox baseline's E2E mean error as a percentage.\n\n    Returns:\n        {\"passed\": bool, \"e2e_error\": float, \"message\": str}\n        passed=True means no flag (research is justified).\n        passed=False means flagged (blackbox already good enough, needs justification).\n    \"\"\"\n    e2e_error = float(blackbox_e2e_mean_error)\n    flagged = abs(e2e_error) < 12.0\n\n    if flagged:\n        message = (\n            f\"R4 gate FLAGGED: blackbox E2E mean error = {e2e_error:.1f}% \"\n            f\"(|error| < 12%). Blackbox may already be sufficient. \"\n            f\"Review research justification before proceeding.\"\n        )\n    else:\n        message = (\n            f\"R4 gate passed: blackbox E2E mean error = {e2e_error:.1f}% \"\n            f\"(|error| >= 12%). Step-level ML improvement is justified.\"\n        )\n\n    return {\n        \"passed\": not flagged,\n        \"e2e_error\": e2e_error,\n        \"message\": message,\n    }\n","numLines":210,"startLine":1,"totalLines":210}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01QMtg6fobiHZatFgDGLmYEL","type":"tool_result","content":"     1→package latency\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\t\"testing\"\n     7→\n     8→\t\"github.com/inference-sim/inference-sim/sim\"\n     9→)\n    10→\n    11→// validArtifactJSON is a minimal StepML artifact for testing.\n    12→const validArtifactJSON = `{\n    13→\t\"version\": 1,\n    14→\t\"step_time\": {\n    15→\t\t\"model_type\": \"linear\",\n    16→\t\t\"intercept\": 100.0,\n    17→\t\t\"feature_coefficients\": {\n    18→\t\t\t\"prefill_tokens\": 50.0,\n    19→\t\t\t\"decode_tokens\": 5.0\n    20→\t\t}\n    21→\t},\n    22→\t\"queueing_time\": {\n    23→\t\t\"model_type\": \"linear\",\n    24→\t\t\"intercept\": 10.0,\n    25→\t\t\"feature_coefficients\": {\n    26→\t\t\t\"input_len\": 0.5\n    27→\t\t}\n    28→\t},\n    29→\t\"output_token_processing_time_us\": 2.0,\n    30→\t\"scheduling_processing_time_us\": 5.0,\n    31→\t\"preemption_processing_time_us\": 3.0\n    32→}`\n    33→\n    34→func writeArtifact(t *testing.T, content string) string {\n    35→\tt.Helper()\n    36→\tdir := t.TempDir()\n    37→\tpath := filepath.Join(dir, \"model.json\")\n    38→\tif err := os.WriteFile(path, []byte(content), 0o644); err != nil {\n    39→\t\tt.Fatalf(\"write artifact: %v\", err)\n    40→\t}\n    41→\treturn path\n    42→}\n    43→\n    44→func TestLoadStepMLArtifact_Valid(t *testing.T) {\n    45→\tpath := writeArtifact(t, validArtifactJSON)\n    46→\tart, err := LoadStepMLArtifact(path)\n    47→\tif err != nil {\n    48→\t\tt.Fatalf(\"unexpected error: %v\", err)\n    49→\t}\n    50→\tif art.Version != 1 {\n    51→\t\tt.Errorf(\"version = %d, want 1\", art.Version)\n    52→\t}\n    53→\tif art.StepTime.Intercept != 100.0 {\n    54→\t\tt.Errorf(\"step_time intercept = %f, want 100.0\", art.StepTime.Intercept)\n    55→\t}\n    56→\tif art.StepTime.FeatureCoefficients[\"prefill_tokens\"] != 50.0 {\n    57→\t\tt.Errorf(\"prefill_tokens coeff = %f, want 50.0\", art.StepTime.FeatureCoefficients[\"prefill_tokens\"])\n    58→\t}\n    59→}\n    60→\n    61→func TestLoadStepMLArtifact_MissingFile(t *testing.T) {\n    62→\t_, err := LoadStepMLArtifact(\"/nonexistent/path.json\")\n    63→\tif err == nil {\n    64→\t\tt.Fatal(\"expected error for missing file\")\n    65→\t}\n    66→}\n    67→\n    68→func TestLoadStepMLArtifact_MissingStepTime(t *testing.T) {\n    69→\tpath := writeArtifact(t, `{\"version\": 1}`)\n    70→\t_, err := LoadStepMLArtifact(path)\n    71→\tif err == nil {\n    72→\t\tt.Fatal(\"expected error for missing step_time\")\n    73→\t}\n    74→}\n    75→\n    76→func TestLoadStepMLArtifact_InvalidVersion(t *testing.T) {\n    77→\tpath := writeArtifact(t, `{\"version\": 0, \"step_time\": {\"model_type\": \"linear\", \"intercept\": 0}}`)\n    78→\t_, err := LoadStepMLArtifact(path)\n    79→\tif err == nil {\n    80→\t\tt.Fatal(\"expected error for version 0\")\n    81→\t}\n    82→}\n    83→\n    84→func TestLoadStepMLArtifact_NaNCoefficient(t *testing.T) {\n    85→\t// JSON doesn't support NaN natively; test via a model type error instead\n    86→\tpath := writeArtifact(t, `{\"version\": 1, \"step_time\": {\"model_type\": \"neural_net\", \"intercept\": 0}}`)\n    87→\t_, err := LoadStepMLArtifact(path)\n    88→\tif err == nil {\n    89→\t\tt.Fatal(\"expected error for unsupported model_type\")\n    90→\t}\n    91→}\n    92→\n    93→func TestStepMLLatencyModel_StepTime(t *testing.T) {\n    94→\tpath := writeArtifact(t, validArtifactJSON)\n    95→\tart, err := LoadStepMLArtifact(path)\n    96→\tif err != nil {\n    97→\t\tt.Fatalf(\"load artifact: %v\", err)\n    98→\t}\n    99→\tmodel := NewStepMLLatencyModel(art)\n   100→\n   101→\t// Batch: 1 prefill request (100 new tokens), 2 decode requests (1 new token each)\n   102→\tbatch := []*sim.Request{\n   103→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},  // prefill\n   104→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1}, // decode\n   105→\t\t{InputTokens: make([]int, 80), OutputTokens: make([]int, 30), ProgressIndex: 110, NumNewTokens: 1},  // decode\n   106→\t}\n   107→\n   108→\t// Expected: 100 (intercept) + 50*100 (prefill) + 5*2 (decode) = 100 + 5000 + 10 = 5110\n   109→\tgot := model.StepTime(batch)\n   110→\tif got != 5110 {\n   111→\t\tt.Errorf(\"StepTime = %d, want 5110\", got)\n   112→\t}\n   113→}\n   114→\n   115→func TestStepMLLatencyModel_StepTime_Positive(t *testing.T) {\n   116→\t// Test INV-M-1: predictions are always positive\n   117→\tart := &StepMLArtifact{\n   118→\t\tVersion: 1,\n   119→\t\tStepTime: &LinearModel{\n   120→\t\t\tModelType:           \"linear\",\n   121→\t\t\tIntercept:           -1000,\n   122→\t\t\tFeatureCoefficients: map[string]float64{},\n   123→\t\t},\n   124→\t}\n   125→\tmodel := NewStepMLLatencyModel(art)\n   126→\tgot := model.StepTime([]*sim.Request{})\n   127→\tif got < 1 {\n   128→\t\tt.Errorf(\"StepTime = %d, want >= 1 (INV-M-1)\", got)\n   129→\t}\n   130→}\n   131→\n   132→func TestStepMLLatencyModel_QueueingTime(t *testing.T) {\n   133→\tpath := writeArtifact(t, validArtifactJSON)\n   134→\tart, err := LoadStepMLArtifact(path)\n   135→\tif err != nil {\n   136→\t\tt.Fatalf(\"load artifact: %v\", err)\n   137→\t}\n   138→\tmodel := NewStepMLLatencyModel(art)\n   139→\n   140→\treq := &sim.Request{InputTokens: make([]int, 200)}\n   141→\t// Expected: 10 (intercept) + 0.5 * 200 = 110\n   142→\tgot := model.QueueingTime(req)\n   143→\tif got != 110 {\n   144→\t\tt.Errorf(\"QueueingTime = %d, want 110\", got)\n   145→\t}\n   146→}\n   147→\n   148→func TestStepMLLatencyModel_QueueingTime_NilModel(t *testing.T) {\n   149→\tart := &StepMLArtifact{\n   150→\t\tVersion:  1,\n   151→\t\tStepTime: &LinearModel{ModelType: \"linear\", Intercept: 10, FeatureCoefficients: map[string]float64{}},\n   152→\t}\n   153→\tmodel := NewStepMLLatencyModel(art)\n   154→\tgot := model.QueueingTime(&sim.Request{InputTokens: make([]int, 100)})\n   155→\tif got != 0 {\n   156→\t\tt.Errorf(\"QueueingTime with nil model = %d, want 0\", got)\n   157→\t}\n   158→}\n   159→\n   160→func TestStepMLLatencyModel_ConstantMethods(t *testing.T) {\n   161→\tpath := writeArtifact(t, validArtifactJSON)\n   162→\tart, err := LoadStepMLArtifact(path)\n   163→\tif err != nil {\n   164→\t\tt.Fatalf(\"load artifact: %v\", err)\n   165→\t}\n   166→\tmodel := NewStepMLLatencyModel(art)\n   167→\n   168→\tif got := model.OutputTokenProcessingTime(); got != 2 {\n   169→\t\tt.Errorf(\"OutputTokenProcessingTime = %d, want 2\", got)\n   170→\t}\n   171→\tif got := model.SchedulingProcessingTime(); got != 5 {\n   172→\t\tt.Errorf(\"SchedulingProcessingTime = %d, want 5\", got)\n   173→\t}\n   174→\tif got := model.PreemptionProcessingTime(); got != 3 {\n   175→\t\tt.Errorf(\"PreemptionProcessingTime = %d, want 3\", got)\n   176→\t}\n   177→}\n   178→\n   179→func TestStepMLLatencyModel_KVFeatures(t *testing.T) {\n   180→\t// Test that KV proxy features (ProgressIndex) are extracted and used\n   181→\tart := &StepMLArtifact{\n   182→\t\tVersion: 1,\n   183→\t\tStepTime: &LinearModel{\n   184→\t\t\tModelType: \"linear\",\n   185→\t\t\tIntercept: 0,\n   186→\t\t\tFeatureCoefficients: map[string]float64{\n   187→\t\t\t\t\"kv_sum\":  0.1,\n   188→\t\t\t\t\"kv_mean\": 10.0,\n   189→\t\t\t\t\"kv_max\":  1.0,\n   190→\t\t\t},\n   191→\t\t},\n   192→\t}\n   193→\tmodel := NewStepMLLatencyModel(art)\n   194→\n   195→\tbatch := []*sim.Request{\n   196→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1},\n   197→\t\t{InputTokens: make([]int, 200), OutputTokens: make([]int, 100), ProgressIndex: 300, NumNewTokens: 1},\n   198→\t}\n   199→\n   200→\t// kv_sum = 150 + 300 = 450 → 450 * 0.1 = 45\n   201→\t// kv_mean = 225 → 225 * 10 = 2250\n   202→\t// kv_max = 300 → 300 * 1 = 300\n   203→\t// total = 45 + 2250 + 300 = 2595\n   204→\tgot := model.StepTime(batch)\n   205→\tif got != 2595 {\n   206→\t\tt.Errorf(\"StepTime with KV features = %d, want 2595\", got)\n   207→\t}\n   208→}\n   209→\n   210→func TestExtractBatchFeatures(t *testing.T) {\n   211→\tbatch := []*sim.Request{\n   212→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},   // prefill: 50 < 200\n   213→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 1), ProgressIndex: 150, NumNewTokens: 1}, // decode: 150 >= 100\n   214→\t}\n   215→\n   216→\tf := extractBatchFeatures(batch)\n   217→\n   218→\ttests := []struct {\n   219→\t\tname string\n   220→\t\twant float64\n   221→\t}{\n   222→\t\t{\"prefill_tokens\", 100},\n   223→\t\t{\"decode_tokens\", 1},\n   224→\t\t{\"num_prefill_reqs\", 1},\n   225→\t\t{\"num_decode_reqs\", 1},\n   226→\t\t{\"scheduled_tokens\", 101},\n   227→\t\t{\"kv_sum\", 200},    // 50 + 150\n   228→\t\t{\"kv_max\", 150},\n   229→\t\t{\"kv_mean\", 100},   // 200 / 2\n   230→\t}\n   231→\tfor _, tt := range tests {\n   232→\t\tif got := f[tt.name]; got != tt.want {\n   233→\t\t\tt.Errorf(\"feature %q = %f, want %f\", tt.name, got, tt.want)\n   234→\t\t}\n   235→\t}\n   236→}\n   237→\n   238→func TestNewLatencyModel_StepMLDispatch(t *testing.T) {\n   239→\tpath := writeArtifact(t, validArtifactJSON)\n   240→\tcoeffs := sim.NewLatencyCoeffs(\n   241→\t\t[]float64{0, 0, 0}, // beta (unused by stepml)\n   242→\t\t[]float64{0, 0, 0}, // alpha (unused by stepml)\n   243→\t)\n   244→\thw := sim.NewModelHardwareConfig(sim.ModelConfig{}, sim.HardwareCalib{}, \"\", \"\", 0, false).\n   245→\t\tWithStepMLModel(path)\n   246→\n   247→\tmodel, err := NewLatencyModel(coeffs, hw)\n   248→\tif err != nil {\n   249→\t\tt.Fatalf(\"NewLatencyModel with StepML: %v\", err)\n   250→\t}\n   251→\n   252→\tif _, ok := model.(*StepMLLatencyModel); !ok {\n   253→\t\tt.Errorf(\"expected *StepMLLatencyModel, got %T\", model)\n   254→\t}\n   255→}\n   256→\n   257→// regimeArtifactJSON has 2 regimes: decode-only and mixed-batch (fallback).\n   258→const regimeArtifactJSON = `{\n   259→\t\"version\": 2,\n   260→\t\"step_time_regimes\": [\n   261→\t\t{\n   262→\t\t\t\"name\": \"decode_only\",\n   263→\t\t\t\"condition\": {\"feature\": \"prefill_tokens\", \"op\": \"==\", \"value\": 0},\n   264→\t\t\t\"model\": {\n   265→\t\t\t\t\"model_type\": \"linear\",\n   266→\t\t\t\t\"intercept\": 50.0,\n   267→\t\t\t\t\"feature_coefficients\": {\"decode_tokens\": 10.0, \"kv_mean\": 0.5}\n   268→\t\t\t}\n   269→\t\t},\n   270→\t\t{\n   271→\t\t\t\"name\": \"mixed\",\n   272→\t\t\t\"condition\": null,\n   273→\t\t\t\"model\": {\n   274→\t\t\t\t\"model_type\": \"linear\",\n   275→\t\t\t\t\"intercept\": 200.0,\n   276→\t\t\t\t\"feature_coefficients\": {\"prefill_tokens\": 2.0, \"decode_tokens\": 8.0}\n   277→\t\t\t}\n   278→\t\t}\n   279→\t],\n   280→\t\"output_token_processing_time_us\": 1.0,\n   281→\t\"scheduling_processing_time_us\": 2.0,\n   282→\t\"preemption_processing_time_us\": 0.0\n   283→}`\n   284→\n   285→func TestStepMLLatencyModel_RegimeDispatch(t *testing.T) {\n   286→\tpath := writeArtifact(t, regimeArtifactJSON)\n   287→\tart, err := LoadStepMLArtifact(path)\n   288→\tif err != nil {\n   289→\t\tt.Fatalf(\"load regime artifact: %v\", err)\n   290→\t}\n   291→\tmodel := NewStepMLLatencyModel(art)\n   292→\n   293→\t// Decode-only batch: 2 decode requests, 1 new token each\n   294→\tdecodeBatch := []*sim.Request{\n   295→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1},\n   296→\t\t{InputTokens: make([]int, 80), OutputTokens: make([]int, 30), ProgressIndex: 110, NumNewTokens: 1},\n   297→\t}\n   298→\t// prefill_tokens=0 → decode_only regime\n   299→\t// decode_tokens=2, kv_mean=(150+110)/2=130\n   300→\t// Expected: 50 + 10*2 + 0.5*130 = 50 + 20 + 65 = 135\n   301→\tgot := model.StepTime(decodeBatch)\n   302→\tif got != 135 {\n   303→\t\tt.Errorf(\"StepTime(decode_only) = %d, want 135\", got)\n   304→\t}\n   305→\n   306→\t// Mixed batch: 1 prefill + 1 decode\n   307→\tmixedBatch := []*sim.Request{\n   308→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},  // prefill\n   309→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1}, // decode\n   310→\t}\n   311→\t// prefill_tokens=100 > 0 → mixed regime\n   312→\t// decode_tokens=1\n   313→\t// Expected: 200 + 2*100 + 8*1 = 200 + 200 + 8 = 408\n   314→\tgot = model.StepTime(mixedBatch)\n   315→\tif got != 408 {\n   316→\t\tt.Errorf(\"StepTime(mixed) = %d, want 408\", got)\n   317→\t}\n   318→}\n   319→\n   320→func TestStepMLLatencyModel_RegimeNoStepTime(t *testing.T) {\n   321→\t// Artifact with only regimes (no step_time field) should work\n   322→\tpath := writeArtifact(t, regimeArtifactJSON)\n   323→\tart, err := LoadStepMLArtifact(path)\n   324→\tif err != nil {\n   325→\t\tt.Fatalf(\"load: %v\", err)\n   326→\t}\n   327→\tif art.StepTime != nil {\n   328→\t\tt.Error(\"expected nil step_time when using regimes only\")\n   329→\t}\n   330→\tif len(art.StepTimeRegimes) != 2 {\n   331→\t\tt.Errorf(\"got %d regimes, want 2\", len(art.StepTimeRegimes))\n   332→\t}\n   333→}\n   334→\n   335→func TestExtractBatchFeatures_InteractionFeatures(t *testing.T) {\n   336→\tbatch := []*sim.Request{\n   337→\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},   // prefill\n   338→\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 1), ProgressIndex: 150, NumNewTokens: 1}, // decode\n   339→\t}\n   340→\n   341→\tf := extractBatchFeatures(batch)\n   342→\n   343→\t// prefill_x_decode = 100 * 1 = 100\n   344→\tif got := f[\"prefill_x_decode\"]; got != 100 {\n   345→\t\tt.Errorf(\"prefill_x_decode = %f, want 100\", got)\n   346→\t}\n   347→\t// decode_x_kv_mean = 1 * 100 = 100 (kv_mean = (50+150)/2 = 100)\n   348→\tif got := f[\"decode_x_kv_mean\"]; got != 100 {\n   349→\t\tt.Errorf(\"decode_x_kv_mean = %f, want 100\", got)\n   350→\t}\n   351→\t// prefill_sq = 100 * 100 = 10000\n   352→\tif got := f[\"prefill_sq\"]; got != 10000 {\n   353→\t\tt.Errorf(\"prefill_sq = %f, want 10000\", got)\n   354→\t}\n   355→\t// kv_std: pi values are 50 and 150, mean=100\n   356→\t// variance = ((50-100)^2 + (150-100)^2) / 2 = (2500+2500)/2 = 2500\n   357→\t// std = sqrt(2500) = 50\n   358→\tif got := f[\"kv_std\"]; got != 50 {\n   359→\t\tt.Errorf(\"kv_std = %f, want 50\", got)\n   360→\t}\n   361→}\n   362→\n   363→func TestStepMLLatencyModel_OverheadFloorAndCap(t *testing.T) {\n   364→\t// Overhead floor: prediction < overhead → use overhead.\n   365→\t// Overhead cap: prediction > 3*overhead → clamp to 3*overhead.\n   366→\tart := &StepMLArtifact{\n   367→\t\tVersion: 1,\n   368→\t\tStepTime: &LinearModel{\n   369→\t\t\tModelType:           \"linear\",\n   370→\t\t\tIntercept:           100,\n   371→\t\t\tFeatureCoefficients: map[string]float64{\"decode_tokens\": 200},\n   372→\t\t},\n   373→\t\tStepOverheadUs: 5000,\n   374→\t}\n   375→\tmodel := NewStepMLLatencyModel(art)\n   376→\n   377→\t// Small batch: 100 + 200*1 = 300 < 5000 → floored to 5000\n   378→\tsmall := []*sim.Request{\n   379→\t\t{InputTokens: make([]int, 10), OutputTokens: make([]int, 1), ProgressIndex: 10, NumNewTokens: 1},\n   380→\t}\n   381→\tgot := model.StepTime(small)\n   382→\tif got != 5000 {\n   383→\t\tt.Errorf(\"StepTime(small) = %d, want 5000 (overhead floor)\", got)\n   384→\t}\n   385→\n   386→\t// Large batch: 100 + 200*100 = 20100, cap = 3*5000 = 15000 → capped\n   387→\tvar large []*sim.Request\n   388→\tfor i := 0; i < 100; i++ {\n   389→\t\tlarge = append(large, &sim.Request{\n   390→\t\t\tInputTokens: make([]int, 10), OutputTokens: make([]int, 1),\n   391→\t\t\tProgressIndex: 10, NumNewTokens: 1,\n   392→\t\t})\n   393→\t}\n   394→\tgot = model.StepTime(large)\n   395→\tif got != 15000 {\n   396→\t\tt.Errorf(\"StepTime(large) = %d, want 15000 (overhead cap)\", got)\n   397→\t}\n   398→\n   399→\t// Medium batch: 100 + 200*30 = 6100, between floor and cap → use as-is\n   400→\tvar medium []*sim.Request\n   401→\tfor i := 0; i < 30; i++ {\n   402→\t\tmedium = append(medium, &sim.Request{\n   403→\t\t\tInputTokens: make([]int, 10), OutputTokens: make([]int, 1),\n   404→\t\t\tProgressIndex: 10, NumNewTokens: 1,\n   405→\t\t})\n   406→\t}\n   407→\tgot = model.StepTime(medium)\n   408→\tif got != 6100 {\n   409→\t\tt.Errorf(\"StepTime(medium) = %d, want 6100 (between floor and cap)\", got)\n   410→\t}\n   411→}\n   412→\n   413→func TestNewLatencyModel_StepMLInvalidPath(t *testing.T) {\n   414→\tcoeffs := sim.NewLatencyCoeffs(\n   415→\t\t[]float64{0, 0, 0},\n   416→\t\t[]float64{0, 0, 0},\n   417→\t)\n   418→\thw := sim.NewModelHardwareConfig(sim.ModelConfig{}, sim.HardwareCalib{}, \"\", \"\", 0, false).\n   419→\t\tWithStepMLModel(\"/nonexistent/model.json\")\n   420→\n   421→\t_, err := NewLatencyModel(coeffs, hw)\n   422→\tif err == nil {\n   423→\t\tt.Fatal(\"expected error for nonexistent StepML model path\")\n   424→\t}\n   425→}\n   426→\n   427→func TestNewLatencyModel_RooflineTakesPrecedence(t *testing.T) {\n   428→\t// Verify that roofline dispatch happens before StepML (isolation guarantee)\n   429→\tpath := writeArtifact(t, validArtifactJSON)\n   430→\tcoeffs := sim.NewLatencyCoeffs(\n   431→\t\t[]float64{0, 0, 0},\n   432→\t\t[]float64{0, 0, 0},\n   433→\t)\n   434→\thw := sim.NewModelHardwareConfig(\n   435→\t\tsim.ModelConfig{NumLayers: 32, HiddenDim: 4096, NumHeads: 32, NumKVHeads: 32, VocabSize: 32000, BytesPerParam: 2, IntermediateDim: 11008},\n   436→\t\tsim.HardwareCalib{TFlopsPeak: 989.5, BwPeakTBs: 3.35},\n   437→\t\t\"test-model\", \"H100\", 1, true, // Roofline=true\n   438→\t).WithStepMLModel(path)\n   439→\n   440→\t// This should fail on roofline validation (missing MFU database), NOT try StepML\n   441→\t_, err := NewLatencyModel(coeffs, hw)\n   442→\tif err == nil {\n   443→\t\tt.Fatal(\"expected roofline validation error, not StepML dispatch\")\n   444→\t}\n   445→}\n   446→"}]},"parent_tool_use_id":null,"session_id":"5cda49b4-0eac-4d7d-a6da-e3880a46a823","uuid":"28b01b6a-fcaf-42bb-8080-a513ce1324b5","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/stepml-worktrees/round3-idea-3-e2e-calibration/sim/latency/stepml_test.go","content":"package latency\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/inference-sim/inference-sim/sim\"\n)\n\n// validArtifactJSON is a minimal StepML artifact for testing.\nconst validArtifactJSON = `{\n\t\"version\": 1,\n\t\"step_time\": {\n\t\t\"model_type\": \"linear\",\n\t\t\"intercept\": 100.0,\n\t\t\"feature_coefficients\": {\n\t\t\t\"prefill_tokens\": 50.0,\n\t\t\t\"decode_tokens\": 5.0\n\t\t}\n\t},\n\t\"queueing_time\": {\n\t\t\"model_type\": \"linear\",\n\t\t\"intercept\": 10.0,\n\t\t\"feature_coefficients\": {\n\t\t\t\"input_len\": 0.5\n\t\t}\n\t},\n\t\"output_token_processing_time_us\": 2.0,\n\t\"scheduling_processing_time_us\": 5.0,\n\t\"preemption_processing_time_us\": 3.0\n}`\n\nfunc writeArtifact(t *testing.T, content string) string {\n\tt.Helper()\n\tdir := t.TempDir()\n\tpath := filepath.Join(dir, \"model.json\")\n\tif err := os.WriteFile(path, []byte(content), 0o644); err != nil {\n\t\tt.Fatalf(\"write artifact: %v\", err)\n\t}\n\treturn path\n}\n\nfunc TestLoadStepMLArtifact_Valid(t *testing.T) {\n\tpath := writeArtifact(t, validArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"unexpected error: %v\", err)\n\t}\n\tif art.Version != 1 {\n\t\tt.Errorf(\"version = %d, want 1\", art.Version)\n\t}\n\tif art.StepTime.Intercept != 100.0 {\n\t\tt.Errorf(\"step_time intercept = %f, want 100.0\", art.StepTime.Intercept)\n\t}\n\tif art.StepTime.FeatureCoefficients[\"prefill_tokens\"] != 50.0 {\n\t\tt.Errorf(\"prefill_tokens coeff = %f, want 50.0\", art.StepTime.FeatureCoefficients[\"prefill_tokens\"])\n\t}\n}\n\nfunc TestLoadStepMLArtifact_MissingFile(t *testing.T) {\n\t_, err := LoadStepMLArtifact(\"/nonexistent/path.json\")\n\tif err == nil {\n\t\tt.Fatal(\"expected error for missing file\")\n\t}\n}\n\nfunc TestLoadStepMLArtifact_MissingStepTime(t *testing.T) {\n\tpath := writeArtifact(t, `{\"version\": 1}`)\n\t_, err := LoadStepMLArtifact(path)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for missing step_time\")\n\t}\n}\n\nfunc TestLoadStepMLArtifact_InvalidVersion(t *testing.T) {\n\tpath := writeArtifact(t, `{\"version\": 0, \"step_time\": {\"model_type\": \"linear\", \"intercept\": 0}}`)\n\t_, err := LoadStepMLArtifact(path)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for version 0\")\n\t}\n}\n\nfunc TestLoadStepMLArtifact_NaNCoefficient(t *testing.T) {\n\t// JSON doesn't support NaN natively; test via a model type error instead\n\tpath := writeArtifact(t, `{\"version\": 1, \"step_time\": {\"model_type\": \"neural_net\", \"intercept\": 0}}`)\n\t_, err := LoadStepMLArtifact(path)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for unsupported model_type\")\n\t}\n}\n\nfunc TestStepMLLatencyModel_StepTime(t *testing.T) {\n\tpath := writeArtifact(t, validArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"load artifact: %v\", err)\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\t// Batch: 1 prefill request (100 new tokens), 2 decode requests (1 new token each)\n\tbatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},  // prefill\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1}, // decode\n\t\t{InputTokens: make([]int, 80), OutputTokens: make([]int, 30), ProgressIndex: 110, NumNewTokens: 1},  // decode\n\t}\n\n\t// Expected: 100 (intercept) + 50*100 (prefill) + 5*2 (decode) = 100 + 5000 + 10 = 5110\n\tgot := model.StepTime(batch)\n\tif got != 5110 {\n\t\tt.Errorf(\"StepTime = %d, want 5110\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_StepTime_Positive(t *testing.T) {\n\t// Test INV-M-1: predictions are always positive\n\tart := &StepMLArtifact{\n\t\tVersion: 1,\n\t\tStepTime: &LinearModel{\n\t\t\tModelType:           \"linear\",\n\t\t\tIntercept:           -1000,\n\t\t\tFeatureCoefficients: map[string]float64{},\n\t\t},\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\tgot := model.StepTime([]*sim.Request{})\n\tif got < 1 {\n\t\tt.Errorf(\"StepTime = %d, want >= 1 (INV-M-1)\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_QueueingTime(t *testing.T) {\n\tpath := writeArtifact(t, validArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"load artifact: %v\", err)\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\treq := &sim.Request{InputTokens: make([]int, 200)}\n\t// Expected: 10 (intercept) + 0.5 * 200 = 110\n\tgot := model.QueueingTime(req)\n\tif got != 110 {\n\t\tt.Errorf(\"QueueingTime = %d, want 110\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_QueueingTime_NilModel(t *testing.T) {\n\tart := &StepMLArtifact{\n\t\tVersion:  1,\n\t\tStepTime: &LinearModel{ModelType: \"linear\", Intercept: 10, FeatureCoefficients: map[string]float64{}},\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\tgot := model.QueueingTime(&sim.Request{InputTokens: make([]int, 100)})\n\tif got != 0 {\n\t\tt.Errorf(\"QueueingTime with nil model = %d, want 0\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_ConstantMethods(t *testing.T) {\n\tpath := writeArtifact(t, validArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"load artifact: %v\", err)\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\tif got := model.OutputTokenProcessingTime(); got != 2 {\n\t\tt.Errorf(\"OutputTokenProcessingTime = %d, want 2\", got)\n\t}\n\tif got := model.SchedulingProcessingTime(); got != 5 {\n\t\tt.Errorf(\"SchedulingProcessingTime = %d, want 5\", got)\n\t}\n\tif got := model.PreemptionProcessingTime(); got != 3 {\n\t\tt.Errorf(\"PreemptionProcessingTime = %d, want 3\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_KVFeatures(t *testing.T) {\n\t// Test that KV proxy features (ProgressIndex) are extracted and used\n\tart := &StepMLArtifact{\n\t\tVersion: 1,\n\t\tStepTime: &LinearModel{\n\t\t\tModelType: \"linear\",\n\t\t\tIntercept: 0,\n\t\t\tFeatureCoefficients: map[string]float64{\n\t\t\t\t\"kv_sum\":  0.1,\n\t\t\t\t\"kv_mean\": 10.0,\n\t\t\t\t\"kv_max\":  1.0,\n\t\t\t},\n\t\t},\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\tbatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1},\n\t\t{InputTokens: make([]int, 200), OutputTokens: make([]int, 100), ProgressIndex: 300, NumNewTokens: 1},\n\t}\n\n\t// kv_sum = 150 + 300 = 450 → 450 * 0.1 = 45\n\t// kv_mean = 225 → 225 * 10 = 2250\n\t// kv_max = 300 → 300 * 1 = 300\n\t// total = 45 + 2250 + 300 = 2595\n\tgot := model.StepTime(batch)\n\tif got != 2595 {\n\t\tt.Errorf(\"StepTime with KV features = %d, want 2595\", got)\n\t}\n}\n\nfunc TestExtractBatchFeatures(t *testing.T) {\n\tbatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},   // prefill: 50 < 200\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 1), ProgressIndex: 150, NumNewTokens: 1}, // decode: 150 >= 100\n\t}\n\n\tf := extractBatchFeatures(batch)\n\n\ttests := []struct {\n\t\tname string\n\t\twant float64\n\t}{\n\t\t{\"prefill_tokens\", 100},\n\t\t{\"decode_tokens\", 1},\n\t\t{\"num_prefill_reqs\", 1},\n\t\t{\"num_decode_reqs\", 1},\n\t\t{\"scheduled_tokens\", 101},\n\t\t{\"kv_sum\", 200},    // 50 + 150\n\t\t{\"kv_max\", 150},\n\t\t{\"kv_mean\", 100},   // 200 / 2\n\t}\n\tfor _, tt := range tests {\n\t\tif got := f[tt.name]; got != tt.want {\n\t\t\tt.Errorf(\"feature %q = %f, want %f\", tt.name, got, tt.want)\n\t\t}\n\t}\n}\n\nfunc TestNewLatencyModel_StepMLDispatch(t *testing.T) {\n\tpath := writeArtifact(t, validArtifactJSON)\n\tcoeffs := sim.NewLatencyCoeffs(\n\t\t[]float64{0, 0, 0}, // beta (unused by stepml)\n\t\t[]float64{0, 0, 0}, // alpha (unused by stepml)\n\t)\n\thw := sim.NewModelHardwareConfig(sim.ModelConfig{}, sim.HardwareCalib{}, \"\", \"\", 0, false).\n\t\tWithStepMLModel(path)\n\n\tmodel, err := NewLatencyModel(coeffs, hw)\n\tif err != nil {\n\t\tt.Fatalf(\"NewLatencyModel with StepML: %v\", err)\n\t}\n\n\tif _, ok := model.(*StepMLLatencyModel); !ok {\n\t\tt.Errorf(\"expected *StepMLLatencyModel, got %T\", model)\n\t}\n}\n\n// regimeArtifactJSON has 2 regimes: decode-only and mixed-batch (fallback).\nconst regimeArtifactJSON = `{\n\t\"version\": 2,\n\t\"step_time_regimes\": [\n\t\t{\n\t\t\t\"name\": \"decode_only\",\n\t\t\t\"condition\": {\"feature\": \"prefill_tokens\", \"op\": \"==\", \"value\": 0},\n\t\t\t\"model\": {\n\t\t\t\t\"model_type\": \"linear\",\n\t\t\t\t\"intercept\": 50.0,\n\t\t\t\t\"feature_coefficients\": {\"decode_tokens\": 10.0, \"kv_mean\": 0.5}\n\t\t\t}\n\t\t},\n\t\t{\n\t\t\t\"name\": \"mixed\",\n\t\t\t\"condition\": null,\n\t\t\t\"model\": {\n\t\t\t\t\"model_type\": \"linear\",\n\t\t\t\t\"intercept\": 200.0,\n\t\t\t\t\"feature_coefficients\": {\"prefill_tokens\": 2.0, \"decode_tokens\": 8.0}\n\t\t\t}\n\t\t}\n\t],\n\t\"output_token_processing_time_us\": 1.0,\n\t\"scheduling_processing_time_us\": 2.0,\n\t\"preemption_processing_time_us\": 0.0\n}`\n\nfunc TestStepMLLatencyModel_RegimeDispatch(t *testing.T) {\n\tpath := writeArtifact(t, regimeArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"load regime artifact: %v\", err)\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\t// Decode-only batch: 2 decode requests, 1 new token each\n\tdecodeBatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1},\n\t\t{InputTokens: make([]int, 80), OutputTokens: make([]int, 30), ProgressIndex: 110, NumNewTokens: 1},\n\t}\n\t// prefill_tokens=0 → decode_only regime\n\t// decode_tokens=2, kv_mean=(150+110)/2=130\n\t// Expected: 50 + 10*2 + 0.5*130 = 50 + 20 + 65 = 135\n\tgot := model.StepTime(decodeBatch)\n\tif got != 135 {\n\t\tt.Errorf(\"StepTime(decode_only) = %d, want 135\", got)\n\t}\n\n\t// Mixed batch: 1 prefill + 1 decode\n\tmixedBatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},  // prefill\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 50), ProgressIndex: 150, NumNewTokens: 1}, // decode\n\t}\n\t// prefill_tokens=100 > 0 → mixed regime\n\t// decode_tokens=1\n\t// Expected: 200 + 2*100 + 8*1 = 200 + 200 + 8 = 408\n\tgot = model.StepTime(mixedBatch)\n\tif got != 408 {\n\t\tt.Errorf(\"StepTime(mixed) = %d, want 408\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_RegimeNoStepTime(t *testing.T) {\n\t// Artifact with only regimes (no step_time field) should work\n\tpath := writeArtifact(t, regimeArtifactJSON)\n\tart, err := LoadStepMLArtifact(path)\n\tif err != nil {\n\t\tt.Fatalf(\"load: %v\", err)\n\t}\n\tif art.StepTime != nil {\n\t\tt.Error(\"expected nil step_time when using regimes only\")\n\t}\n\tif len(art.StepTimeRegimes) != 2 {\n\t\tt.Errorf(\"got %d regimes, want 2\", len(art.StepTimeRegimes))\n\t}\n}\n\nfunc TestExtractBatchFeatures_InteractionFeatures(t *testing.T) {\n\tbatch := []*sim.Request{\n\t\t{InputTokens: make([]int, 200), ProgressIndex: 50, NumNewTokens: 100},   // prefill\n\t\t{InputTokens: make([]int, 100), OutputTokens: make([]int, 1), ProgressIndex: 150, NumNewTokens: 1}, // decode\n\t}\n\n\tf := extractBatchFeatures(batch)\n\n\t// prefill_x_decode = 100 * 1 = 100\n\tif got := f[\"prefill_x_decode\"]; got != 100 {\n\t\tt.Errorf(\"prefill_x_decode = %f, want 100\", got)\n\t}\n\t// decode_x_kv_mean = 1 * 100 = 100 (kv_mean = (50+150)/2 = 100)\n\tif got := f[\"decode_x_kv_mean\"]; got != 100 {\n\t\tt.Errorf(\"decode_x_kv_mean = %f, want 100\", got)\n\t}\n\t// prefill_sq = 100 * 100 = 10000\n\tif got := f[\"prefill_sq\"]; got != 10000 {\n\t\tt.Errorf(\"prefill_sq = %f, want 10000\", got)\n\t}\n\t// kv_std: pi values are 50 and 150, mean=100\n\t// variance = ((50-100)^2 + (150-100)^2) / 2 = (2500+2500)/2 = 2500\n\t// std = sqrt(2500) = 50\n\tif got := f[\"kv_std\"]; got != 50 {\n\t\tt.Errorf(\"kv_std = %f, want 50\", got)\n\t}\n}\n\nfunc TestStepMLLatencyModel_OverheadFloorAndCap(t *testing.T) {\n\t// Overhead floor: prediction < overhead → use overhead.\n\t// Overhead cap: prediction > 3*overhead → clamp to 3*overhead.\n\tart := &StepMLArtifact{\n\t\tVersion: 1,\n\t\tStepTime: &LinearModel{\n\t\t\tModelType:           \"linear\",\n\t\t\tIntercept:           100,\n\t\t\tFeatureCoefficients: map[string]float64{\"decode_tokens\": 200},\n\t\t},\n\t\tStepOverheadUs: 5000,\n\t}\n\tmodel := NewStepMLLatencyModel(art)\n\n\t// Small batch: 100 + 200*1 = 300 < 5000 → floored to 5000\n\tsmall := []*sim.Request{\n\t\t{InputTokens: make([]int, 10), OutputTokens: make([]int, 1), ProgressIndex: 10, NumNewTokens: 1},\n\t}\n\tgot := model.StepTime(small)\n\tif got != 5000 {\n\t\tt.Errorf(\"StepTime(small) = %d, want 5000 (overhead floor)\", got)\n\t}\n\n\t// Large batch: 100 + 200*100 = 20100, cap = 3*5000 = 15000 → capped\n\tvar large []*sim.Request\n\tfor i := 0; i < 100; i++ {\n\t\tlarge = append(large, &sim.Request{\n\t\t\tInputTokens: make([]int, 10), OutputTokens: make([]int, 1),\n\t\t\tProgressIndex: 10, NumNewTokens: 1,\n\t\t})\n\t}\n\tgot = model.StepTime(large)\n\tif got != 15000 {\n\t\tt.Errorf(\"StepTime(large) = %d, want 15000 (overhead cap)\", got)\n\t}\n\n\t// Medium batch: 100 + 200*30 = 6100, between floor and cap → use as-is\n\tvar medium []*sim.Request\n\tfor i := 0; i < 30; i++ {\n\t\tmedium = append(medium, &sim.Request{\n\t\t\tInputTokens: make([]int, 10), OutputTokens: make([]int, 1),\n\t\t\tProgressIndex: 10, NumNewTokens: 1,\n\t\t})\n\t}\n\tgot = model.StepTime(medium)\n\tif got != 6100 {\n\t\tt.Errorf(\"StepTime(medium) = %d, want 6100 (between floor and cap)\", got)\n\t}\n}\n\nfunc TestNewLatencyModel_StepMLInvalidPath(t *testing.T) {\n\tcoeffs := sim.NewLatencyCoeffs(\n\t\t[]float64{0, 0, 0},\n\t\t[]float64{0, 0, 0},\n\t)\n\thw := sim.NewModelHardwareConfig(sim.ModelConfig{}, sim.HardwareCalib{}, \"\", \"\", 0, false).\n\t\tWithStepMLModel(\"/nonexistent/model.json\")\n\n\t_, err := NewLatencyModel(coeffs, hw)\n\tif err == nil {\n\t\tt.Fatal(\"expected error for nonexistent StepML model path\")\n\t}\n}\n\nfunc TestNewLatencyModel_RooflineTakesPrecedence(t *testing.T) {\n\t// Verify that roofline dispatch happens before StepML (isolation guarantee)\n\tpath := writeArtifact(t, validArtifactJSON)\n\tcoeffs := sim.NewLatencyCoeffs(\n\t\t[]float64{0, 0, 0},\n\t\t[]float64{0, 0, 0},\n\t)\n\thw := sim.NewModelHardwareConfig(\n\t\tsim.ModelConfig{NumLayers: 32, HiddenDim: 4096, NumHeads: 32, NumKVHeads: 32, VocabSize: 32000, BytesPerParam: 2, IntermediateDim: 11008},\n\t\tsim.HardwareCalib{TFlopsPeak: 989.5, BwPeakTBs: 3.35},\n\t\t\"test-model\", \"H100\", 1, true, // Roofline=true\n\t).WithStepMLModel(path)\n\n\t// This should fail on roofline validation (missing MFU database), NOT try StepML\n\t_, err := NewLatencyModel(coeffs, hw)\n\tif err == nil {\n\t\tt.Fatal(\"expected roofline validation error, not StepML dispatch\")\n\t}\n}\n","numLines":446,"startLine":1,"totalLines":446}}}
