s\": {\n          \"initial\": 7.951495295147041,\n          \"optimized\": 34.54326345010829,\n          \"pct_change\": 334.4247486531338\n        },\n        \"mixed_light_intercept\": {\n          \"initial\": -77.97943712885353,\n          \"optimized\": -705.360949980872,\n          \"pct_change\": -804.5473729379845\n        },\n        \"mixed_light_decode_tokens\": {\n          \"initial\": 8.238725686646465,\n          \"optimized\": 22.46098983352772,\n          \"pct_change\": 172.62698975319765\n        },\n        \"mixed_light_num_decode_reqs\": {\n          \"initial\": 8.238725687421233,\n          \"optimized\": -72.56272687325628,\n          \"pct_change\": -980.7518252979827\n        },\n        \"mixed_light_num_prefill_reqs\": {\n          \"initial\": 48.63455190521838,\n          \"optimized\": 169.1264650417708,\n          \"pct_change\": 247.74961095842625","numLines":80,"startLine":1,"totalLines":2374}}}
