{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01JTLDTodVzaxQnNF7J1MsJ8","type":"tool_result","content":"     1→// Package latency — StepML latency model.\n     2→//\n     3→// StepMLLatencyModel is a data-driven LatencyModel that loads trained model\n     4→// artifacts from a JSON file. It supports linear coefficient models and\n     5→// (future) XGBoost tree ensembles.\n     6→//\n     7→// This is the lightweight research-phase implementation (WP0). Production\n     8→// quality with full INV-M-1 through INV-M-6 validation comes in WP5.\n     9→package latency\n    10→\n    11→import (\n    12→\t\"encoding/json\"\n    13→\t\"fmt\"\n    14→\t\"math\"\n    15→\t\"os\"\n    16→\n    17→\t\"github.com/inference-sim/inference-sim/sim\"\n    18→\t\"github.com/inference-sim/inference-sim/sim/internal/util\"\n    19→)\n    20→\n    21→// StepMLArtifact is the top-level JSON schema for a StepML model artifact.\n    22→type StepMLArtifact struct {\n    23→\tVersion                      int              `json:\"version\"`\n    24→\tStepTime                     *LinearModel     `json:\"step_time\"`\n    25→\tStepTimeRegimes              []RegimeEntry    `json:\"step_time_regimes,omitempty\"`\n    26→\tQueueingTime                 *LinearModel     `json:\"queueing_time,omitempty\"`\n    27→\tStepOverheadUs               float64          `json:\"step_overhead_us\"`\n    28→\tStepOverheadPerReqUs         float64          `json:\"step_overhead_per_req_us\"`\n    29→\tOutputTokenProcessingTimeUs  float64          `json:\"output_token_processing_time_us\"`\n    30→\tSchedulingProcessingTimeUs   float64          `json:\"scheduling_processing_time_us\"`\n    31→\tPreemptionProcessingTimeUs   float64          `json:\"preemption_processing_time_us\"`\n    32→}\n    33→\n    34→// LinearModel represents a linear prediction model: intercept + Σ(coeff_i * feature_i).\n    35→// When OutputTransform is \"expm1\", the prediction is exponentiated: exp(linear) - 1.\n    36→// This supports log-linear models trained on log1p(target).\n    37→type LinearModel struct {\n    38→\tModelType           string             `json:\"model_type\"`\n    39→\tIntercept           float64            `json:\"intercept\"`\n    40→\tFeatureCoefficients map[string]float64 `json:\"feature_coefficients\"`\n    41→\tOutputTransform     string             `json:\"output_transform,omitempty\"`\n    42→}\n    43→\n    44→// RegimeEntry pairs a condition with a linear model for regime-based dispatch.\n    45→// Regimes are evaluated in order; the first matching condition wins.\n    46→// A nil Condition acts as a fallback (matches everything).\n    47→type RegimeEntry struct {\n    48→\tName      string          `json:\"name\"`\n    49→\tCondition *RegimeCondition `json:\"condition\"`\n    50→\tModel     LinearModel     `json:\"model\"`\n    51→}\n    52→\n    53→// RegimeCondition is a simple threshold condition on a batch feature.\n    54→type RegimeCondition struct {\n    55→\tFeature string  `json:\"feature\"`\n    56→\tOp      string  `json:\"op\"` // \"==\", \"<\", \"<=\", \">\", \">=\"\n    57→\tValue   float64 `json:\"value\"`\n    58→}\n    59→\n    60→// StepMLLatencyModel implements sim.LatencyModel using trained artifacts.\n    61→type StepMLLatencyModel struct {\n    62→\tartifact StepMLArtifact\n    63→}\n    64→\n    65→// LoadStepMLArtifact reads and validates a StepML JSON artifact from disk.\n    66→func LoadStepMLArtifact(path string) (*StepMLArtifact, error) {\n    67→\tdata, err := os.ReadFile(path)\n    68→\tif err != nil {\n    69→\t\treturn nil, fmt.Errorf(\"stepml: read artifact %q: %w\", path, err)\n    70→\t}\n    71→\n    72→\tvar art StepMLArtifact\n    73→\tif err := json.Unmarshal(data, &art); err != nil {\n    74→\t\treturn nil, fmt.Errorf(\"stepml: parse artifact %q: %w\", path, err)\n    75→\t}\n    76→\n    77→\tif art.Version < 1 {\n    78→\t\treturn nil, fmt.Errorf(\"stepml: unsupported artifact version %d\", art.Version)\n    79→\t}\n    80→\n    81→\thasRegimes := len(art.StepTimeRegimes) > 0\n    82→\thasSingleModel := art.StepTime != nil\n    83→\n    84→\tif !hasRegimes && !hasSingleModel {\n    85→\t\treturn nil, fmt.Errorf(\"stepml: artifact missing step_time model (provide step_time or step_time_regimes)\")\n    86→\t}\n    87→\n    88→\tif hasSingleModel {\n    89→\t\tif art.StepTime.ModelType != \"linear\" {\n    90→\t\t\treturn nil, fmt.Errorf(\"stepml: unsupported step_time model_type %q (supported: linear)\", art.StepTime.ModelType)\n    91→\t\t}\n    92→\t\tif err := validateLinearModel(\"step_time\", art.StepTime); err != nil {\n    93→\t\t\treturn nil, err\n    94→\t\t}\n    95→\t}\n    96→\n    97→\tfor i, r := range art.StepTimeRegimes {\n    98→\t\tname := fmt.Sprintf(\"step_time_regimes[%d](%s)\", i, r.Name)\n    99→\t\tif err := validateLinearModel(name, &r.Model); err != nil {\n   100→\t\t\treturn nil, err\n   101→\t\t}\n   102→\t\tif r.Condition != nil {\n   103→\t\t\tswitch r.Condition.Op {\n   104→\t\t\tcase \"==\", \"<\", \"<=\", \">\", \">=\":\n   105→\t\t\t\t// valid\n   106→\t\t\tdefault:\n   107→\t\t\t\treturn nil, fmt.Errorf(\"stepml: %s has unsupported condition op %q\", name, r.Condition.Op)\n   108→\t\t\t}\n   109→\t\t}\n   110→\t}\n   111→\n   112→\tif art.QueueingTime != nil {\n   113→\t\tif err := validateLinearModel(\"queueing_time\", art.QueueingTime); err != nil {\n   114→\t\t\treturn nil, err\n   115→\t\t}\n   116→\t}\n   117→\n   118→\treturn &art, nil\n   119→}\n   120→\n   121→func validateLinearModel(name string, m *LinearModel) error {\n   122→\tif math.IsNaN(m.Intercept) || math.IsInf(m.Intercept, 0) {\n   123→\t\treturn fmt.Errorf(\"stepml: %s intercept is NaN/Inf\", name)\n   124→\t}\n   125→\tfor feat, coeff := range m.FeatureCoefficients {\n   126→\t\tif math.IsNaN(coeff) || math.IsInf(coeff, 0) {\n   127→\t\t\treturn fmt.Errorf(\"stepml: %s coefficient %q is NaN/Inf\", name, feat)\n   128→\t\t}\n   129→\t}\n   130→\treturn nil\n   131→}\n   132→\n   133→// NewStepMLLatencyModel creates a StepML LatencyModel from a loaded artifact.\n   134→func NewStepMLLatencyModel(art *StepMLArtifact) *StepMLLatencyModel {\n   135→\treturn &StepMLLatencyModel{artifact: *art}\n   136→}\n   137→\n   138→// extractBatchFeatures computes aggregate features from a batch of requests.\n   139→// These features mirror the ground-truth step-level data schema.\n   140→func extractBatchFeatures(batch []*sim.Request) map[string]float64 {\n   141→\tvar prefillTokens, decodeTokens int64\n   142→\tvar numPrefillReqs, numDecodeReqs int64\n   143→\tvar kvSum, kvMax int64\n   144→\tvar kvCount int64\n   145→\tvar kvSumSq float64 // for kv_std computation\n   146→\n   147→\tfor _, req := range batch {\n   148→\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n   149→\t\t\t// Prefill phase\n   150→\t\t\tprefillTokens += int64(req.NumNewTokens)\n   151→\t\t\tnumPrefillReqs++\n   152→\t\t} else if len(req.OutputTokens) > 0 {\n   153→\t\t\t// Decode phase\n   154→\t\t\tdecodeTokens += int64(req.NumNewTokens)\n   155→\t\t\tnumDecodeReqs++\n   156→\t\t}\n   157→\n   158→\t\t// KV cache proxy features from ProgressIndex\n   159→\t\tpi := req.ProgressIndex\n   160→\t\tkvSum += pi\n   161→\t\tkvSumSq += float64(pi) * float64(pi)\n   162→\t\tkvCount++\n   163→\t\tif pi > kvMax {\n   164→\t\t\tkvMax = pi\n   165→\t\t}\n   166→\t}\n   167→\n   168→\tvar kvMean, kvStd float64\n   169→\tif kvCount > 0 {\n   170→\t\tkvMean = float64(kvSum) / float64(kvCount)\n   171→\t\tif kvCount > 1 {\n   172→\t\t\t// Population std: sqrt(E[X^2] - E[X]^2)\n   173→\t\t\tvariance := kvSumSq/float64(kvCount) - kvMean*kvMean\n   174→\t\t\tif variance > 0 {\n   175→\t\t\t\tkvStd = math.Sqrt(variance)\n   176→\t\t\t}\n   177→\t\t}\n   178→\t}\n   179→\n   180→\tpf := float64(prefillTokens)\n   181→\tdt := float64(decodeTokens)\n   182→\tndr := float64(numDecodeReqs)\n   183→\n   184→\treturn map[string]float64{\n   185→\t\t\"prefill_tokens\":   pf,\n   186→\t\t\"decode_tokens\":    dt,\n   187→\t\t\"num_prefill_reqs\": float64(numPrefillReqs),\n   188→\t\t\"num_decode_reqs\":  ndr,\n   189→\t\t\"scheduled_tokens\": pf + dt,\n   190→\t\t\"kv_sum\":           float64(kvSum),\n   191→\t\t\"kv_max\":           float64(kvMax),\n   192→\t\t\"kv_mean\":          kvMean,\n   193→\t\t\"kv_std\":           kvStd,\n   194→\t\t// Interaction features for regime-specific models\n   195→\t\t\"prefill_x_decode\":  pf * dt,\n   196→\t\t\"decode_x_kv_mean\":  ndr * kvMean,\n   197→\t\t\"prefill_sq\":        pf * pf,\n   198→\t}\n   199→}\n   200→\n   201→// predictLinear evaluates intercept + Σ(coeff_i * features[i]).\n   202→// Features not present in the coefficient map are ignored (zero contribution).\n   203→// When OutputTransform is \"expm1\", applies exp(result) - 1 (inverse of log1p).\n   204→func predictLinear(m *LinearModel, features map[string]float64) float64 {\n   205→\tresult := m.Intercept\n   206→\tfor feat, coeff := range m.FeatureCoefficients {\n   207→\t\tif val, ok := features[feat]; ok {\n   208→\t\t\tresult += coeff * val\n   209→\t\t}\n   210→\t}\n   211→\tif m.OutputTransform == \"expm1\" {\n   212→\t\tresult = math.Expm1(result) // exp(result) - 1\n   213→\t}\n   214→\treturn result\n   215→}\n   216→\n   217→// StepTime estimates batch step execution time in microseconds.\n   218→//\n   219→// The model predicts GPU compute time from batch features. Since the training\n   220→// data only captures GPU forward pass time (step.duration_us), the full step\n   221→// cycle time also includes CPU-side overhead (scheduling, sync, memory management).\n   222→//\n   223→// The overhead is applied as a floor (max) rather than additive because:\n   224→//   - Small batches: overhead-dominated (~4ms); compute is negligible (~100µs)\n   225→//   - Large batches: compute-dominated (~6ms); overhead is negligible\n   226→//   - The transition is at the memory↔compute bound crossover point\n   227→//\n   228→// step_overhead_per_req_us is additive (per-request scheduling cost).\n   229→//\n   230→// When StepTimeRegimes is present, evaluates regimes in order; first match wins.\n   231→// Otherwise falls back to the single StepTime linear model.\n   232→func (s *StepMLLatencyModel) StepTime(batch []*sim.Request) int64 {\n   233→\tfeatures := extractBatchFeatures(batch)\n   234→\n   235→\tvar prediction float64\n   236→\tif len(s.artifact.StepTimeRegimes) > 0 {\n   237→\t\tprediction = s.predictRegime(features)\n   238→\t} else {\n   239→\t\tprediction = predictLinear(s.artifact.StepTime, features)\n   240→\t}\n   241→\n   242→\t// Apply overhead as a floor: step_cycle = max(overhead, compute).\n   243→\t// This models the memory↔compute crossover: at small batches the overhead\n   244→\t// floor dominates; at large batches, compute exceeds the floor naturally.\n   245→\t//\n   246→\t// Also cap at 5x overhead to prevent exponential blowup from the expm1\n   247→\t// transform on outlier feature values. 5x covers the realistic range\n   248→\t// (e.g., 4ms overhead → 20ms cap, well above any real step time).\n   249→\tif s.artifact.StepOverheadUs > 0 {\n   250→\t\tif prediction < s.artifact.StepOverheadUs {\n   251→\t\t\tprediction = s.artifact.StepOverheadUs\n   252→\t\t}\n   253→\t\tmaxStep := s.artifact.StepOverheadUs * 3\n   254→\t\tif prediction > maxStep {\n   255→\t\t\tprediction = maxStep\n   256→\t\t}\n   257→\t}\n   258→\n   259→\t// Per-request overhead is always additive (scheduling cost per request).\n   260→\tif s.artifact.StepOverheadPerReqUs > 0 {\n   261→\t\tbatchSize := features[\"num_prefill_reqs\"] + features[\"num_decode_reqs\"]\n   262→\t\tprediction += s.artifact.StepOverheadPerReqUs * batchSize\n   263→\t}\n   264→\n   265→\tif prediction < 1 {\n   266→\t\tprediction = 1 // INV-M-1: positive predictions\n   267→\t}\n   268→\treturn int64(prediction)\n   269→}\n   270→\n   271→// predictRegime evaluates regime conditions in order and uses the first matching model.\n   272→func (s *StepMLLatencyModel) predictRegime(features map[string]float64) float64 {\n   273→\tfor _, r := range s.artifact.StepTimeRegimes {\n   274→\t\tif r.Condition == nil || evalCondition(r.Condition, features) {\n   275→\t\t\treturn predictLinear(&r.Model, features)\n   276→\t\t}\n   277→\t}\n   278→\t// No regime matched and no fallback — use single model if available\n   279→\tif s.artifact.StepTime != nil {\n   280→\t\treturn predictLinear(s.artifact.StepTime, features)\n   281→\t}\n   282→\treturn 1 // safety fallback\n   283→}\n   284→\n   285→// evalCondition checks a simple threshold condition against feature values.\n   286→func evalCondition(c *RegimeCondition, features map[string]float64) bool {\n   287→\tval := features[c.Feature]\n   288→\tswitch c.Op {\n   289→\tcase \"==\":\n   290→\t\treturn val == c.Value\n   291→\tcase \"<\":\n   292→\t\treturn val < c.Value\n   293→\tcase \"<=\":\n   294→\t\treturn val <= c.Value\n   295→\tcase \">\":\n   296→\t\treturn val > c.Value\n   297→\tcase \">=\":\n   298→\t\treturn val >= c.Value\n   299→\tdefault:\n   300→\t\treturn false\n   301→\t}\n   302→}\n   303→\n   304→// QueueingTime estimates arrival-to-queue delay for a request in microseconds.\n   305→func (s *StepMLLatencyModel) QueueingTime(req *sim.Request) int64 {\n   306→\tif s.artifact.QueueingTime == nil {\n   307→\t\treturn 0\n   308→\t}\n   309→\tfeatures := map[string]float64{\n   310→\t\t\"input_len\": float64(len(req.InputTokens)),\n   311→\t}\n   312→\tprediction := predictLinear(s.artifact.QueueingTime, features)\n   313→\tif prediction < 0 {\n   314→\t\tprediction = 0\n   315→\t}\n   316→\treturn int64(prediction)\n   317→}\n   318→\n   319→// OutputTokenProcessingTime estimates per-token post-processing in microseconds.\n   320→func (s *StepMLLatencyModel) OutputTokenProcessingTime() int64 {\n   321→\tv := s.artifact.OutputTokenProcessingTimeUs\n   322→\tif v < 0 {\n   323→\t\treturn 0\n   324→\t}\n   325→\treturn int64(v)\n   326→}\n   327→\n   328→// SchedulingProcessingTime estimates scheduling overhead per request in microseconds.\n   329→func (s *StepMLLatencyModel) SchedulingProcessingTime() int64 {\n   330→\tv := s.artifact.SchedulingProcessingTimeUs\n   331→\tif v < 0 {\n   332→\t\treturn 0\n   333→\t}\n   334→\treturn int64(v)\n   335→}\n   336→\n   337→// PreemptionProcessingTime estimates preemption overhead per eviction in microseconds.\n   338→func (s *StepMLLatencyModel) PreemptionProcessingTime() int64 {\n   339→\tv := s.artifact.PreemptionProcessingTimeUs\n   340→\tif v < 0 {\n   341→\t\treturn 0\n   342→\t}\n   343→\treturn int64(v)\n   344→}\n   345→"}]},"parent_tool_use_id":null,"session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"1614175c-65cc-44aa-b407-d002f9db1cee","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/BLIS-research/sim/latency/stepml.go","content":"// Package latency — StepML latency model.\n//\n// StepMLLatencyModel is a data-driven LatencyModel that loads trained model\n// artifacts from a JSON file. It supports linear coefficient models and\n// (future) XGBoost tree ensembles.\n//\n// This is the lightweight research-phase implementation (WP0). Production\n// quality with full INV-M-1 through INV-M-6 validation comes in WP5.\npackage latency\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"math\"\n\t\"os\"\n\n\t\"github.com/inference-sim/inference-sim/sim\"\n\t\"github.com/inference-sim/inference-sim/sim/internal/util\"\n)\n\n// StepMLArtifact is the top-level JSON schema for a StepML model artifact.\ntype StepMLArtifact struct {\n\tVersion                      int              `json:\"version\"`\n\tStepTime                     *LinearModel     `json:\"step_time\"`\n\tStepTimeRegimes              []RegimeEntry    `json:\"step_time_regimes,omitempty\"`\n\tQueueingTime                 *LinearModel     `json:\"queueing_time,omitempty\"`\n\tStepOverheadUs               float64          `json:\"step_overhead_us\"`\n\tStepOverheadPerReqUs         float64          `json:\"step_overhead_per_req_us\"`\n\tOutputTokenProcessingTimeUs  float64          `json:\"output_token_processing_time_us\"`\n\tSchedulingProcessingTimeUs   float64          `json:\"scheduling_processing_time_us\"`\n\tPreemptionProcessingTimeUs   float64          `json:\"preemption_processing_time_us\"`\n}\n\n// LinearModel represents a linear prediction model: intercept + Σ(coeff_i * feature_i).\n// When OutputTransform is \"expm1\", the prediction is exponentiated: exp(linear) - 1.\n// This supports log-linear models trained on log1p(target).\ntype LinearModel struct {\n\tModelType           string             `json:\"model_type\"`\n\tIntercept           float64            `json:\"intercept\"`\n\tFeatureCoefficients map[string]float64 `json:\"feature_coefficients\"`\n\tOutputTransform     string             `json:\"output_transform,omitempty\"`\n}\n\n// RegimeEntry pairs a condition with a linear model for regime-based dispatch.\n// Regimes are evaluated in order; the first matching condition wins.\n// A nil Condition acts as a fallback (matches everything).\ntype RegimeEntry struct {\n\tName      string          `json:\"name\"`\n\tCondition *RegimeCondition `json:\"condition\"`\n\tModel     LinearModel     `json:\"model\"`\n}\n\n// RegimeCondition is a simple threshold condition on a batch feature.\ntype RegimeCondition struct {\n\tFeature string  `json:\"feature\"`\n\tOp      string  `json:\"op\"` // \"==\", \"<\", \"<=\", \">\", \">=\"\n\tValue   float64 `json:\"value\"`\n}\n\n// StepMLLatencyModel implements sim.LatencyModel using trained artifacts.\ntype StepMLLatencyModel struct {\n\tartifact StepMLArtifact\n}\n\n// LoadStepMLArtifact reads and validates a StepML JSON artifact from disk.\nfunc LoadStepMLArtifact(path string) (*StepMLArtifact, error) {\n\tdata, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"stepml: read artifact %q: %w\", path, err)\n\t}\n\n\tvar art StepMLArtifact\n\tif err := json.Unmarshal(data, &art); err != nil {\n\t\treturn nil, fmt.Errorf(\"stepml: parse artifact %q: %w\", path, err)\n\t}\n\n\tif art.Version < 1 {\n\t\treturn nil, fmt.Errorf(\"stepml: unsupported artifact version %d\", art.Version)\n\t}\n\n\thasRegimes := len(art.StepTimeRegimes) > 0\n\thasSingleModel := art.StepTime != nil\n\n\tif !hasRegimes && !hasSingleModel {\n\t\treturn nil, fmt.Errorf(\"stepml: artifact missing step_time model (provide step_time or step_time_regimes)\")\n\t}\n\n\tif hasSingleModel {\n\t\tif art.StepTime.ModelType != \"linear\" {\n\t\t\treturn nil, fmt.Errorf(\"stepml: unsupported step_time model_type %q (supported: linear)\", art.StepTime.ModelType)\n\t\t}\n\t\tif err := validateLinearModel(\"step_time\", art.StepTime); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tfor i, r := range art.StepTimeRegimes {\n\t\tname := fmt.Sprintf(\"step_time_regimes[%d](%s)\", i, r.Name)\n\t\tif err := validateLinearModel(name, &r.Model); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tif r.Condition != nil {\n\t\t\tswitch r.Condition.Op {\n\t\t\tcase \"==\", \"<\", \"<=\", \">\", \">=\":\n\t\t\t\t// valid\n\t\t\tdefault:\n\t\t\t\treturn nil, fmt.Errorf(\"stepml: %s has unsupported condition op %q\", name, r.Condition.Op)\n\t\t\t}\n\t\t}\n\t}\n\n\tif art.QueueingTime != nil {\n\t\tif err := validateLinearModel(\"queueing_time\", art.QueueingTime); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn &art, nil\n}\n\nfunc validateLinearModel(name string, m *LinearModel) error {\n\tif math.IsNaN(m.Intercept) || math.IsInf(m.Intercept, 0) {\n\t\treturn fmt.Errorf(\"stepml: %s intercept is NaN/Inf\", name)\n\t}\n\tfor feat, coeff := range m.FeatureCoefficients {\n\t\tif math.IsNaN(coeff) || math.IsInf(coeff, 0) {\n\t\t\treturn fmt.Errorf(\"stepml: %s coefficient %q is NaN/Inf\", name, feat)\n\t\t}\n\t}\n\treturn nil\n}\n\n// NewStepMLLatencyModel creates a StepML LatencyModel from a loaded artifact.\nfunc NewStepMLLatencyModel(art *StepMLArtifact) *StepMLLatencyModel {\n\treturn &StepMLLatencyModel{artifact: *art}\n}\n\n// extractBatchFeatures computes aggregate features from a batch of requests.\n// These features mirror the ground-truth step-level data schema.\nfunc extractBatchFeatures(batch []*sim.Request) map[string]float64 {\n\tvar prefillTokens, decodeTokens int64\n\tvar numPrefillReqs, numDecodeReqs int64\n\tvar kvSum, kvMax int64\n\tvar kvCount int64\n\tvar kvSumSq float64 // for kv_std computation\n\n\tfor _, req := range batch {\n\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n\t\t\t// Prefill phase\n\t\t\tprefillTokens += int64(req.NumNewTokens)\n\t\t\tnumPrefillReqs++\n\t\t} else if len(req.OutputTokens) > 0 {\n\t\t\t// Decode phase\n\t\t\tdecodeTokens += int64(req.NumNewTokens)\n\t\t\tnumDecodeReqs++\n\t\t}\n\n\t\t// KV cache proxy features from ProgressIndex\n\t\tpi := req.ProgressIndex\n\t\tkvSum += pi\n\t\tkvSumSq += float64(pi) * float64(pi)\n\t\tkvCount++\n\t\tif pi > kvMax {\n\t\t\tkvMax = pi\n\t\t}\n\t}\n\n\tvar kvMean, kvStd float64\n\tif kvCount > 0 {\n\t\tkvMean = float64(kvSum) / float64(kvCount)\n\t\tif kvCount > 1 {\n\t\t\t// Population std: sqrt(E[X^2] - E[X]^2)\n\t\t\tvariance := kvSumSq/float64(kvCount) - kvMean*kvMean\n\t\t\tif variance > 0 {\n\t\t\t\tkvStd = math.Sqrt(variance)\n\t\t\t}\n\t\t}\n\t}\n\n\tpf := float64(prefillTokens)\n\tdt := float64(decodeTokens)\n\tndr := float64(numDecodeReqs)\n\n\treturn map[string]float64{\n\t\t\"prefill_tokens\":   pf,\n\t\t\"decode_tokens\":    dt,\n\t\t\"num_prefill_reqs\": float64(numPrefillReqs),\n\t\t\"num_decode_reqs\":  ndr,\n\t\t\"scheduled_tokens\": pf + dt,\n\t\t\"kv_sum\":           float64(kvSum),\n\t\t\"kv_max\":           float64(kvMax),\n\t\t\"kv_mean\":          kvMean,\n\t\t\"kv_std\":           kvStd,\n\t\t// Interaction features for regime-specific models\n\t\t\"prefill_x_decode\":  pf * dt,\n\t\t\"decode_x_kv_mean\":  ndr * kvMean,\n\t\t\"prefill_sq\":        pf * pf,\n\t}\n}\n\n// predictLinear evaluates intercept + Σ(coeff_i * features[i]).\n// Features not present in the coefficient map are ignored (zero contribution).\n// When OutputTransform is \"expm1\", applies exp(result) - 1 (inverse of log1p).\nfunc predictLinear(m *LinearModel, features map[string]float64) float64 {\n\tresult := m.Intercept\n\tfor feat, coeff := range m.FeatureCoefficients {\n\t\tif val, ok := features[feat]; ok {\n\t\t\tresult += coeff * val\n\t\t}\n\t}\n\tif m.OutputTransform == \"expm1\" {\n\t\tresult = math.Expm1(result) // exp(result) - 1\n\t}\n\treturn result\n}\n\n// StepTime estimates batch step execution time in microseconds.\n//\n// The model predicts GPU compute time from batch features. Since the training\n// data only captures GPU forward pass time (step.duration_us), the full step\n// cycle time also includes CPU-side overhead (scheduling, sync, memory management).\n//\n// The overhead is applied as a floor (max) rather than additive because:\n//   - Small batches: overhead-dominated (~4ms); compute is negligible (~100µs)\n//   - Large batches: compute-dominated (~6ms); overhead is negligible\n//   - The transition is at the memory↔compute bound crossover point\n//\n// step_overhead_per_req_us is additive (per-request scheduling cost).\n//\n// When StepTimeRegimes is present, evaluates regimes in order; first match wins.\n// Otherwise falls back to the single StepTime linear model.\nfunc (s *StepMLLatencyModel) StepTime(batch []*sim.Request) int64 {\n\tfeatures := extractBatchFeatures(batch)\n\n\tvar prediction float64\n\tif len(s.artifact.StepTimeRegimes) > 0 {\n\t\tprediction = s.predictRegime(features)\n\t} else {\n\t\tprediction = predictLinear(s.artifact.StepTime, features)\n\t}\n\n\t// Apply overhead as a floor: step_cycle = max(overhead, compute).\n\t// This models the memory↔compute crossover: at small batches the overhead\n\t// floor dominates; at large batches, compute exceeds the floor naturally.\n\t//\n\t// Also cap at 5x overhead to prevent exponential blowup from the expm1\n\t// transform on outlier feature values. 5x covers the realistic range\n\t// (e.g., 4ms overhead → 20ms cap, well above any real step time).\n\tif s.artifact.StepOverheadUs > 0 {\n\t\tif prediction < s.artifact.StepOverheadUs {\n\t\t\tprediction = s.artifact.StepOverheadUs\n\t\t}\n\t\tmaxStep := s.artifact.StepOverheadUs * 3\n\t\tif prediction > maxStep {\n\t\t\tprediction = maxStep\n\t\t}\n\t}\n\n\t// Per-request overhead is always additive (scheduling cost per request).\n\tif s.artifact.StepOverheadPerReqUs > 0 {\n\t\tbatchSize := features[\"num_prefill_reqs\"] + features[\"num_decode_reqs\"]\n\t\tprediction += s.artifact.StepOverheadPerReqUs * batchSize\n\t}\n\n\tif prediction < 1 {\n\t\tprediction = 1 // INV-M-1: positive predictions\n\t}\n\treturn int64(prediction)\n}\n\n// predictRegime evaluates regime conditions in order and uses the first matching model.\nfunc (s *StepMLLatencyModel) predictRegime(features map[string]float64) float64 {\n\tfor _, r := range s.artifact.StepTimeRegimes {\n\t\tif r.Condition == nil || evalCondition(r.Condition, features) {\n\t\t\treturn predictLinear(&r.Model, features)\n\t\t}\n\t}\n\t// No regime matched and no fallback — use single model if available\n\tif s.artifact.StepTime != nil {\n\t\treturn predictLinear(s.artifact.StepTime, features)\n\t}\n\treturn 1 // safety fallback\n}\n\n// evalCondition checks a simple threshold condition against feature values.\nfunc evalCondition(c *RegimeCondition, features map[string]float64) bool {\n\tval := features[c.Feature]\n\tswitch c.Op {\n\tcase \"==\":\n\t\treturn val == c.Value\n\tcase \"<\":\n\t\treturn val < c.Value\n\tcase \"<=\":\n\t\treturn val <= c.Value\n\tcase \">\":\n\t\treturn val > c.Value\n\tcase \">=\":\n\t\treturn val >= c.Value\n\tdefault:\n\t\treturn false\n\t}\n}\n\n// QueueingTime estimates arrival-to-queue delay for a request in microseconds.\nfunc (s *StepMLLatencyModel) QueueingTime(req *sim.Request) int64 {\n\tif s.artifact.QueueingTime == nil {\n\t\treturn 0\n\t}\n\tfeatures := map[string]float64{\n\t\t\"input_len\": float64(len(req.InputTokens)),\n\t}\n\tprediction := predictLinear(s.artifact.QueueingTime, features)\n\tif prediction < 0 {\n\t\tprediction = 0\n\t}\n\treturn int64(prediction)\n}\n\n// OutputTokenProcessingTime estimates per-token post-processing in microseconds.\nfunc (s *StepMLLatencyModel) OutputTokenProcessingTime() int64 {\n\tv := s.artifact.OutputTokenProcessingTimeUs\n\tif v < 0 {\n\t\treturn 0\n\t}\n\treturn int64(v)\n}\n\n// SchedulingProcessingTime estimates scheduling overhead per request in microseconds.\nfunc (s *StepMLLatencyModel) SchedulingProcessingTime() int64 {\n\tv := s.artifact.SchedulingProcessingTimeUs\n\tif v < 0 {\n\t\treturn 0\n\t}\n\treturn int64(v)\n}\n\n// PreemptionProcessingTime estimates preemption overhead per eviction in microseconds.\nfunc (s *StepMLLatencyModel) PreemptionProcessingTime() int64 {\n\tv := s.artifact.PreemptionProcessingTimeUs\n\tif v < 0 {\n\t\treturn 0\n\t}\n\treturn int64(v)\n}\n","numLines":345,"startLine":1,"totalLines":345}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01RwwosmQJJmx1tKFYwNBFcR","type":"tool_result","content":"     1→// Package latency provides latency model implementations for the BLIS simulator.\n     2→// The LatencyModel interface is defined in sim/ (parent package).\n     3→// This package provides BlackboxLatencyModel (alpha/beta regression) and\n     4→// RooflineLatencyModel (analytical FLOPs/bandwidth).\n     5→package latency\n     6→\n     7→import (\n     8→\t\"fmt\"\n     9→\t\"math\"\n    10→\n    11→\t\"github.com/inference-sim/inference-sim/sim\"\n    12→\t\"github.com/inference-sim/inference-sim/sim/internal/util\"\n    13→)\n    14→\n    15→// BlackboxLatencyModel estimates latency using trained alpha/beta regression coefficients.\n    16→// Beta coefficients estimate step time: beta0 + beta1*cacheMissTokens + beta2*decodeTokens.\n    17→// Alpha coefficients estimate overheads: alpha0 + alpha1*inputLen (queueing), alpha2 (output processing).\n    18→type BlackboxLatencyModel struct {\n    19→\tbetaCoeffs  []float64\n    20→\talphaCoeffs []float64\n    21→}\n    22→\n    23→func (m *BlackboxLatencyModel) StepTime(batch []*sim.Request) int64 {\n    24→\tvar totalCacheMissTokens, totalDecodeTokens int64\n    25→\tfor _, req := range batch {\n    26→\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n    27→\t\t\t// Prefill phase: NumNewTokens are cache-miss tokens\n    28→\t\t\ttotalCacheMissTokens += int64(req.NumNewTokens)\n    29→\t\t} else if len(req.OutputTokens) > 0 {\n    30→\t\t\t// Decode phase: NumNewTokens is 1 (set by FormBatch)\n    31→\t\t\ttotalDecodeTokens += int64(req.NumNewTokens)\n    32→\t\t}\n    33→\t}\n    34→\tvar totalStepTime float64\n    35→\ttotalStepTime += m.betaCoeffs[0]\n    36→\ttotalStepTime += m.betaCoeffs[1] * float64(totalCacheMissTokens)\n    37→\ttotalStepTime += m.betaCoeffs[2] * float64(totalDecodeTokens)\n    38→\treturn int64(totalStepTime)\n    39→}\n    40→\n    41→func (m *BlackboxLatencyModel) QueueingTime(req *sim.Request) int64 {\n    42→\tvar totalProcessingTime float64\n    43→\ttotalProcessingTime += m.alphaCoeffs[0]\n    44→\ttotalProcessingTime += m.alphaCoeffs[1] * float64(len(req.InputTokens))\n    45→\treturn int64(totalProcessingTime)\n    46→}\n    47→\n    48→func (m *BlackboxLatencyModel) OutputTokenProcessingTime() int64 {\n    49→\treturn int64(m.alphaCoeffs[2])\n    50→}\n    51→\n    52→func (m *BlackboxLatencyModel) SchedulingProcessingTime() int64 {\n    53→\treturn 0\n    54→}\n    55→\n    56→func (m *BlackboxLatencyModel) PreemptionProcessingTime() int64 {\n    57→\treturn 0\n    58→}\n    59→\n    60→// RooflineLatencyModel estimates latency using analytical FLOPs/bandwidth roofline model.\n    61→// Step time is computed via rooflineStepTime(); overhead estimates use alpha coefficients.\n    62→// In v2 mode (mfuDB != nil), MFU values are looked up from benchmark data instead of\n    63→// using static constants.\n    64→type RooflineLatencyModel struct {\n    65→\tmodelConfig sim.ModelConfig\n    66→\thwConfig    sim.HardwareCalib\n    67→\tmfuDB       *sim.MFUDatabase\n    68→\tgpu         string\n    69→\ttp          int\n    70→\talphaCoeffs []float64\n    71→}\n    72→\n    73→func (m *RooflineLatencyModel) StepTime(batch []*sim.Request) int64 {\n    74→\tstepConfig := StepConfig{\n    75→\t\tPrefillRequests: make([]PrefillRequestConfig, 0, len(batch)),\n    76→\t\tDecodeRequests:  make([]DecodeRequestConfig, 0, len(batch)),\n    77→\t}\n    78→\tfor _, req := range batch {\n    79→\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n    80→\t\t\tstepConfig.PrefillRequests = append(stepConfig.PrefillRequests, PrefillRequestConfig{\n    81→\t\t\t\tProgressIndex:       req.ProgressIndex,\n    82→\t\t\t\tNumNewPrefillTokens: req.NumNewTokens,\n    83→\t\t\t})\n    84→\t\t} else if len(req.OutputTokens) > 0 {\n    85→\t\t\tstepConfig.DecodeRequests = append(stepConfig.DecodeRequests, DecodeRequestConfig{\n    86→\t\t\t\tProgressIndex:      req.ProgressIndex,\n    87→\t\t\t\tNumNewDecodeTokens: req.NumNewTokens,\n    88→\t\t\t})\n    89→\t\t}\n    90→\t}\n    91→\treturn rooflineStepTime(m.gpu, m.modelConfig, m.hwConfig, stepConfig, m.tp, m.mfuDB)\n    92→}\n    93→\n    94→func (m *RooflineLatencyModel) QueueingTime(req *sim.Request) int64 {\n    95→\tvar totalProcessingTime float64\n    96→\ttotalProcessingTime += m.alphaCoeffs[0]\n    97→\ttotalProcessingTime += m.alphaCoeffs[1] * float64(len(req.InputTokens))\n    98→\treturn int64(totalProcessingTime)\n    99→}\n   100→\n   101→func (m *RooflineLatencyModel) OutputTokenProcessingTime() int64 {\n   102→\treturn int64(m.alphaCoeffs[2])\n   103→}\n   104→\n   105→func (m *RooflineLatencyModel) SchedulingProcessingTime() int64 {\n   106→\treturn 0\n   107→}\n   108→\n   109→func (m *RooflineLatencyModel) PreemptionProcessingTime() int64 {\n   110→\treturn 0\n   111→}\n   112→\n   113→// validateCoeffs checks for NaN or Inf in a coefficient slice.\n   114→func validateCoeffs(name string, coeffs []float64) error {\n   115→\tfor i, c := range coeffs {\n   116→\t\tif math.IsNaN(c) {\n   117→\t\t\treturn fmt.Errorf(\"latency model: %s[%d] is NaN\", name, i)\n   118→\t\t}\n   119→\t\tif math.IsInf(c, 0) {\n   120→\t\t\treturn fmt.Errorf(\"latency model: %s[%d] is Inf\", name, i)\n   121→\t\t}\n   122→\t}\n   123→\treturn nil\n   124→}\n   125→\n   126→// NewLatencyModel creates the appropriate LatencyModel based on config.\n   127→// Returns RooflineLatencyModel if hw.Roofline is true, BlackboxLatencyModel otherwise.\n   128→// Returns error if coefficient slices are too short, contain NaN/Inf, or roofline config validation fails.\n   129→func NewLatencyModel(coeffs sim.LatencyCoeffs, hw sim.ModelHardwareConfig) (sim.LatencyModel, error) {\n   130→\t// Both implementations index alphaCoeffs[0..2]; validate upfront.\n   131→\tif len(coeffs.AlphaCoeffs) < 3 {\n   132→\t\treturn nil, fmt.Errorf(\"latency model: AlphaCoeffs requires at least 3 elements, got %d\", len(coeffs.AlphaCoeffs))\n   133→\t}\n   134→\tif err := validateCoeffs(\"AlphaCoeffs\", coeffs.AlphaCoeffs); err != nil {\n   135→\t\treturn nil, err\n   136→\t}\n   137→\tif hw.Roofline {\n   138→\t\tif hw.TP <= 0 {\n   139→\t\t\treturn nil, fmt.Errorf(\"latency model: roofline requires TP > 0, got %d\", hw.TP)\n   140→\t\t}\n   141→\t\tif err := ValidateRooflineConfig(hw.ModelConfig, hw.HWConfig); err != nil {\n   142→\t\t\treturn nil, fmt.Errorf(\"latency model: %w\", err)\n   143→\t\t}\n   144→\t\tif hw.MFUDatabase == nil {\n   145→\t\t\treturn nil, fmt.Errorf(\"latency model: roofline requires MFUDatabase (bench_data); provide --bench-data-path or ensure bench_data/ is bundled\")\n   146→\t\t}\n   147→\t\treturn &RooflineLatencyModel{\n   148→\t\t\tmodelConfig: hw.ModelConfig,\n   149→\t\t\thwConfig:    hw.HWConfig,\n   150→\t\t\tmfuDB:       hw.MFUDatabase,\n   151→\t\t\tgpu:         hw.GPU,\n   152→\t\t\ttp:          hw.TP,\n   153→\t\t\talphaCoeffs: coeffs.AlphaCoeffs,\n   154→\t\t}, nil\n   155→\t}\n   156→\t// StepML model: dispatched when artifact path is configured.\n   157→\tif hw.StepMLModelPath != \"\" {\n   158→\t\tart, err := LoadStepMLArtifact(hw.StepMLModelPath)\n   159→\t\tif err != nil {\n   160→\t\t\treturn nil, fmt.Errorf(\"latency model: %w\", err)\n   161→\t\t}\n   162→\t\treturn NewStepMLLatencyModel(art), nil\n   163→\t}\n   164→\n   165→\t// BlackboxLatencyModel indexes betaCoeffs[0..2]; validate upfront.\n   166→\tif len(coeffs.BetaCoeffs) < 3 {\n   167→\t\treturn nil, fmt.Errorf(\"latency model: BetaCoeffs requires at least 3 elements, got %d\", len(coeffs.BetaCoeffs))\n   168→\t}\n   169→\tif err := validateCoeffs(\"BetaCoeffs\", coeffs.BetaCoeffs); err != nil {\n   170→\t\treturn nil, err\n   171→\t}\n   172→\treturn &BlackboxLatencyModel{\n   173→\t\tbetaCoeffs:  coeffs.BetaCoeffs,\n   174→\t\talphaCoeffs: coeffs.AlphaCoeffs,\n   175→\t}, nil\n   176→}\n   177→"}]},"parent_tool_use_id":null,"session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"0f46b717-e879-42ae-98b5-ab1bfbf4ef46","tool_use_result":{"type":"text","file":{"filePath":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/BLIS-research/sim/latency/latency.go","content":"// Package latency provides latency model implementations for the BLIS simulator.\n// The LatencyModel interface is defined in sim/ (parent package).\n// This package provides BlackboxLatencyModel (alpha/beta regression) and\n// RooflineLatencyModel (analytical FLOPs/bandwidth).\npackage latency\n\nimport (\n\t\"fmt\"\n\t\"math\"\n\n\t\"github.com/inference-sim/inference-sim/sim\"\n\t\"github.com/inference-sim/inference-sim/sim/internal/util\"\n)\n\n// BlackboxLatencyModel estimates latency using trained alpha/beta regression coefficients.\n// Beta coefficients estimate step time: beta0 + beta1*cacheMissTokens + beta2*decodeTokens.\n// Alpha coefficients estimate overheads: alpha0 + alpha1*inputLen (queueing), alpha2 (output processing).\ntype BlackboxLatencyModel struct {\n\tbetaCoeffs  []float64\n\talphaCoeffs []float64\n}\n\nfunc (m *BlackboxLatencyModel) StepTime(batch []*sim.Request) int64 {\n\tvar totalCacheMissTokens, totalDecodeTokens int64\n\tfor _, req := range batch {\n\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n\t\t\t// Prefill phase: NumNewTokens are cache-miss tokens\n\t\t\ttotalCacheMissTokens += int64(req.NumNewTokens)\n\t\t} else if len(req.OutputTokens) > 0 {\n\t\t\t// Decode phase: NumNewTokens is 1 (set by FormBatch)\n\t\t\ttotalDecodeTokens += int64(req.NumNewTokens)\n\t\t}\n\t}\n\tvar totalStepTime float64\n\ttotalStepTime += m.betaCoeffs[0]\n\ttotalStepTime += m.betaCoeffs[1] * float64(totalCacheMissTokens)\n\ttotalStepTime += m.betaCoeffs[2] * float64(totalDecodeTokens)\n\treturn int64(totalStepTime)\n}\n\nfunc (m *BlackboxLatencyModel) QueueingTime(req *sim.Request) int64 {\n\tvar totalProcessingTime float64\n\ttotalProcessingTime += m.alphaCoeffs[0]\n\ttotalProcessingTime += m.alphaCoeffs[1] * float64(len(req.InputTokens))\n\treturn int64(totalProcessingTime)\n}\n\nfunc (m *BlackboxLatencyModel) OutputTokenProcessingTime() int64 {\n\treturn int64(m.alphaCoeffs[2])\n}\n\nfunc (m *BlackboxLatencyModel) SchedulingProcessingTime() int64 {\n\treturn 0\n}\n\nfunc (m *BlackboxLatencyModel) PreemptionProcessingTime() int64 {\n\treturn 0\n}\n\n// RooflineLatencyModel estimates latency using analytical FLOPs/bandwidth roofline model.\n// Step time is computed via rooflineStepTime(); overhead estimates use alpha coefficients.\n// In v2 mode (mfuDB != nil), MFU values are looked up from benchmark data instead of\n// using static constants.\ntype RooflineLatencyModel struct {\n\tmodelConfig sim.ModelConfig\n\thwConfig    sim.HardwareCalib\n\tmfuDB       *sim.MFUDatabase\n\tgpu         string\n\ttp          int\n\talphaCoeffs []float64\n}\n\nfunc (m *RooflineLatencyModel) StepTime(batch []*sim.Request) int64 {\n\tstepConfig := StepConfig{\n\t\tPrefillRequests: make([]PrefillRequestConfig, 0, len(batch)),\n\t\tDecodeRequests:  make([]DecodeRequestConfig, 0, len(batch)),\n\t}\n\tfor _, req := range batch {\n\t\tif req.ProgressIndex < util.Len64(req.InputTokens) {\n\t\t\tstepConfig.PrefillRequests = append(stepConfig.PrefillRequests, PrefillRequestConfig{\n\t\t\t\tProgressIndex:       req.ProgressIndex,\n\t\t\t\tNumNewPrefillTokens: req.NumNewTokens,\n\t\t\t})\n\t\t} else if len(req.OutputTokens) > 0 {\n\t\t\tstepConfig.DecodeRequests = append(stepConfig.DecodeRequests, DecodeRequestConfig{\n\t\t\t\tProgressIndex:      req.ProgressIndex,\n\t\t\t\tNumNewDecodeTokens: req.NumNewTokens,\n\t\t\t})\n\t\t}\n\t}\n\treturn rooflineStepTime(m.gpu, m.modelConfig, m.hwConfig, stepConfig, m.tp, m.mfuDB)\n}\n\nfunc (m *RooflineLatencyModel) QueueingTime(req *sim.Request) int64 {\n\tvar totalProcessingTime float64\n\ttotalProcessingTime += m.alphaCoeffs[0]\n\ttotalProcessingTime += m.alphaCoeffs[1] * float64(len(req.InputTokens))\n\treturn int64(totalProcessingTime)\n}\n\nfunc (m *RooflineLatencyModel) OutputTokenProcessingTime() int64 {\n\treturn int64(m.alphaCoeffs[2])\n}\n\nfunc (m *RooflineLatencyModel) SchedulingProcessingTime() int64 {\n\treturn 0\n}\n\nfunc (m *RooflineLatencyModel) PreemptionProcessingTime() int64 {\n\treturn 0\n}\n\n// validateCoeffs checks for NaN or Inf in a coefficient slice.\nfunc validateCoeffs(name string, coeffs []float64) error {\n\tfor i, c := range coeffs {\n\t\tif math.IsNaN(c) {\n\t\t\treturn fmt.Errorf(\"latency model: %s[%d] is NaN\", name, i)\n\t\t}\n\t\tif math.IsInf(c, 0) {\n\t\t\treturn fmt.Errorf(\"latency model: %s[%d] is Inf\", name, i)\n\t\t}\n\t}\n\treturn nil\n}\n\n// NewLatencyModel creates the appropriate LatencyModel based on config.\n// Returns RooflineLatencyModel if hw.Roofline is true, BlackboxLatencyModel otherwise.\n// Returns error if coefficient slices are too short, contain NaN/Inf, or roofline config validation fails.\nfunc NewLatencyModel(coeffs sim.LatencyCoeffs, hw sim.ModelHardwareConfig) (sim.LatencyModel, error) {\n\t// Both implementations index alphaCoeffs[0..2]; validate upfront.\n\tif len(coeffs.AlphaCoeffs) < 3 {\n\t\treturn nil, fmt.Errorf(\"latency model: AlphaCoeffs requires at least 3 elements, got %d\", len(coeffs.AlphaCoeffs))\n\t}\n\tif err := validateCoeffs(\"AlphaCoeffs\", coeffs.AlphaCoeffs); err != nil {\n\t\treturn nil, err\n\t}\n\tif hw.Roofline {\n\t\tif hw.TP <= 0 {\n\t\t\treturn nil, fmt.Errorf(\"latency model: roofline requires TP > 0, got %d\", hw.TP)\n\t\t}\n\t\tif err := ValidateRooflineConfig(hw.ModelConfig, hw.HWConfig); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"latency model: %w\", err)\n\t\t}\n\t\tif hw.MFUDatabase == nil {\n\t\t\treturn nil, fmt.Errorf(\"latency model: roofline requires MFUDatabase (bench_data); provide --bench-data-path or ensure bench_data/ is bundled\")\n\t\t}\n\t\treturn &RooflineLatencyModel{\n\t\t\tmodelConfig: hw.ModelConfig,\n\t\t\thwConfig:    hw.HWConfig,\n\t\t\tmfuDB:       hw.MFUDatabase,\n\t\t\tgpu:         hw.GPU,\n\t\t\ttp:          hw.TP,\n\t\t\talphaCoeffs: coeffs.AlphaCoeffs,\n\t\t}, nil\n\t}\n\t// StepML model: dispatched when artifact path is configured.\n\tif hw.StepMLModelPath != \"\" {\n\t\tart, err := LoadStepMLArtifact(hw.StepMLModelPath)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"latency model: %w\", err)\n\t\t}\n\t\treturn NewStepMLLatencyModel(art), nil\n\t}\n\n\t// BlackboxLatencyModel indexes betaCoeffs[0..2]; validate upfront.\n\tif len(coeffs.BetaCoeffs) < 3 {\n\t\treturn nil, fmt.Errorf(\"latency model: BetaCoeffs requires at least 3 elements, got %d\", len(coeffs.BetaCoeffs))\n\t}\n\tif err := validateCoeffs(\"BetaCoeffs\", coeffs.BetaCoeffs); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &BlackboxLatencyModel{\n\t\tbetaCoeffs:  coeffs.BetaCoeffs,\n\t\talphaCoeffs: coeffs.AlphaCoeffs,\n\t}, nil\n}\n","numLines":177,"startLine":1,"totalLines":177}}}
