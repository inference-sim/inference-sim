{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_0165qML2za1FUNFtRVUKQyXg","type":"tool_result","content":"     1→\"\"\"Sampling bias characterization for StepML ground truth data.\n     2→\n     3→The ground truth dataset uses step_tracing_sample_rate=0.1, meaning only ~10%\n     4→of steps are traced. This module characterizes whether the sampling introduces\n     5→systematic bias (e.g., periodic sampling, uneven experiment coverage).\n     6→\"\"\"\n     7→\n     8→import numpy as np\n     9→import pandas as pd\n    10→\n    11→\n    12→def characterize_sampling(df: pd.DataFrame) -> dict:\n    13→    \"\"\"Characterize sampling patterns in the ground truth step data.\n    14→\n    15→    Analyzes the step.id gaps within each experiment to determine whether\n    16→    the 10% sampling is periodic (every Nth step) or random/pseudo-random,\n    17→    and whether all experiments are represented uniformly.\n    18→\n    19→    Args:\n    20→        df: DataFrame from load_all_experiments() with columns including\n    21→            'experiment_id' and 'step.id'.\n    22→\n    23→    Returns:\n    24→        dict with keys:\n    25→            - total_steps: int -- total rows loaded\n    26→            - per_experiment_counts: dict[str, int] -- row count per experiment_id\n    27→            - step_id_gaps: dict -- per-experiment gap statistics (mean, std, min, max)\n    28→            - is_periodic: bool -- True if any experiment has gap std < 0.5\n    29→            - coverage_uniformity: float -- coefficient of variation of per-experiment counts\n    30→            - summary: str -- human-readable summary of findings\n    31→    \"\"\"\n    32→    total_steps = len(df)\n    33→\n    34→    # Per-experiment step counts\n    35→    per_experiment_counts = df.groupby(\"experiment_id\").size().to_dict()\n    36→\n    37→    # Per-experiment step.id gap analysis\n    38→    step_id_gaps = {}\n    39→    any_periodic = False\n    40→\n    41→    for exp_id, group in df.groupby(\"experiment_id\"):\n    42→        step_ids = group[\"step.id\"].sort_values().reset_index(drop=True)\n    43→        gaps = step_ids.diff().dropna()\n    44→\n    45→        gap_mean = float(gaps.mean())\n    46→        gap_std = float(gaps.std())\n    47→        gap_min = int(gaps.min())\n    48→        gap_max = int(gaps.max())\n    49→\n    50→        step_id_gaps[exp_id] = {\n    51→            \"mean\": gap_mean,\n    52→            \"std\": gap_std,\n    53→            \"min\": gap_min,\n    54→            \"max\": gap_max,\n    55→        }\n    56→\n    57→        if gap_std < 0.5:\n    58→            any_periodic = True\n    59→\n    60→    # Coverage uniformity: coefficient of variation of per-experiment counts\n    61→    counts_array = np.array(list(per_experiment_counts.values()), dtype=float)\n    62→    coverage_uniformity = float(counts_array.std() / counts_array.mean())\n    63→\n    64→    # Build human-readable summary\n    65→    summary_lines = [\n    66→        f\"Sampling characterization for {len(per_experiment_counts)} experiments:\",\n    67→        f\"  Total traced steps: {total_steps:,}\",\n    68→        f\"  Estimated total steps (at 10% rate): ~{total_steps * 10:,}\",\n    69→        f\"  Steps per experiment: min={int(counts_array.min()):,}, \"\n    70→        f\"max={int(counts_array.max()):,}, \"\n    71→        f\"mean={counts_array.mean():,.0f}\",\n    72→        f\"  Coverage uniformity (CV): {coverage_uniformity:.4f}\",\n    73→        f\"  Periodic sampling detected: {any_periodic}\",\n    74→    ]\n    75→\n    76→    # Aggregate gap statistics across all experiments\n    77→    all_means = [v[\"mean\"] for v in step_id_gaps.values()]\n    78→    all_stds = [v[\"std\"] for v in step_id_gaps.values()]\n    79→    summary_lines.append(\n    80→        f\"  Step ID gap (across experiments): \"\n    81→        f\"mean of means={np.mean(all_means):.2f}, \"\n    82→        f\"mean of stds={np.mean(all_stds):.2f}\"\n    83→    )\n    84→\n    85→    if any_periodic:\n    86→        summary_lines.append(\n    87→            \"  WARNING: At least one experiment shows periodic sampling \"\n    88→            \"(gap std < 0.5). This may introduce systematic bias.\"\n    89→        )\n    90→    else:\n    91→        summary_lines.append(\n    92→            \"  Sampling appears random/pseudo-random (all experiments have \"\n    93→            \"gap std > 0.5). No periodic bias detected.\"\n    94→        )\n    95→\n    96→    summary = \"\\n\".join(summary_lines)\n    97→\n    98→    return {\n    99→        \"total_steps\": total_steps,\n   100→        \"per_experiment_counts\": per_experiment_counts,\n   101→        \"step_id_gaps\": step_id_gaps,\n   102→        \"is_periodic\": any_periodic,\n   103→        \"coverage_uniformity\": coverage_uniformity,\n   104→        \"summary\": summary,\n   105→    }\n   106→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"73383af8-588f-4b92-a8df-480305b81229"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01MXPP6gVzu75GPhzY6aAkTL","type":"tool_result","content":"     1→\"\"\"MFU benchmark indexer for InferSim bench_data.\n     2→\n     3→Loads and indexes hardware MFU (Model FLOPs Utilization) benchmarks from\n     4→InferSim's bench_data/ directory so that research ideas can query real\n     5→hardware performance data by GPU type, matrix shape, and attention\n     6→configuration.\n     7→\n     8→Supported benchmark families:\n     9→  - GEMM: dense matrix multiply MFU by (m, k, n) shape\n    10→  - MHA decode: multi-head attention decode MFU by head config and KV length\n    11→  - MHA prefill: multi-head attention prefill MFU by head config and seq length\n    12→  - Grouped GEMM: MoE expert MFU (up_proj + down_proj) by expert config\n    13→\n    14→All data is stored as pandas DataFrames and queried with exact-match or\n    15→nearest-neighbor interpolation.\n    16→\"\"\"\n    17→\n    18→import os\n    19→import re\n    20→from typing import Optional\n    21→\n    22→import numpy as np\n    23→import pandas as pd\n    24→\n    25→# ---------------------------------------------------------------------------\n    26→# Default bench_data root: InferSim/bench_data/ relative to this file\n    27→# ---------------------------------------------------------------------------\n    28→DEFAULT_BENCH_DATA_ROOT = os.path.join(\n    29→    os.path.dirname(__file__), \"..\", \"..\", \"..\", \"InferSim\", \"bench_data\"\n    30→)\n    31→\n    32→# Regex for MHA decode filenames: {heads}-{kv_heads}-{head_dim}[-tp{N}].csv\n    33→_MHA_DECODE_PATTERN = re.compile(\n    34→    r\"^(\\d+)-(\\d+)-(\\d+)(?:-tp(\\d+))?\\.csv$\"\n    35→)\n    36→\n    37→# Regex for MHA prefill filenames: {heads}-{kv_heads}-{head_dim}.csv\n    38→_MHA_PREFILL_PATTERN = re.compile(\n    39→    r\"^(\\d+)-(\\d+)-(\\d+)\\.csv$\"\n    40→)\n    41→\n    42→\n    43→def _nearest_row(df: pd.DataFrame, columns: list[str], values: list) -> pd.Series:\n    44→    \"\"\"Find the row in *df* whose *columns* are nearest to *values*.\n    45→\n    46→    Uses Euclidean distance across the specified columns after casting\n    47→    everything to float.  Returns the first row at minimum distance.\n    48→    \"\"\"\n    49→    dist = np.zeros(len(df))\n    50→    for col, val in zip(columns, values):\n    51→        dist += (df[col].astype(float).values - float(val)) ** 2\n    52→    idx = int(np.argmin(dist))\n    53→    return df.iloc[idx]\n    54→\n    55→\n    56→class MFUBenchmarkIndex:\n    57→    \"\"\"Index and query InferSim hardware MFU benchmarks.\n    58→\n    59→    Parameters\n    60→    ----------\n    61→    bench_data_root : str, optional\n    62→        Path to the ``bench_data/`` directory.  Defaults to\n    63→        ``InferSim/bench_data/`` relative to this file.\n    64→    \"\"\"\n    65→\n    66→    def __init__(self, bench_data_root: str = None):\n    67→        if bench_data_root is None:\n    68→            bench_data_root = DEFAULT_BENCH_DATA_ROOT\n    69→        self._root = os.path.abspath(bench_data_root)\n    70→\n    71→        # Lazy-loaded caches\n    72→        self._gemm: dict[str, pd.DataFrame] = {}\n    73→        self._mha_decode: dict[str, pd.DataFrame] = {}\n    74→        self._mha_prefill: dict[str, pd.DataFrame] = {}\n    75→        self._grouped_gemm: dict[str, pd.DataFrame] = {}\n    76→        self._loaded = False\n    77→\n    78→    # ------------------------------------------------------------------\n    79→    # Public loading\n    80→    # ------------------------------------------------------------------\n    81→\n    82→    def load(self) -> \"MFUBenchmarkIndex\":\n    83→        \"\"\"Eagerly load all available benchmark data.\n    84→\n    85→        Returns *self* for chaining.\n    86→        \"\"\"\n    87→        self._load_gemm()\n    88→        self._load_mha_decode()\n    89→        self._load_mha_prefill()\n    90→        self._load_grouped_gemm()\n    91→        self._loaded = True\n    92→        return self\n    93→\n    94→    # ------------------------------------------------------------------\n    95→    # GEMM queries\n    96→    # ------------------------------------------------------------------\n    97→\n    98→    def query_gemm_mfu(self, gpu: str, m: int, k: int, n: int) -> float:\n    99→        \"\"\"Look up GEMM MFU for a given (m, k, n) matrix shape.\n   100→\n   101→        Parameters\n   102→        ----------\n   103→        gpu : str\n   104→            GPU identifier (e.g. ``\"h100\"``).\n   105→        m, k, n : int\n   106→            GEMM dimensions.\n   107→\n   108→        Returns\n   109→        -------\n   110→        float\n   111→            MFU value.  Exact match preferred; falls back to nearest\n   112→            neighbor in (m, k, n) space.\n   113→\n   114→        Raises\n   115→        ------\n   116→        ValueError\n   117→            If no GEMM data is available for *gpu*.\n   118→        \"\"\"\n   119→        self._ensure_gemm(gpu)\n   120→        df = self._gemm[gpu]\n   121→\n   122→        exact = df[(df[\"m\"] == m) & (df[\"k\"] == k) & (df[\"n\"] == n)]\n   123→        if len(exact) > 0:\n   124→            return float(exact.iloc[0][\"mfu\"])\n   125→\n   126→        row = _nearest_row(df, [\"m\", \"k\", \"n\"], [m, k, n])\n   127→        return float(row[\"mfu\"])\n   128→\n   129→    # ------------------------------------------------------------------\n   130→    # MHA decode queries\n   131→    # ------------------------------------------------------------------\n   132→\n   133→    def query_mha_decode_mfu(\n   134→        self,\n   135→        gpu: str,\n   136→        num_heads: int,\n   137→        num_kv_heads: int,\n   138→        head_dim: int,\n   139→        batch_size: int,\n   140→        kv_len: int,\n   141→        tp: int = 1,\n   142→    ) -> float:\n   143→        \"\"\"Look up MHA decode MFU.\n   144→\n   145→        Parameters\n   146→        ----------\n   147→        gpu : str\n   148→            GPU identifier.\n   149→        num_heads, num_kv_heads, head_dim : int\n   150→            Attention head configuration.\n   151→        batch_size : int\n   152→            Batch size.\n   153→        kv_len : int\n   154→            KV cache length.\n   155→        tp : int\n   156→            Tensor parallelism degree (default 1).\n   157→\n   158→        Returns\n   159→        -------\n   160→        float\n   161→            MFU value.\n   162→\n   163→        Raises\n   164→        ------\n   165→        ValueError\n   166→            If no matching benchmark file exists.\n   167→        \"\"\"\n   168→        self._ensure_mha_decode(gpu)\n   169→        key = self._mha_decode_key(gpu, num_heads, num_kv_heads, head_dim, tp)\n   170→        if key not in self._mha_decode:\n   171→            raise ValueError(\n   172→                f\"No MHA decode benchmark for gpu={gpu}, \"\n   173→                f\"heads={num_heads}-{num_kv_heads}-{head_dim}, tp={tp}\"\n   174→            )\n   175→        df = self._mha_decode[key]\n   176→\n   177→        exact = df[(df[\"batch_size\"] == batch_size) & (df[\"kv_len\"] == kv_len)]\n   178→        if len(exact) > 0:\n   179→            return float(exact.iloc[0][\"mfu\"])\n   180→\n   181→        row = _nearest_row(df, [\"batch_size\", \"kv_len\"], [batch_size, kv_len])\n   182→        return float(row[\"mfu\"])\n   183→\n   184→    # ------------------------------------------------------------------\n   185→    # MHA prefill queries\n   186→    # ------------------------------------------------------------------\n   187→\n   188→    def query_mha_prefill_mfu(\n   189→        self,\n   190→        gpu: str,\n   191→        num_heads: int,\n   192→        num_kv_heads: int,\n   193→        head_dim: int,\n   194→        seq_len: int,\n   195→    ) -> float:\n   196→        \"\"\"Look up MHA prefill MFU.\n   197→\n   198→        Parameters\n   199→        ----------\n   200→        gpu : str\n   201→            GPU identifier.\n   202→        num_heads, num_kv_heads, head_dim : int\n   203→            Attention head configuration.\n   204→        seq_len : int\n   205→            Sequence length.\n   206→\n   207→        Returns\n   208→        -------\n   209→        float\n   210→            MFU value.\n   211→\n   212→        Raises\n   213→        ------\n   214→        ValueError\n   215→            If no matching benchmark file exists.\n   216→        \"\"\"\n   217→        self._ensure_mha_prefill(gpu)\n   218→        key = self._mha_prefill_key(gpu, num_heads, num_kv_heads, head_dim)\n   219→        if key not in self._mha_prefill:\n   220→            raise ValueError(\n   221→                f\"No MHA prefill benchmark for gpu={gpu}, \"\n   222→                f\"heads={num_heads}-{num_kv_heads}-{head_dim}\"\n   223→            )\n   224→        df = self._mha_prefill[key]\n   225→\n   226→        exact = df[df[\"seq_len\"] == seq_len]\n   227→        if len(exact) > 0:\n   228→            return float(exact.iloc[0][\"mfu\"])\n   229→\n   230→        row = _nearest_row(df, [\"seq_len\"], [seq_len])\n   231→        return float(row[\"mfu\"])\n   232→\n   233→    # ------------------------------------------------------------------\n   234→    # Grouped GEMM queries (MoE)\n   235→    # ------------------------------------------------------------------\n   236→\n   237→    def query_grouped_gemm_mfu(self, gpu: str, phase: str, **kwargs) -> dict:\n   238→        \"\"\"Look up grouped GEMM (MoE) MFU.\n   239→\n   240→        Parameters\n   241→        ----------\n   242→        gpu : str\n   243→            GPU identifier.\n   244→        phase : str\n   245→            ``\"decode\"`` or ``\"prefill\"``.\n   246→        **kwargs\n   247→            Filter columns to match (e.g. ``batch_size_per_gpu=128``).\n   248→\n   249→        Returns\n   250→        -------\n   251→        dict\n   252→            Dictionary with at least ``up_mfu`` and ``down_mfu`` keys,\n   253→            plus all columns from the matched row.\n   254→\n   255→        Raises\n   256→        ------\n   257→        ValueError\n   258→            If no grouped GEMM data is available for *gpu*/*phase*, or\n   259→            *phase* is invalid.\n   260→        \"\"\"\n   261→        if phase not in (\"decode\", \"prefill\"):\n   262→            raise ValueError(f\"phase must be 'decode' or 'prefill', got {phase!r}\")\n   263→\n   264→        self._ensure_grouped_gemm(gpu, phase)\n   265→        key = f\"{gpu}/{phase}\"\n   266→        if key not in self._grouped_gemm:\n   267→            raise ValueError(\n   268→                f\"No grouped GEMM benchmark for gpu={gpu}, phase={phase}\"\n   269→            )\n   270→        df = self._grouped_gemm[key]\n   271→\n   272→        # Try exact match on all provided kwargs\n   273→        mask = pd.Series(True, index=df.index)\n   274→        filter_cols = []\n   275→        filter_vals = []\n   276→        for col, val in kwargs.items():\n   277→            if col in df.columns:\n   278→                mask = mask & (df[col] == val)\n   279→                filter_cols.append(col)\n   280→                filter_vals.append(val)\n   281→\n   282→        exact = df[mask]\n   283→        if len(exact) > 0:\n   284→            row = exact.iloc[0]\n   285→        elif filter_cols:\n   286→            row = _nearest_row(df, filter_cols, filter_vals)\n   287→        else:\n   288→            row = df.iloc[0]\n   289→\n   290→        return row.to_dict()\n   291→\n   292→    # ------------------------------------------------------------------\n   293→    # Discovery helpers\n   294→    # ------------------------------------------------------------------\n   295→\n   296→    def available_gpus(self) -> list[str]:\n   297→        \"\"\"List GPU types with any benchmark data.\n   298→\n   299→        Scans the GEMM and MHA directories for GPU subdirectories.\n   300→\n   301→        Returns\n   302→        -------\n   303→        list[str]\n   304→            Sorted list of GPU identifiers (e.g. ``[\"h100\", \"h20\", \"h800\"]``).\n   305→        \"\"\"\n   306→        gpus: set[str] = set()\n   307→        for subdir in (\"gemm\", \"mha/decode\", \"mha/prefill\",\n   308→                        \"grouped_gemm/decode\", \"grouped_gemm/prefill\"):\n   309→            path = os.path.join(self._root, subdir)\n   310→            if os.path.isdir(path):\n   311→                for name in os.listdir(path):\n   312→                    if os.path.isdir(os.path.join(path, name)):\n   313→                        gpus.add(name)\n   314→        return sorted(gpus)\n   315→\n   316→    def available_benchmarks(self) -> dict:\n   317→        \"\"\"Summarize what benchmarks are available.\n   318→\n   319→        Returns\n   320→        -------\n   321→        dict\n   322→            Mapping of benchmark family to list of GPU types that have\n   323→            data for that family.\n   324→        \"\"\"\n   325→        result = {}\n   326→        families = {\n   327→            \"gemm\": \"gemm\",\n   328→            \"mha_decode\": \"mha/decode\",\n   329→            \"mha_prefill\": \"mha/prefill\",\n   330→            \"grouped_gemm_decode\": \"grouped_gemm/decode\",\n   331→            \"grouped_gemm_prefill\": \"grouped_gemm/prefill\",\n   332→        }\n   333→        for family_name, subdir in families.items():\n   334→            path = os.path.join(self._root, subdir)\n   335→            if os.path.isdir(path):\n   336→                gpus = sorted(\n   337→                    name\n   338→                    for name in os.listdir(path)\n   339→                    if os.path.isdir(os.path.join(path, name))\n   340→                )\n   341→                if gpus:\n   342→                    result[family_name] = gpus\n   343→        return result\n   344→\n   345→    # ------------------------------------------------------------------\n   346→    # Internal loading helpers\n   347→    # ------------------------------------------------------------------\n   348→\n   349→    def _ensure_gemm(self, gpu: str) -> None:\n   350→        \"\"\"Ensure GEMM data for *gpu* is loaded.\"\"\"\n   351→        if gpu in self._gemm:\n   352→            return\n   353→        csv_path = os.path.join(self._root, \"gemm\", gpu, \"data.csv\")\n   354→        if not os.path.isfile(csv_path):\n   355→            raise ValueError(\n   356→                f\"No GEMM benchmark data for gpu={gpu!r} \"\n   357→                f\"(expected {csv_path})\"\n   358→            )\n   359→        df = pd.read_csv(csv_path)\n   360→        # Ensure numeric types\n   361→        for col in (\"m\", \"k\", \"n\"):\n   362→            df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n   363→        df[\"mfu\"] = pd.to_numeric(df[\"mfu\"], errors=\"coerce\")\n   364→        self._gemm[gpu] = df\n   365→\n   366→    def _load_gemm(self) -> None:\n   367→        \"\"\"Load GEMM data for all available GPUs.\"\"\"\n   368→        gemm_dir = os.path.join(self._root, \"gemm\")\n   369→        if not os.path.isdir(gemm_dir):\n   370→            return\n   371→        for gpu in os.listdir(gemm_dir):\n   372→            gpu_dir = os.path.join(gemm_dir, gpu)\n   373→            if os.path.isdir(gpu_dir):\n   374→                try:\n   375→                    self._ensure_gemm(gpu)\n   376→                except ValueError:\n   377→                    pass\n   378→\n   379→    @staticmethod\n   380→    def _mha_decode_key(\n   381→        gpu: str, num_heads: int, num_kv_heads: int, head_dim: int, tp: int\n   382→    ) -> str:\n   383→        if tp > 1:\n   384→            return f\"{gpu}/{num_heads}-{num_kv_heads}-{head_dim}-tp{tp}\"\n   385→        return f\"{gpu}/{num_heads}-{num_kv_heads}-{head_dim}\"\n   386→\n   387→    def _ensure_mha_decode(self, gpu: str) -> None:\n   388→        \"\"\"Load all MHA decode CSVs for *gpu* if not already loaded.\"\"\"\n   389→        # Check if we already loaded this GPU (use a sentinel)\n   390→        sentinel = f\"_loaded_mha_decode_{gpu}\"\n   391→        if hasattr(self, sentinel):\n   392→            return\n   393→\n   394→        decode_dir = os.path.join(self._root, \"mha\", \"decode\", gpu)\n   395→        if not os.path.isdir(decode_dir):\n   396→            raise ValueError(\n   397→                f\"No MHA decode benchmark data for gpu={gpu!r} \"\n   398→                f\"(expected directory {decode_dir})\"\n   399→            )\n   400→        for fname in os.listdir(decode_dir):\n   401→            m = _MHA_DECODE_PATTERN.match(fname)\n   402→            if not m:\n   403→                continue\n   404→            num_heads = int(m.group(1))\n   405→            num_kv_heads = int(m.group(2))\n   406→            head_dim = int(m.group(3))\n   407→            tp = int(m.group(4)) if m.group(4) else 1\n   408→            key = self._mha_decode_key(gpu, num_heads, num_kv_heads, head_dim, tp)\n   409→            csv_path = os.path.join(decode_dir, fname)\n   410→            df = pd.read_csv(csv_path)\n   411→            for col in (\"batch_size\", \"kv_len\"):\n   412→                if col in df.columns:\n   413→                    df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n   414→            if \"mfu\" in df.columns:\n   415→                df[\"mfu\"] = pd.to_numeric(df[\"mfu\"], errors=\"coerce\")\n   416→            self._mha_decode[key] = df\n   417→\n   418→        setattr(self, sentinel, True)\n   419→\n   420→    def _load_mha_decode(self) -> None:\n   421→        \"\"\"Load MHA decode data for all available GPUs.\"\"\"\n   422→        decode_dir = os.path.join(self._root, \"mha\", \"decode\")\n   423→        if not os.path.isdir(decode_dir):\n   424→            return\n   425→        for gpu in os.listdir(decode_dir):\n   426→            if os.path.isdir(os.path.join(decode_dir, gpu)):\n   427→                try:\n   428→                    self._ensure_mha_decode(gpu)\n   429→                except ValueError:\n   430→                    pass\n   431→\n   432→    @staticmethod\n   433→    def _mha_prefill_key(\n   434→        gpu: str, num_heads: int, num_kv_heads: int, head_dim: int\n   435→    ) -> str:\n   436→        return f\"{gpu}/{num_heads}-{num_kv_heads}-{head_dim}\"\n   437→\n   438→    def _ensure_mha_prefill(self, gpu: str) -> None:\n   439→        \"\"\"Load all MHA prefill CSVs for *gpu* if not already loaded.\"\"\"\n   440→        sentinel = f\"_loaded_mha_prefill_{gpu}\"\n   441→        if hasattr(self, sentinel):\n   442→            return\n   443→\n   444→        prefill_dir = os.path.join(self._root, \"mha\", \"prefill\", gpu)\n   445→        if not os.path.isdir(prefill_dir):\n   446→            raise ValueError(\n   447→                f\"No MHA prefill benchmark data for gpu={gpu!r} \"\n   448→                f\"(expected directory {prefill_dir})\"\n   449→            )\n   450→        for fname in os.listdir(prefill_dir):\n   451→            m = _MHA_PREFILL_PATTERN.match(fname)\n   452→            if not m:\n   453→                continue\n   454→            num_heads = int(m.group(1))\n   455→            num_kv_heads = int(m.group(2))\n   456→            head_dim = int(m.group(3))\n   457→            key = self._mha_prefill_key(gpu, num_heads, num_kv_heads, head_dim)\n   458→            csv_path = os.path.join(prefill_dir, fname)\n   459→            df = pd.read_csv(csv_path)\n   460→            if \"seq_len\" in df.columns:\n   461→                df[\"seq_len\"] = pd.to_numeric(df[\"seq_len\"], errors=\"coerce\")\n   462→            if \"mfu\" in df.columns:\n   463→                df[\"mfu\"] = pd.to_numeric(df[\"mfu\"], errors=\"coerce\")\n   464→            self._mha_prefill[key] = df\n   465→\n   466→        setattr(self, sentinel, True)\n   467→\n   468→    def _load_mha_prefill(self) -> None:\n   469→        \"\"\"Load MHA prefill data for all available GPUs.\"\"\"\n   470→        prefill_dir = os.path.join(self._root, \"mha\", \"prefill\")\n   471→        if not os.path.isdir(prefill_dir):\n   472→            return\n   473→        for gpu in os.listdir(prefill_dir):\n   474→            if os.path.isdir(os.path.join(prefill_dir, gpu)):\n   475→                try:\n   476→                    self._ensure_mha_prefill(gpu)\n   477→                except ValueError:\n   478→                    pass\n   479→\n   480→    def _ensure_grouped_gemm(self, gpu: str, phase: str) -> None:\n   481→        \"\"\"Load grouped GEMM data for *gpu*/*phase* if not already loaded.\"\"\"\n   482→        key = f\"{gpu}/{phase}\"\n   483→        if key in self._grouped_gemm:\n   484→            return\n   485→        csv_path = os.path.join(\n   486→            self._root, \"grouped_gemm\", phase, gpu, \"data.csv\"\n   487→        )\n   488→        if not os.path.isfile(csv_path):\n   489→            raise ValueError(\n   490→                f\"No grouped GEMM benchmark data for gpu={gpu!r}, \"\n   491→                f\"phase={phase!r} (expected {csv_path})\"\n   492→            )\n   493→        df = pd.read_csv(csv_path)\n   494→        # Coerce numeric columns\n   495→        for col in df.columns:\n   496→            if col not in (\"dtype\", \"kv_dtype\"):\n   497→                df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n   498→        self._grouped_gemm[key] = df\n   499→\n   500→    def _load_grouped_gemm(self) -> None:\n   501→        \"\"\"Load grouped GEMM data for all available GPUs and phases.\"\"\"\n   502→        for phase in (\"decode\", \"prefill\"):\n   503→            phase_dir = os.path.join(self._root, \"grouped_gemm\", phase)\n   504→            if not os.path.isdir(phase_dir):\n   505→                continue\n   506→            for gpu in os.listdir(phase_dir):\n   507→                if os.path.isdir(os.path.join(phase_dir, gpu)):\n   508→                    try:\n   509→                        self._ensure_grouped_gemm(gpu, phase)\n   510→                    except ValueError:\n   511→                        pass\n   512→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"c15d6bed-33ca-4303-995f-63e6014046e5"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01EFE6YucgHrzXG7hNf125xd","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"Idea 2, H2: BLIS E2E validation with per-model regime StepML artifacts.\n     3→\n     4→For each ground-truth experiment, selects the matching model artifact\n     5→(regime or single) and runs BLIS to compute E2E, TTFT, ITL errors.\n     6→\n     7→Usage: python3 validate_e2e.py --artifact-dir DIR [--mode regime|single] [--output-dir DIR]\n     8→\"\"\"\n     9→import argparse\n    10→import json\n    11→import os\n    12→import sys\n    13→import tempfile\n    14→from pathlib import Path\n    15→\n    16→import yaml\n    17→\n    18→# Add shared infrastructure to path\n    19→SHARED_DIR = Path(__file__).resolve().parent.parent.parent.parent / \"shared\"\n    20→sys.path.insert(0, str(SHARED_DIR))\n    21→\n    22→from data_loader import DEFAULT_DATA_ROOT\n    23→from validate_blis import (\n    24→    build_workload_spec,\n    25→    extract_kv_blocks_from_vllm_log,\n    26→    load_exp_config,\n    27→    load_ground_truth_metrics,\n    28→    load_profile,\n    29→    parse_experiment_dir,\n    30→    run_blis,\n    31→)\n    32→\n    33→\n    34→def _model_key_from_experiment(meta: dict) -> str:\n    35→    \"\"\"Convert experiment metadata to artifact filename key.\"\"\"\n    36→    return f\"{meta['model']}_tp{meta['tp']}\"\n    37→\n    38→\n    39→def _find_artifact(artifact_dir: str, model_key: str, mode: str) -> str | None:\n    40→    \"\"\"Find the StepML artifact for a given model key and mode.\"\"\"\n    41→    suffix = \"_regime.json\" if mode == \"regime\" else \"_single.json\"\n    42→    path = os.path.join(artifact_dir, model_key + suffix)\n    43→    if os.path.isfile(path):\n    44→        return path\n    45→\n    46→    # Try normalizing model key (strip -hf suffix)\n    47→    normalized = model_key.replace(\"-hf_\", \"_\")\n    48→    path = os.path.join(artifact_dir, normalized + suffix)\n    49→    if os.path.isfile(path):\n    50→        return path\n    51→\n    52→    return None\n    53→\n    54→\n    55→def main():\n    56→    parser = argparse.ArgumentParser(description=__doc__)\n    57→    parser.add_argument(\n    58→        \"--artifact-dir\",\n    59→        required=True,\n    60→        help=\"Directory containing per-model StepML artifacts\",\n    61→    )\n    62→    parser.add_argument(\n    63→        \"--mode\",\n    64→        choices=[\"regime\", \"single\"],\n    65→        default=\"regime\",\n    66→        help=\"Which artifact type to use (default: regime)\",\n    67→    )\n    68→    parser.add_argument(\n    69→        \"--output-dir\",\n    70→        default=str(Path(__file__).parent / \"output\"),\n    71→        help=\"Output directory for results\",\n    72→    )\n    73→    parser.add_argument(\n    74→        \"--binary\",\n    75→        default=str(Path(__file__).resolve().parents[4] / \"simulation_worker\"),\n    76→        help=\"Path to BLIS binary\",\n    77→    )\n    78→    parser.add_argument(\n    79→        \"--data-root\",\n    80→        default=DEFAULT_DATA_ROOT,\n    81→        help=\"Path to ground truth data\",\n    82→    )\n    83→    parser.add_argument(\n    84→        \"--workers\",\n    85→        type=int,\n    86→        default=2,\n    87→        help=\"Number of parallel BLIS runs\",\n    88→    )\n    89→    args = parser.parse_args()\n    90→\n    91→    os.makedirs(args.output_dir, exist_ok=True)\n    92→\n    93→    results = []\n    94→    skipped = []\n    95→\n    96→    for dirname in sorted(os.listdir(args.data_root)):\n    97→        dirpath = os.path.join(args.data_root, dirname)\n    98→        if not os.path.isdir(dirpath):\n    99→            continue\n   100→\n   101→        summary_path = os.path.join(\n   102→            dirpath, \"results\", \"summary_lifecycle_metrics.json\"\n   103→        )\n   104→        if not os.path.isfile(summary_path):\n   105→            continue\n   106→\n   107→        try:\n   108→            meta = parse_experiment_dir(dirname)\n   109→        except ValueError:\n   110→            continue\n   111→\n   112→        model_key = _model_key_from_experiment(meta)\n   113→        artifact_path = _find_artifact(args.artifact_dir, model_key, args.mode)\n   114→\n   115→        if artifact_path is None:\n   116→            print(f\"  {dirname}: SKIP (no artifact for {model_key})\")\n   117→            skipped.append(dirname)\n   118→            continue\n   119→\n   120→        gt = load_ground_truth_metrics(dirpath)\n   121→        exp_config = load_exp_config(dirpath)\n   122→        total_kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n   123→        if total_kv_blocks is None:\n   124→            print(f\"  {dirname}: SKIP (no KV blocks)\")\n   125→            skipped.append(dirname)\n   126→            continue\n   127→\n   128→        try:\n   129→            profile = load_profile(dirpath)\n   130→        except Exception:\n   131→            print(f\"  {dirname}: SKIP (no profile)\")\n   132→            skipped.append(dirname)\n   133→            continue\n   134→\n   135→        workload_spec = build_workload_spec(profile, gt)\n   136→\n   137→        with tempfile.NamedTemporaryFile(\n   138→            mode=\"w\", suffix=\".yaml\", delete=False\n   139→        ) as f:\n   140→            yaml.dump(workload_spec, f, default_flow_style=False)\n   141→            spec_path = f.name\n   142→\n   143→        with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n   144→            results_json_path = f.name\n   145→\n   146→        try:\n   147→            blis_metrics = run_blis(\n   148→                binary=args.binary,\n   149→                workload_spec_path=spec_path,\n   150→                exp_config=exp_config,\n   151→                total_kv_blocks=total_kv_blocks,\n   152→                alpha_coeffs=[0, 0, 0],\n   153→                beta_coeffs=[0, 0, 0],\n   154→                results_path=results_json_path,\n   155→                stepml_model_path=artifact_path,\n   156→            )\n   157→        finally:\n   158→            os.unlink(spec_path)\n   159→            if os.path.exists(results_json_path):\n   160→                os.unlink(results_json_path)\n   161→\n   162→        if blis_metrics is None:\n   163→            print(f\"  {dirname}: TIMEOUT or FAIL\")\n   164→            skipped.append(dirname)\n   165→            continue\n   166→\n   167→        gt_e2e_ms = gt[\"e2e_mean_s\"] * 1000\n   168→        gt_ttft_ms = gt[\"ttft_mean_s\"] * 1000\n   169→        gt_itl_ms = gt[\"itl_mean_s\"] * 1000\n   170→\n   171→        e2e_err = abs(blis_metrics[\"e2e_mean_ms\"] - gt_e2e_ms) / gt_e2e_ms * 100\n   172→        ttft_err = abs(blis_metrics[\"ttft_mean_ms\"] - gt_ttft_ms) / gt_ttft_ms * 100 if gt_ttft_ms > 0 else 0\n   173→        itl_err = abs(blis_metrics[\"itl_mean_ms\"] - gt_itl_ms) / gt_itl_ms * 100 if gt_itl_ms > 0 else 0\n   174→\n   175→        results.append({\n   176→            \"experiment\": dirname,\n   177→            \"model\": meta[\"model\"],\n   178→            \"workload\": meta[\"workload\"],\n   179→            \"tp\": meta[\"tp\"],\n   180→            \"model_key\": model_key,\n   181→            \"artifact\": os.path.basename(artifact_path),\n   182→            \"gt_e2e_ms\": gt_e2e_ms,\n   183→            \"blis_e2e_ms\": blis_metrics[\"e2e_mean_ms\"],\n   184→            \"e2e_error_pct\": e2e_err,\n   185→            \"gt_ttft_ms\": gt_ttft_ms,\n   186→            \"blis_ttft_ms\": blis_metrics[\"ttft_mean_ms\"],\n   187→            \"ttft_error_pct\": ttft_err,\n   188→            \"gt_itl_ms\": gt_itl_ms,\n   189→            \"blis_itl_ms\": blis_metrics[\"itl_mean_ms\"],\n   190→            \"itl_error_pct\": itl_err,\n   191→        })\n   192→\n   193→        print(\n   194→            f\"  {dirname}: GT={gt_e2e_ms:.0f}ms  BLIS={blis_metrics['e2e_mean_ms']:.0f}ms  \"\n   195→            f\"E2E={e2e_err:.1f}%  TTFT={ttft_err:.1f}%  ITL={itl_err:.1f}%\"\n   196→        )\n   197→\n   198→    # -----------------------------------------------------------------------\n   199→    # Summary\n   200→    # -----------------------------------------------------------------------\n   201→    import pandas as pd\n   202→\n   203→    if not results:\n   204→        print(\"\\nNo experiments completed successfully!\")\n   205→        return\n   206→\n   207→    df = pd.DataFrame(results)\n   208→    csv_path = os.path.join(args.output_dir, f\"e2e_validation_{args.mode}.csv\")\n   209→    df.to_csv(csv_path, index=False)\n   210→\n   211→    mean_e2e = df[\"e2e_error_pct\"].mean()\n   212→    mean_ttft = df[\"ttft_error_pct\"].mean()\n   213→    mean_itl = df[\"itl_error_pct\"].mean()\n   214→    below_10 = (df[\"e2e_error_pct\"] < 10).sum()\n   215→\n   216→    print(f\"\\n{'='*70}\")\n   217→    print(f\"  BLIS E2E VALIDATION — {args.mode.upper()} MODEL\")\n   218→    print(f\"{'='*70}\")\n   219→    print(f\"\\n  Experiments: {len(df)} completed, {len(skipped)} skipped\")\n   220→    print(f\"\\n  {'Experiment':<55s} {'E2E%':>6s} {'TTFT%':>7s} {'ITL%':>6s}\")\n   221→    print(f\"  {'-'*55} {'-'*6} {'-'*7} {'-'*6}\")\n   222→    for _, row in df.iterrows():\n   223→        print(\n   224→            f\"  {row['experiment']:<55s} {row['e2e_error_pct']:>5.1f}% \"\n   225→            f\"{row['ttft_error_pct']:>6.1f}% {row['itl_error_pct']:>5.1f}%\"\n   226→        )\n   227→    print(f\"\\n  Mean E2E error:  {mean_e2e:.1f}%\")\n   228→    print(f\"  Mean TTFT error: {mean_ttft:.1f}%\")\n   229→    print(f\"  Mean ITL error:  {mean_itl:.1f}%\")\n   230→    print(f\"\\n  E2E < 10%: {below_10}/{len(df)} experiments\")\n   231→    print(f\"\\n  Results: {csv_path}\")\n   232→    print(f\"{'='*70}\")\n   233→\n   234→    # Save summary JSON\n   235→    summary = {\n   236→        \"mode\": args.mode,\n   237→        \"n_completed\": len(df),\n   238→        \"n_skipped\": len(skipped),\n   239→        \"mean_e2e_error_pct\": mean_e2e,\n   240→        \"mean_ttft_error_pct\": mean_ttft,\n   241→        \"mean_itl_error_pct\": mean_itl,\n   242→        \"experiments_below_10pct\": int(below_10),\n   243→    }\n   244→    summary_path = os.path.join(args.output_dir, f\"e2e_summary_{args.mode}.json\")\n   245→    with open(summary_path, \"w\") as f:\n   246→        json.dump(summary, f, indent=2)\n   247→\n   248→\n   249→if __name__ == \"__main__\":\n   250→    main()\n   251→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"31ceb64b-3407-44d9-9ece-dec0cca5c6a8"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_012T85teuu6DRJGSytQ3thwf","type":"tool_result","content":"     1→\"\"\"Per-request KV cache length extractor for step-level feature enrichment.\n     2→\n     3→Bridges the gap between step-level batch summaries (which lack per-request KV\n     4→cache lengths) and per-request lifecycle data (which has token timestamps).\n     5→By joining these two data sources, we derive per-step KV statistics\n     6→(kv_mean, kv_max, kv_sum, kv_count) needed for accurate roofline step-time\n     7→prediction.\n     8→\n     9→Background: Round 1 H8 showed a 12.96x overestimate when using batch-level\n    10→kv_max (the max across the whole experiment) instead of per-request KV lengths.\n    11→This module computes the actual per-step KV distribution from lifecycle data.\n    12→\"\"\"\n    13→\n    14→from __future__ import annotations\n    15→\n    16→import os\n    17→\n    18→import numpy as np\n    19→import pandas as pd\n    20→\n    21→from data_loader import (\n    22→    DEFAULT_DATA_ROOT,\n    23→    load_all_experiments,\n    24→    load_experiment_steps,\n    25→    load_lifecycle_data,\n    26→    parse_experiment_metadata,\n    27→)\n    28→\n    29→\n    30→def _estimate_kv_length(request_row: pd.Series, step_start_ns: int) -> int:\n    31→    \"\"\"Estimate KV cache length for a request at a given step timestamp.\n    32→\n    33→    KV length = input_tokens + number of output tokens generated before\n    34→    step_start_ns. This mirrors the simulator's Request.ProgressIndex\n    35→    (input_tokens_processed + output_tokens_generated).\n    36→\n    37→    Args:\n    38→        request_row: A row from the lifecycle DataFrame with columns:\n    39→            input_tokens (int), output_token_times (list of float, epoch seconds).\n    40→        step_start_ns: Step start timestamp in nanoseconds.\n    41→\n    42→    Returns:\n    43→        Estimated KV cache length (non-negative integer).\n    44→    \"\"\"\n    45→    input_tokens = int(request_row[\"input_tokens\"])\n    46→    output_token_times = request_row[\"output_token_times\"]\n    47→\n    48→    if not output_token_times:\n    49→        return input_tokens\n    50→\n    51→    # Convert step_start_ns to seconds for comparison with output_token_times\n    52→    step_start_s = step_start_ns / 1e9\n    53→\n    54→    # Count output tokens generated before step_start_ns\n    55→    tokens_generated = 0\n    56→    for t in output_token_times:\n    57→        if t < step_start_s:\n    58→            tokens_generated += 1\n    59→        else:\n    60→            # output_token_times are chronologically ordered; once we pass\n    61→            # the step boundary, no further tokens qualify.\n    62→            break\n    63→\n    64→    return input_tokens + tokens_generated\n    65→\n    66→\n    67→def extract_kv_features(\n    68→    steps_df: pd.DataFrame, lifecycle_df: pd.DataFrame\n    69→) -> pd.DataFrame:\n    70→    \"\"\"Join step-level data with lifecycle data to derive per-step KV features.\n    71→\n    72→    For each step, identifies active requests (those whose time window overlaps\n    73→    the step window), estimates each request's KV cache length at step start,\n    74→    and computes aggregate statistics.\n    75→\n    76→    Args:\n    77→        steps_df: Step-level DataFrame from data_loader.load_experiment_steps().\n    78→            Must have columns: step.id, step.ts_start_ns, step.ts_end_ns,\n    79→            experiment_id.\n    80→        lifecycle_df: Per-request DataFrame from data_loader.load_lifecycle_data().\n    81→            Must have columns: start_time, end_time, input_tokens,\n    82→            output_tokens, output_token_times. Index is request_id.\n    83→\n    84→    Returns:\n    85→        DataFrame with same index as steps_df plus new columns:\n    86→        kv_mean, kv_max, kv_sum, kv_count.\n    87→    \"\"\"\n    88→    # Pre-convert lifecycle timestamps from seconds to nanoseconds for\n    89→    # efficient comparison with step timestamps.\n    90→    lc_start_ns = (lifecycle_df[\"start_time\"].values * 1e9).astype(np.int64)\n    91→    lc_end_ns = (lifecycle_df[\"end_time\"].values * 1e9).astype(np.int64)\n    92→\n    93→    kv_means = np.zeros(len(steps_df), dtype=np.float64)\n    94→    kv_maxes = np.zeros(len(steps_df), dtype=np.float64)\n    95→    kv_sums = np.zeros(len(steps_df), dtype=np.float64)\n    96→    kv_stds = np.zeros(len(steps_df), dtype=np.float64)\n    97→    kv_counts = np.zeros(len(steps_df), dtype=np.int64)\n    98→\n    99→    for i, (_, step_row) in enumerate(steps_df.iterrows()):\n   100→        step_start_ns = int(step_row[\"step.ts_start_ns\"])\n   101→        step_end_ns = int(step_row[\"step.ts_end_ns\"])\n   102→\n   103→        # Active requests: start_time < step.ts_end AND end_time > step.ts_start\n   104→        # (overlapping time windows)\n   105→        active_mask = (lc_start_ns < step_end_ns) & (lc_end_ns > step_start_ns)\n   106→        active_indices = np.where(active_mask)[0]\n   107→\n   108→        if len(active_indices) == 0:\n   109→            # No active requests -> all zeros (already initialized)\n   110→            continue\n   111→\n   112→        kv_lengths = np.array(\n   113→            [\n   114→                _estimate_kv_length(lifecycle_df.iloc[idx], step_start_ns)\n   115→                for idx in active_indices\n   116→            ],\n   117→            dtype=np.float64,\n   118→        )\n   119→\n   120→        kv_means[i] = np.mean(kv_lengths)\n   121→        kv_maxes[i] = np.max(kv_lengths)\n   122→        kv_sums[i] = np.sum(kv_lengths)\n   123→        kv_stds[i] = np.std(kv_lengths) if len(kv_lengths) > 1 else 0.0\n   124→        kv_counts[i] = len(kv_lengths)\n   125→\n   126→    result = steps_df.copy()\n   127→    result[\"kv_mean\"] = kv_means\n   128→    result[\"kv_max\"] = kv_maxes\n   129→    result[\"kv_sum\"] = kv_sums\n   130→    result[\"kv_std\"] = kv_stds\n   131→    result[\"kv_count\"] = kv_counts\n   132→\n   133→    return result\n   134→\n   135→\n   136→def extract_all_experiments_kv_features(\n   137→    data_root: str | None = None,\n   138→) -> pd.DataFrame:\n   139→    \"\"\"Load all experiments and extract KV features for every step.\n   140→\n   141→    Convenience wrapper that iterates over experiment directories, loads both\n   142→    step data and lifecycle data for each, calls extract_kv_features, and\n   143→    concatenates all results.\n   144→\n   145→    Args:\n   146→        data_root: Path to the ground truth data directory. Defaults to\n   147→            eval/ground_truth/ relative to this file.\n   148→\n   149→    Returns:\n   150→        Concatenated DataFrame with step data enriched with KV columns,\n   151→        plus metadata columns (model, tp, workload, timestamp).\n   152→    \"\"\"\n   153→    if data_root is None:\n   154→        data_root = DEFAULT_DATA_ROOT\n   155→\n   156→    frames = []\n   157→    for dirname in sorted(os.listdir(data_root)):\n   158→        dirpath = os.path.join(data_root, dirname)\n   159→        if not os.path.isdir(dirpath):\n   160→            continue\n   161→\n   162→        # Skip directories that lack required files\n   163→        traces_path = os.path.join(dirpath, \"traces.json\")\n   164→        lifecycle_path = os.path.join(\n   165→            dirpath, \"results\", \"per_request_lifecycle_metrics.json\"\n   166→        )\n   167→        if not os.path.isfile(traces_path) or not os.path.isfile(lifecycle_path):\n   168→            continue\n   169→\n   170→        steps_df = load_experiment_steps(dirpath)\n   171→        lifecycle_df = load_lifecycle_data(dirpath)\n   172→\n   173→        enriched = extract_kv_features(steps_df, lifecycle_df)\n   174→\n   175→        meta = parse_experiment_metadata(dirname)\n   176→        enriched[\"model\"] = meta[\"model\"]\n   177→        enriched[\"tp\"] = meta[\"tp\"]\n   178→        enriched[\"workload\"] = meta[\"workload\"]\n   179→        enriched[\"timestamp\"] = meta[\"timestamp\"]\n   180→\n   181→        frames.append(enriched)\n   182→\n   183→    if not frames:\n   184→        return pd.DataFrame()\n   185→\n   186→    result = pd.concat(frames, ignore_index=True)\n   187→    result[\"tp\"] = result[\"tp\"].astype(\"Int64\")\n   188→\n   189→    return result\n   190→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"6dbf5136-60a8-4c44-ba6b-6d00558143b5"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_018Pe1LHHnaKBrVsgsA1iwDN","type":"tool_result","content":"     1→\"\"\"Convert ground-truth per_request_lifecycle_metrics.json to BLIS trace CSV.\n     2→\n     3→The simulator's legacy trace replay (--workload traces) expects a 5-column CSV:\n     4→    arrival_time,request_id,model,\"[token_ids]\",\"[token_ids]\"\n     5→\n     6→This script reads the lifecycle JSON and generates synthetic token IDs of the\n     7→correct lengths, with relative arrival times.\n     8→\"\"\"\n     9→\n    10→import json\n    11→import os\n    12→import random\n    13→\n    14→\n    15→def convert_lifecycle_to_csv(\n    16→    lifecycle_path: str,\n    17→    output_csv_path: str,\n    18→    model_name: str = \"model\",\n    19→    seed: int = 42,\n    20→) -> dict:\n    21→    \"\"\"Convert a per_request_lifecycle_metrics.json to BLIS trace CSV.\n    22→\n    23→    Args:\n    24→        lifecycle_path: Path to per_request_lifecycle_metrics.json.\n    25→        output_csv_path: Path to write the output CSV.\n    26→        model_name: Model name for the CSV (unused by simulator but required).\n    27→        seed: RNG seed for synthetic token ID generation.\n    28→\n    29→    Returns:\n    30→        dict with: num_requests, min_arrival_s, max_arrival_s, duration_s\n    31→    \"\"\"\n    32→    with open(lifecycle_path, \"r\") as f:\n    33→        data = json.load(f)\n    34→\n    35→    if not data:\n    36→        raise ValueError(f\"Empty lifecycle data: {lifecycle_path}\")\n    37→\n    38→    rng = random.Random(seed)\n    39→\n    40→    # Find the earliest start_time to compute relative arrivals\n    41→    base_time = min(entry[\"start_time\"] for entry in data)\n    42→\n    43→    rows = []\n    44→    for i, entry in enumerate(data):\n    45→        info = entry.get(\"info\", {})\n    46→        input_count = info.get(\"input_tokens\", 0)\n    47→        output_count = info.get(\"output_tokens\", 0)\n    48→\n    49→        # Relative arrival time in seconds\n    50→        arrival_s = entry[\"start_time\"] - base_time\n    51→\n    52→        # Generate synthetic token IDs (simulator only cares about array lengths)\n    53→        input_tokens = [rng.randint(0, 31999) for _ in range(input_count)]\n    54→        output_tokens = [rng.randint(0, 31999) for _ in range(output_count)]\n    55→\n    56→        rows.append((arrival_s, i, model_name, input_tokens, output_tokens))\n    57→\n    58→    # Sort by arrival time (should already be sorted, but ensure)\n    59→    rows.sort(key=lambda x: x[0])\n    60→\n    61→    with open(output_csv_path, \"w\") as f:\n    62→        f.write(\"arrival_time,request_id,model,prefill_tokens,decode_tokens\\n\")\n    63→        for arrival_s, req_id, model, inp, out in rows:\n    64→            f.write(\n    65→                f\"{arrival_s:.6f},request_{req_id},{model},\"\n    66→                f'\"{json.dumps(inp)}\",\"{json.dumps(out)}\"\\n'\n    67→            )\n    68→\n    69→    return {\n    70→        \"num_requests\": len(rows),\n    71→        \"min_arrival_s\": rows[0][0],\n    72→        \"max_arrival_s\": rows[-1][0],\n    73→        \"duration_s\": rows[-1][0] - rows[0][0],\n    74→    }\n    75→\n    76→\n    77→def convert_experiment(\n    78→    experiment_dir: str,\n    79→    output_dir: str,\n    80→    seed: int = 42,\n    81→) -> str:\n    82→    \"\"\"Convert a single experiment's lifecycle data to trace CSV.\n    83→\n    84→    Args:\n    85→        experiment_dir: Path to the experiment directory.\n    86→        output_dir: Directory to write the trace CSV.\n    87→        seed: RNG seed.\n    88→\n    89→    Returns:\n    90→        Path to the generated CSV file.\n    91→    \"\"\"\n    92→    lifecycle_path = os.path.join(\n    93→        experiment_dir, \"results\", \"per_request_lifecycle_metrics.json\"\n    94→    )\n    95→    if not os.path.isfile(lifecycle_path):\n    96→        raise FileNotFoundError(f\"No lifecycle data: {lifecycle_path}\")\n    97→\n    98→    exp_name = os.path.basename(experiment_dir)\n    99→    os.makedirs(output_dir, exist_ok=True)\n   100→    csv_path = os.path.join(output_dir, f\"{exp_name}.csv\")\n   101→\n   102→    # Read exp-config for model name\n   103→    config_path = os.path.join(experiment_dir, \"exp-config.yaml\")\n   104→    model_name = \"model\"\n   105→    if os.path.isfile(config_path):\n   106→        import yaml\n   107→\n   108→        with open(config_path, \"r\") as f:\n   109→            config = yaml.safe_load(f)\n   110→        model_name = config.get(\"model\", \"model\")\n   111→\n   112→    convert_lifecycle_to_csv(lifecycle_path, csv_path, model_name, seed)\n   113→    return csv_path\n   114→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"86f0f29a-beef-408b-8d15-fb0bee1d185a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01U2q1omYWKXoMa6AGk9o36H","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"Train regime-specific Ridge regression with ProgressIndex-derived KV features.\n     3→\n     4→Idea 2, H1: 3-regime ensemble (decode-only, mixed-light, mixed-heavy) per model.\n     5→Exports StepML artifacts compatible with the Go evaluator's regime dispatch.\n     6→\n     7→Usage: python3 train_regime_ridge.py [--output-dir OUTPUT_DIR] [--threshold THRESHOLD]\n     8→\"\"\"\n     9→import argparse\n    10→import json\n    11→import os\n    12→import sys\n    13→from pathlib import Path\n    14→\n    15→import numpy as np\n    16→import pandas as pd\n    17→from sklearn.linear_model import Ridge\n    18→from sklearn.model_selection import GridSearchCV\n    19→\n    20→# Add shared infrastructure to path\n    21→SHARED_DIR = Path(__file__).resolve().parent.parent.parent.parent / \"shared\"\n    22→sys.path.insert(0, str(SHARED_DIR))\n    23→\n    24→from data_loader import load_all_experiments\n    25→from evaluation import compute_mape, compute_mspe, compute_pearson_r, compute_p99_error\n    26→from lifecycle_kv_extractor import extract_all_experiments_kv_features\n    27→from splits import temporal_split\n    28→\n    29→\n    30→# ---------------------------------------------------------------------------\n    31→# Regime classification\n    32→# ---------------------------------------------------------------------------\n    33→\n    34→REGIME_DECODE_ONLY = \"decode_only\"\n    35→REGIME_MIXED_LIGHT = \"mixed_light\"\n    36→REGIME_MIXED_HEAVY = \"mixed_heavy\"\n    37→\n    38→\n    39→def classify_regimes(df: pd.DataFrame, threshold: int = 256) -> pd.Series:\n    40→    \"\"\"Classify each step into a batch-composition regime.\"\"\"\n    41→    prefill = df[\"batch.prefill_tokens\"].fillna(0).astype(int)\n    42→    regime = pd.Series(REGIME_DECODE_ONLY, index=df.index)\n    43→    regime[prefill > 0] = REGIME_MIXED_LIGHT\n    44→    regime[prefill >= threshold] = REGIME_MIXED_HEAVY\n    45→    return regime\n    46→\n    47→\n    48→# ---------------------------------------------------------------------------\n    49→# Feature engineering\n    50→# ---------------------------------------------------------------------------\n    51→\n    52→DECODE_FEATURES = [\n    53→    \"batch.decode_tokens\",\n    54→    \"batch.num_decode_reqs\",\n    55→    \"kv_sum\",\n    56→    \"kv_max\",\n    57→    \"kv_mean\",\n    58→    \"kv_std\",\n    59→    \"decode_x_kv_mean\",\n    60→]\n    61→\n    62→MIXED_FEATURES = [\n    63→    \"batch.prefill_tokens\",\n    64→    \"batch.decode_tokens\",\n    65→    \"batch.num_prefill_reqs\",\n    66→    \"batch.num_decode_reqs\",\n    67→    \"kv_sum\",\n    68→    \"kv_max\",\n    69→    \"prefill_x_decode\",\n    70→    \"prefill_sq\",\n    71→]\n    72→\n    73→TARGET = \"step.duration_us\"\n    74→\n    75→\n    76→def add_interaction_features(df: pd.DataFrame) -> pd.DataFrame:\n    77→    \"\"\"Add derived interaction features matching Go's extractBatchFeatures.\"\"\"\n    78→    df = df.copy()\n    79→    df[\"prefill_x_decode\"] = (\n    80→        df[\"batch.prefill_tokens\"].fillna(0) * df[\"batch.decode_tokens\"].fillna(0)\n    81→    )\n    82→    df[\"decode_x_kv_mean\"] = (\n    83→        df[\"batch.num_decode_reqs\"].fillna(0) * df[\"kv_mean\"].fillna(0)\n    84→    )\n    85→    df[\"prefill_sq\"] = df[\"batch.prefill_tokens\"].fillna(0) ** 2\n    86→    return df\n    87→\n    88→\n    89→# ---------------------------------------------------------------------------\n    90→# Training\n    91→# ---------------------------------------------------------------------------\n    92→\n    93→\n    94→def train_regime_model(\n    95→    train_df: pd.DataFrame, features: list[str], target: str = TARGET,\n    96→    use_log_target: bool = True,\n    97→) -> tuple[Ridge, dict]:\n    98→    \"\"\"Train Ridge with CV-tuned alpha on a single regime.\n    99→\n   100→    When use_log_target=True, trains on log(step_time) to prevent negative\n   101→    predictions. Predictions must be exponentiated before use.\n   102→\n   103→    IMPORTANT: use_log_target=False is required when training on cycle_time\n   104→    (compute + overhead) because the overhead is additive but expm1 makes\n   105→    predictions multiplicative, causing exponential amplification of per-request\n   106→    coefficients at large batch sizes.\n   107→    \"\"\"\n   108→    X = train_df[features].fillna(0).values\n   109→    y = train_df[target].values\n   110→\n   111→    if use_log_target:\n   112→        y = np.log1p(np.maximum(y, 1))  # log(1 + max(y, 1))\n   113→\n   114→    alphas = [0.01, 0.1, 1.0, 10.0, 100.0, 1000.0]\n   115→    grid = GridSearchCV(\n   116→        Ridge(), {\"alpha\": alphas}, cv=5, scoring=\"neg_mean_absolute_error\"\n   117→    )\n   118→    grid.fit(X, y)\n   119→    best = grid.best_estimator_\n   120→\n   121→    return best, {\"alpha\": grid.best_params_[\"alpha\"], \"n_samples\": len(X),\n   122→                  \"log_target\": use_log_target}\n   123→\n   124→\n   125→def evaluate_model(\n   126→    model: Ridge, df: pd.DataFrame, features: list[str], target: str = TARGET,\n   127→    use_log_target: bool = True,\n   128→) -> dict:\n   129→    \"\"\"Evaluate a trained model on a DataFrame.\"\"\"\n   130→    X = df[features].fillna(0).values\n   131→    y = df[target].values\n   132→    pred = model.predict(X)\n   133→\n   134→    if use_log_target:\n   135→        # Exponentiate predictions back to original scale\n   136→        pred = np.expm1(pred)  # exp(pred) - 1\n   137→        pred = np.maximum(pred, 1)  # ensure positive\n   138→\n   139→    return {\n   140→        \"mape\": compute_mape(pred, y),\n   141→        \"mspe\": compute_mspe(pred, y),\n   142→        \"pearson_r\": compute_pearson_r(pred, y),\n   143→        \"p99_error\": compute_p99_error(pred, y),\n   144→        \"n_samples\": len(y),\n   145→        \"mean_predicted\": float(np.mean(pred)),\n   146→        \"mean_actual\": float(np.mean(y)),\n   147→    }\n   148→\n   149→\n   150→# ---------------------------------------------------------------------------\n   151→# Artifact export\n   152→# ---------------------------------------------------------------------------\n   153→\n   154→# Mapping from Python feature column names to Go feature names\n   155→_FEATURE_NAME_MAP = {\n   156→    \"batch.prefill_tokens\": \"prefill_tokens\",\n   157→    \"batch.decode_tokens\": \"decode_tokens\",\n   158→    \"batch.num_prefill_reqs\": \"num_prefill_reqs\",\n   159→    \"batch.num_decode_reqs\": \"num_decode_reqs\",\n   160→    \"batch.scheduled_tokens\": \"scheduled_tokens\",\n   161→    \"kv_sum\": \"kv_sum\",\n   162→    \"kv_max\": \"kv_max\",\n   163→    \"kv_mean\": \"kv_mean\",\n   164→    \"kv_std\": \"kv_std\",\n   165→    \"prefill_x_decode\": \"prefill_x_decode\",\n   166→    \"decode_x_kv_mean\": \"decode_x_kv_mean\",\n   167→    \"prefill_sq\": \"prefill_sq\",\n   168→}\n   169→\n   170→\n   171→def export_regime_artifact(\n   172→    models: dict[str, tuple],\n   173→    threshold: int,\n   174→    secondary_constants: dict,\n   175→    output_path: str,\n   176→    step_overhead_us: float = 0.0,\n   177→    log_target: bool = True,\n   178→):\n   179→    \"\"\"Export a regime-based StepML artifact JSON for the Go evaluator.\n   180→\n   181→    models values can be (Ridge, features) or (Ridge, features, use_log).\n   182→    When use_log is present, it overrides the global log_target for that regime.\n   183→    \"\"\"\n   184→    regimes = []\n   185→\n   186→    def _unpack(entry):\n   187→        if len(entry) == 3:\n   188→            return entry[0], entry[1], entry[2]\n   189→        return entry[0], entry[1], log_target\n   190→\n   191→    # Regime 1: decode-only (prefill_tokens == 0)\n   192→    if REGIME_DECODE_ONLY in models:\n   193→        ridge, features, use_log = _unpack(models[REGIME_DECODE_ONLY])\n   194→        regimes.append({\n   195→            \"name\": \"decode_only\",\n   196→            \"condition\": {\"feature\": \"prefill_tokens\", \"op\": \"==\", \"value\": 0},\n   197→            \"model\": _ridge_to_linear_model(ridge, features, log_target=use_log),\n   198→        })\n   199→\n   200→    # Regime 2: mixed-light (0 < prefill_tokens < threshold)\n   201→    if REGIME_MIXED_LIGHT in models:\n   202→        ridge, features, use_log = _unpack(models[REGIME_MIXED_LIGHT])\n   203→        regimes.append({\n   204→            \"name\": \"mixed_light\",\n   205→            \"condition\": {\"feature\": \"prefill_tokens\", \"op\": \"<\", \"value\": threshold},\n   206→            \"model\": _ridge_to_linear_model(ridge, features, log_target=use_log),\n   207→        })\n   208→\n   209→    # Regime 3: mixed-heavy (fallback — prefill_tokens >= threshold)\n   210→    if REGIME_MIXED_HEAVY in models:\n   211→        ridge, features, use_log = _unpack(models[REGIME_MIXED_HEAVY])\n   212→        regimes.append({\n   213→            \"name\": \"mixed_heavy\",\n   214→            \"condition\": None,  # fallback\n   215→            \"model\": _ridge_to_linear_model(ridge, features, log_target=use_log),\n   216→        })\n   217→\n   218→    artifact = {\n   219→        \"version\": 2,\n   220→        \"step_time_regimes\": regimes,\n   221→        \"step_overhead_us\": step_overhead_us,\n   222→        \"output_token_processing_time_us\": secondary_constants.get(\"output_token\", 0.0),\n   223→        \"scheduling_processing_time_us\": secondary_constants.get(\"scheduling\", 0.0),\n   224→        \"preemption_processing_time_us\": secondary_constants.get(\"preemption\", 0.0),\n   225→    }\n   226→\n   227→    os.makedirs(os.path.dirname(output_path), exist_ok=True)\n   228→    with open(output_path, \"w\") as f:\n   229→        json.dump(artifact, f, indent=2)\n   230→\n   231→\n   232→def _ridge_to_linear_model(ridge: Ridge, features: list[str],\n   233→                           log_target: bool = True) -> dict:\n   234→    \"\"\"Convert a sklearn Ridge model to Go LinearModel JSON format.\"\"\"\n   235→    coeffs = {}\n   236→    for feat, coeff in zip(features, ridge.coef_):\n   237→        go_name = _FEATURE_NAME_MAP.get(feat, feat)\n   238→        if abs(coeff) > 1e-10:  # skip near-zero coefficients\n   239→            coeffs[go_name] = float(coeff)\n   240→    model = {\n   241→        \"model_type\": \"linear\",\n   242→        \"intercept\": float(ridge.intercept_),\n   243→        \"feature_coefficients\": coeffs,\n   244→    }\n   245→    if log_target:\n   246→        model[\"output_transform\"] = \"expm1\"\n   247→    return model\n   248→\n   249→\n   250→# ---------------------------------------------------------------------------\n   251→# Also export a single (non-regime) model for comparison\n   252→# ---------------------------------------------------------------------------\n   253→\n   254→ALL_FEATURES = [\n   255→    \"batch.prefill_tokens\",\n   256→    \"batch.decode_tokens\",\n   257→    \"batch.num_prefill_reqs\",\n   258→    \"batch.num_decode_reqs\",\n   259→    \"kv_sum\",\n   260→    \"kv_max\",\n   261→    \"kv_mean\",\n   262→    \"kv_std\",\n   263→]\n   264→\n   265→\n   266→def export_single_artifact(\n   267→    ridge: Ridge,\n   268→    features: list[str],\n   269→    secondary_constants: dict,\n   270→    output_path: str,\n   271→    step_overhead_us: float = 0.0,\n   272→    log_target: bool = True,\n   273→):\n   274→    \"\"\"Export a single (non-regime) StepML artifact for comparison.\"\"\"\n   275→    artifact = {\n   276→        \"version\": 1,\n   277→        \"step_time\": _ridge_to_linear_model(ridge, features, log_target=log_target),\n   278→        \"step_overhead_us\": step_overhead_us,\n   279→        \"output_token_processing_time_us\": secondary_constants.get(\"output_token\", 0.0),\n   280→        \"scheduling_processing_time_us\": secondary_constants.get(\"scheduling\", 0.0),\n   281→        \"preemption_processing_time_us\": secondary_constants.get(\"preemption\", 0.0),\n   282→    }\n   283→    os.makedirs(os.path.dirname(output_path), exist_ok=True)\n   284→    with open(output_path, \"w\") as f:\n   285→        json.dump(artifact, f, indent=2)\n   286→\n   287→\n   288→# ---------------------------------------------------------------------------\n   289→# Main\n   290→# ---------------------------------------------------------------------------\n   291→\n   292→\n   293→def compute_step_overhead(df: pd.DataFrame) -> dict[str, float]:\n   294→    \"\"\"Compute per-model per-step overhead from ground truth ITL.\n   295→\n   296→    The training data's step.duration_us only captures GPU compute time.\n   297→    The real step cycle includes scheduling, sync, and CPU-side overhead.\n   298→\n   299→    We derive the overhead from ground truth inter-token latency (ITL),\n   300→    which equals the full step cycle time in continuous batching:\n   301→        overhead = GT_ITL - mean_compute_time_per_step\n   302→\n   303→    Returns a dict mapping model_key → overhead in µs.\n   304→    \"\"\"\n   305→    from data_loader import DEFAULT_DATA_ROOT\n   306→\n   307→    overheads: dict[str, list[float]] = {}\n   308→\n   309→    for exp_id in sorted(df[\"experiment_id\"].unique()):\n   310→        # Skip reasoning workloads (different dynamics — overhead is\n   311→        # negative due to large-batch compute dominating)\n   312→        if \"reasoning\" in exp_id:\n   313→            continue\n   314→\n   315→        sub = df[df[\"experiment_id\"] == exp_id]\n   316→        model = sub.iloc[0][\"model\"]\n   317→        tp = int(sub.iloc[0][\"tp\"])\n   318→        model_key = normalize_model_key(model, tp)\n   319→\n   320→        exp_dir = os.path.join(DEFAULT_DATA_ROOT, exp_id)\n   321→        gt_path = os.path.join(exp_dir, \"results\", \"summary_lifecycle_metrics.json\")\n   322→        if not os.path.isfile(gt_path):\n   323→            continue\n   324→        with open(gt_path) as f:\n   325→            gt = json.load(f)\n   326→\n   327→        # Ground truth ITL = step cycle time in continuous batching\n   328→        successes = gt.get(\"successes\", {})\n   329→        itl_mean_s = successes.get(\"latency\", {}).get(\n   330→            \"inter_token_latency\", {}\n   331→        ).get(\"mean\", 0)\n   332→        if itl_mean_s <= 0:\n   333→            continue\n   334→\n   335→        itl_mean_us = itl_mean_s * 1e6\n   336→        compute_mean = sub[\"step.duration_us\"].mean()\n   337→        overhead = itl_mean_us - compute_mean\n   338→\n   339→        if overhead > 0:\n   340→            if model_key not in overheads:\n   341→                overheads[model_key] = []\n   342→            overheads[model_key].append(overhead)\n   343→\n   344→    return {mk: float(np.mean(vals)) for mk, vals in overheads.items()}\n   345→\n   346→\n   347→def normalize_model_key(model: str, tp: int) -> str:\n   348→    \"\"\"Create a model+TP key matching the baseline convention.\"\"\"\n   349→    return f\"{model}_tp{tp}\"\n   350→\n   351→\n   352→def main():\n   353→    parser = argparse.ArgumentParser(description=__doc__)\n   354→    parser.add_argument(\n   355→        \"--output-dir\",\n   356→        default=str(Path(__file__).parent / \"output\"),\n   357→        help=\"Directory for output files\",\n   358→    )\n   359→    parser.add_argument(\n   360→        \"--threshold\",\n   361→        type=int,\n   362→        default=256,\n   363→        help=\"Mixed-light/heavy regime boundary (prefill tokens)\",\n   364→    )\n   365→    args = parser.parse_args()\n   366→\n   367→    output_dir = args.output_dir\n   368→    os.makedirs(output_dir, exist_ok=True)\n   369→\n   370→    # -----------------------------------------------------------------------\n   371→    # Step 1: Load data with KV features\n   372→    # -----------------------------------------------------------------------\n   373→    print(\"Step 1: Loading data with KV features...\", flush=True)\n   374→    df = extract_all_experiments_kv_features()\n   375→    print(f\"  Loaded {len(df)} steps from {df['experiment_id'].nunique()} experiments\")\n   376→\n   377→    df = add_interaction_features(df)\n   378→    df[\"model_key\"] = df.apply(\n   379→        lambda r: normalize_model_key(r[\"model\"], r[\"tp\"]), axis=1\n   380→    )\n   381→\n   382→    # -----------------------------------------------------------------------\n   383→    # Step 1b: Compute per-model step overhead\n   384→    # -----------------------------------------------------------------------\n   385→    print(\"Step 1b: Computing per-model step overhead...\", flush=True)\n   386→    model_overheads = compute_step_overhead(df)\n   387→    for mk, oh in sorted(model_overheads.items()):\n   388→        print(f\"  {mk}: {oh:.0f} µs\")\n   389→\n   390→    # -----------------------------------------------------------------------\n   391→    # Step 2: Temporal split (per-model to avoid cross-model interference)\n   392→    # -----------------------------------------------------------------------\n   393→    print(\"Step 2: Per-model temporal split (60/20/20)...\", flush=True)\n   394→\n   395→    # -----------------------------------------------------------------------\n   396→    # Step 3: Classify regimes\n   397→    # -----------------------------------------------------------------------\n   398→    print(f\"Step 3: Classifying regimes (threshold={args.threshold})...\", flush=True)\n   399→    df[\"regime\"] = classify_regimes(df, threshold=args.threshold)\n   400→    regime_counts = df[\"regime\"].value_counts()\n   401→    for regime, count in regime_counts.items():\n   402→        pct = 100 * count / len(df)\n   403→        print(f\"  {regime}: {count} steps ({pct:.1f}%)\")\n   404→\n   405→    # -----------------------------------------------------------------------\n   406→    # Step 4: Train per-model regime-specific Ridge models\n   407→    # -----------------------------------------------------------------------\n   408→    # Step 3b: Augment target with per-model overhead (cycle time = compute + overhead)\n   409→    # -----------------------------------------------------------------------\n   410→    print(\"Step 3b: Augmenting target with per-model overhead...\", flush=True)\n   411→    CYCLE_TARGET = \"step.cycle_time_us\"\n   412→    df[CYCLE_TARGET] = df[TARGET].astype(float)  # start with compute time (float for overhead addition)\n   413→    for model_key, overhead in model_overheads.items():\n   414→        mask = df[\"model_key\"] == model_key\n   415→        df.loc[mask, CYCLE_TARGET] = df.loc[mask, TARGET] + overhead\n   416→        n = mask.sum()\n   417→        print(f\"  {model_key}: +{overhead:.0f} µs overhead applied to {n} steps\")\n   418→\n   419→    # -----------------------------------------------------------------------\n   420→    print(\"Step 4: Training per-model regime-specific Ridge models...\", flush=True)\n   421→    results = []\n   422→    all_model_keys = sorted(df[\"model_key\"].unique())\n   423→\n   424→    for model_key in all_model_keys:\n   425→        model_mask = df[\"model_key\"] == model_key\n   426→        model_df = df[model_mask]\n   427→        # Per-model temporal split avoids cross-model interference\n   428→        # when experiments are added/removed from ground truth.\n   429→        model_split = temporal_split(model_df)\n   430→        model_train = model_df.loc[model_split[\"train\"]]\n   431→        model_valid = model_df.loc[model_split[\"valid\"]]\n   432→        model_test = model_df.loc[model_split[\"test\"]]\n   433→\n   434→        regime_models = {}\n   435→\n   436→        for regime_name in [REGIME_DECODE_ONLY, REGIME_MIXED_LIGHT, REGIME_MIXED_HEAVY]:\n   437→            features = DECODE_FEATURES if regime_name == REGIME_DECODE_ONLY else MIXED_FEATURES\n   438→            regime_train = model_train[model_train[\"regime\"] == regime_name]\n   439→            regime_test = model_test[model_test[\"regime\"] == regime_name]\n   440→\n   441→            if len(regime_train) < 50:\n   442→                print(f\"  {model_key}/{regime_name}: SKIP (only {len(regime_train)} training samples)\")\n   443→                continue\n   444→\n   445→            # ALL regimes: raw linear (no log transform).\n   446→            # Log-space (expm1) is unsafe for BLIS E2E because KV features\n   447→            # and prefill tokens cause exponential blowup at large values.\n   448→            # The overhead floor handles small-batch accuracy; raw linear\n   449→            # provides correct batch-size scaling for large batches.\n   450→            ridge, train_info = train_regime_model(\n   451→                regime_train, features, use_log_target=False\n   452→            )\n   453→            regime_models[regime_name] = (ridge, features)\n   454→\n   455→            if len(regime_test) > 0:\n   456→                test_metrics = evaluate_model(\n   457→                    ridge, regime_test, features, use_log_target=False\n   458→                )\n   459→                results.append({\n   460→                    \"model_key\": model_key,\n   461→                    \"regime\": regime_name,\n   462→                    \"n_train\": train_info[\"n_samples\"],\n   463→                    \"alpha\": train_info[\"alpha\"],\n   464→                    \"test_mape\": test_metrics[\"mape\"],\n   465→                    \"test_mspe\": test_metrics[\"mspe\"],\n   466→                    \"test_r\": test_metrics[\"pearson_r\"],\n   467→                    \"test_p99\": test_metrics[\"p99_error\"],\n   468→                    \"test_n\": test_metrics[\"n_samples\"],\n   469→                })\n   470→                print(\n   471→                    f\"  {model_key}/{regime_name}: MAPE={test_metrics['mape']:.1f}%, \"\n   472→                    f\"r={test_metrics['pearson_r']:.3f}, \"\n   473→                    f\"n_train={train_info['n_samples']}, n_test={test_metrics['n_samples']}, \"\n   474→                    f\"alpha={train_info['alpha']}\"\n   475→                )\n   476→\n   477→        # Export regime artifact: raw linear compute + overhead floor/cap in Go\n   478→        overhead = model_overheads.get(model_key, 0.0)\n   479→        artifact_path = os.path.join(output_dir, \"artifacts\", f\"{model_key}_regime.json\")\n   480→        export_regime_artifact(\n   481→            regime_models, args.threshold,\n   482→            secondary_constants={\"output_token\": 0, \"scheduling\": 0, \"preemption\": 0},\n   483→            output_path=artifact_path,\n   484→            step_overhead_us=overhead,\n   485→            log_target=False,\n   486→        )\n   487→\n   488→        # Also train and export a single (non-regime) model for comparison\n   489→        single_ridge, single_info = train_regime_model(\n   490→            model_train, ALL_FEATURES, use_log_target=False\n   491→        )\n   492→        single_test_metrics = evaluate_model(\n   493→            single_ridge, model_test, ALL_FEATURES, use_log_target=False\n   494→        )\n   495→        results.append({\n   496→            \"model_key\": model_key,\n   497→            \"regime\": \"single_global\",\n   498→            \"n_train\": single_info[\"n_samples\"],\n   499→            \"alpha\": single_info[\"alpha\"],\n   500→            \"test_mape\": single_test_metrics[\"mape\"],\n   501→            \"test_mspe\": single_test_metrics[\"mspe\"],\n   502→            \"test_r\": single_test_metrics[\"pearson_r\"],\n   503→            \"test_p99\": single_test_metrics[\"p99_error\"],\n   504→            \"test_n\": single_test_metrics[\"n_samples\"],\n   505→        })\n   506→        print(\n   507→            f\"  {model_key}/single_global: MAPE={single_test_metrics['mape']:.1f}%, \"\n   508→            f\"r={single_test_metrics['pearson_r']:.3f}\"\n   509→        )\n   510→\n   511→        single_path = os.path.join(output_dir, \"artifacts\", f\"{model_key}_single.json\")\n   512→        export_single_artifact(\n   513→            single_ridge, ALL_FEATURES,\n   514→            secondary_constants={\"output_token\": 0, \"scheduling\": 0, \"preemption\": 0},\n   515→            output_path=single_path,\n   516→            step_overhead_us=overhead,\n   517→            log_target=False,\n   518→        )\n   519→\n   520→    # -----------------------------------------------------------------------\n   521→    # Step 5: Blackbox baseline comparison\n   522→    # -----------------------------------------------------------------------\n   523→    print(\"\\nStep 5: Blackbox baseline comparison...\", flush=True)\n   524→    bb_features = [\"batch.prefill_tokens\", \"batch.decode_tokens\"]\n   525→    for model_key in all_model_keys:\n   526→        model_mask = df[\"model_key\"] == model_key\n   527→        model_df = df[model_mask]\n   528→        model_split = temporal_split(model_df)\n   529→        model_train = model_df.loc[model_split[\"train\"]]\n   530→        model_test = model_df.loc[model_split[\"test\"]]\n   531→\n   532→        bb_ridge, _ = train_regime_model(model_train, bb_features)\n   533→        bb_metrics = evaluate_model(bb_ridge, model_test, bb_features)\n   534→        results.append({\n   535→            \"model_key\": model_key,\n   536→            \"regime\": \"blackbox_baseline\",\n   537→            \"n_train\": len(model_train),\n   538→            \"alpha\": 0,\n   539→            \"test_mape\": bb_metrics[\"mape\"],\n   540→            \"test_mspe\": bb_metrics[\"mspe\"],\n   541→            \"test_r\": bb_metrics[\"pearson_r\"],\n   542→            \"test_p99\": bb_metrics[\"p99_error\"],\n   543→            \"test_n\": bb_metrics[\"n_samples\"],\n   544→        })\n   545→        print(\n   546→            f\"  {model_key}/blackbox: MAPE={bb_metrics['mape']:.1f}%, \"\n   547→            f\"r={bb_metrics['pearson_r']:.3f}\"\n   548→        )\n   549→\n   550→    # -----------------------------------------------------------------------\n   551→    # Step 6: KV feature ablation\n   552→    # -----------------------------------------------------------------------\n   553→    print(\"\\nStep 6: KV feature ablation (regime models WITHOUT KV features)...\", flush=True)\n   554→    no_kv_decode = [\"batch.decode_tokens\", \"batch.num_decode_reqs\"]\n   555→    no_kv_mixed = [\n   556→        \"batch.prefill_tokens\", \"batch.decode_tokens\",\n   557→        \"batch.num_prefill_reqs\", \"batch.num_decode_reqs\",\n   558→        \"prefill_x_decode\", \"prefill_sq\",\n   559→    ]\n   560→    for model_key in all_model_keys:\n   561→        model_mask = df[\"model_key\"] == model_key\n   562→        model_df = df[model_mask]\n   563→        model_split = temporal_split(model_df)\n   564→        model_train = model_df.loc[model_split[\"train\"]]\n   565→        model_test = model_df.loc[model_split[\"test\"]]\n   566→\n   567→        for regime_name in [REGIME_DECODE_ONLY, REGIME_MIXED_LIGHT, REGIME_MIXED_HEAVY]:\n   568→            features = no_kv_decode if regime_name == REGIME_DECODE_ONLY else no_kv_mixed\n   569→            regime_train = model_train[model_train[\"regime\"] == regime_name]\n   570→            regime_test = model_test[model_test[\"regime\"] == regime_name]\n   571→\n   572→            if len(regime_train) < 50 or len(regime_test) < 10:\n   573→                continue\n   574→\n   575→            ridge, _ = train_regime_model(regime_train, features)\n   576→            metrics = evaluate_model(ridge, regime_test, features)\n   577→            results.append({\n   578→                \"model_key\": model_key,\n   579→                \"regime\": f\"{regime_name}_no_kv\",\n   580→                \"n_train\": len(regime_train),\n   581→                \"alpha\": 0,\n   582→                \"test_mape\": metrics[\"mape\"],\n   583→                \"test_mspe\": metrics[\"mspe\"],\n   584→                \"test_r\": metrics[\"pearson_r\"],\n   585→                \"test_p99\": metrics[\"p99_error\"],\n   586→                \"test_n\": metrics[\"n_samples\"],\n   587→            })\n   588→\n   589→    # -----------------------------------------------------------------------\n   590→    # Step 7: Save results\n   591→    # -----------------------------------------------------------------------\n   592→    results_df = pd.DataFrame(results)\n   593→    results_path = os.path.join(output_dir, \"regime_ridge_results.csv\")\n   594→    results_df.to_csv(results_path, index=False)\n   595→    print(f\"\\nResults saved to {results_path}\")\n   596→\n   597→    # -----------------------------------------------------------------------\n   598→    # Step 8: Summary\n   599→    # -----------------------------------------------------------------------\n   600→    print(\"\\n\" + \"=\" * 70)\n   601→    print(\"  REGIME-SPECIFIC RIDGE RESULTS SUMMARY\")\n   602→    print(\"=\" * 70)\n   603→\n   604→    # Per-model aggregate (regime-specific)\n   605→    regime_results = results_df[\n   606→        results_df[\"regime\"].isin([REGIME_DECODE_ONLY, REGIME_MIXED_LIGHT, REGIME_MIXED_HEAVY])\n   607→    ]\n   608→    if len(regime_results) > 0:\n   609→        print(\"\\n  --- Per-Model Regime MAPE (test set) ---\")\n   610→        for model_key in all_model_keys:\n   611→            model_regime = regime_results[regime_results[\"model_key\"] == model_key]\n   612→            if len(model_regime) > 0:\n   613→                # Weighted average MAPE by sample count\n   614→                total_n = model_regime[\"test_n\"].sum()\n   615→                weighted_mape = (model_regime[\"test_mape\"] * model_regime[\"test_n\"]).sum() / total_n\n   616→                print(f\"  {model_key}: weighted MAPE = {weighted_mape:.1f}%\")\n   617→                for _, row in model_regime.iterrows():\n   618→                    print(\n   619→                        f\"    {row['regime']}: MAPE={row['test_mape']:.1f}%, \"\n   620→                        f\"r={row['test_r']:.3f}, n={row['test_n']}\"\n   621→                    )\n   622→\n   623→        overall_n = regime_results[\"test_n\"].sum()\n   624→        overall_mape = (regime_results[\"test_mape\"] * regime_results[\"test_n\"]).sum() / overall_n\n   625→        print(f\"\\n  Overall weighted MAPE (regime models): {overall_mape:.1f}%\")\n   626→\n   627→    # Single-model comparison\n   628→    single_results = results_df[results_df[\"regime\"] == \"single_global\"]\n   629→    if len(single_results) > 0:\n   630→        single_n = single_results[\"test_n\"].sum()\n   631→        single_mape = (single_results[\"test_mape\"] * single_results[\"test_n\"]).sum() / single_n\n   632→        print(f\"  Overall weighted MAPE (single model):  {single_mape:.1f}%\")\n   633→\n   634→    # Blackbox baseline\n   635→    bb_results = results_df[results_df[\"regime\"] == \"blackbox_baseline\"]\n   636→    if len(bb_results) > 0:\n   637→        bb_n = bb_results[\"test_n\"].sum()\n   638→        bb_mape = (bb_results[\"test_mape\"] * bb_results[\"test_n\"]).sum() / bb_n\n   639→        print(f\"  Overall weighted MAPE (blackbox):       {bb_mape:.1f}%\")\n   640→\n   641→    # KV ablation\n   642→    no_kv_results = results_df[results_df[\"regime\"].str.endswith(\"_no_kv\")]\n   643→    if len(no_kv_results) > 0:\n   644→        no_kv_n = no_kv_results[\"test_n\"].sum()\n   645→        no_kv_mape = (no_kv_results[\"test_mape\"] * no_kv_results[\"test_n\"]).sum() / no_kv_n\n   646→        print(f\"  Overall weighted MAPE (no KV features): {no_kv_mape:.1f}%\")\n   647→        kv_improvement = no_kv_mape - overall_mape\n   648→        print(f\"  KV feature contribution: {kv_improvement:.1f} pp improvement\")\n   649→\n   650→    print(\"\\n  Artifact directory:\", os.path.join(output_dir, \"artifacts\"))\n   651→    print(\"=\" * 70)\n   652→\n   653→\n   654→if __name__ == \"__main__\":\n   655→    main()\n   656→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"c0f5dc82-4cad-43a7-a97f-076a1f12a04e"}
