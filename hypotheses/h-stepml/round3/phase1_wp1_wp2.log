{"type":"assistant","message":{"id":"msg_bdrk_01LksD4QSznfP6Kh7GHnqLPM","type":"message","role":"assistant","model":"claude-opus-4-6","content":[{"type":"tool_use","id":"toolu_bdrk_01W24hTQzeCh4Pax3d5nFApM","name":"Read","input":{"file_path":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/BLIS-research/hypotheses/h-stepml/shared/e2e_decomposition.py"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"output_tokens":0},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"fb8498dd-923e-4a61-bbe0-cf0ad25d62e1"}
{"type":"assistant","message":{"id":"msg_bdrk_01LksD4QSznfP6Kh7GHnqLPM","type":"message","role":"assistant","model":"claude-opus-4-6","content":[{"type":"tool_use","id":"toolu_bdrk_0124NnuoeDYjm4LiVELYrga8","name":"Read","input":{"file_path":"/Users/dipanwitaguhathakurta/Downloads/inference-sim-package/BLIS-research/hypotheses/h-stepml/shared/establish_baseline.py"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"output_tokens":0},"context_management":null},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"eb1a73b4-006f-4bff-b11f-9e27ef5e4e60"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_019Xwqt3jQbnAMJd1Fdmk792","type":"tool_result","content":"     1→\"\"\"Data splitting strategies for StepML experiments.\n     2→\n     3→Provides three splitting functions for ML training and evaluation:\n     4→\n     5→- **temporal_split**: Within each experiment, sorts steps by step.id and\n     6→  assigns the first 60% to train, next 20% to validation, last 20% to test.\n     7→  Every experiment is represented in all three splits (stratified).\n     8→\n     9→- **leave_one_model_out**: 4-fold cross-validation where each fold holds out\n    10→  all data from one model. Model names are normalized so that variants\n    11→  (e.g., \"llama-2-70b\" and \"llama-2-70b-hf\") are grouped together.\n    12→\n    13→- **leave_one_workload_out**: 4-fold cross-validation where each fold holds\n    14→  out all data from one workload type.\n    15→\n    16→All functions return integer indices (into the DataFrame's index) rather than\n    17→boolean masks, making them compatible with iloc/loc indexing.\n    18→\"\"\"\n    19→\n    20→import re\n    21→\n    22→import numpy as np\n    23→import pandas as pd\n    24→\n    25→\n    26→# ---------------------------------------------------------------------------\n    27→# Model name normalization\n    28→# ---------------------------------------------------------------------------\n    29→# Some experiments use variant names for the same model, e.g.:\n    30→#   \"llama-2-70b\" and \"llama-2-70b-hf\"\n    31→# We normalize by stripping known suffixes so they group together.\n    32→_MODEL_SUFFIX_PATTERN = re.compile(r\"-hf$\")\n    33→\n    34→\n    35→def _normalize_model_name(name: str) -> str:\n    36→    \"\"\"Normalize model names by stripping variant suffixes.\n    37→\n    38→    Examples:\n    39→        \"llama-2-70b-hf\" -> \"llama-2-70b\"\n    40→        \"llama-2-7b\"     -> \"llama-2-7b\"\n    41→        \"mixtral-8x7b-v0-1\" -> \"mixtral-8x7b-v0-1\"\n    42→    \"\"\"\n    43→    return _MODEL_SUFFIX_PATTERN.sub(\"\", name)\n    44→\n    45→\n    46→# ---------------------------------------------------------------------------\n    47→# Temporal split\n    48→# ---------------------------------------------------------------------------\n    49→\n    50→\n    51→def temporal_split(\n    52→    df: pd.DataFrame,\n    53→    train_frac: float = 0.6,\n    54→    valid_frac: float = 0.2,\n    55→    seed: int = 42,\n    56→) -> dict:\n    57→    \"\"\"Split data temporally within each experiment.\n    58→\n    59→    Within each experiment (grouped by ``experiment_id``), rows are sorted by\n    60→    ``step.id`` and the first ``train_frac`` fraction is assigned to training,\n    61→    the next ``valid_frac`` fraction to validation, and the remainder to test.\n    62→\n    63→    This split is deterministic given the data (step ordering is fixed), so\n    64→    the ``seed`` parameter is included for API consistency but does not affect\n    65→    the result.\n    66→\n    67→    Args:\n    68→        df: DataFrame with ``experiment_id`` and ``step.id`` columns.\n    69→        train_frac: Fraction of steps for training (default 0.6).\n    70→        valid_frac: Fraction of steps for validation (default 0.2).\n    71→        seed: Included for API consistency; does not affect the split.\n    72→\n    73→    Returns:\n    74→        Dict with keys ``\"train\"``, ``\"valid\"``, ``\"test\"``, each mapping to a\n    75→        sorted numpy array of integer row indices from df.index.\n    76→    \"\"\"\n    77→    train_indices = []\n    78→    valid_indices = []\n    79→    test_indices = []\n    80→\n    81→    for _exp_id, group in df.groupby(\"experiment_id\"):\n    82→        # Sort by step.id within this experiment\n    83→        sorted_group = group.sort_values(\"step.id\")\n    84→        indices = sorted_group.index.values\n    85→        n = len(indices)\n    86→\n    87→        # Compute split boundaries\n    88→        n_train = int(round(n * train_frac))\n    89→        n_valid = int(round(n * valid_frac))\n    90→\n    91→        train_indices.append(indices[:n_train])\n    92→        valid_indices.append(indices[n_train : n_train + n_valid])\n    93→        test_indices.append(indices[n_train + n_valid :])\n    94→\n    95→    return {\n    96→        \"train\": np.sort(np.concatenate(train_indices)),\n    97→        \"valid\": np.sort(np.concatenate(valid_indices)),\n    98→        \"test\": np.sort(np.concatenate(test_indices)),\n    99→    }\n   100→\n   101→\n   102→# ---------------------------------------------------------------------------\n   103→# Leave-one-model-out\n   104→# ---------------------------------------------------------------------------\n   105→\n   106→\n   107→def leave_one_model_out(df: pd.DataFrame) -> list:\n   108→    \"\"\"Leave-one-model-out cross-validation folds.\n   109→\n   110→    Produces 4 folds, one per unique model. Model names are normalized so\n   111→    that variants like \"llama-2-70b\" and \"llama-2-70b-hf\" are treated as\n   112→    the same model.\n   113→\n   114→    Within each fold, the test set contains all rows for the held-out model,\n   115→    and the training set contains all remaining rows.\n   116→\n   117→    Args:\n   118→        df: DataFrame with a ``model`` column.\n   119→\n   120→    Returns:\n   121→        List of 4 dicts, each with keys:\n   122→        - ``\"train\"``: numpy array of training row indices\n   123→        - ``\"test\"``: numpy array of test row indices\n   124→        - ``\"holdout_model\"``: the normalized model name held out\n   125→\n   126→    Note:\n   127→        As a side effect, the ``model`` column in ``df`` is normalized\n   128→        in-place (e.g., \"llama-2-70b-hf\" becomes \"llama-2-70b\"). This\n   129→        ensures downstream consumers see consistent model names.\n   130→    \"\"\"\n   131→    normalized = df[\"model\"].map(_normalize_model_name)\n   132→    unique_models = sorted(normalized.unique())\n   133→\n   134→    folds = []\n   135→    for holdout_model in unique_models:\n   136→        is_holdout = normalized == holdout_model\n   137→        test_idx = df.index[is_holdout].values\n   138→        train_idx = df.index[~is_holdout].values\n   139→\n   140→        folds.append(\n   141→            {\n   142→                \"train\": np.sort(train_idx),\n   143→                \"test\": np.sort(test_idx),\n   144→                \"holdout_model\": holdout_model,\n   145→            }\n   146→        )\n   147→\n   148→    # Normalize the model column in the dataframe so downstream consumers\n   149→    # see consistent names. This is intentional: variants of the same model\n   150→    # should be unified.\n   151→    df[\"model\"] = normalized.values\n   152→\n   153→    return folds\n   154→\n   155→\n   156→# ---------------------------------------------------------------------------\n   157→# Leave-one-workload-out\n   158→# ---------------------------------------------------------------------------\n   159→\n   160→\n   161→def leave_one_workload_out(df: pd.DataFrame) -> list:\n   162→    \"\"\"Leave-one-workload-out cross-validation folds.\n   163→\n   164→    Produces 4 folds, one per unique workload. Within each fold, the test set\n   165→    contains all rows for the held-out workload, and the training set contains\n   166→    all remaining rows.\n   167→\n   168→    Args:\n   169→        df: DataFrame with a ``workload`` column.\n   170→\n   171→    Returns:\n   172→        List of 4 dicts, each with keys:\n   173→        - ``\"train\"``: numpy array of training row indices\n   174→        - ``\"test\"``: numpy array of test row indices\n   175→        - ``\"holdout_workload\"``: the workload name held out\n   176→    \"\"\"\n   177→    unique_workloads = sorted(df[\"workload\"].unique())\n   178→\n   179→    folds = []\n   180→    for holdout_workload in unique_workloads:\n   181→        is_holdout = df[\"workload\"] == holdout_workload\n   182→        test_idx = df.index[is_holdout].values\n   183→        train_idx = df.index[~is_holdout].values\n   184→\n   185→        folds.append(\n   186→            {\n   187→                \"train\": np.sort(train_idx),\n   188→                \"test\": np.sort(test_idx),\n   189→                \"holdout_workload\": holdout_workload,\n   190→            }\n   191→        )\n   192→\n   193→    return folds\n   194→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"efbc02b9-4532-4e42-b7b6-e9fb02f361d8"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01Bj3E3H1Krmv11Yz3ommvkp","type":"tool_result","content":"     1→\"\"\"Baseline models for step-time prediction.\n     2→\n     3→Provides two baselines:\n     4→- BlackboxBaseline: re-trained 3-coefficient linear regression matching BLIS blackbox model\n     5→- NaiveMeanBaseline: always predicts the training set mean step duration\n     6→\n     7→Plus calibration and gating utilities for the StepML research workflow.\n     8→\"\"\"\n     9→\n    10→from __future__ import annotations\n    11→\n    12→import numpy as np\n    13→import pandas as pd\n    14→from scipy.optimize import nnls\n    15→\n    16→from evaluation import (\n    17→    compute_mape,\n    18→    compute_mspe,\n    19→    compute_p99_error,\n    20→    compute_pearson_r,\n    21→)\n    22→\n    23→# Feature columns used by the blackbox model\n    24→_FEATURE_COLS = [\"batch.prefill_tokens\", \"batch.decode_tokens\"]\n    25→# Target column\n    26→_TARGET_COL = \"step.duration_us\"\n    27→\n    28→\n    29→class BlackboxBaseline:\n    30→    \"\"\"Re-trained 3-coefficient non-negative linear model matching BLIS blackbox.\n    31→\n    32→    StepTime = beta0 + beta1 * batch.prefill_tokens + beta2 * batch.decode_tokens\n    33→\n    34→    All three coefficients are constrained to be >= 0 via NNLS (non-negative\n    35→    least squares). The intercept is modelled as a third feature (ones column)\n    36→    so that the non-negativity constraint applies uniformly to all betas.\n    37→\n    38→    Column normalization is applied before NNLS to avoid scale mismatch between\n    39→    the ones column (~1) and token columns (~0-2048), then coefficients are\n    40→    rescaled to original units.\n    41→    \"\"\"\n    42→\n    43→    def __init__(self) -> None:\n    44→        self._coeffs: np.ndarray | None = None  # [beta0, beta1, beta2]\n    45→\n    46→    def fit(self, train_df: pd.DataFrame) -> BlackboxBaseline:\n    47→        \"\"\"Train on step-level data using column-normalized NNLS.\n    48→\n    49→        Constructs A = [ones, prefill_tokens, decode_tokens], normalizes each\n    50→        column by its L2 norm, solves NNLS, then rescales coefficients back.\n    51→        \"\"\"\n    52→        X = train_df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n    53→        y = train_df[_TARGET_COL].to_numpy(dtype=np.float64)\n    54→\n    55→        # Build design matrix: [ones, prefill, decode]\n    56→        ones = np.ones((X.shape[0], 1), dtype=np.float64)\n    57→        A = np.hstack([ones, X])\n    58→\n    59→        # Column-normalize to fix conditioning\n    60→        col_norms = np.linalg.norm(A, axis=0)\n    61→        col_norms[col_norms == 0] = 1.0  # guard against zero columns\n    62→        A_normed = A / col_norms\n    63→\n    64→        # Solve NNLS on normalized problem\n    65→        x_normed, _ = nnls(A_normed, y)\n    66→\n    67→        # Rescale coefficients back to original units\n    68→        self._coeffs = x_normed / col_norms\n    69→        return self\n    70→\n    71→    def predict(self, df: pd.DataFrame) -> np.ndarray:\n    72→        \"\"\"Predict step.duration_us from batch features.\"\"\"\n    73→        if self._coeffs is None:\n    74→            raise RuntimeError(\"BlackboxBaseline.predict() called before fit()\")\n    75→        X = df[_FEATURE_COLS].to_numpy(dtype=np.float64)\n    76→        return self._coeffs[0] + X @ self._coeffs[1:]\n    77→\n    78→    @property\n    79→    def coefficients(self) -> dict:\n    80→        \"\"\"Return {\"beta0\": intercept, \"beta1\": prefill_coeff, \"beta2\": decode_coeff}.\"\"\"\n    81→        if self._coeffs is None:\n    82→            raise RuntimeError(\"BlackboxBaseline.coefficients accessed before fit()\")\n    83→        return {\n    84→            \"beta0\": float(self._coeffs[0]),\n    85→            \"beta1\": float(self._coeffs[1]),\n    86→            \"beta2\": float(self._coeffs[2]),\n    87→        }\n    88→\n    89→\n    90→class NaiveMeanBaseline:\n    91→    \"\"\"Always predicts the training set mean step duration.\"\"\"\n    92→\n    93→    def __init__(self) -> None:\n    94→        self._mean: float | None = None\n    95→\n    96→    def fit(self, train_df: pd.DataFrame) -> NaiveMeanBaseline:\n    97→        \"\"\"Compute and store the training set mean of step.duration_us.\"\"\"\n    98→        self._mean = float(train_df[_TARGET_COL].mean())\n    99→        return self\n   100→\n   101→    def predict(self, df: pd.DataFrame) -> np.ndarray:\n   102→        \"\"\"Return an array of the training mean, one per input row.\"\"\"\n   103→        if self._mean is None:\n   104→            raise RuntimeError(\"NaiveMeanBaseline.predict() called before fit()\")\n   105→        return np.full(len(df), self._mean)\n   106→\n   107→\n   108→def compute_baseline_report(\n   109→    train_df: pd.DataFrame,\n   110→    test_df: pd.DataFrame,\n   111→    baselines: dict | None = None,\n   112→) -> dict:\n   113→    \"\"\"Compute evaluation metrics for all baselines.\n   114→\n   115→    Args:\n   116→        train_df: Training split DataFrame with feature and target columns.\n   117→        test_df: Test split DataFrame with feature and target columns.\n   118→        baselines: Optional dict of {name: baseline_instance}. If None, uses\n   119→            default baselines (blackbox + naive_mean).\n   120→\n   121→    Returns:\n   122→        Dict like:\n   123→        {\n   124→            \"blackbox\": {\"mape\": 15.2, \"mspe\": -3.1, \"pearson_r\": 0.89, \"p99_error\": 45.3},\n   125→            \"naive_mean\": {\"mape\": 42.1, ...},\n   126→        }\n   127→        Uses evaluation.py functions (compute_mape, compute_mspe, compute_pearson_r, compute_p99_error).\n   128→    \"\"\"\n   129→    if baselines is None:\n   130→        baselines = {\n   131→            \"blackbox\": BlackboxBaseline(),\n   132→            \"naive_mean\": NaiveMeanBaseline(),\n   133→        }\n   134→\n   135→    actual = test_df[_TARGET_COL].values\n   136→    report: dict = {}\n   137→\n   138→    for name, model in baselines.items():\n   139→        model.fit(train_df)\n   140→        predicted = model.predict(test_df)\n   141→\n   142→        pearson_r = compute_pearson_r(predicted, actual)\n   143→        # pearsonr returns NaN for constant inputs (e.g., NaiveMeanBaseline).\n   144→        # Replace with 0.0 — constant predictions have zero useful correlation.\n   145→        if np.isnan(pearson_r):\n   146→            pearson_r = 0.0\n   147→\n   148→        report[name] = {\n   149→            \"mape\": float(compute_mape(predicted, actual)),\n   150→            \"mspe\": float(compute_mspe(predicted, actual)),\n   151→            \"pearson_r\": float(pearson_r),\n   152→            \"p99_error\": float(compute_p99_error(predicted, actual)),\n   153→        }\n   154→\n   155→    return report\n   156→\n   157→\n   158→def calibrate_short_circuit_threshold(blackbox_mape: float) -> float:\n   159→    \"\"\"Determine the short-circuit threshold for StepML improvement.\n   160→\n   161→    If blackbox MAPE > 25%, threshold = blackbox_MAPE + 10%.\n   162→    Otherwise threshold = 35% (25% + 10% buffer).\n   163→\n   164→    Args:\n   165→        blackbox_mape: The blackbox baseline's MAPE as a percentage.\n   166→\n   167→    Returns:\n   168→        The threshold as a percentage.\n   169→    \"\"\"\n   170→    if blackbox_mape > 25.0:\n   171→        return blackbox_mape + 10.0\n   172→    return 35.0\n   173→\n   174→\n   175→def check_r4_gate(blackbox_e2e_mean_error: float) -> dict:\n   176→    \"\"\"Check if blackbox is already good enough (R4 risk).\n   177→\n   178→    If abs(blackbox_e2e_mean_error) < 12%, flag for research justification review.\n   179→    This means the blackbox model is already performing well at the E2E level,\n   180→    so additional ML complexity may not be justified.\n   181→\n   182→    Args:\n   183→        blackbox_e2e_mean_error: The blackbox baseline's E2E mean error as a percentage.\n   184→\n   185→    Returns:\n   186→        {\"passed\": bool, \"e2e_error\": float, \"message\": str}\n   187→        passed=True means no flag (research is justified).\n   188→        passed=False means flagged (blackbox already good enough, needs justification).\n   189→    \"\"\"\n   190→    e2e_error = float(blackbox_e2e_mean_error)\n   191→    flagged = abs(e2e_error) < 12.0\n   192→\n   193→    if flagged:\n   194→        message = (\n   195→            f\"R4 gate FLAGGED: blackbox E2E mean error = {e2e_error:.1f}% \"\n   196→            f\"(|error| < 12%). Blackbox may already be sufficient. \"\n   197→            f\"Review research justification before proceeding.\"\n   198→        )\n   199→    else:\n   200→        message = (\n   201→            f\"R4 gate passed: blackbox E2E mean error = {e2e_error:.1f}% \"\n   202→            f\"(|error| >= 12%). Step-level ML improvement is justified.\"\n   203→        )\n   204→\n   205→    return {\n   206→        \"passed\": not flagged,\n   207→        \"e2e_error\": e2e_error,\n   208→        \"message\": message,\n   209→    }\n   210→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"13384145-522f-4436-8bb6-8e5738aeaa85"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01W24hTQzeCh4Pax3d5nFApM","type":"tool_result","content":"     1→\"\"\"Component-level error attribution for E2E latency prediction.\n     2→\n     3→Analyzes which of the 5 LatencyModel methods contributes most to E2E\n     4→prediction error.  This informs research ideation by identifying where\n     5→to focus improvement efforts.\n     6→\n     7→E2E(request) = QueueingTime(req)              [1] arrival-to-queue delay\n     8→             + (time waiting in WaitQ)         [2] emergent from simulation dynamics\n     9→             + SchedulingProcessingTime()      [3] per-request scheduling overhead\n    10→             + sum StepTime(batch)             [4] GPU execution per batch step\n    11→             + sum OutputTokenProcessingTime() [5] per-token post-processing\n    12→             + KV transfer latency             [6] CPU<->GPU offload/reload\n    13→             + PreemptionProcessingTime()      [7] if preempted and re-queued\n    14→\n    15→The 5 LatencyModel methods and their blackbox implementations:\n    16→  1. StepTime:                     beta0 + beta1*prefill + beta2*decode\n    17→  2. QueueingTime:                 alpha0 + alpha1*input_len\n    18→  3. OutputTokenProcessingTime:    constant alpha2 (per output token)\n    19→  4. SchedulingProcessingTime:     returns 0\n    20→  5. PreemptionProcessingTime:     returns 0\n    21→\n    22→All percentage values are returned as floats where 10.0 means 10%.\n    23→All time values are in microseconds unless otherwise noted.\n    24→\"\"\"\n    25→\n    26→from __future__ import annotations\n    27→\n    28→import os\n    29→\n    30→import numpy as np\n    31→import pandas as pd\n    32→\n    33→from evaluation import compute_mape, compute_mspe, compute_p99_error, compute_pearson_r\n    34→from data_loader import DEFAULT_DATA_ROOT, load_all_experiments, load_lifecycle_data\n    35→\n    36→\n    37→def compute_blackbox_step_predictions(\n    38→    steps_df: pd.DataFrame,\n    39→    beta_coeffs: list[float],\n    40→) -> pd.Series:\n    41→    \"\"\"Predict step time using blackbox model: beta0 + beta1*prefill + beta2*decode.\n    42→\n    43→    Args:\n    44→        steps_df: DataFrame with batch.prefill_tokens and batch.decode_tokens columns.\n    45→        beta_coeffs: [beta0, beta1, beta2].\n    46→\n    47→    Returns:\n    48→        Series of predicted step times (microseconds).\n    49→    \"\"\"\n    50→    if len(beta_coeffs) != 3:\n    51→        raise ValueError(f\"Expected 3 beta coefficients, got {len(beta_coeffs)}\")\n    52→\n    53→    beta0, beta1, beta2 = beta_coeffs\n    54→    prefill = steps_df[\"batch.prefill_tokens\"].astype(np.float64)\n    55→    decode = steps_df[\"batch.decode_tokens\"].astype(np.float64)\n    56→    predicted = beta0 + beta1 * prefill + beta2 * decode\n    57→    return predicted\n    58→\n    59→\n    60→def compute_step_time_error(\n    61→    steps_df: pd.DataFrame,\n    62→    beta_coeffs: list[float],\n    63→) -> dict:\n    64→    \"\"\"Compute step time prediction error metrics.\n    65→\n    66→    Args:\n    67→        steps_df: DataFrame with batch.prefill_tokens, batch.decode_tokens,\n    68→            and step.duration_us columns.\n    69→        beta_coeffs: [beta0, beta1, beta2].\n    70→\n    71→    Returns:\n    72→        Dict with keys: mape, mspe (signed), pearson_r, p99_error,\n    73→        mean_predicted, mean_actual, total_predicted, total_actual.\n    74→    \"\"\"\n    75→    predicted = compute_blackbox_step_predictions(steps_df, beta_coeffs).values\n    76→    actual = steps_df[\"step.duration_us\"].astype(np.float64).values\n    77→\n    78→    # pearsonr requires at least 2 data points\n    79→    if len(predicted) < 2:\n    80→        pearson_r = 0.0\n    81→    else:\n    82→        pearson_r = compute_pearson_r(predicted, actual)\n    83→        if np.isnan(pearson_r):\n    84→            pearson_r = 0.0\n    85→\n    86→    return {\n    87→        \"mape\": float(compute_mape(predicted, actual)),\n    88→        \"mspe\": float(compute_mspe(predicted, actual)),\n    89→        \"pearson_r\": float(pearson_r),\n    90→        \"p99_error\": float(compute_p99_error(predicted, actual)),\n    91→        \"mean_predicted\": float(np.mean(predicted)),\n    92→        \"mean_actual\": float(np.mean(actual)),\n    93→        \"total_predicted\": float(np.sum(predicted)),\n    94→        \"total_actual\": float(np.sum(actual)),\n    95→    }\n    96→\n    97→\n    98→def estimate_queueing_contribution(\n    99→    lifecycle_df: pd.DataFrame,\n   100→    alpha_coeffs: list[float],\n   101→) -> dict:\n   102→    \"\"\"Estimate queueing time contribution.\n   103→\n   104→    For each request: queueing = alpha0 + alpha1 * input_tokens.\n   105→    Compares total predicted queueing time against total E2E time.\n   106→\n   107→    Args:\n   108→        lifecycle_df: DataFrame indexed by request_id with columns:\n   109→            start_time, end_time, input_tokens.\n   110→        alpha_coeffs: [alpha0, alpha1, alpha2] (alpha2 unused here).\n   111→\n   112→    Returns:\n   113→        Dict with keys: mean_queueing_us, total_queueing_us, fraction_of_e2e.\n   114→        fraction_of_e2e = total_queueing / total_e2e where\n   115→        e2e = end_time - start_time.\n   116→    \"\"\"\n   117→    alpha0 = alpha_coeffs[0]\n   118→    alpha1 = alpha_coeffs[1]\n   119→\n   120→    input_tokens = lifecycle_df[\"input_tokens\"].astype(np.float64).values\n   121→    queueing = alpha0 + alpha1 * input_tokens\n   122→\n   123→    e2e = (\n   124→        lifecycle_df[\"end_time\"].astype(np.float64).values\n   125→        - lifecycle_df[\"start_time\"].astype(np.float64).values\n   126→    )\n   127→    total_e2e = float(np.sum(e2e))\n   128→    total_queueing = float(np.sum(queueing))\n   129→\n   130→    if total_e2e == 0:\n   131→        fraction = 0.0\n   132→    else:\n   133→        fraction = total_queueing / total_e2e\n   134→\n   135→    return {\n   136→        \"mean_queueing_us\": float(np.mean(queueing)),\n   137→        \"total_queueing_us\": total_queueing,\n   138→        \"fraction_of_e2e\": fraction,\n   139→    }\n   140→\n   141→\n   142→def estimate_output_processing_contribution(\n   143→    lifecycle_df: pd.DataFrame,\n   144→    alpha2: float,\n   145→) -> dict:\n   146→    \"\"\"Estimate output token processing contribution.\n   147→\n   148→    For each request: output_processing = alpha2 * output_tokens.\n   149→\n   150→    Args:\n   151→        lifecycle_df: DataFrame indexed by request_id with columns:\n   152→            start_time, end_time, output_tokens.\n   153→        alpha2: Per-token processing time (microseconds).\n   154→\n   155→    Returns:\n   156→        Dict with keys: mean_output_us, total_output_us, fraction_of_e2e.\n   157→    \"\"\"\n   158→    output_tokens = lifecycle_df[\"output_tokens\"].astype(np.float64).values\n   159→    output_processing = alpha2 * output_tokens\n   160→\n   161→    e2e = (\n   162→        lifecycle_df[\"end_time\"].astype(np.float64).values\n   163→        - lifecycle_df[\"start_time\"].astype(np.float64).values\n   164→    )\n   165→    total_e2e = float(np.sum(e2e))\n   166→    total_output = float(np.sum(output_processing))\n   167→\n   168→    if total_e2e == 0:\n   169→        fraction = 0.0\n   170→    else:\n   171→        fraction = total_output / total_e2e\n   172→\n   173→    return {\n   174→        \"mean_output_us\": float(np.mean(output_processing)),\n   175→        \"total_output_us\": total_output,\n   176→        \"fraction_of_e2e\": fraction,\n   177→    }\n   178→\n   179→\n   180→def estimate_step_time_contribution(\n   181→    steps_df: pd.DataFrame,\n   182→    lifecycle_df: pd.DataFrame,\n   183→) -> dict:\n   184→    \"\"\"Estimate step time's share of total E2E time from ground truth.\n   185→\n   186→    Sums all step.duration_us and compares against total E2E from lifecycle.\n   187→\n   188→    Args:\n   189→        steps_df: DataFrame with step.duration_us column.\n   190→        lifecycle_df: DataFrame indexed by request_id with start_time, end_time.\n   191→\n   192→    Returns:\n   193→        Dict with keys: total_step_us, total_e2e_us, fraction_of_e2e,\n   194→        mean_steps_per_request (total steps / number of requests).\n   195→    \"\"\"\n   196→    total_step = float(steps_df[\"step.duration_us\"].astype(np.float64).sum())\n   197→\n   198→    e2e = (\n   199→        lifecycle_df[\"end_time\"].astype(np.float64).values\n   200→        - lifecycle_df[\"start_time\"].astype(np.float64).values\n   201→    )\n   202→    total_e2e = float(np.sum(e2e))\n   203→    n_requests = len(lifecycle_df)\n   204→    n_steps = len(steps_df)\n   205→\n   206→    if total_e2e == 0:\n   207→        fraction = 0.0\n   208→    else:\n   209→        fraction = total_step / total_e2e\n   210→\n   211→    if n_requests == 0:\n   212→        mean_steps_per_request = 0.0\n   213→    else:\n   214→        mean_steps_per_request = n_steps / n_requests\n   215→\n   216→    return {\n   217→        \"total_step_us\": total_step,\n   218→        \"total_e2e_us\": total_e2e,\n   219→        \"fraction_of_e2e\": fraction,\n   220→        \"mean_steps_per_request\": mean_steps_per_request,\n   221→    }\n   222→\n   223→\n   224→def component_error_attribution(\n   225→    steps_df: pd.DataFrame,\n   226→    lifecycle_df: pd.DataFrame,\n   227→    alpha_coeffs: list[float],\n   228→    beta_coeffs: list[float],\n   229→) -> dict:\n   230→    \"\"\"Full component-level error attribution report.\n   231→\n   232→    Combines step-time error metrics, queueing contribution, output\n   233→    processing contribution, and step-time contribution fractions into\n   234→    a unified report that identifies where E2E prediction error originates.\n   235→\n   236→    Args:\n   237→        steps_df: DataFrame with batch.prefill_tokens, batch.decode_tokens,\n   238→            step.duration_us.\n   239→        lifecycle_df: DataFrame indexed by request_id with start_time,\n   240→            end_time, input_tokens, output_tokens.\n   241→        alpha_coeffs: [alpha0, alpha1, alpha2].\n   242→        beta_coeffs: [beta0, beta1, beta2].\n   243→\n   244→    Returns:\n   245→        Dict with keys:\n   246→        - step_time: step-level error metrics + contribution fraction\n   247→        - queueing_time: predicted contribution + fraction of E2E\n   248→        - output_processing: predicted contribution + fraction of E2E\n   249→        - scheduling: current status (returns 0)\n   250→        - preemption: current status (returns 0)\n   251→        - summary: which component dominates E2E error\n   252→        - recommendation: where to focus improvement\n   253→    \"\"\"\n   254→    # Step time error metrics\n   255→    step_error = compute_step_time_error(steps_df, beta_coeffs)\n   256→\n   257→    # Step time contribution to E2E\n   258→    step_contrib = estimate_step_time_contribution(steps_df, lifecycle_df)\n   259→\n   260→    # Queueing time contribution\n   261→    queueing = estimate_queueing_contribution(lifecycle_df, alpha_coeffs)\n   262→\n   263→    # Output processing contribution\n   264→    alpha2 = alpha_coeffs[2] if len(alpha_coeffs) >= 3 else 0.0\n   265→    output = estimate_output_processing_contribution(lifecycle_df, alpha2)\n   266→\n   267→    # Identify dominant error source\n   268→    step_frac = step_contrib[\"fraction_of_e2e\"]\n   269→    queue_frac = queueing[\"fraction_of_e2e\"]\n   270→    output_frac = output[\"fraction_of_e2e\"]\n   271→\n   272→    fractions = {\n   273→        \"step_time\": step_frac,\n   274→        \"queueing_time\": queue_frac,\n   275→        \"output_processing\": output_frac,\n   276→    }\n   277→    dominant_component = max(fractions, key=fractions.get)\n   278→\n   279→    summary = (\n   280→        f\"Step time accounts for {step_frac:.1%} of total E2E, \"\n   281→        f\"with MAPE={step_error['mape']:.1f}% and MSPE={step_error['mspe']:.1f}%. \"\n   282→        f\"Queueing accounts for {queue_frac:.1%}, \"\n   283→        f\"output processing for {output_frac:.1%}. \"\n   284→        f\"Dominant component: {dominant_component}.\"\n   285→    )\n   286→\n   287→    if dominant_component == \"step_time\" and step_error[\"mape\"] > 10.0:\n   288→        recommendation = (\n   289→            \"Step time dominates E2E and has significant prediction error \"\n   290→            f\"(MAPE={step_error['mape']:.1f}%). Focus on improving StepTime \"\n   291→            \"prediction (beta coefficients or ML replacement).\"\n   292→        )\n   293→    elif dominant_component == \"queueing_time\":\n   294→        recommendation = (\n   295→            \"Queueing time dominates E2E. Focus on improving QueueingTime \"\n   296→            \"prediction (alpha0/alpha1 coefficients) or reducing actual queueing.\"\n   297→        )\n   298→    elif dominant_component == \"output_processing\":\n   299→        recommendation = (\n   300→            \"Output processing dominates E2E. Focus on improving \"\n   301→            \"OutputTokenProcessingTime (alpha2 coefficient).\"\n   302→        )\n   303→    else:\n   304→        recommendation = (\n   305→            f\"Step time dominates E2E with low error (MAPE={step_error['mape']:.1f}%). \"\n   306→            \"Consider whether other components (scheduling, preemption) are \"\n   307→            \"under-modeled.\"\n   308→        )\n   309→\n   310→    return {\n   311→        \"step_time\": {\n   312→            **step_error,\n   313→            \"fraction_of_e2e\": step_frac,\n   314→            \"mean_steps_per_request\": step_contrib[\"mean_steps_per_request\"],\n   315→        },\n   316→        \"queueing_time\": queueing,\n   317→        \"output_processing\": output,\n   318→        \"scheduling\": {\n   319→            \"current_value\": 0.0,\n   320→            \"note\": (\n   321→                \"SchedulingProcessingTime currently returns 0. \"\n   322→                \"If real scheduling overhead is non-trivial, this is an \"\n   323→                \"unmodeled error source.\"\n   324→            ),\n   325→        },\n   326→        \"preemption\": {\n   327→            \"current_value\": 0.0,\n   328→            \"note\": (\n   329→                \"PreemptionProcessingTime currently returns 0. \"\n   330→                \"If preemptions are frequent, this is an unmodeled error source.\"\n   331→            ),\n   332→        },\n   333→        \"summary\": summary,\n   334→        \"recommendation\": recommendation,\n   335→    }\n   336→\n   337→\n   338→def component_error_attribution_all_experiments(\n   339→    data_root: str = None,\n   340→    coefficients: dict = None,\n   341→) -> pd.DataFrame:\n   342→    \"\"\"Run error attribution across all experiments.\n   343→\n   344→    Iterates over experiment directories under data_root, loads step-level\n   345→    and lifecycle data for each, and computes per-experiment error\n   346→    attribution using the provided (or default zero) coefficients.\n   347→\n   348→    Args:\n   349→        data_root: Path to ground truth data directory. Defaults to\n   350→            eval/ground_truth/ relative to this file.\n   351→        coefficients: Optional dict mapping experiment_id to\n   352→            {\"alpha\": [a0, a1, a2], \"beta\": [b0, b1, b2]}.\n   353→            If None or if an experiment_id is missing, uses zeros.\n   354→\n   355→    Returns:\n   356→        DataFrame with one row per experiment, columns for each component's\n   357→        error contribution and fraction.\n   358→    \"\"\"\n   359→    if data_root is None:\n   360→        data_root = DEFAULT_DATA_ROOT\n   361→\n   362→    if coefficients is None:\n   363→        coefficients = {}\n   364→\n   365→    default_alpha = [0.0, 0.0, 0.0]\n   366→    default_beta = [0.0, 0.0, 0.0]\n   367→\n   368→    rows = []\n   369→    for dirname in sorted(os.listdir(data_root)):\n   370→        dirpath = os.path.join(data_root, dirname)\n   371→        if not os.path.isdir(dirpath):\n   372→            continue\n   373→        traces_path = os.path.join(dirpath, \"traces.json\")\n   374→        lifecycle_path = os.path.join(\n   375→            dirpath, \"results\", \"per_request_lifecycle_metrics.json\"\n   376→        )\n   377→        if not os.path.isfile(traces_path) or not os.path.isfile(lifecycle_path):\n   378→            continue\n   379→\n   380→        from data_loader import load_experiment_steps, load_lifecycle_data as _load_lc\n   381→\n   382→        steps_df = load_experiment_steps(dirpath)\n   383→        lifecycle_df = _load_lc(dirpath)\n   384→\n   385→        if steps_df.empty or lifecycle_df.empty:\n   386→            continue\n   387→\n   388→        exp_coeffs = coefficients.get(dirname, {})\n   389→        alpha = exp_coeffs.get(\"alpha\", default_alpha)\n   390→        beta = exp_coeffs.get(\"beta\", default_beta)\n   391→\n   392→        report = component_error_attribution(steps_df, lifecycle_df, alpha, beta)\n   393→\n   394→        rows.append({\n   395→            \"experiment_id\": dirname,\n   396→            \"step_mape\": report[\"step_time\"][\"mape\"],\n   397→            \"step_mspe\": report[\"step_time\"][\"mspe\"],\n   398→            \"step_pearson_r\": report[\"step_time\"][\"pearson_r\"],\n   399→            \"step_p99_error\": report[\"step_time\"][\"p99_error\"],\n   400→            \"step_fraction_of_e2e\": report[\"step_time\"][\"fraction_of_e2e\"],\n   401→            \"queueing_fraction_of_e2e\": report[\"queueing_time\"][\"fraction_of_e2e\"],\n   402→            \"output_fraction_of_e2e\": report[\"output_processing\"][\"fraction_of_e2e\"],\n   403→            \"mean_steps_per_request\": report[\"step_time\"][\"mean_steps_per_request\"],\n   404→            \"recommendation\": report[\"recommendation\"],\n   405→        })\n   406→\n   407→    if not rows:\n   408→        return pd.DataFrame()\n   409→\n   410→    return pd.DataFrame(rows)\n   411→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"50d99dc9-0e27-46f1-accb-4595ba26e8c7"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_0124NnuoeDYjm4LiVELYrga8","type":"tool_result","content":"     1→\"\"\"Establish baselines for StepML research.\n     2→\n     3→Runs two baselines through BLIS E2E validation and measures E2E/TTFT/ITL error\n     4→against ground truth.  These are the accuracy bars that StepML models must beat.\n     5→\n     6→Baseline 1 — Roofline (analytical):\n     7→    Uses the analytical FLOPs/bandwidth roofline model.  Zero calibration data\n     8→    needed — step time is estimated from model architecture (HuggingFace\n     9→    config.json) and GPU specs (hardware_config.json).\n    10→\n    11→Baseline 2 — Per-model linear regression:\n    12→    Trains a separate 3-coefficient linear regression per model+TP on\n    13→    ground-truth step traces (step_time = beta0 + beta1*prefill + beta2*decode),\n    14→    pooling all workloads for a given model.  Requires training data.\n    15→\n    16→Usage:\n    17→    python establish_baseline.py [--data-root PATH] [--output-dir PATH]\n    18→    python establish_baseline.py --skip-linear              # roofline only\n    19→    python establish_baseline.py --skip-roofline            # linear only\n    20→    python establish_baseline.py --hardware A100            # non-default GPU\n    21→\"\"\"\n    22→\n    23→import argparse\n    24→import csv as csv_mod\n    25→import json\n    26→import os\n    27→import subprocess\n    28→import sys\n    29→import tempfile\n    30→from concurrent.futures import ThreadPoolExecutor, as_completed\n    31→\n    32→import numpy as np\n    33→import pandas as pd\n    34→\n    35→# Add shared/ to path for imports\n    36→_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n    37→sys.path.insert(0, _SCRIPT_DIR)\n    38→\n    39→import yaml\n    40→\n    41→from baselines import BlackboxBaseline, check_r4_gate\n    42→from data_loader import load_all_experiments, load_experiment_steps, parse_experiment_metadata\n    43→from evaluation import compute_mape, compute_mspe, compute_pearson_r, compute_p99_error\n    44→from validate_blis import (\n    45→    build_workload_spec,\n    46→    compute_error,\n    47→    extract_cpu_kv_blocks_from_vllm_log,\n    48→    extract_kv_blocks_from_vllm_log,\n    49→    load_exp_config,\n    50→    load_ground_truth_metrics,\n    51→    load_profile,\n    52→    parse_experiment_dir,\n    53→    run_blis,\n    54→)\n    55→\n    56→_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\"))\n    57→DEFAULT_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\n    58→_DEFAULT_WORKERS = min((os.cpu_count() or 4) // 2, 4)\n    59→\n    60→\n    61→def _build_canonical_model_map(data_root: str) -> dict:\n    62→    \"\"\"Build a map from experiment_id to canonical (model, tp) from exp-config.yaml.\n    63→\n    64→    Directory names have inconsistencies (e.g. \"llama-2-70b\" vs \"llama-2-70b-hf\"\n    65→    for the same model).  exp-config.yaml has the authoritative HF model name.\n    66→    \"\"\"\n    67→    mapping = {}\n    68→    for dirname in sorted(os.listdir(data_root)):\n    69→        config_path = os.path.join(data_root, dirname, \"exp-config.yaml\")\n    70→        if not os.path.isfile(config_path):\n    71→            continue\n    72→        with open(config_path) as f:\n    73→            cfg = yaml.safe_load(f)\n    74→        # Canonical model name from HF (e.g. \"meta-llama/Llama-2-70b-hf\")\n    75→        model = cfg.get(\"model\", \"\")\n    76→        tp = cfg.get(\"tensor_parallelism\", 1)\n    77→        mapping[dirname] = (model, tp)\n    78→    return mapping\n    79→\n    80→\n    81→def train_per_model_coefficients(data_root: str) -> dict:\n    82→    \"\"\"Train a linear regression per model+TP and return fitted coefficients.\n    83→\n    84→    Groups experiments by canonical (model, tp) from exp-config.yaml, trains\n    85→    one linear regression per group, and returns the coefficients.\n    86→\n    87→    Returns:\n    88→        dict keyed by (model, tp) with values:\n    89→        {\n    90→            \"beta0\": float, \"beta1\": float, \"beta2\": float,\n    91→            \"n_steps\": int, \"n_experiments\": int,\n    92→            \"train_mape\": float, \"train_r\": float,\n    93→            \"experiments\": [list of experiment_ids],\n    94→        }\n    95→    \"\"\"\n    96→    if data_root is None:\n    97→        data_root = DEFAULT_DATA_ROOT\n    98→\n    99→    # Build canonical model map from exp-config.yaml\n   100→    canon_map = _build_canonical_model_map(data_root)\n   101→\n   102→    all_steps = load_all_experiments(data_root)\n   103→    if all_steps.empty:\n   104→        raise ValueError(f\"No step data found in {data_root}\")\n   105→\n   106→    # Replace parsed model/tp with canonical values from exp-config.yaml\n   107→    all_steps[\"canonical_model\"] = all_steps[\"experiment_id\"].map(\n   108→        lambda eid: canon_map.get(eid, (\"unknown\", 0))[0]\n   109→    )\n   110→    all_steps[\"canonical_tp\"] = all_steps[\"experiment_id\"].map(\n   111→        lambda eid: canon_map.get(eid, (\"unknown\", 0))[1]\n   112→    )\n   113→\n   114→    # Group by canonical model+tp\n   115→    results = {}\n   116→    for (model, tp), group_df in all_steps.groupby([\"canonical_model\", \"canonical_tp\"]):\n   117→        tp_val = int(tp)\n   118→        baseline = BlackboxBaseline().fit(group_df)\n   119→        coeffs = baseline.coefficients\n   120→\n   121→        predicted = baseline.predict(group_df)\n   122→        actual = group_df[\"step.duration_us\"].values\n   123→\n   124→        train_mape = compute_mape(predicted, actual)\n   125→        train_r = compute_pearson_r(predicted, actual)\n   126→        train_mspe = compute_mspe(predicted, actual)\n   127→\n   128→        experiments = sorted(group_df[\"experiment_id\"].unique().tolist())\n   129→\n   130→        results[(model, tp_val)] = {\n   131→            \"beta0\": coeffs[\"beta0\"],\n   132→            \"beta1\": coeffs[\"beta1\"],\n   133→            \"beta2\": coeffs[\"beta2\"],\n   134→            \"n_steps\": len(group_df),\n   135→            \"n_experiments\": len(experiments),\n   136→            \"train_mape\": train_mape,\n   137→            \"train_mspe\": train_mspe,\n   138→            \"train_r\": train_r,\n   139→            \"experiments\": experiments,\n   140→        }\n   141→\n   142→    return results\n   143→\n   144→\n   145→def _ensure_binary() -> str:\n   146→    \"\"\"Return path to the simulation_worker binary, building if needed.\"\"\"\n   147→    binary = os.path.join(_REPO_ROOT, \"simulation_worker\")\n   148→    if not os.path.isfile(binary):\n   149→        print(\"Building simulation_worker...\", file=sys.stderr)\n   150→        subprocess.run(\n   151→            [\"go\", \"build\", \"-o\", binary, \"main.go\"],\n   152→            cwd=_REPO_ROOT, check=True,\n   153→        )\n   154→    return binary\n   155→\n   156→\n   157→def _run_single_experiment(\n   158→    binary: str,\n   159→    dirname: str,\n   160→    dirpath: str,\n   161→    alpha_coeffs: list[float],\n   162→    beta_coeffs: list[float],\n   163→    roofline: bool = False,\n   164→    hardware: str | None = None,\n   165→    extra_fields: dict | None = None,\n   166→) -> dict:\n   167→    \"\"\"Run BLIS for a single experiment and return a result row.\n   168→\n   169→    This is the unit of work dispatched to the thread pool.\n   170→    \"\"\"\n   171→    try:\n   172→        meta = parse_experiment_dir(dirname)\n   173→    except ValueError:\n   174→        return {\"experiment\": dirname, \"status\": \"parse_failed\"}\n   175→\n   176→    gt = load_ground_truth_metrics(dirpath)\n   177→    exp_config = load_exp_config(dirpath)\n   178→    total_kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n   179→    if total_kv_blocks is None:\n   180→        return {\n   181→            \"experiment\": dirname, \"model\": meta[\"model\"],\n   182→            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   183→            \"status\": \"no_kv_blocks\",\n   184→        }\n   185→    cpu_kv_blocks = extract_cpu_kv_blocks_from_vllm_log(dirpath)\n   186→\n   187→    try:\n   188→        profile = load_profile(dirpath)\n   189→    except Exception:\n   190→        return {\n   191→            \"experiment\": dirname, \"model\": meta[\"model\"],\n   192→            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   193→            \"status\": \"no_profile\",\n   194→        }\n   195→\n   196→    workload_spec = build_workload_spec(profile, gt)\n   197→\n   198→    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".yaml\", delete=False) as f:\n   199→        yaml.dump(workload_spec, f, default_flow_style=False)\n   200→        spec_path = f.name\n   201→\n   202→    with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n   203→        results_json_path = f.name\n   204→\n   205→    try:\n   206→        blis_metrics = run_blis(\n   207→            binary=binary,\n   208→            workload_spec_path=spec_path,\n   209→            exp_config=exp_config,\n   210→            total_kv_blocks=total_kv_blocks,\n   211→            alpha_coeffs=alpha_coeffs,\n   212→            beta_coeffs=beta_coeffs,\n   213→            results_path=results_json_path,\n   214→            roofline=roofline,\n   215→            hardware=hardware,\n   216→            cpu_kv_blocks=cpu_kv_blocks,\n   217→        )\n   218→    finally:\n   219→        os.unlink(spec_path)\n   220→        if os.path.exists(results_json_path):\n   221→            os.unlink(results_json_path)\n   222→\n   223→    if blis_metrics is None:\n   224→        return {\n   225→            \"experiment\": dirname, \"model\": meta[\"model\"],\n   226→            \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   227→            \"status\": \"blis_failed\",\n   228→        }\n   229→\n   230→    e2e_err = compute_error(blis_metrics[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000)\n   231→    ttft_err = compute_error(blis_metrics[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000)\n   232→    itl_err = compute_error(blis_metrics[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000)\n   233→\n   234→    marker = \" <10%\" if e2e_err < 0.10 else \"\"\n   235→    print(f\"  {dirname}: GT={gt['e2e_mean_s']*1000:.0f}ms  \"\n   236→          f\"BLIS={blis_metrics['e2e_mean_ms']:.0f}ms  \"\n   237→          f\"E2E={e2e_err*100:.1f}%{marker}\")\n   238→\n   239→    row = {\n   240→        \"experiment\": dirname, \"model\": meta[\"model\"],\n   241→        \"workload\": meta[\"workload\"], \"tp\": meta[\"tp\"],\n   242→        \"status\": \"ok\",\n   243→        \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n   244→        \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n   245→        \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n   246→        \"blis_e2e_ms\": blis_metrics[\"e2e_mean_ms\"],\n   247→        \"blis_ttft_ms\": blis_metrics[\"ttft_mean_ms\"],\n   248→        \"blis_itl_ms\": blis_metrics[\"itl_mean_ms\"],\n   249→        \"e2e_error\": e2e_err, \"ttft_error\": ttft_err, \"itl_error\": itl_err,\n   250→        \"blis_completed\": blis_metrics[\"completed_requests\"],\n   251→        \"gt_requests\": gt[\"num_requests\"],\n   252→    }\n   253→    if extra_fields:\n   254→        row.update(extra_fields)\n   255→    return row\n   256→\n   257→\n   258→def _write_results_csv(rows: list[dict], output_csv: str) -> None:\n   259→    \"\"\"Write result rows to CSV.\"\"\"\n   260→    if not rows:\n   261→        return\n   262→    all_keys = set()\n   263→    for r in rows:\n   264→        all_keys.update(r.keys())\n   265→    fieldnames = sorted(all_keys)\n   266→    with open(output_csv, \"w\", newline=\"\") as f:\n   267→        writer = csv_mod.DictWriter(f, fieldnames=fieldnames)\n   268→        writer.writeheader()\n   269→        writer.writerows(rows)\n   270→\n   271→\n   272→def _discover_experiments(data_root: str) -> list[tuple[str, str]]:\n   273→    \"\"\"Return list of (dirname, dirpath) for valid experiment directories.\"\"\"\n   274→    experiments = []\n   275→    for dirname in sorted(os.listdir(data_root)):\n   276→        dirpath = os.path.join(data_root, dirname)\n   277→        if not os.path.isdir(dirpath):\n   278→            continue\n   279→        summary_path = os.path.join(dirpath, \"results\", \"summary_lifecycle_metrics.json\")\n   280→        if not os.path.isfile(summary_path):\n   281→            continue\n   282→        experiments.append((dirname, dirpath))\n   283→    return experiments\n   284→\n   285→\n   286→def run_blis_validation(\n   287→    coefficients: dict,\n   288→    data_root: str,\n   289→    output_csv: str,\n   290→    max_workers: int = _DEFAULT_WORKERS,\n   291→) -> str:\n   292→    \"\"\"Run BLIS for each experiment using its model+TP-specific coefficients.\n   293→\n   294→    All experiments run in parallel via ThreadPoolExecutor.\n   295→\n   296→    Returns path to the output CSV.\n   297→    \"\"\"\n   298→    # Build experiment → coefficients lookup\n   299→    exp_to_coeffs = {}\n   300→    for (_model, _tp), coeffs in coefficients.items():\n   301→        for exp_id in coeffs[\"experiments\"]:\n   302→            exp_to_coeffs[exp_id] = coeffs\n   303→\n   304→    binary = _ensure_binary()\n   305→    experiments = _discover_experiments(data_root)\n   306→\n   307→    futures = {}\n   308→    with ThreadPoolExecutor(max_workers=max_workers) as pool:\n   309→        for dirname, dirpath in experiments:\n   310→            coeffs = exp_to_coeffs.get(dirname)\n   311→            if coeffs is None:\n   312→                continue\n   313→            beta = [coeffs[\"beta0\"], coeffs[\"beta1\"], coeffs[\"beta2\"]]\n   314→            extra = {\n   315→                \"beta0\": coeffs[\"beta0\"], \"beta1\": coeffs[\"beta1\"],\n   316→                \"beta2\": coeffs[\"beta2\"], \"train_mape\": coeffs[\"train_mape\"],\n   317→            }\n   318→            fut = pool.submit(\n   319→                _run_single_experiment,\n   320→                binary=binary, dirname=dirname, dirpath=dirpath,\n   321→                alpha_coeffs=[0.0, 0.0, 0.0], beta_coeffs=beta,\n   322→                extra_fields=extra,\n   323→            )\n   324→            futures[fut] = dirname\n   325→\n   326→        all_rows = []\n   327→        for fut in as_completed(futures):\n   328→            all_rows.append(fut.result())\n   329→\n   330→    # Sort by experiment name for deterministic output\n   331→    all_rows.sort(key=lambda r: r[\"experiment\"])\n   332→    _write_results_csv(all_rows, output_csv)\n   333→    return output_csv\n   334→\n   335→\n   336→def run_roofline_validation(\n   337→    data_root: str,\n   338→    output_csv: str,\n   339→    hardware: str = \"H100\",\n   340→    max_workers: int = _DEFAULT_WORKERS,\n   341→) -> str:\n   342→    \"\"\"Run BLIS in roofline mode for all experiments in parallel.\n   343→\n   344→    The roofline model is analytical — no training step.  It estimates step\n   345→    time from FLOPs/bandwidth using HuggingFace model config + GPU hardware\n   346→    specs.  Zero calibration data needed.\n   347→\n   348→    Returns path to the output CSV.\n   349→    \"\"\"\n   350→    print(f\"\\n{'='*60}\")\n   351→    print(f\"  Roofline baseline: hardware={hardware}\")\n   352→    print(f\"  (analytical FLOPs/bandwidth — no trained coefficients)\")\n   353→    print(f\"{'='*60}\")\n   354→\n   355→    binary = _ensure_binary()\n   356→    experiments = _discover_experiments(data_root)\n   357→\n   358→    futures = {}\n   359→    with ThreadPoolExecutor(max_workers=max_workers) as pool:\n   360→        for dirname, dirpath in experiments:\n   361→            fut = pool.submit(\n   362→                _run_single_experiment,\n   363→                binary=binary, dirname=dirname, dirpath=dirpath,\n   364→                alpha_coeffs=[0, 0, 0], beta_coeffs=[0, 0, 0],\n   365→                roofline=True, hardware=hardware,\n   366→            )\n   367→            futures[fut] = dirname\n   368→\n   369→        all_rows = []\n   370→        for fut in as_completed(futures):\n   371→            all_rows.append(fut.result())\n   372→\n   373→    all_rows.sort(key=lambda r: r[\"experiment\"])\n   374→    _write_results_csv(all_rows, output_csv)\n   375→    return output_csv\n   376→\n   377→\n   378→def print_roofline_summary(output_csv: str):\n   379→    \"\"\"Print a human-readable summary of the roofline baseline results.\"\"\"\n   380→    if not os.path.isfile(output_csv):\n   381→        print(\"No roofline results to summarize.\")\n   382→        return\n   383→\n   384→    df = pd.read_csv(output_csv)\n   385→    ok = df[df[\"status\"] == \"ok\"]\n   386→\n   387→    if ok.empty:\n   388→        print(\"\\nNo successful roofline experiments. Check BLIS binary and data.\")\n   389→        return\n   390→\n   391→    print(f\"\\n{'='*70}\")\n   392→    print(\"  ROOFLINE BASELINE RESULTS (analytical — no training)\")\n   393→    print(f\"{'='*70}\")\n   394→\n   395→    print(f\"\\n  Experiments: {len(ok)} completed, \"\n   396→          f\"{len(df) - len(ok)} skipped/failed\")\n   397→\n   398→    print(f\"\\n  {'Experiment':<55s} {'E2E%':>6s} {'TTFT%':>6s} {'ITL%':>6s}\")\n   399→    print(f\"  {'-'*55} {'-'*6} {'-'*6} {'-'*6}\")\n   400→    for _, row in ok.iterrows():\n   401→        e2e_pct = row[\"e2e_error\"] * 100\n   402→        ttft_pct = row[\"ttft_error\"] * 100\n   403→        itl_pct = row[\"itl_error\"] * 100\n   404→        marker = \" <10%\" if e2e_pct < 10 else \"\"\n   405→        print(f\"  {row['experiment']:<55s} \"\n   406→              f\"{e2e_pct:>5.1f}% {ttft_pct:>5.1f}% {itl_pct:>5.1f}%{marker}\")\n   407→\n   408→    e2e_errors = ok[\"e2e_error\"].values * 100\n   409→    ttft_errors = ok[\"ttft_error\"].values * 100\n   410→    itl_errors = ok[\"itl_error\"].values * 100\n   411→\n   412→    print(f\"\\n  Mean E2E error:  {e2e_errors.mean():.1f}%\")\n   413→    print(f\"  Mean TTFT error: {ttft_errors.mean():.1f}%\")\n   414→    print(f\"  Mean ITL error:  {itl_errors.mean():.1f}%\")\n   415→\n   416→    passing = (e2e_errors < 10).sum()\n   417→    print(f\"\\n  E2E < 10%: {passing}/{len(ok)} experiments\")\n   418→\n   419→    # Save summary JSON\n   420→    summary = {\n   421→        \"model\": \"roofline (analytical)\",\n   422→        \"e2e_validation\": {\n   423→            \"mean_e2e_error_pct\": float(e2e_errors.mean()),\n   424→            \"mean_ttft_error_pct\": float(ttft_errors.mean()),\n   425→            \"mean_itl_error_pct\": float(itl_errors.mean()),\n   426→            \"experiments_below_10pct\": int(passing),\n   427→            \"total_experiments\": len(ok),\n   428→        },\n   429→    }\n   430→    summary_path = output_csv.replace(\".csv\", \"_summary.json\")\n   431→    with open(summary_path, \"w\") as f:\n   432→        json.dump(summary, f, indent=2)\n   433→    print(f\"\\n  Summary JSON: {summary_path}\")\n   434→\n   435→\n   436→def print_summary(output_csv: str, coefficients: dict):\n   437→    \"\"\"Print a human-readable summary of the baseline results.\"\"\"\n   438→    if not os.path.isfile(output_csv):\n   439→        print(\"No results to summarize.\")\n   440→        return\n   441→\n   442→    df = pd.read_csv(output_csv)\n   443→    ok = df[df[\"status\"] == \"ok\"]\n   444→\n   445→    if ok.empty:\n   446→        print(\"\\nNo successful experiments. Check BLIS binary and data.\")\n   447→        return\n   448→\n   449→    print(f\"\\n{'='*70}\")\n   450→    print(\"  PER-MODEL LINEAR REGRESSION BASELINE RESULTS\")\n   451→    print(f\"{'='*70}\")\n   452→\n   453→    print(f\"\\n  Experiments: {len(ok)} completed, \"\n   454→          f\"{len(df) - len(ok)} skipped/failed\")\n   455→\n   456→    # Per-step training metrics\n   457→    print(f\"\\n  --- Per-Step Training Metrics (linear regression on step traces) ---\")\n   458→    for (model, tp), coeffs in sorted(coefficients.items()):\n   459→        print(f\"  {model} TP={tp}: \"\n   460→              f\"MAPE={coeffs['train_mape']:.1f}%, \"\n   461→              f\"MSPE={coeffs['train_mspe']:+.1f}%, \"\n   462→              f\"r={coeffs['train_r']:.3f}, \"\n   463→              f\"n_steps={coeffs['n_steps']:,}\")\n   464→        print(f\"    beta = [{coeffs['beta0']:.2f}, \"\n   465→              f\"{coeffs['beta1']:.4f}, {coeffs['beta2']:.4f}]\")\n   466→\n   467→    # E2E validation metrics\n   468→    print(f\"\\n  --- BLIS E2E Validation (simulator vs ground truth) ---\")\n   469→    print(f\"  {'Experiment':<55s} {'E2E%':>6s} {'TTFT%':>6s} {'ITL%':>6s}\")\n   470→    print(f\"  {'-'*55} {'-'*6} {'-'*6} {'-'*6}\")\n   471→    for _, row in ok.iterrows():\n   472→        e2e_pct = row[\"e2e_error\"] * 100\n   473→        ttft_pct = row[\"ttft_error\"] * 100\n   474→        itl_pct = row[\"itl_error\"] * 100\n   475→        marker = \" <10%\" if e2e_pct < 10 else \"\"\n   476→        print(f\"  {row['experiment']:<55s} \"\n   477→              f\"{e2e_pct:>5.1f}% {ttft_pct:>5.1f}% {itl_pct:>5.1f}%{marker}\")\n   478→\n   479→    e2e_errors = ok[\"e2e_error\"].values * 100\n   480→    ttft_errors = ok[\"ttft_error\"].values * 100\n   481→    itl_errors = ok[\"itl_error\"].values * 100\n   482→\n   483→    print(f\"\\n  Mean E2E error:  {e2e_errors.mean():.1f}%\")\n   484→    print(f\"  Mean TTFT error: {ttft_errors.mean():.1f}%\")\n   485→    print(f\"  Mean ITL error:  {itl_errors.mean():.1f}%\")\n   486→\n   487→    passing = (e2e_errors < 10).sum()\n   488→    print(f\"\\n  E2E < 10%: {passing}/{len(ok)} experiments\")\n   489→\n   490→    # R4 gate check\n   491→    print(f\"\\n  --- R4 Gate (is linear regression already good enough?) ---\")\n   492→    r4 = check_r4_gate(e2e_errors.mean())\n   493→    print(f\"  {r4['message']}\")\n   494→\n   495→    # Save summary JSON\n   496→    summary = {\n   497→        \"per_model_coefficients\": {\n   498→            f\"{m}_tp{tp}\": {k: v for k, v in coeffs.items()\n   499→                            if k != \"experiments\"}\n   500→            for (m, tp), coeffs in coefficients.items()\n   501→        },\n   502→        \"e2e_validation\": {\n   503→            \"mean_e2e_error_pct\": float(e2e_errors.mean()),\n   504→            \"mean_ttft_error_pct\": float(ttft_errors.mean()),\n   505→            \"mean_itl_error_pct\": float(itl_errors.mean()),\n   506→            \"experiments_below_10pct\": int(passing),\n   507→            \"total_experiments\": len(ok),\n   508→        },\n   509→        \"r4_gate\": r4,\n   510→    }\n   511→    summary_path = output_csv.replace(\".csv\", \"_summary.json\")\n   512→    with open(summary_path, \"w\") as f:\n   513→        json.dump(summary, f, indent=2)\n   514→    print(f\"\\n  Summary JSON: {summary_path}\")\n   515→\n   516→\n   517→def main():\n   518→    parser = argparse.ArgumentParser(\n   519→        description=\"Establish per-model linear regression baseline\"\n   520→    )\n   521→    parser.add_argument(\n   522→        \"--data-root\",\n   523→        default=DEFAULT_DATA_ROOT,\n   524→        help=\"Path to eval/ground_truth/\",\n   525→    )\n   526→    parser.add_argument(\n   527→        \"--output-dir\",\n   528→        default=os.path.join(_SCRIPT_DIR, \"baseline_results\"),\n   529→        help=\"Directory for output files\",\n   530→    )\n   531→    parser.add_argument(\n   532→        \"--hardware\",\n   533→        default=\"H100\",\n   534→        help=\"GPU type for roofline baseline (default: H100)\",\n   535→    )\n   536→    parser.add_argument(\n   537→        \"--skip-roofline\",\n   538→        action=\"store_true\",\n   539→        help=\"Skip the roofline baseline (only run linear regression)\",\n   540→    )\n   541→    parser.add_argument(\n   542→        \"--skip-linear\",\n   543→        action=\"store_true\",\n   544→        help=\"Skip the linear regression baseline (only run roofline)\",\n   545→    )\n   546→    parser.add_argument(\n   547→        \"--workers\",\n   548→        type=int,\n   549→        default=_DEFAULT_WORKERS,\n   550→        help=f\"Max parallel BLIS runs (default: {_DEFAULT_WORKERS})\",\n   551→    )\n   552→    args = parser.parse_args()\n   553→\n   554→    os.makedirs(args.output_dir, exist_ok=True)\n   555→\n   556→    # --- Baseline 1: Roofline (analytical, no training) ---\n   557→    if not args.skip_roofline:\n   558→        roofline_csv = os.path.join(args.output_dir, \"roofline_baseline.csv\")\n   559→\n   560→        print(f\"Step 1: Running roofline baseline \"\n   561→              f\"(hardware={args.hardware}, workers={args.workers})...\")\n   562→        run_roofline_validation(\n   563→            args.data_root, roofline_csv, args.hardware,\n   564→            max_workers=args.workers,\n   565→        )\n   566→\n   567→        print_roofline_summary(roofline_csv)\n   568→\n   569→    # --- Baseline 2: Per-model linear regression ---\n   570→    if not args.skip_linear:\n   571→        linear_csv = os.path.join(args.output_dir, \"per_model_linear_baseline.csv\")\n   572→\n   573→        step_num = \"2\" if not args.skip_roofline else \"1\"\n   574→        print(f\"\\nStep {step_num}: Training per-model linear regression on step traces...\")\n   575→        coefficients = train_per_model_coefficients(args.data_root)\n   576→        print(f\"  Trained {len(coefficients)} model+TP groups\")\n   577→\n   578→        print(f\"\\nStep {int(step_num)+1}: Running BLIS E2E validation \"\n   579→              f\"(workers={args.workers})...\")\n   580→        run_blis_validation(\n   581→            coefficients, args.data_root, linear_csv,\n   582→            max_workers=args.workers,\n   583→        )\n   584→\n   585→        print_summary(linear_csv, coefficients)\n   586→\n   587→\n   588→if __name__ == \"__main__\":\n   589→    main()\n   590→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"49cd651e-4b82-4dc3-b405-8d7d80b49295"}
