{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01LptB347h5WRVCv1Hzk9aF8","type":"tool_result","content":"     1→\"\"\"StepML ground truth data loader.\n     2→\n     3→Loads OpenTelemetry traces (BATCH_SUMMARY events) and per-request lifecycle\n     4→metrics from the eval/ground_truth/ experiment directories into pandas\n     5→DataFrames suitable for ML training and evaluation.\n     6→\"\"\"\n     7→\n     8→import json\n     9→import os\n    10→import re\n    11→\n    12→import pandas as pd\n    13→\n    14→# ---------------------------------------------------------------------------\n    15→# Default data root: eval/ground_truth/ relative to this file's location\n    16→# ---------------------------------------------------------------------------\n    17→DEFAULT_DATA_ROOT = os.path.join(\n    18→    os.path.dirname(__file__), \"..\", \"..\", \"..\", \"eval\", \"ground_truth\"\n    19→)\n    20→\n    21→# Regex to split directory names: YYYYMMDD-HHMMSS-<model>-tp<N>-<workload>\n    22→# The model name can contain hyphens, so we anchor on the -tp<N>- pattern.\n    23→_DIR_PATTERN = re.compile(\n    24→    r\"^(\\d{8}-\\d{6})-(.+)-tp(\\d+)-(\\w+)$\"\n    25→)\n    26→\n    27→\n    28→def parse_experiment_metadata(dirname: str) -> dict:\n    29→    \"\"\"Parse experiment metadata from a directory name.\n    30→\n    31→    Directory names follow the convention:\n    32→        YYYYMMDD-HHMMSS-<model>-tp<N>-<workload>\n    33→\n    34→    The model name may contain hyphens (e.g., llama-2-7b, mixtral-8x7b-v0-1).\n    35→    We locate the *last* occurrence of ``-tp<digits>-`` to split model from\n    36→    workload, since tp values are always a simple integer and the workload\n    37→    name has no hyphens.\n    38→\n    39→    Returns:\n    40→        dict with keys: model, tp, workload, timestamp\n    41→    \"\"\"\n    42→    m = _DIR_PATTERN.match(dirname)\n    43→    if m:\n    44→        return {\n    45→            \"timestamp\": m.group(1),\n    46→            \"model\": m.group(2),\n    47→            \"tp\": int(m.group(3)),\n    48→            \"workload\": m.group(4),\n    49→        }\n    50→\n    51→    # Fallback: find the *last* -tp<digits>- boundary\n    52→    tp_matches = list(re.finditer(r\"-tp(\\d+)-\", dirname))\n    53→    if not tp_matches:\n    54→        raise ValueError(\n    55→            f\"Cannot parse experiment metadata from directory name: {dirname}\"\n    56→        )\n    57→    last_tp = tp_matches[-1]\n    58→    tp_value = int(last_tp.group(1))\n    59→\n    60→    # Timestamp is the first 15 characters: YYYYMMDD-HHMMSS\n    61→    timestamp = dirname[:15]\n    62→    # Model is between timestamp+'-' and the tp boundary\n    63→    model = dirname[16 : last_tp.start()]\n    64→    # Workload is everything after -tp<N>-\n    65→    workload = dirname[last_tp.end() :]\n    66→\n    67→    return {\n    68→        \"timestamp\": timestamp,\n    69→        \"model\": model,\n    70→        \"tp\": tp_value,\n    71→        \"workload\": workload,\n    72→    }\n    73→\n    74→\n    75→def _extract_attribute_value(attr: dict):\n    76→    \"\"\"Extract a scalar value from an OpenTelemetry attribute.\n    77→\n    78→    Attribute values are nested like:\n    79→        {\"key\": \"step.id\", \"value\": {\"intValue\": \"29\"}}\n    80→    or:\n    81→        {\"key\": \"kv.usage_gpu_ratio\", \"value\": {\"doubleValue\": 0.02}}\n    82→\n    83→    Note: intValue is often a string in OTLP JSON encoding.\n    84→    \"\"\"\n    85→    value_obj = attr.get(\"value\", {})\n    86→    if \"intValue\" in value_obj:\n    87→        return int(value_obj[\"intValue\"])\n    88→    if \"doubleValue\" in value_obj:\n    89→        return float(value_obj[\"doubleValue\"])\n    90→    if \"stringValue\" in value_obj:\n    91→        return value_obj[\"stringValue\"]\n    92→    return None\n    93→\n    94→\n    95→def load_experiment_steps(experiment_dir: str) -> pd.DataFrame:\n    96→    \"\"\"Load step-level BATCH_SUMMARY data from an experiment's traces.json.\n    97→\n    98→    Parses the OpenTelemetry JSONL file line by line, extracts events named\n    99→    ``step.BATCH_SUMMARY``, and flattens their attributes into a DataFrame.\n   100→\n   101→    Args:\n   102→        experiment_dir: Path to a single experiment directory containing\n   103→            traces.json.\n   104→\n   105→    Returns:\n   106→        DataFrame with one row per step. Columns include all BATCH_SUMMARY\n   107→        attribute keys plus ``experiment_id`` (the directory basename).\n   108→    \"\"\"\n   109→    traces_path = os.path.join(experiment_dir, \"traces.json\")\n   110→    experiment_id = os.path.basename(experiment_dir)\n   111→    rows = []\n   112→\n   113→    with open(traces_path, \"r\") as f:\n   114→        for line in f:\n   115→            line = line.strip()\n   116→            if not line:\n   117→                continue\n   118→            data = json.loads(line)\n   119→            for resource_span in data.get(\"resourceSpans\", []):\n   120→                for scope_span in resource_span.get(\"scopeSpans\", []):\n   121→                    for span in scope_span.get(\"spans\", []):\n   122→                        for event in span.get(\"events\", []):\n   123→                            if event.get(\"name\") != \"step.BATCH_SUMMARY\":\n   124→                                continue\n   125→                            row = {}\n   126→                            for attr in event.get(\"attributes\", []):\n   127→                                key = attr[\"key\"]\n   128→                                row[key] = _extract_attribute_value(attr)\n   129→                            rows.append(row)\n   130→\n   131→    df = pd.DataFrame(rows)\n   132→    df[\"experiment_id\"] = experiment_id\n   133→\n   134→    # Ensure integer columns are proper int types (not object/float)\n   135→    int_columns = [\n   136→        \"step.id\",\n   137→        \"step.ts_start_ns\",\n   138→        \"step.ts_end_ns\",\n   139→        \"step.duration_us\",\n   140→        \"batch.prefill_tokens\",\n   141→        \"batch.decode_tokens\",\n   142→        \"batch.scheduled_tokens\",\n   143→        \"batch.num_prefill_reqs\",\n   144→        \"batch.num_decode_reqs\",\n   145→        \"batch.num_finished\",\n   146→        \"batch.num_preempted\",\n   147→        \"queue.running_depth\",\n   148→        \"queue.waiting_depth\",\n   149→        \"kv.blocks_free_gpu\",\n   150→        \"kv.blocks_total_gpu\",\n   151→    ]\n   152→    for col in int_columns:\n   153→        if col in df.columns:\n   154→            df[col] = pd.to_numeric(df[col], errors=\"coerce\").astype(\"Int64\")\n   155→\n   156→    # Ensure float columns\n   157→    float_columns = [\"kv.usage_gpu_ratio\"]\n   158→    for col in float_columns:\n   159→        if col in df.columns:\n   160→            df[col] = pd.to_numeric(df[col], errors=\"coerce\").astype(\"float64\")\n   161→\n   162→    return df\n   163→\n   164→\n   165→def load_all_experiments(data_root: str = None) -> pd.DataFrame:\n   166→    \"\"\"Load step data from all experiments and concatenate into one DataFrame.\n   167→\n   168→    Iterates over subdirectories in ``data_root``, calls\n   169→    :func:`load_experiment_steps` for each, and adds metadata columns\n   170→    (model, tp, workload, timestamp) parsed from each directory name.\n   171→\n   172→    Args:\n   173→        data_root: Path to the ground truth data directory. Defaults to\n   174→            ``eval/ground_truth/`` relative to this file.\n   175→\n   176→    Returns:\n   177→        Concatenated DataFrame with all step data plus metadata columns.\n   178→    \"\"\"\n   179→    if data_root is None:\n   180→        data_root = DEFAULT_DATA_ROOT\n   181→\n   182→    frames = []\n   183→    for dirname in sorted(os.listdir(data_root)):\n   184→        dirpath = os.path.join(data_root, dirname)\n   185→        if not os.path.isdir(dirpath):\n   186→            continue\n   187→        # Skip directories that don't look like experiment dirs\n   188→        traces_path = os.path.join(dirpath, \"traces.json\")\n   189→        if not os.path.isfile(traces_path):\n   190→            continue\n   191→\n   192→        df = load_experiment_steps(dirpath)\n   193→        meta = parse_experiment_metadata(dirname)\n   194→        df[\"model\"] = meta[\"model\"]\n   195→        df[\"tp\"] = meta[\"tp\"]\n   196→        df[\"workload\"] = meta[\"workload\"]\n   197→        df[\"timestamp\"] = meta[\"timestamp\"]\n   198→        frames.append(df)\n   199→\n   200→    if not frames:\n   201→        return pd.DataFrame()\n   202→\n   203→    result = pd.concat(frames, ignore_index=True)\n   204→\n   205→    # Ensure tp is integer dtype in the concatenated result\n   206→    result[\"tp\"] = result[\"tp\"].astype(\"Int64\")\n   207→\n   208→    return result\n   209→\n   210→\n   211→def load_lifecycle_data(experiment_dir: str) -> pd.DataFrame:\n   212→    \"\"\"Load per-request lifecycle metrics from an experiment.\n   213→\n   214→    Reads ``results/per_request_lifecycle_metrics.json`` which contains a\n   215→    JSON array of request objects.\n   216→\n   217→    Args:\n   218→        experiment_dir: Path to a single experiment directory.\n   219→\n   220→    Returns:\n   221→        DataFrame indexed by ``request_id`` (0-based) with columns:\n   222→        start_time, end_time, input_tokens, output_tokens,\n   223→        output_token_times (as list).\n   224→    \"\"\"\n   225→    metrics_path = os.path.join(\n   226→        experiment_dir, \"results\", \"per_request_lifecycle_metrics.json\"\n   227→    )\n   228→\n   229→    with open(metrics_path, \"r\") as f:\n   230→        data = json.load(f)\n   231→\n   232→    rows = []\n   233→    for i, entry in enumerate(data):\n   234→        info = entry.get(\"info\", {})\n   235→        rows.append(\n   236→            {\n   237→                \"request_id\": i,\n   238→                \"start_time\": entry.get(\"start_time\"),\n   239→                \"end_time\": entry.get(\"end_time\"),\n   240→                \"input_tokens\": info.get(\"input_tokens\"),\n   241→                \"output_tokens\": info.get(\"output_tokens\"),\n   242→                \"output_token_times\": info.get(\"output_token_times\", []),\n   243→            }\n   244→        )\n   245→\n   246→    df = pd.DataFrame(rows)\n   247→    df = df.set_index(\"request_id\")\n   248→    return df\n   249→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"084a98e7-e824-4fd3-a7d2-511a33dee4b3"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01ToJcSozi8uA5C5QE4X5i9R","type":"tool_result","content":"     1→\"\"\"Validation functions for StepML WP0 infrastructure.\n     2→\n     3→Part A: Temporal split effectiveness — confirms that temporal splitting\n     4→prevents autocorrelation leakage by comparing random vs temporal split MAPE.\n     5→\n     6→Part B: ProgressIndex as KV cache length proxy (R1 gate) — validates that\n     7→total tokens (input + output) correlate with end-to-end request time.\n     8→\"\"\"\n     9→\n    10→from __future__ import annotations\n    11→\n    12→import numpy as np\n    13→import pandas as pd\n    14→from sklearn.linear_model import Ridge\n    15→\n    16→from evaluation import compute_mape, compute_pearson_r\n    17→from splits import temporal_split\n    18→\n    19→\n    20→def temporal_vs_random_split_comparison(\n    21→    all_df: pd.DataFrame,\n    22→    seed: int = 42,\n    23→) -> dict:\n    24→    \"\"\"Compare random vs temporal split to validate temporal split prevents leakage.\n    25→\n    26→    Trains a Ridge regression on batch features (batch.prefill_tokens,\n    27→    batch.decode_tokens) to predict step.duration_us.  Evaluates on\n    28→    test splits from both a random 60/20/20 split and the canonical\n    29→    temporal split.\n    30→\n    31→    If random split MAPE is much lower (gap > 5%), it confirms that temporal\n    32→    splitting correctly prevents autocorrelation leakage: adjacent steps are\n    33→    correlated, so random splitting \"cheats\" by mixing correlated steps\n    34→    across train and test.\n    35→\n    36→    Args:\n    37→        all_df: DataFrame with columns experiment_id, step.id,\n    38→            batch.prefill_tokens, batch.decode_tokens, step.duration_us.\n    39→        seed: Random seed for the random split and Ridge model.\n    40→\n    41→    Returns:\n    42→        Dict with keys:\n    43→        - temporal_mape: MAPE (%) on the temporal test split\n    44→        - random_mape: MAPE (%) on the random test split\n    45→        - gap: temporal_mape - random_mape (positive means temporal is harder)\n    46→        - conclusion: Human-readable interpretation of the result\n    47→    \"\"\"\n    48→    feature_cols = [\"batch.prefill_tokens\", \"batch.decode_tokens\"]\n    49→    target_col = \"step.duration_us\"\n    50→\n    51→    X = all_df[feature_cols].values.astype(np.float64)\n    52→    y = all_df[target_col].values.astype(np.float64)\n    53→\n    54→    # --- Temporal split ---\n    55→    temporal_splits = temporal_split(all_df, seed=seed)\n    56→    train_idx_t = temporal_splits[\"train\"]\n    57→    test_idx_t = temporal_splits[\"test\"]\n    58→\n    59→    model_t = Ridge(alpha=1.0)\n    60→    model_t.fit(X[train_idx_t], y[train_idx_t])\n    61→    pred_t = model_t.predict(X[test_idx_t])\n    62→    temporal_mape = compute_mape(pred_t, y[test_idx_t])\n    63→\n    64→    # --- Random split (60/20/20 shuffled) ---\n    65→    rng = np.random.default_rng(seed)\n    66→    n = len(all_df)\n    67→    perm = rng.permutation(n)\n    68→    n_train = int(round(n * 0.6))\n    69→    n_valid = int(round(n * 0.2))\n    70→    train_idx_r = perm[:n_train]\n    71→    # valid_idx_r = perm[n_train : n_train + n_valid]  # not used\n    72→    test_idx_r = perm[n_train + n_valid :]\n    73→\n    74→    model_r = Ridge(alpha=1.0)\n    75→    model_r.fit(X[train_idx_r], y[train_idx_r])\n    76→    pred_r = model_r.predict(X[test_idx_r])\n    77→    random_mape = compute_mape(pred_r, y[test_idx_r])\n    78→\n    79→    gap = temporal_mape - random_mape\n    80→\n    81→    if gap > 5.0:\n    82→        conclusion = (\n    83→            f\"Temporal split MAPE ({temporal_mape:.1f}%) is {gap:.1f}pp higher \"\n    84→            f\"than random split MAPE ({random_mape:.1f}%). \"\n    85→            f\"This confirms temporal splitting prevents autocorrelation leakage. \"\n    86→            f\"Random splitting allows correlated adjacent steps to leak between \"\n    87→            f\"train and test sets, artificially lowering error.\"\n    88→        )\n    89→    elif gap > 0:\n    90→        conclusion = (\n    91→            f\"Temporal split MAPE ({temporal_mape:.1f}%) is {gap:.1f}pp higher \"\n    92→            f\"than random split MAPE ({random_mape:.1f}%). \"\n    93→            f\"Small gap suggests mild autocorrelation in the data.\"\n    94→        )\n    95→    else:\n    96→        conclusion = (\n    97→            f\"Temporal split MAPE ({temporal_mape:.1f}%) is not higher \"\n    98→            f\"than random split MAPE ({random_mape:.1f}%). \"\n    99→            f\"No evidence of autocorrelation leakage in this dataset.\"\n   100→        )\n   101→\n   102→    return {\n   103→        \"temporal_mape\": float(temporal_mape),\n   104→        \"random_mape\": float(random_mape),\n   105→        \"gap\": float(gap),\n   106→        \"conclusion\": conclusion,\n   107→    }\n   108→\n   109→\n   110→def validate_progress_index(\n   111→    lifecycle_df: pd.DataFrame,\n   112→) -> dict:\n   113→    \"\"\"Validate ProgressIndex as KV cache length proxy (R1 gate).\n   114→\n   115→    ProgressIndex is defined as input_tokens + output_tokens (the total\n   116→    tokens processed by a request).  This function validates that total\n   117→    tokens correlate with end-to-end request time, confirming the proxy\n   118→    is informative for KV cache modeling.\n   119→\n   120→    The R1 gate passes if Pearson correlation > 0.9.  If correlation < 0.9,\n   121→    an informational flag is raised but the gate does not abort.\n   122→\n   123→    Args:\n   124→        lifecycle_df: DataFrame indexed by request_id with columns:\n   125→            start_time, end_time, input_tokens, output_tokens,\n   126→            output_token_times.\n   127→\n   128→    Returns:\n   129→        Dict with keys:\n   130→        - correlation: Pearson r between total_tokens and E2E time\n   131→        - n_requests: Number of requests analyzed\n   132→        - passed: True if correlation >= 0.9\n   133→        - conclusion: Human-readable interpretation\n   134→    \"\"\"\n   135→    n_requests = len(lifecycle_df)\n   136→\n   137→    total_tokens = (\n   138→        lifecycle_df[\"input_tokens\"].values.astype(np.float64)\n   139→        + lifecycle_df[\"output_tokens\"].values.astype(np.float64)\n   140→    )\n   141→    e2e_times = (\n   142→        lifecycle_df[\"end_time\"].values.astype(np.float64)\n   143→        - lifecycle_df[\"start_time\"].values.astype(np.float64)\n   144→    )\n   145→\n   146→    correlation = compute_pearson_r(total_tokens, e2e_times)\n   147→    passed = correlation >= 0.9\n   148→\n   149→    if passed:\n   150→        conclusion = (\n   151→            f\"ProgressIndex proxy validated: Pearson r = {correlation:.3f} \"\n   152→            f\"(n={n_requests}). Total tokens (input + output) correlate \"\n   153→            f\"strongly with E2E time, confirming ProgressIndex is an \"\n   154→            f\"informative KV cache length proxy.\"\n   155→        )\n   156→    else:\n   157→        conclusion = (\n   158→            f\"R1 flag: ProgressIndex correlation is {correlation:.3f} \"\n   159→            f\"(n={n_requests}), below the 0.9 threshold. \"\n   160→            f\"Total tokens are a weak proxy for E2E time in this dataset. \"\n   161→            f\"This is an informational flag — does not abort.\"\n   162→        )\n   163→\n   164→    return {\n   165→        \"correlation\": float(correlation),\n   166→        \"n_requests\": n_requests,\n   167→        \"passed\": passed,\n   168→        \"conclusion\": conclusion,\n   169→    }\n   170→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"0eced81e-f918-4f44-89ec-e24618ba5ac9"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01EQaaSFa95GYQPtSLG2twKS","type":"tool_result","content":"     1→\"\"\"BLIS validation harness for StepML research.\n     2→\n     3→Runs BLIS on each ground-truth experiment using the *same* vLLM args and\n     4→inference-perf profile, then compares BLIS-predicted latencies against\n     5→observed values.  Produces a per-experiment summary CSV.\n     6→\n     7→All experiment-specific parameters come from the experiment directory itself:\n     8→  - exp-config.yaml   → model, tensor_parallelism, max_model_len,\n     9→                         max_num_batched_tokens, max_num_seqs\n    10→  - profile.yaml      → inference-perf stages + shared_prefix config\n    11→  - vllm.log          → GPU KV cache size (tokens → blocks)\n    12→  - results/summary_lifecycle_metrics.json → ground-truth latencies\n    13→\n    14→Latency coefficients are passed explicitly (--alpha-coeffs / --beta-coeffs)\n    15→or via a StepML model artifact (--stepml-model).\n    16→\n    17→Usage:\n    18→    python validate_blis.py --alpha-coeffs 0,0,0 --beta-coeffs 0,0,0\n    19→    python validate_blis.py --stepml-model path/to/model.json\n    20→\"\"\"\n    21→\n    22→import argparse\n    23→import csv\n    24→import json\n    25→import os\n    26→import re\n    27→import subprocess\n    28→import sys\n    29→import tempfile\n    30→\n    31→import yaml\n    32→\n    33→# ---------------------------------------------------------------------------\n    34→# Paths\n    35→# ---------------------------------------------------------------------------\n    36→_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\n    37→_REPO_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, \"..\", \"..\", \"..\"))\n    38→DEFAULT_DATA_ROOT = os.path.join(_REPO_ROOT, \"eval\", \"ground_truth\")\n    39→DEFAULT_BINARY = os.path.join(_REPO_ROOT, \"simulation_worker\")\n    40→\n    41→BLOCK_SIZE_TOKENS = 16\n    42→\n    43→\n    44→# ---------------------------------------------------------------------------\n    45→# Experiment parsing helpers\n    46→# ---------------------------------------------------------------------------\n    47→def parse_experiment_dir(dirname: str) -> dict:\n    48→    \"\"\"Parse experiment metadata from directory name.\n    49→\n    50→    Expected format: <timestamp>-<model>-tp<N>-<workload>\n    51→    \"\"\"\n    52→    pattern = re.compile(r\"^(\\d{8}-\\d{6})-(.+)-tp(\\d+)-(\\w+)$\")\n    53→    m = pattern.match(dirname)\n    54→    if m:\n    55→        return {\n    56→            \"timestamp\": m.group(1),\n    57→            \"model\": m.group(2),\n    58→            \"tp\": int(m.group(3)),\n    59→            \"workload\": m.group(4),\n    60→        }\n    61→    # Fallback: find last -tp<N>-\n    62→    tp_matches = list(re.finditer(r\"-tp(\\d+)-\", dirname))\n    63→    if not tp_matches:\n    64→        raise ValueError(f\"Cannot parse experiment dir: {dirname}\")\n    65→    last_tp = tp_matches[-1]\n    66→    return {\n    67→        \"timestamp\": dirname[:15],\n    68→        \"model\": dirname[16:last_tp.start()],\n    69→        \"tp\": int(last_tp.group(1)),\n    70→        \"workload\": dirname[last_tp.end():],\n    71→    }\n    72→\n    73→\n    74→def load_ground_truth_metrics(experiment_dir: str) -> dict:\n    75→    \"\"\"Load summary latency metrics from ground-truth experiment.\"\"\"\n    76→    summary_path = os.path.join(\n    77→        experiment_dir, \"results\", \"summary_lifecycle_metrics.json\"\n    78→    )\n    79→    with open(summary_path) as f:\n    80→        data = json.load(f)\n    81→\n    82→    successes = data.get(\"successes\", {})\n    83→    latency = successes.get(\"latency\", {})\n    84→\n    85→    return {\n    86→        \"e2e_mean_s\": latency.get(\"request_latency\", {}).get(\"mean\", 0),\n    87→        \"ttft_mean_s\": latency.get(\"time_to_first_token\", {}).get(\"mean\", 0),\n    88→        \"itl_mean_s\": latency.get(\"inter_token_latency\", {}).get(\"mean\", 0),\n    89→        \"throughput_rps\": successes.get(\"throughput\", {}).get(\n    90→            \"requests_per_sec\", 0\n    91→        ),\n    92→        \"num_requests\": data.get(\"load_summary\", {}).get(\"count\", 0),\n    93→        \"prompt_len_mean\": successes.get(\"prompt_len\", {}).get(\"mean\", 0),\n    94→        \"output_len_mean\": successes.get(\"output_len\", {}).get(\"mean\", 0),\n    95→    }\n    96→\n    97→\n    98→def load_exp_config(experiment_dir: str) -> dict:\n    99→    \"\"\"Load exp-config.yaml from experiment directory.\"\"\"\n   100→    config_path = os.path.join(experiment_dir, \"exp-config.yaml\")\n   101→    with open(config_path) as f:\n   102→        return yaml.safe_load(f)\n   103→\n   104→\n   105→def load_profile(experiment_dir: str) -> dict:\n   106→    \"\"\"Load profile.yaml (inference-perf config) from experiment directory.\n   107→\n   108→    profile.yaml is JSON despite the .yaml extension.\n   109→    \"\"\"\n   110→    profile_path = os.path.join(experiment_dir, \"profile.yaml\")\n   111→    with open(profile_path) as f:\n   112→        content = f.read()\n   113→    try:\n   114→        return json.loads(content)\n   115→    except json.JSONDecodeError:\n   116→        return yaml.safe_load(content)\n   117→\n   118→\n   119→def extract_kv_blocks_from_vllm_log(experiment_dir: str) -> int | None:\n   120→    \"\"\"Parse vllm.log for 'GPU KV cache size: N tokens' and convert to blocks.\n   121→\n   122→    Returns total KV blocks (tokens / BLOCK_SIZE_TOKENS), or None if not found.\n   123→    \"\"\"\n   124→    vllm_log_path = os.path.join(experiment_dir, \"vllm.log\")\n   125→    if not os.path.isfile(vllm_log_path):\n   126→        return None\n   127→\n   128→    pattern = re.compile(r\"GPU KV cache size:\\s+([\\d,]+)\\s+tokens\")\n   129→    with open(vllm_log_path) as f:\n   130→        for line in f:\n   131→            m = pattern.search(line)\n   132→            if m:\n   133→                tokens = int(m.group(1).replace(\",\", \"\"))\n   134→                return tokens // BLOCK_SIZE_TOKENS\n   135→    return None\n   136→\n   137→\n   138→def extract_cpu_kv_blocks_from_vllm_log(experiment_dir: str) -> int:\n   139→    \"\"\"Parse vllm.log for CPU offloading config and KV cache shape.\n   140→\n   141→    Computes CPU KV blocks from:\n   142→      - cpu_bytes_to_use from kv_connector_extra_config\n   143→      - per-block size derived from the KV cache shape\n   144→        shape = (num_blocks, num_layers, 2, block_size, num_kv_heads, head_dim)\n   145→        per_block_bytes = num_layers * 2 * block_size * num_kv_heads * head_dim * 2 (fp16)\n   146→\n   147→    Returns 0 if no offloading config found.\n   148→    \"\"\"\n   149→    vllm_log_path = os.path.join(experiment_dir, \"vllm.log\")\n   150→    if not os.path.isfile(vllm_log_path):\n   151→        return 0\n   152→\n   153→    cpu_bytes = None\n   154→    kv_shape = None\n   155→    cpu_pattern = re.compile(r\"cpu_bytes_to_use['\\\"]?:\\s*([\\d.]+)\")\n   156→    shape_pattern = re.compile(\n   157→        r\"cross layer KV cache of shape \\((\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+),\\s*(\\d+)\\)\"\n   158→    )\n   159→\n   160→    with open(vllm_log_path) as f:\n   161→        for line in f:\n   162→            if cpu_bytes is None:\n   163→                m = cpu_pattern.search(line)\n   164→                if m:\n   165→                    cpu_bytes = float(m.group(1))\n   166→            if kv_shape is None:\n   167→                m = shape_pattern.search(line)\n   168→                if m:\n   169→                    kv_shape = tuple(int(m.group(i)) for i in range(1, 7))\n   170→            if cpu_bytes is not None and kv_shape is not None:\n   171→                break\n   172→\n   173→    if cpu_bytes is None or kv_shape is None or cpu_bytes == 0:\n   174→        return 0\n   175→\n   176→    # shape = (num_blocks, num_layers, 2, block_size, num_kv_heads, head_dim)\n   177→    _, num_layers, _, block_size, num_kv_heads, head_dim = kv_shape\n   178→    per_block_bytes = num_layers * 2 * block_size * num_kv_heads * head_dim * 2  # fp16\n   179→    return int(cpu_bytes) // per_block_bytes\n   180→\n   181→\n   182→# ---------------------------------------------------------------------------\n   183→# Workload spec construction\n   184→# ---------------------------------------------------------------------------\n   185→def build_workload_spec(profile: dict, ground_truth: dict) -> dict:\n   186→    \"\"\"Build a BLIS workload-spec YAML from inference-perf profile.\n   187→\n   188→    Extracts shared prefix parameters and stage-based load from the profile,\n   189→    then constructs a WorkloadSpec with inference_perf section.\n   190→    \"\"\"\n   191→    data = profile.get(\"data\", {})\n   192→    load_config = profile.get(\"load\", {})\n   193→    sp = data.get(\"shared_prefix\", {})\n   194→\n   195→    stages = []\n   196→    for stage in load_config.get(\"stages\", []):\n   197→        stages.append({\n   198→            \"rate\": stage[\"rate\"],\n   199→            \"duration\": stage[\"duration\"],\n   200→        })\n   201→\n   202→    # Fallback: synthesize a stage from ground-truth throughput\n   203→    if not stages:\n   204→        num_requests = ground_truth.get(\"num_requests\", 1000)\n   205→        rps = ground_truth.get(\"throughput_rps\", 10)\n   206→        duration = int(num_requests / rps) + 60\n   207→        stages.append({\"rate\": rps, \"duration\": duration})\n   208→\n   209→    total_requests = sum(s[\"rate\"] * s[\"duration\"] for s in stages)\n   210→    total_duration_s = sum(s[\"duration\"] for s in stages)\n   211→    horizon_us = int(total_duration_s * 1_000_000) + 60_000_000  # +60s buffer\n   212→\n   213→    # Compute time-weighted average rate (needed by BLIS validation before\n   214→    # InferencePerf expansion fills it in GenerateRequests).\n   215→    aggregate_rate = sum(\n   216→        s[\"rate\"] * s[\"duration\"] for s in stages\n   217→    ) / total_duration_s\n   218→\n   219→    return {\n   220→        \"version\": \"2\",\n   221→        \"seed\": 42,\n   222→        \"num_requests\": int(total_requests),\n   223→        \"horizon\": horizon_us,\n   224→        \"aggregate_rate\": aggregate_rate,\n   225→        \"inference_perf\": {\n   226→            \"stages\": stages,\n   227→            \"shared_prefix\": {\n   228→                \"num_unique_system_prompts\": sp.get(\n   229→                    \"num_unique_system_prompts\", 9\n   230→                ),\n   231→                \"num_users_per_system_prompt\": sp.get(\n   232→                    \"num_users_per_system_prompt\", 5\n   233→                ),\n   234→                \"system_prompt_len\": sp.get(\"system_prompt_len\", 100),\n   235→                \"question_len\": sp.get(\n   236→                    \"question_len\",\n   237→                    int(ground_truth.get(\"prompt_len_mean\", 500)),\n   238→                ),\n   239→                \"output_len\": sp.get(\n   240→                    \"output_len\",\n   241→                    int(ground_truth.get(\"output_len_mean\", 250)),\n   242→                ),\n   243→                \"enable_multi_turn_chat\": sp.get(\n   244→                    \"enable_multi_turn_chat\", False\n   245→                ),\n   246→            },\n   247→        },\n   248→    }\n   249→\n   250→\n   251→# ---------------------------------------------------------------------------\n   252→# BLIS execution\n   253→# ---------------------------------------------------------------------------\n   254→def run_blis(\n   255→    binary: str,\n   256→    workload_spec_path: str,\n   257→    exp_config: dict,\n   258→    total_kv_blocks: int,\n   259→    alpha_coeffs: list[float],\n   260→    beta_coeffs: list[float],\n   261→    results_path: str,\n   262→    stepml_model_path: str | None = None,\n   263→    roofline: bool = False,\n   264→    hardware: str | None = None,\n   265→    cpu_kv_blocks: int = 0,\n   266→) -> dict | None:\n   267→    \"\"\"Run BLIS with the same vLLM args as the ground-truth experiment.\n   268→\n   269→    When roofline=True, uses the analytical roofline latency model instead of\n   270→    alpha/beta coefficients.  Requires hardware (GPU type, e.g. \"H100\").\n   271→\n   272→    Returns dict with e2e_mean_ms, ttft_mean_ms, itl_mean_ms, or None on failure.\n   273→    \"\"\"\n   274→    model_name = exp_config.get(\"model\", \"unknown\")\n   275→    tp = exp_config.get(\"tensor_parallelism\", 1)\n   276→    max_model_len = exp_config.get(\"max_model_len\", 4096)\n   277→    max_num_seqs = exp_config.get(\"max_num_seqs\", 128)\n   278→    max_num_batched_tokens = exp_config.get(\"max_num_batched_tokens\", 2048)\n   279→\n   280→    cmd = [\n   281→        binary,\n   282→        \"run\",\n   283→        \"--model\", model_name,\n   284→        \"--workload-spec\", workload_spec_path,\n   285→        # --- Match vLLM serving args exactly ---\n   286→        \"--tp\", str(tp),\n   287→        \"--max-model-len\", str(max_model_len),\n   288→        \"--max-num-running-reqs\", str(max_num_seqs),\n   289→        \"--max-num-scheduled-tokens\", str(max_num_batched_tokens),\n   290→        \"--total-kv-blocks\", str(total_kv_blocks),\n   291→        \"--block-size-in-tokens\", str(BLOCK_SIZE_TOKENS),\n   292→    ]\n   293→\n   294→    if cpu_kv_blocks > 0:\n   295→        cmd.extend([\"--kv-cpu-blocks\", str(cpu_kv_blocks)])\n   296→\n   297→    if roofline:\n   298→        if not hardware:\n   299→            raise ValueError(\"roofline=True requires hardware (GPU type)\")\n   300→        cmd.extend([\"--roofline\", \"--hardware\", hardware])\n   301→    else:\n   302→        # --- Latency coefficients (use = to handle negative values) ---\n   303→        cmd.append(\"--alpha-coeffs=\" + \",\".join(str(c) for c in alpha_coeffs))\n   304→        cmd.append(\"--beta-coeffs=\" + \",\".join(str(c) for c in beta_coeffs))\n   305→\n   306→    # --- Output ---\n   307→    cmd.extend([\"--results-path\", results_path, \"--log\", \"error\"])\n   308→\n   309→    if stepml_model_path:\n   310→        cmd.extend([\"--stepml-model\", stepml_model_path])\n   311→\n   312→    try:\n   313→        result = subprocess.run(\n   314→            cmd,\n   315→            capture_output=True,\n   316→            text=True,\n   317→            timeout=600,\n   318→            cwd=os.path.dirname(binary),\n   319→        )\n   320→    except subprocess.TimeoutExpired:\n   321→        print(\"  TIMEOUT after 600s\", file=sys.stderr)\n   322→        return None\n   323→    except FileNotFoundError:\n   324→        print(f\"  Binary not found: {binary}\", file=sys.stderr)\n   325→        return None\n   326→\n   327→    if result.returncode != 0:\n   328→        print(\n   329→            f\"  BLIS failed (exit {result.returncode}): {result.stderr[:500]}\",\n   330→            file=sys.stderr,\n   331→        )\n   332→        return None\n   333→\n   334→    return parse_blis_stdout(result.stdout)\n   335→\n   336→\n   337→def parse_blis_stdout(stdout: str) -> dict | None:\n   338→    \"\"\"Parse BLIS stdout for the JSON block after '=== Simulation Metrics ==='.\"\"\"\n   339→    lines = stdout.split(\"\\n\")\n   340→    json_lines = []\n   341→    in_json = False\n   342→    brace_depth = 0\n   343→\n   344→    for line in lines:\n   345→        if \"Simulation Metrics\" in line:\n   346→            in_json = False\n   347→            json_lines = []\n   348→            continue\n   349→        if not in_json and line.strip().startswith(\"{\"):\n   350→            in_json = True\n   351→        if in_json:\n   352→            json_lines.append(line)\n   353→            brace_depth += line.count(\"{\") - line.count(\"}\")\n   354→            if brace_depth <= 0:\n   355→                break\n   356→\n   357→    if not json_lines:\n   358→        return None\n   359→\n   360→    try:\n   361→        metrics = json.loads(\"\\n\".join(json_lines))\n   362→    except json.JSONDecodeError:\n   363→        return None\n   364→\n   365→    return {\n   366→        \"e2e_mean_ms\": metrics.get(\"e2e_mean_ms\", 0),\n   367→        \"ttft_mean_ms\": metrics.get(\"ttft_mean_ms\", 0),\n   368→        \"itl_mean_ms\": metrics.get(\"itl_mean_ms\", 0),\n   369→        \"completed_requests\": metrics.get(\"completed_requests\", 0),\n   370→        \"tokens_per_sec\": metrics.get(\"tokens_per_sec\", 0),\n   371→    }\n   372→\n   373→\n   374→def compute_error(predicted: float, observed: float) -> float:\n   375→    \"\"\"Compute relative error: |predicted - observed| / observed.\"\"\"\n   376→    if observed == 0:\n   377→        return float(\"inf\") if predicted != 0 else 0.0\n   378→    return abs(predicted - observed) / observed\n   379→\n   380→\n   381→# ---------------------------------------------------------------------------\n   382→# Main validation loop\n   383→# ---------------------------------------------------------------------------\n   384→def validate_all_experiments(\n   385→    binary: str,\n   386→    data_root: str,\n   387→    output_path: str,\n   388→    alpha_coeffs: list[float],\n   389→    beta_coeffs: list[float],\n   390→    stepml_model_path: str | None = None,\n   391→    roofline: bool = False,\n   392→    hardware: str | None = None,\n   393→):\n   394→    \"\"\"Run BLIS validation across all ground-truth experiments.\"\"\"\n   395→    results = []\n   396→\n   397→    for dirname in sorted(os.listdir(data_root)):\n   398→        dirpath = os.path.join(data_root, dirname)\n   399→        if not os.path.isdir(dirpath):\n   400→            continue\n   401→\n   402→        summary_path = os.path.join(\n   403→            dirpath, \"results\", \"summary_lifecycle_metrics.json\"\n   404→        )\n   405→        if not os.path.isfile(summary_path):\n   406→            continue\n   407→\n   408→        print(f\"\\n{'='*60}\")\n   409→        print(f\"Experiment: {dirname}\")\n   410→        print(f\"{'='*60}\")\n   411→\n   412→        # Parse metadata from directory name\n   413→        try:\n   414→            meta = parse_experiment_dir(dirname)\n   415→        except ValueError as e:\n   416→            print(f\"  SKIP: {e}\", file=sys.stderr)\n   417→            continue\n   418→\n   419→        # Load ground truth metrics\n   420→        gt = load_ground_truth_metrics(dirpath)\n   421→        print(f\"  Ground truth: E2E={gt['e2e_mean_s']*1000:.1f}ms, \"\n   422→              f\"TTFT={gt['ttft_mean_s']*1000:.1f}ms, \"\n   423→              f\"ITL={gt['itl_mean_s']*1000:.2f}ms\")\n   424→\n   425→        # Load experiment config (vLLM serving args)\n   426→        exp_config = load_exp_config(dirpath)\n   427→\n   428→        # Extract KV cache blocks from vllm.log\n   429→        total_kv_blocks = extract_kv_blocks_from_vllm_log(dirpath)\n   430→        if total_kv_blocks is None:\n   431→            print(\"  SKIP: Cannot parse KV blocks from vllm.log\",\n   432→                  file=sys.stderr)\n   433→            results.append({\n   434→                \"experiment\": dirname,\n   435→                \"model\": meta[\"model\"],\n   436→                \"workload\": meta[\"workload\"],\n   437→                \"tp\": meta[\"tp\"],\n   438→                \"status\": \"no_kv_blocks\",\n   439→            })\n   440→            continue\n   441→        cpu_kv_blocks = extract_cpu_kv_blocks_from_vllm_log(dirpath)\n   442→        print(f\"  KV blocks: {total_kv_blocks} GPU \"\n   443→              f\"({total_kv_blocks * BLOCK_SIZE_TOKENS:,} tokens)\"\n   444→              f\" + {cpu_kv_blocks} CPU\")\n   445→\n   446→        # Load inference-perf profile and build workload spec\n   447→        try:\n   448→            profile = load_profile(dirpath)\n   449→        except (FileNotFoundError, json.JSONDecodeError, yaml.YAMLError) as e:\n   450→            print(f\"  SKIP: Cannot load profile: {e}\", file=sys.stderr)\n   451→            results.append({\n   452→                \"experiment\": dirname,\n   453→                \"model\": meta[\"model\"],\n   454→                \"workload\": meta[\"workload\"],\n   455→                \"tp\": meta[\"tp\"],\n   456→                \"status\": \"no_profile\",\n   457→            })\n   458→            continue\n   459→\n   460→        workload_spec = build_workload_spec(profile, gt)\n   461→\n   462→        # Write workload spec and results path to temp files\n   463→        with tempfile.NamedTemporaryFile(\n   464→            mode=\"w\", suffix=\".yaml\", delete=False\n   465→        ) as f:\n   466→            yaml.dump(workload_spec, f, default_flow_style=False)\n   467→            spec_path = f.name\n   468→\n   469→        with tempfile.NamedTemporaryFile(suffix=\".json\", delete=False) as f:\n   470→            results_json_path = f.name\n   471→\n   472→        try:\n   473→            blis_metrics = run_blis(\n   474→                binary=binary,\n   475→                workload_spec_path=spec_path,\n   476→                exp_config=exp_config,\n   477→                total_kv_blocks=total_kv_blocks,\n   478→                alpha_coeffs=alpha_coeffs,\n   479→                beta_coeffs=beta_coeffs,\n   480→                results_path=results_json_path,\n   481→                stepml_model_path=stepml_model_path,\n   482→                roofline=roofline,\n   483→                hardware=hardware,\n   484→                cpu_kv_blocks=cpu_kv_blocks,\n   485→            )\n   486→        finally:\n   487→            os.unlink(spec_path)\n   488→            if os.path.exists(results_json_path):\n   489→                os.unlink(results_json_path)\n   490→\n   491→        if blis_metrics is None:\n   492→            results.append({\n   493→                \"experiment\": dirname,\n   494→                \"model\": meta[\"model\"],\n   495→                \"workload\": meta[\"workload\"],\n   496→                \"tp\": meta[\"tp\"],\n   497→                \"status\": \"blis_failed\",\n   498→            })\n   499→            continue\n   500→\n   501→        # Compute errors (ground truth is in seconds, BLIS outputs ms)\n   502→        e2e_error = compute_error(\n   503→            blis_metrics[\"e2e_mean_ms\"], gt[\"e2e_mean_s\"] * 1000\n   504→        )\n   505→        ttft_error = compute_error(\n   506→            blis_metrics[\"ttft_mean_ms\"], gt[\"ttft_mean_s\"] * 1000\n   507→        )\n   508→        itl_error = compute_error(\n   509→            blis_metrics[\"itl_mean_ms\"], gt[\"itl_mean_s\"] * 1000\n   510→        )\n   511→\n   512→        print(f\"  BLIS:         E2E={blis_metrics['e2e_mean_ms']:.1f}ms, \"\n   513→              f\"TTFT={blis_metrics['ttft_mean_ms']:.1f}ms, \"\n   514→              f\"ITL={blis_metrics['itl_mean_ms']:.2f}ms\")\n   515→        print(f\"  Errors:       E2E={e2e_error*100:.1f}%, \"\n   516→              f\"TTFT={ttft_error*100:.1f}%, \"\n   517→              f\"ITL={itl_error*100:.1f}%\")\n   518→\n   519→        results.append({\n   520→            \"experiment\": dirname,\n   521→            \"model\": meta[\"model\"],\n   522→            \"workload\": meta[\"workload\"],\n   523→            \"tp\": meta[\"tp\"],\n   524→            \"status\": \"ok\",\n   525→            \"gt_e2e_ms\": gt[\"e2e_mean_s\"] * 1000,\n   526→            \"gt_ttft_ms\": gt[\"ttft_mean_s\"] * 1000,\n   527→            \"gt_itl_ms\": gt[\"itl_mean_s\"] * 1000,\n   528→            \"blis_e2e_ms\": blis_metrics[\"e2e_mean_ms\"],\n   529→            \"blis_ttft_ms\": blis_metrics[\"ttft_mean_ms\"],\n   530→            \"blis_itl_ms\": blis_metrics[\"itl_mean_ms\"],\n   531→            \"e2e_error\": e2e_error,\n   532→            \"ttft_error\": ttft_error,\n   533→            \"itl_error\": itl_error,\n   534→            \"blis_completed\": blis_metrics[\"completed_requests\"],\n   535→            \"gt_requests\": gt[\"num_requests\"],\n   536→        })\n   537→\n   538→    # Write summary CSV\n   539→    if results:\n   540→        all_keys = set()\n   541→        for r in results:\n   542→            all_keys.update(r.keys())\n   543→        fieldnames = sorted(all_keys)\n   544→\n   545→        with open(output_path, \"w\", newline=\"\") as f:\n   546→            writer = csv.DictWriter(f, fieldnames=fieldnames)\n   547→            writer.writeheader()\n   548→            writer.writerows(results)\n   549→\n   550→        print(f\"\\n{'='*60}\")\n   551→        print(f\"Summary written to: {output_path}\")\n   552→        print(f\"{'='*60}\")\n   553→\n   554→        ok_results = [r for r in results if r.get(\"status\") == \"ok\"]\n   555→        if ok_results:\n   556→            e2e_errors = [r[\"e2e_error\"] for r in ok_results]\n   557→            ttft_errors = [r[\"ttft_error\"] for r in ok_results]\n   558→            itl_errors = [r[\"itl_error\"] for r in ok_results]\n   559→\n   560→            print(f\"\\nExperiments: {len(ok_results)} completed, \"\n   561→                  f\"{len(results) - len(ok_results)} skipped/failed\")\n   562→            print(f\"E2E  mean error: \"\n   563→                  f\"{sum(e2e_errors)/len(e2e_errors)*100:.1f}%\")\n   564→            print(f\"TTFT mean error: \"\n   565→                  f\"{sum(ttft_errors)/len(ttft_errors)*100:.1f}%\")\n   566→            print(f\"ITL  mean error: \"\n   567→                  f\"{sum(itl_errors)/len(itl_errors)*100:.1f}%\")\n   568→\n   569→            passing = sum(1 for e in e2e_errors if e < 0.10)\n   570→            print(f\"E2E < 10%: {passing}/{len(ok_results)} experiments\")\n   571→\n   572→\n   573→def main():\n   574→    parser = argparse.ArgumentParser(\n   575→        description=\"BLIS validation harness for StepML research\"\n   576→    )\n   577→    parser.add_argument(\n   578→        \"--binary\",\n   579→        default=DEFAULT_BINARY,\n   580→        help=f\"Path to simulation_worker binary (default: {DEFAULT_BINARY})\",\n   581→    )\n   582→    parser.add_argument(\n   583→        \"--data-root\",\n   584→        default=DEFAULT_DATA_ROOT,\n   585→        help=f\"Path to eval/ground_truth/ (default: {DEFAULT_DATA_ROOT})\",\n   586→    )\n   587→    parser.add_argument(\n   588→        \"--output\",\n   589→        default=os.path.join(_SCRIPT_DIR, \"blis_validation_results.csv\"),\n   590→        help=\"Output CSV path\",\n   591→    )\n   592→    parser.add_argument(\n   593→        \"--alpha-coeffs\",\n   594→        default=\"0,0,0\",\n   595→        help=\"Comma-separated alpha coefficients (default: 0,0,0)\",\n   596→    )\n   597→    parser.add_argument(\n   598→        \"--beta-coeffs\",\n   599→        default=\"0,0,0\",\n   600→        help=\"Comma-separated beta coefficients (default: 0,0,0)\",\n   601→    )\n   602→    parser.add_argument(\n   603→        \"--stepml-model\",\n   604→        default=None,\n   605→        help=\"Path to StepML model artifact JSON (optional)\",\n   606→    )\n   607→    parser.add_argument(\n   608→        \"--roofline\",\n   609→        action=\"store_true\",\n   610→        help=\"Use analytical roofline latency model instead of alpha/beta coefficients\",\n   611→    )\n   612→    parser.add_argument(\n   613→        \"--hardware\",\n   614→        default=None,\n   615→        help=\"GPU type for roofline mode (e.g. H100). Required when --roofline is set.\",\n   616→    )\n   617→    args = parser.parse_args()\n   618→\n   619→    if args.roofline and not args.hardware:\n   620→        parser.error(\"--roofline requires --hardware (GPU type, e.g. H100)\")\n   621→\n   622→    alpha_coeffs = [float(x) for x in args.alpha_coeffs.split(\",\")]\n   623→    beta_coeffs = [float(x) for x in args.beta_coeffs.split(\",\")]\n   624→\n   625→    if not args.roofline:\n   626→        if len(alpha_coeffs) < 3:\n   627→            parser.error(\"--alpha-coeffs requires at least 3 values\")\n   628→        if len(beta_coeffs) < 3:\n   629→            parser.error(\"--beta-coeffs requires at least 3 values\")\n   630→\n   631→    # Build binary if needed\n   632→    if not os.path.isfile(args.binary):\n   633→        print(\"Building simulation_worker...\", file=sys.stderr)\n   634→        build_result = subprocess.run(\n   635→            [\"go\", \"build\", \"-o\", args.binary, \"main.go\"],\n   636→            cwd=_REPO_ROOT,\n   637→            capture_output=True,\n   638→            text=True,\n   639→        )\n   640→        if build_result.returncode != 0:\n   641→            print(f\"Build failed: {build_result.stderr}\", file=sys.stderr)\n   642→            sys.exit(1)\n   643→\n   644→    validate_all_experiments(\n   645→        binary=args.binary,\n   646→        data_root=args.data_root,\n   647→        output_path=args.output,\n   648→        alpha_coeffs=alpha_coeffs,\n   649→        beta_coeffs=beta_coeffs,\n   650→        stepml_model_path=args.stepml_model,\n   651→        roofline=args.roofline,\n   652→        hardware=args.hardware,\n   653→    )\n   654→\n   655→\n   656→if __name__ == \"__main__\":\n   657→    main()\n   658→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"f0bb7ef6-3940-4341-90bb-75a9c6b04468"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01CX95pFfg26cboT53unzzhD","type":"tool_result","content":"     1→\"\"\"Evaluation harness for step-time prediction models.\n     2→\n     3→Pure computation on arrays — no dependency on real data or external services.\n     4→All percentage values are returned as floats where 10.0 means 10%.\n     5→\"\"\"\n     6→\n     7→from __future__ import annotations\n     8→\n     9→import numpy as np\n    10→from scipy.stats import pearsonr\n    11→\n    12→\n    13→def compute_mape(predicted: np.ndarray, actual: np.ndarray) -> float:\n    14→    \"\"\"Mean Absolute Percentage Error.\n    15→\n    16→    Excludes rows where actual == 0 to avoid division by zero.\n    17→    Returns percentage as a float (e.g., 10.0 for 10%).\n    18→    \"\"\"\n    19→    mask = actual != 0\n    20→    actual_filtered = actual[mask]\n    21→    predicted_filtered = predicted[mask]\n    22→    if len(actual_filtered) == 0:\n    23→        return 0.0\n    24→    abs_pct_errors = np.abs((predicted_filtered - actual_filtered) / actual_filtered)\n    25→    return float(np.mean(abs_pct_errors) * 100.0)\n    26→\n    27→\n    28→def compute_mspe(predicted: np.ndarray, actual: np.ndarray) -> float:\n    29→    \"\"\"Mean Signed Percentage Error.\n    30→\n    31→    Positive values indicate overestimation; negative values indicate\n    32→    underestimation. Excludes rows where actual == 0.\n    33→    Returns percentage as a float (e.g., 15.0 for +15%).\n    34→    \"\"\"\n    35→    mask = actual != 0\n    36→    actual_filtered = actual[mask]\n    37→    predicted_filtered = predicted[mask]\n    38→    if len(actual_filtered) == 0:\n    39→        return 0.0\n    40→    signed_pct_errors = (predicted_filtered - actual_filtered) / actual_filtered\n    41→    return float(np.mean(signed_pct_errors) * 100.0)\n    42→\n    43→\n    44→def compute_pearson_r(predicted: np.ndarray, actual: np.ndarray) -> float:\n    45→    \"\"\"Pearson correlation coefficient between predicted and actual.\"\"\"\n    46→    r, _ = pearsonr(predicted, actual)\n    47→    return float(r)\n    48→\n    49→\n    50→def compute_p99_error(predicted: np.ndarray, actual: np.ndarray) -> float:\n    51→    \"\"\"99th percentile of absolute percentage errors.\n    52→\n    53→    Excludes rows where actual == 0.\n    54→    Returns percentage as a float.\n    55→    \"\"\"\n    56→    mask = actual != 0\n    57→    actual_filtered = actual[mask]\n    58→    predicted_filtered = predicted[mask]\n    59→    if len(actual_filtered) == 0:\n    60→        return 0.0\n    61→    abs_pct_errors = np.abs((predicted_filtered - actual_filtered) / actual_filtered) * 100.0\n    62→    return float(np.percentile(abs_pct_errors, 99))\n    63→\n    64→\n    65→def bootstrap_ci(\n    66→    metric_fn,\n    67→    predicted: np.ndarray,\n    68→    actual: np.ndarray,\n    69→    n_resamples: int = 1000,\n    70→    confidence: float = 0.95,\n    71→    seed: int = 42,\n    72→) -> tuple[float, float]:\n    73→    \"\"\"Bootstrap confidence interval for any metric function.\n    74→\n    75→    Args:\n    76→        metric_fn: A function with signature (predicted, actual) -> float.\n    77→        predicted: Predicted values array.\n    78→        actual: Actual values array.\n    79→        n_resamples: Number of bootstrap resamples.\n    80→        confidence: Confidence level (e.g. 0.95 for 95% CI).\n    81→        seed: Random seed for reproducibility.\n    82→\n    83→    Returns:\n    84→        (lower_bound, upper_bound) tuple.\n    85→    \"\"\"\n    86→    rng = np.random.default_rng(seed)\n    87→    n = len(predicted)\n    88→    bootstrap_estimates = np.empty(n_resamples)\n    89→\n    90→    for i in range(n_resamples):\n    91→        indices = rng.integers(0, n, size=n)\n    92→        bootstrap_estimates[i] = metric_fn(predicted[indices], actual[indices])\n    93→\n    94→    alpha = 1.0 - confidence\n    95→    lower = float(np.percentile(bootstrap_estimates, 100 * alpha / 2))\n    96→    upper = float(np.percentile(bootstrap_estimates, 100 * (1 - alpha / 2)))\n    97→    return lower, upper\n    98→\n    99→\n   100→def compute_e2e_mean_error(\n   101→    predicted_step_times: dict,\n   102→    actual_e2e_times: dict,\n   103→) -> float:\n   104→    \"\"\"Workload-level end-to-end mean error.\n   105→\n   106→    For each request, sums predicted step times to get predicted E2E.\n   107→    Computes mean predicted E2E across requests and compares to the mean\n   108→    of actual E2E times.\n   109→\n   110→    Args:\n   111→        predicted_step_times: {request_id: [step_time1, step_time2, ...]}\n   112→        actual_e2e_times: {request_id: float}\n   113→\n   114→    Returns:\n   115→        Percentage error as a float (e.g. 10.0 for 10%).\n   116→    \"\"\"\n   117→    request_ids = sorted(set(predicted_step_times.keys()) & set(actual_e2e_times.keys()))\n   118→    if not request_ids:\n   119→        return 0.0\n   120→\n   121→    predicted_e2e = np.array([sum(predicted_step_times[rid]) for rid in request_ids])\n   122→    actual_e2e = np.array([actual_e2e_times[rid] for rid in request_ids])\n   123→\n   124→    mean_predicted = np.mean(predicted_e2e)\n   125→    mean_actual = np.mean(actual_e2e)\n   126→\n   127→    if mean_actual == 0:\n   128→        return 0.0\n   129→\n   130→    return float((mean_predicted - mean_actual) / mean_actual * 100.0)\n   131→"}]},"parent_tool_use_id":"toolu_bdrk_01G9D4AX6txJT8XM4avPQmbK","session_id":"6b183c99-f74b-427d-be1f-597eb641e46a","uuid":"bd4b75fe-7602-4af2-ba0d-73d559618238"}
